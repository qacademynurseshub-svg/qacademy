{
  "name": "qacademy-gamma-payment-workers",
  "main": "src/index.js",
  "compatibility_date": "2026-03-17",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "logs": {
      "invocation_logs": true
    }
  },
  "vars": {
    "SUPABASE_URL": "https://zrakjibtxyzoqcdtvpmq.supabase.co",
    "APP_BASE_URL": "https://qacademy-gamma.pages.dev",
    "APP_ORIGIN": "https://qacademy-gamma.pages.dev"
  },
  "rate_limiting": [
    {
      "binding": "RATE_LIMITER",
      "namespace_id": "1",
      "simple": {
        "limit": 5,
        "period": 60
      }
    }
  ]
}
