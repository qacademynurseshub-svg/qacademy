  }

  $("gate").style.display = "block";
  $("app").style.display = "none";
  $("gateMsg").textContent = "Verifying teacher access...";
  gateLoading(true, "Verifying access...");

  let data;
  try{
    data = await taPost("teacher.verify", {});
  }catch(err){
