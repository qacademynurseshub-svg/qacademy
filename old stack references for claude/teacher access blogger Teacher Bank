  }

  teacher = {
    user_id: data.user && data.user.user_id ? data.user.user_id : "",
    name: data.user && data.user.name ? data.user.name : "Teacher",
    email: data.user && data.user.email ? data.user.email : "",
    plan_type: data.teacher && data.teacher.plan_type ? data.teacher.plan_type : "FREE",
    role: data.user && data.user.role ? data.user.role : ""
  };

  $("teacherName").textContent = teacher.name || "Teacher";
  $("teacherPlan").textContent = teacher.plan_type || "FREE";
  $("teacherChip").style.display = "inline-flex";
  $("subline").textContent = teacher.email ? teacher.email : ("Role: " + (teacher.role || "—"));
$("btnDashboard").disabled = false;
  $("btnRefresh").disabled = false;
  $("btnBulkCsv").disabled = IS_PICKER;
  $("btnAddToQuiz").disabled = IS_PICKER;
  $("btnNew").disabled = IS_PICKER;
  $("btnSave").disabled = IS_PICKER;

  gateLoading(true, "Loading filters..");
  await loadMeta();

  if (IS_PICKER){
    gateLoading(true, "Loading draft quizzes..");
    await loadPickerQuizDropdown();
  }

  gateLoading(true, "Loading bank...");
  const hasActiveCache = teacher && teacher.user_id ? hydrateBucketFromStorage("ACTIVE") : false;
  setCurrentBucket("ACTIVE");

  if (!hasActiveCache){
    await loadList(true);
  } else {
    applyFiltersAndRender();
  }

  wireInstantFilters();
  if (!IS_PICKER) newItem();

  $("gate").style.display = "none";
  $("app").style.display = "block";
  gateLoading(false);

  return true;
}

