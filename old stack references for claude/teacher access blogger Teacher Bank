function filterItemsClient(items, f){
  let out = Array.isArray(items) ? items.slice() : [];

  const subj = normalizeField(f.subject);
  const topic = normalizeField(f.topic);
  const diff = canonDifficulty(f.difficulty);
  const src  = canonSourceType(f.source_type);

  if (subj) out = out.filter(it => normalizeField(it.subject) === subj);
  if (topic) out = out.filter(it => normalizeField(it.topic) === topic);
  if (diff) out = out.filter(it => canonDifficulty(it.difficulty) === diff);
  if (src)  out = out.filter(it => canonSourceType(it.source_type) === src);

  const qraw = normalizeField(f.q).toLowerCase();
  if (qraw){
    const tokens = qraw.split(/\s+/).filter(Boolean);
    out = out.filter(it => {
      const hay = [
        it.stem, it.subject, it.topic, it.difficulty, it.source_type, it.marks
      ].map(x => String(x||"").toLowerCase()).join(" ");
      return tokens.every(t => hay.includes(t));
    });
  }

  out.sort((a,b) => String(b.updated_at||"").localeCompare(String(a.updated_at||"")));
  return out;
}

function applyFiltersAndRender(){
  const f = getFilters();
  const bucket = _bucketKey_(f.status);

  if (bucket !== currentBucket){
    setCurrentBucket(bucket);
    if (!bucketMem[bucket].items.length){
      const ok = teacher && teacher.user_id ? hydrateBucketFromStorage(bucket) : false;
      if (!ok){
        $("rows").innerHTML = `<tr><td colspan="4" class="empty">No cached data for ${esc(bucket)}. Click “Refresh” to sync from server.</td></tr>`;
        $("countPill").textContent = "0 items";
        FEED.uiDone("list", `No cache for ${bucket}.`, "Refresh to sync from server.", { tone:"warn", toast:false });
        return;
      }
    }
  }

  const filtered = filterItemsClient(listCache, f);

  const lim = parseInt(String(f.limit||"50"), 10);
  const limit = (!isNaN(lim) && lim > 0) ? lim : 50;

  const sliced = filtered.slice(0, limit);
  renderRows(sliced);

  $("countPill").textContent = `${sliced.length} shown / ${filtered.length} match / ${listCache.length} total`;
  // IMPORTANT: do not overwrite listMsg/listHint here (keeps “last action” persistent).
}

async function loadList(silent){
  const f = getFilters();
  const bucket = _bucketKey_(f.status);

  const showOverlay = !silent && $("gate").style.display === "none" && $("app").style.display !== "none";
  if (showOverlay){
    FEED.uiBusy("list", "Refreshing bank...", "Syncing from server.");
  }

  let data;
  try{
    data = await taPost("bank.items.list", {
      status: bucket,
      q: "",
      subject: "",
      topic: "",
      difficulty: "",
      source_type: "",
      limit: "1000"
    });
  }catch(err){
    if (showOverlay){
      FEED.uiError("list", "Refresh failed.", "Network error while syncing.", { retry: async()=> loadList(false) });
    } else {
      setMsg($("listMsg"), "Refresh failed.", "bad");
      $("listHint").textContent = "Network error • " + nowIso();
      toast("Refresh failed", "Network error while syncing.");
    }
    return;
  }

  if (!data || !data.ok){
    const reason = (data && data.error) ? String(data.error) : "unknown_error";
    if (showOverlay){
      FEED.uiError("list", "Refresh failed.", reason, { retry: async()=> loadList(false) });
    } else {
      setMsg($("listMsg"), "Refresh failed.", "bad");
      $("listHint").textContent = reason + " • " + nowIso();
      toast("Refresh failed", reason);
    }
    return;
  }

  const raw = Array.isArray(data.items) ? data.items : [];
  const normalized = raw.map(it => ({
    ...it,
    status: String(it.status||"").trim().toUpperCase() || "ACTIVE",
    difficulty: canonDifficulty(it.difficulty),
    source_type: canonSourceType(it.source_type),
  }));

  bucketMem[bucket] = { items: normalized, saved_at: Date.now() };
  persistBucketToStorage(bucket);

  setCurrentBucket(bucket);
  rebuildSubjectTopicOptions(listCache);

  applyFiltersAndRender();

  const detail = `${listCache.length} item(s) synced.`;
  if (showOverlay){
    FEED.uiDone("list", "Refreshed.", detail, { toastTitle:"Refreshed.", toastDetail: detail });
  } else if (!silent) {
    setMsg($("listMsg"), "Refreshed.", "ok");
    $("listHint").textContent = detail + " • " + nowIso();
    toast("Refreshed.", detail);
  }
}

