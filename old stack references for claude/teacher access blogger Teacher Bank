    subject:"",
    topic:"",
    difficulty:"",
    marks:"1",
    source_type:"TEACHER",
    source_course_id:"",
    source_sheet_id:"",
    source_item_id:""
  });
  setMeta("", null);

  // Keep last meaningful outcome in editMsg; only update hint (context)
  $("editHint").textContent = "Ready to create . " + nowIso();
  $("stem").focus();
}

async function loadItem(bank_item_id){
  if (!bank_item_id) return;
  if (FEED.isBusy()) return;

  FEED.uiBusy("edit", "Loading item...", `Item: ${bank_item_id}`);

  let data;
  try{
    data = await taPost("bank.item.get", { bank_item_id });
  }catch(err){
    FEED.uiError("edit", "Load failed.", "Network error while loading the item.", { retry: async()=> loadItem(bank_item_id) });
    return;
  }

  if (!data || !data.ok || !data.item){
    const reason = (data && data.error) ? String(data.error) : "unknown_error";
    FEED.uiError("edit", "Load failed.", reason, { retry: async()=> loadItem(bank_item_id) });
    return;
  }

  currentId = bank_item_id;
  currentOriginal = data.item;

  setMode(true);
  fillForm(currentOriginal);
  setMeta(currentId, currentOriginal);

  FEED.uiDone("edit", "Loaded.", `Item: ${currentId}`, { toastTitle:"Loaded.", toastDetail:`Item ${currentId} is ready to edit.` });
  $("stem").focus();
}

function validateClient(form){
  if (!form.stem) return "Stem is required.";
  if (!form.option_a) return "Option A is required.";
  if (!form.option_b) return "Option B is required.";
  const allowed = ["A","B","C","D","E","F"];
  if (!form.correct || !allowed.includes(form.correct)) return "Choose a correct option (A–F).";

  const map = {
    A: form.option_a, B: form.option_b, C: form.option_c,
    D: form.option_d, E: form.option_e, F: form.option_f
  };
  const nonEmpty = Object.keys(map).filter(k => !!map[k]);
  if (nonEmpty.length < 2) return "Provide at least two options.";
  if (!map[form.correct]) return "Correct option points to an empty option.";

  return "";
}

function diffPatch(original, form){
  const patch = {};
  original = original || {};

  Object.keys(form).forEach(k => {
    const a = normalizeField(original[k]);
    const b = normalizeField(form[k]);
    if (a !== b) patch[k] = b;
  });

  ["source_type","source_course_id","source_sheet_id","source_item_id"].forEach(k => {
    if (k in patch) delete patch[k];
  });

  return patch;
}

async function saveItem(){
  if (FEED.isBusy()) return;

  const form = readForm();
  const err = validateClient(form);
  if (err){
    setMsg($("editMsg"), err, "bad");
    $("editHint").textContent = "Fix required • " + nowIso();
    toast("Fix required", err);
    return;
  }

  try{
    if (!currentId){
      FEED.uiBusy("edit", "Creating item…", "Saving to your bank.");

      const createPayload = Object.assign({}, form);
      ["source_type","source_course_id","source_sheet_id","source_item_id"].forEach(k => delete createPayload[k]);

      const data = await taPost("bank.item.create", createPayload);

      if (!data || !data.ok){
        const reason = (data && data.error) ? String(data.error) : "unknown_error";
        FEED.uiError("edit", "Create failed.", reason, { retry: async()=> saveItem() });
        return;
      }

      const newId = data.bank_item_id;

      // multi-step: fetch full item for accurate cache + editor state
      const got = await taPost("bank.item.get", { bank_item_id: newId });
      if (got && got.ok && got.item){
        const full = got.item;
        const sum = toListSummary(full);

        ["ACTIVE","ALL"].forEach(b => {
          const arr = bucketMem[b].items || [];
          bucketMem[b].items = [sum, ...arr.filter(x => String(x.bank_item_id||"") !== sum.bank_item_id)];
          bucketMem[b].saved_at = Date.now();
          persistBucketToStorage(b);
        });

        if (currentBucket === "ACTIVE" || currentBucket === "ALL"){
          setCurrentBucket(currentBucket);
          rebuildSubjectTopicOptions(listCache);
          applyFiltersAndRender();
        }

        currentId = newId;
        currentOriginal = full;
        setMode(true);
        fillForm(full);
        setMeta(newId, full);
      } else {
        // still set id so the teacher sees the item id
        currentId = newId;
        setMode(true);
        setMeta(newId, { created_at: nowIso(), updated_at: nowIso() });
      }

      FEED.uiDone("edit", "Created.", `Saved item ${newId}.`, { toastTitle:"Created.", toastDetail:`Saved item ${newId}.` });

    } else {
      const patch = diffPatch(currentOriginal, form);
      if (!Object.keys(patch).length){
        setMsg($("editMsg"), "No changes to save.", "warn");
        $("editHint").textContent = "No update needed • " + nowIso();
        toast("No changes", "Nothing to save.");
        return;
      }

      FEED.uiBusy("edit", "Saving item…", `Item: ${currentId}`);

      const data = await taPost("bank.item.update", Object.assign({ bank_item_id: currentId }, patch));
      if (!data || !data.ok){
        const reason = (data && data.error) ? String(data.error) : "unknown_error";
        FEED.uiError("edit", "Save failed.", reason, { retry: async()=> saveItem() });
        return;
      }

      const got = await taPost("bank.item.get", { bank_item_id: currentId });
      if (got && got.ok && got.item){
        const full = got.item;
        const sum = toListSummary(full);

        ["ACTIVE","ALL"].forEach(b => {
          const arr = bucketMem[b].items || [];
          const exists = arr.some(x => String(x.bank_item_id||"") === sum.bank_item_id);
          bucketMem[b].items = exists
            ? arr.map(x => (String(x.bank_item_id||"") === sum.bank_item_id ? sum : x))
            : [sum, ...arr];

          bucketMem[b].items.sort((a,b2)=>String(b2.updated_at||"").localeCompare(String(a.updated_at||"")));
          bucketMem[b].saved_at = Date.now();
          persistBucketToStorage(b);
        });

        setCurrentBucket(currentBucket);
        rebuildSubjectTopicOptions(listCache);
        applyFiltersAndRender();

        currentOriginal = full;
        fillForm(full);
        setMeta(currentId, full);
      }

      FEED.uiDone("edit", "Saved.", `Updated item ${currentId}.`, { toastTitle:"Saved.", toastDetail:`Updated item ${currentId}.` });
    }

  } catch(ex){
    FEED.uiError("edit", "Save failed.", String(ex && (ex.message || ex) || ex));
  } finally {
    // button states are restored by FEED; keep editor delete state correct
    $("btnDelete").disabled = !currentId || IS_PICKER;
  }
}

async function deleteItem(bank_item_id){
  if (!bank_item_id) return;
  if (FEED.isBusy()) return;

  const ok = confirm("Delete this bank item? (This is a soft delete.)");
  if (!ok) return;

  FEED.uiBusy("list", "Deleting item…", `Item: ${bank_item_id}`);

  let data;
  try{
    data = await taPost("bank.item.delete", { bank_item_id });
  }catch(err){
    FEED.uiError("list", "Delete failed.", "Network error while deleting.", { retry: async()=> deleteItem(bank_item_id) });
    return;
  }

  if (!data || !data.ok){
    const reason = (data && data.error) ? String(data.error) : "unknown_error";
    FEED.uiError("list", "Delete failed.", reason, { retry: async()=> deleteItem(bank_item_id) });
    return;
  }

  if (currentId && currentId === bank_item_id){
    newItem();
  }

  const id = String(bank_item_id||"").trim();

  const delApply = (arr, mode) => {
    arr = Array.isArray(arr) ? arr : [];
    if (mode === "REMOVE") return arr.filter(x => String(x.bank_item_id||"") !== id);
    if (mode === "MARK_DELETED") {
      return arr.map(x => {
        if (String(x.bank_item_id||"") !== id) return x;
        return { ...x, status:"DELETED", updated_at: x.updated_at || nowIso() };
      });
    }
    return arr;
  };

  bucketMem.ACTIVE.items = delApply(bucketMem.ACTIVE.items, "REMOVE");
  bucketMem.ACTIVE.saved_at = Date.now();
  persistBucketToStorage("ACTIVE");

  let found = null;
  const inAll = (bucketMem.ALL.items || []).find(x => String(x.bank_item_id||"") === id);
  if (inAll) found = { ...inAll, status:"DELETED" };

  if (found){
    bucketMem.DELETED.items = [found, ...(bucketMem.DELETED.items||[]).filter(x => String(x.bank_item_id||"") !== id)];
    bucketMem.DELETED.saved_at = Date.now();
    persistBucketToStorage("DELETED");
  }

  bucketMem.ALL.items = delApply(bucketMem.ALL.items, "MARK_DELETED");
  bucketMem.ALL.saved_at = Date.now();
  persistBucketToStorage("ALL");

  setCurrentBucket(currentBucket);
  rebuildSubjectTopicOptions(listCache);
  applyFiltersAndRender();

  FEED.uiDone("list", "Deleted.", `Item ${bank_item_id} moved to DELETED.`, { toastTitle:"Deleted.", toastDetail:`Item ${bank_item_id} moved to DELETED.` });
}

/** ================================
 * Events
 * ================================ */
function wireInstantFilters(){
  if (filtersWired) return;
  filtersWired = true;

  const deb = (fn, ms) => {
    let t = null;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    };
  };

  $("f_q").addEventListener("input", deb(applyFiltersAndRender, 150));
  ["f_status","f_subject","f_topic","f_difficulty","f_source_type","f_limit"].forEach(id => {
    $(id).addEventListener("change", applyFiltersAndRender);
  });
}

