async function loadPickerQuizDropdown(){
  if (!IS_PICKER) return;

  $("pickerBar").style.display = "";
  $("pickerDock").style.display = "";
  document.body.classList.add("picker");

  $("btnPickerBack").addEventListener("click", ()=>{
    if (RETURN_TO){
      location.href = RETURN_TO;
      return;
    }
    const u = new URL(location.href);
    u.searchParams.delete("mode");
    u.searchParams.delete("teacher_quiz_id");
    u.searchParams.delete("return_to");
    const qs = u.searchParams.toString();
    location.href = u.pathname + (qs ? ("?" + qs) : "") + (u.hash || "");
  });

  $("btnPickerClear").addEventListener("click", pickerClear);
  $("btnPickerSelectAll").addEventListener("click", pickerSelectAllShown);

  $("pickerQuiz").addEventListener("change", ()=>{
    TARGET_QUIZ_ID = String($("pickerQuiz").value || "").trim();
    pickerUpdateUI();
  });

  async function pickerAddSelectedToDraft(){
    if (!IS_PICKER) return;
    if (FEED.isBusy()) return;

    const totalSelected = selectedOrder.length;

    if (!TARGET_QUIZ_ID){
      FEED.uiDone("list", "Quiz not selected.", "Select a DRAFT quiz first.", { tone:"warn", toastTitle:"Pick a quiz.", toastDetail:"Select a DRAFT quiz first." });
      return;
    }
    if (!totalSelected){
      FEED.uiDone("list", "No questions selected.", "Tick at least 1 question.", { tone:"warn", toastTitle:"No selection.", toastDetail:"Tick at least 1 question." });
      return;
    }

    FEED.uiBusy("list", `Adding ${totalSelected} item(s) to draft…`, `Quiz: ${TARGET_QUIZ_ID}`);

    try{
      const g = await taPost("teacher.quiz.get", { teacher_quiz_id: TARGET_QUIZ_ID });
      if (!g || !g.ok || !g.quiz){
        FEED.uiError("list", "Add to draft failed.", "Could not load the target quiz.", { retry: pickerAddSelectedToDraft });
        return;
      }

      const status = String(g.quiz.status || "").toUpperCase();
      if (status && status !== "DRAFT"){
        FEED.uiDone("list", "Cannot add to draft.", `Quiz is ${status}. Only DRAFT can be edited.`, {
          tone:"warn",
          toastTitle:"Quiz locked.",
          toastDetail:`Quiz is ${status}. Only DRAFT can be edited.`
        });
        return;
      }

      const cur = parseDraftItemsJson(g.quiz.draft_items_json);
      const merged = mergeAppendUnique(cur.items, selectedOrder);

      if (!merged.added){
        FEED.uiDone("list",
          "No new items added.",
          `All ${totalSelected} selected already exist in the draft.`,
          { tone:"warn", toastTitle:"No new items.", toastDetail:`All ${totalSelected} selected already exist in the draft.` }
        );
        // keep selection? your current flow clears it; keep the same behavior
        pickerClear();
        return;
      }

      const patchObj = { draft_items_json: JSON.stringify({ items: merged.items }) };

      const u = await taPostJSON("teacher.quiz.update", {
        teacher_quiz_id: TARGET_QUIZ_ID,
        patch: patchObj
      });

      if (!u || !u.ok){
        FEED.uiError("list", "Add to draft failed.", (u && u.error) ? String(u.error) : "unknown_error", { retry: pickerAddSelectedToDraft });
        return;
      }

      const oneLine = `Added ${merged.added} • Skipped ${merged.skipped} duplicate(s).`;

      FEED.uiDone("list",
        `Added ${merged.added} to draft.`,
        oneLine,
        { toastTitle:"Added to draft.", toastDetail: oneLine, tone:"ok" }
      );

      pickerClear();
    } catch(e){
      FEED.uiError("list", "Add to draft failed.", String(e && (e.message || e) || e), { retry: pickerAddSelectedToDraft });
    } finally {
      pickerUpdateUI();
    }
  }

  $("btnPickerAdd").addEventListener("click", pickerAddSelectedToDraft);

  let drafts = [];
  try{
    const r = await taPost("teacher.quizzes.list", { q:"", status:"DRAFT", limit:"200" });
    const items =
      (r && r.ok && Array.isArray(r.items)) ? r.items :
      (r && r.ok && r.data && Array.isArray(r.data.items)) ? r.data.items :
      [];
    drafts = Array.isArray(items) ? items : [];
  } catch(e){
    drafts = [];
  }

  const sel = $("pickerQuiz");
  const opts = drafts.map(q=>{
    const id = String(q.teacher_quiz_id || "").trim();
    const title = String(q.title || "").trim() || "(Untitled)";
    return { id, label: title };
  }).filter(x=>x.id);

  sel.innerHTML =
    `<option value="">Select a draft quiz…</option>` +
    opts.map(o=> `<option value="${esc(o.id)}">${esc(o.label)}</option>`).join("");

  if (TARGET_QUIZ_ID){
    sel.value = TARGET_QUIZ_ID;
  }

  $("pickerQuizHint").textContent = opts.length
    ? "Select a quiz draft to append your selected questions into."
    : "No DRAFT quizzes found. Create a quiz first.";

  pickerUpdateUI();
}

