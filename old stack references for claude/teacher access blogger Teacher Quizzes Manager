<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Teacher Quizzes</title>

<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#1f2a28;
    --bg:#f6f8f7;
    --card:#ffffff;
    --line:rgba(0,0,0,.10);
    --soft:rgba(0,0,0,.04);
    --warn:#b45309;
    --danger:#b91c1c;
    --ok:#067647;

    /* Wider desktop */
    --pageMax:1560px;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif}
  a{color:var(--brand);text-decoration:none}
  .topbar{
    position:sticky;top:0;z-index:10;
    background:rgba(246,248,247,.92);backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  
  :root{
  --pageMax: 1600px;
  --pagePad: 18px;
}

/* full-bleed shell to escape Blogger center column */
.qaApp{
  width:100vw;
  margin-left:calc(50% - 50vw);
  background:var(--bg);
  min-height:100vh;
  overflow-x:clip;
}

/* avoid horizontal scrollbars from full-bleed */
body{overflow-x:hidden}

/* keep your inner layout but allow it to be wider */
.qaApp .topbar .inner,
.qaApp .wrap{
  max-width:var(--pageMax);
  margin:0 auto;
}

.qaApp .topbar .inner{padding:12px var(--pagePad)}
.qaApp .wrap{padding:14px var(--pagePad) 32px}

/* prevent grid children from forcing overflow/clipping */
.grid > *, .qGrid > *{min-width:0}

/* slightly more adaptive desktop columns */
@media (min-width: 1200px){
  .grid{grid-template-columns:minmax(380px, 480px) 1fr;}
}
@media (max-width: 980px){
  .qaApp{width:100%;margin-left:0}
}

  .topbar .inner{
    max-width:var(--pageMax);margin:0 auto;padding:12px 16px;
    display:flex;align-items:center;gap:12px;justify-content:space-between;
  }
  .brand{display:flex;align-items:center;gap:10px;font-weight:800;letter-spacing:.2px;}
  .dot{width:10px;height:10px;border-radius:50%;background:var(--brand)}
  .actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
  .btn{
    border:1px solid var(--line);background:#fff;border-radius:12px;
    padding:9px 12px;font-weight:700;cursor:pointer;
  }
  .btn.primary{background:var(--brand);border-color:var(--brand);color:#fff}
  .btn.ghost{background:transparent}
  .btn.danger{background:#fff;border-color:rgba(185,28,28,.35);color:var(--danger)}
  .btn:disabled{opacity:.55;cursor:not-allowed}
  .chip{
    display:inline-flex;align-items:center;gap:6px;
    border:1px solid var(--line);background:rgba(255,255,255,.75);
    padding:6px 10px;border-radius:999px;font-weight:700;font-size:12px;
  }
  .chip.ok{border-color:rgba(6,118,71,.22);color:var(--ok)}
  .chip.warn{border-color:rgba(180,83,9,.25);color:var(--warn)}
  .chip.danger{border-color:rgba(185,28,28,.25);color:var(--danger)}
  .wrap{max-width:var(--pageMax);margin:0 auto;padding:14px 16px 32px}
  .grid{
    display:grid;gap:14px;
    grid-template-columns: 420px 1fr;
    align-items:start;
  }
  @media (max-width: 980px){ .grid{grid-template-columns:1fr} }
  .card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:18px;
    box-shadow:0 8px 26px rgba(0,0,0,.05);
    overflow:hidden;
  }
  .card .hd{
    padding:12px 14px;border-bottom:1px solid var(--line);
    display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;
  }
  .card .hd h2{margin:0;font-size:14px;letter-spacing:.2px}
  .card .bd{padding:14px}
  .muted{color:rgba(31,42,40,.7)}
  .row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
  .col{display:flex;flex-direction:column;gap:6px}
  .split{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  @media (max-width:520px){ .split{grid-template-columns:1fr} }
  label{font-size:12px;font-weight:800;color:rgba(31,42,40,.75)}
  input, select, textarea{
    width:100%;
    border:1px solid var(--line);
    border-radius:12px;
    padding:10px 11px;
    background:#fff;
    color:var(--ink);
    outline:none;
  }
  textarea{min-height:74px;resize:vertical}
  input:focus, select:focus, textarea:focus{
    border-color: rgba(11,122,117,.35);
    box-shadow: 0 0 0 4px rgba(11,122,117,.10);
  }

  .hint{font-size:12px;color:rgba(31,42,40,.65);line-height:1.35}
  .list{display:flex;flex-direction:column;gap:10px;}
  .item{
    border:1px solid var(--line);
    border-radius:14px;
    padding:12px;
    background:rgba(255,255,255,.75);
    display:flex;gap:10px;justify-content:space-between;align-items:flex-start;
    cursor:pointer;
  }
  .item:hover{border-color:rgba(11,122,117,.35)}
  .item.active{border-color:rgba(11,122,117,.65);box-shadow:0 0 0 3px rgba(11,122,117,.12)}
  .item .t{font-weight:900}
  .item .s{font-size:12px;color:rgba(31,42,40,.68);margin-top:2px;line-height:1.25}
  .item .right{display:flex;flex-direction:column;gap:6px;align-items:flex-end}
  .hr{height:1px;background:var(--line);margin:12px 0}
  .toast{
    position:fixed;right:14px;bottom:14px;z-index:50;
    background:#fff;border:1px solid var(--line);border-radius:14px;
    padding:10px 12px;box-shadow:0 18px 50px rgba(0,0,0,.12);
    max-width:min(520px, calc(100vw - 28px));
    display:none;
  }
  .toast.show{display:block}
  .toast .t{font-weight:900;margin-bottom:4px}
  .toast .m{font-size:12px;color:rgba(31,42,40,.75);line-height:1.3}
  .kbd{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12px;background:var(--soft);padding:2px 6px;border-radius:8px;border:1px solid var(--line)}
  .mini{font-size:12px}

  .fieldRow{
    border:1px dashed rgba(0,0,0,.18);
    border-radius:14px;padding:10px;background:rgba(0,0,0,.02);
    display:grid;gap:10px;grid-template-columns: 1.2fr .7fr .55fr;
    align-items:end;
  }
  @media (max-width:860px){ .fieldRow{grid-template-columns:1fr} }
  .fieldRow .row2{grid-column:1 / -1}
  
  /* =========================
 * Grade bands editor
 * ========================= */
.bandRow{
  border:1px dashed rgba(0,0,0,.18);
  border-radius:14px;
  padding:10px;
  background:rgba(0,0,0,.02);
  display:grid;
  gap:10px;
  grid-template-columns: 140px 1fr 110px;
  align-items:end;
}
@media (max-width:860px){
  .bandRow{grid-template-columns:1fr}
}
.bandRow .bandActions{
  display:flex;
  justify-content:flex-end;
}

  .pill{display:inline-flex;gap:6px;flex-wrap:wrap;align-items:center;}
  .pill .tag{
    border:1px solid var(--line);background:rgba(255,255,255,.8);
    border-radius:999px;padding:6px 10px;font-weight:800;font-size:12px;
  }

  .clsBox{
    border:1px solid var(--line);
    border-radius:14px;padding:10px;background:rgba(255,255,255,.75);
    display:flex;flex-direction:column;gap:8px;
    max-height:420px;overflow:auto;
  }
  .clsRow{
    display:flex;align-items:center;gap:10px;justify-content:space-between;
    padding:8px 10px;border-radius:12px;border:1px solid transparent;
    background:rgba(255,255,255,.5);
  }
  .clsRow:hover{border-color:rgba(11,122,117,.25)}
  .clsRow .l{display:flex;gap:10px;align-items:flex-start}
  .clsRow input[type="checkbox"]{width:auto;margin-top:2px}
  .badge{
    font-size:11px;font-weight:900;
    border:1px solid var(--line);border-radius:999px;padding:4px 8px;
    background:rgba(0,0,0,.03);
  }
  .subnote{font-size:12px;color:rgba(31,42,40,.65)}

  /* =========================
   * QUESTIONS MODULE (Bank + Draft + Inline) — shared styles
   * ========================= */
  .qCard{
    border:1px solid var(--line);
    border-radius:16px;
    background:rgba(255,255,255,.85);
    overflow:hidden;
  }
  .qCard .qHd{
    padding:10px 12px;border-bottom:1px solid var(--line);
    display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;
  }
  .qCard .qHd b{font-size:13px}
  .qCard .qBd{padding:12px}
  .qBox{
    border:1px solid var(--line);
    border-radius:14px;
    background:#fff;
    overflow:auto;
    max-height:420px;
  }
  .qRow{
    padding:10px 10px;
    border-bottom:1px solid var(--line);
    display:flex;gap:10px;justify-content:space-between;align-items:flex-start;
  }
  .qRow:last-child{border-bottom:none}
  .qRow:hover{background:rgba(0,0,0,.01)}
  .qStem{font-size:13px;font-weight:900;line-height:1.25}
  .qMeta{font-size:12px;color:rgba(31,42,40,.68);margin-top:4px;line-height:1.25}
  .qBtns{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
  .qSmall{padding:7px 10px;border-radius:12px;font-size:12px;font-weight:800}
  .qPill{
    display:inline-flex;align-items:center;gap:6px;
    padding:6px 10px;border-radius:999px;border:1px solid var(--line);
    background:rgba(0,0,0,.02);font-size:12px;font-weight:900;
  }
  .qPill.ok{border-color:rgba(6,118,71,.18);background:rgba(6,118,71,.06);color:var(--ok)}
  .qPill.warn{border-color:rgba(180,83,9,.18);background:rgba(180,83,9,.06);color:var(--warn)}
  .qPill.bad{border-color:rgba(185,28,28,.18);background:rgba(185,28,28,.06);color:var(--danger)}
  .qTbl{width:100%;border-collapse:separate;border-spacing:0}
  .qTbl th{
    font-size:12px;text-align:left;color:rgba(31,42,40,.65);
    background:rgba(0,0,0,.02);
    border-bottom:1px solid var(--line);
    padding:10px;
  }
  .qTbl td{
    font-size:13px;padding:10px;border-bottom:1px solid var(--line);vertical-align:top;
  }
  .qTbl tr:hover td{background:rgba(0,0,0,.01)}
  .mono{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono",monospace;font-size:12px}

  /* =========================
   * EDITOR TABS + PANES (NEW)
   * ========================= */
  .subhd{
    padding:10px 14px;
    border-bottom:1px solid var(--line);
    background:rgba(255,255,255,.65);
  }
  .tabs{
    display:flex;gap:8px;flex-wrap:wrap;align-items:center;
  }
  .tab{
    border:1px solid var(--line);
    background:rgba(255,255,255,.9);
    border-radius:999px;
    padding:8px 12px;
    font-weight:900;
    cursor:pointer;
    font-size:12px;
  }
  .tab.active{
    background:rgba(11,122,117,.10);
    border-color:rgba(11,122,117,.35);
    box-shadow:0 0 0 3px rgba(11,122,117,.10);
  }
  .tab:disabled{opacity:.55;cursor:not-allowed}
  .strip{
    margin-top:10px;
    display:flex;gap:8px;flex-wrap:wrap;align-items:center;justify-content:space-between;
  }
  .strip .left, .strip .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .pane{display:none}
  .pane.active{display:block}
  .paneTitle{
    font-weight:950;
    margin:0 0 6px 0;
    font-size:13px;
  }
  .stickyFooter{
    position:sticky;
    bottom:0;
    background:rgba(246,248,247,.92);
    backdrop-filter:blur(10px);
    border-top:1px solid var(--line);
    padding:10px 0 0 0;
    margin-top:14px;
  }

  /* Questions pane layout */
  .qLayout{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:12px;
    align-items:start;
  }
  @media (max-width: 980px){
    .qLayout{grid-template-columns:1fr}
  }
  .toolTabs{
    display:flex;gap:8px;flex-wrap:wrap;align-items:center;
    margin-bottom:10px;
  }
  .toolTab{
    border:1px solid var(--line);
    background:rgba(255,255,255,.9);
    border-radius:999px;
    padding:7px 10px;
    font-weight:900;
    cursor:pointer;
    font-size:12px;
  }
  .toolTab.active{
    background:rgba(11,122,117,.10);
    border-color:rgba(11,122,117,.35);
    box-shadow:0 0 0 3px rgba(11,122,117,.10);
  }
  .toolPane{display:none}
  .toolPane.active{display:block}

  /* Publish pane */
  .pubBox{
    border:1px solid var(--line);
    border-radius:16px;
    background:rgba(255,255,255,.85);
    padding:12px;
  }
  .checkRow{
    display:flex;gap:10px;align-items:flex-start;justify-content:space-between;
    padding:10px;border:1px solid var(--line);border-radius:14px;background:rgba(255,255,255,.75);
    margin-top:10px;
  }
  .checkRow b{font-size:13px}
  .warnBox{
    border:1px solid rgba(180,83,9,.25);
    background:rgba(180,83,9,.08);
    color:var(--warn);
    border-radius:14px;
    padding:10px;
    margin-top:10px;
    font-weight:800;
    font-size:12px;
    line-height:1.35;
  }
  /* =========================
 * LIST VIEW / EDITOR VIEW SWITCH
 * ========================= */
.view{display:none}
.view.view-active{display:block}

/* Full-width quiz list */
.quizGrid{
  display:grid;
  grid-template-columns:repeat(2, minmax(0, 1fr));
  gap:14px;
}
@media (max-width:1180px){
  .quizGrid{grid-template-columns:1fr}
}

.quizTile{
  border:1px solid var(--line);
  border-radius:18px;
  padding:16px;
  background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(255,255,255,.90));
  box-shadow:0 10px 28px rgba(0,0,0,.05);
  cursor:pointer;
  transition:transform .14s ease, box-shadow .14s ease, border-color .14s ease;
}
.quizTile:hover{
  transform:translateY(-2px);
  border-color:rgba(11,122,117,.30);
  box-shadow:0 16px 34px rgba(0,0,0,.08);
}
.quizTile.active{
  border-color:rgba(11,122,117,.55);
  box-shadow:0 0 0 4px rgba(11,122,117,.10), 0 16px 34px rgba(0,0,0,.08);
  background:linear-gradient(180deg, rgba(11,122,117,.06), rgba(255,255,255,.98));
}

.quizTileTop{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:12px;
}
.quizTileMain{min-width:0;flex:1}
.quizTitle{
  font-size:17px;
  font-weight:900;
  line-height:1.25;
  letter-spacing:.1px;
}
.quizSub{
  margin-top:5px;
  font-size:13px;
  color:rgba(31,42,40,.68);
  line-height:1.35;
}
.quizStateStack{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  justify-content:flex-end;
}

.quizMetaGrid{
  margin-top:14px;
  display:grid;
  grid-template-columns:repeat(3, minmax(0, 1fr));
  gap:10px;
}
@media (max-width:760px){
  .quizMetaGrid{grid-template-columns:repeat(2, minmax(0,1fr))}
}
.quizMetaCell{
  border:1px solid var(--line);
  border-radius:14px;
  padding:10px 11px;
  background:rgba(0,0,0,.02);
  min-width:0;
}
.quizMetaLabel{
  display:block;
  font-size:11px;
  font-weight:800;
  color:rgba(31,42,40,.58);
  text-transform:uppercase;
  letter-spacing:.3px;
}
.quizMetaValue{
  display:block;
  margin-top:4px;
  font-size:13px;
  font-weight:900;
  color:var(--ink);
  line-height:1.25;
  word-break:break-word;
}

.quizFlags{
  margin-top:12px;
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}
.quizFlag{
  display:inline-flex;
  align-items:center;
  padding:7px 10px;
  border-radius:999px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.86);
  font-size:12px;
  font-weight:800;
  color:rgba(31,42,40,.78);
}

.editorHeadLeft{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}
</style>
</head>

<body>
  <div id="qaApp" class="qaApp">
  <div class="topbar">
    <div class="inner">
      <div class="brand">
        <span class="dot"></span>
        <div>
          <div>QAcademy Teacher</div>
          <div class="mini muted">Quizzes • create, configure, link to classes</div>
        </div>
      </div>

      <div class="actions">
        <span id="userChip" class="chip" style="display:none"></span>
        <button class="btn" id="btnRefresh" type="button">Refresh</button>
        <button class="btn primary" id="btnNewQuiz" type="button">+ New Quiz</button>
        <button class="btn danger" id="btnSignOut" type="button">Sign out</button>
      </div>
    </div>
  </div>

  <div class="wrap">
<div id="quizListView" class="view view-active">
      <!-- LEFT: QUIZZES LIST -->
      <div class="card">
        <div class="hd">
          <h2>My Quizzes</h2>
          <span id="countsChips" class="pill"></span>
        </div>
        <div class="bd">
          <div class="split">
            <div class="col">
              <label>Search</label>
              <input id="qSearch" placeholder="Title, subject, code…" />
            </div>
            <div class="col">
              <label>Status</label>
              <select id="qStatus">
                <option value="ANY">Any</option>
                <option value="DRAFT">Draft</option>
                <option value="PUBLISHED">Published</option>
                <option value="ARCHIVED">Archived</option>
              </select>
            </div>
          </div>

          <div class="row" style="margin-top:10px;justify-content:space-between">
            <div class="row">
              <span class="chip"><span>Loaded:</span> <span class="kbd" id="quizCount">0</span></span>
            </div>
            <button class="btn" id="btnLoadMore" style="display:none" type="button">Load more</button>
          </div>

          <div class="hr"></div>
<div id="quizList" class="quizGrid"></div>
          <div id="emptyList" class="hint" style="display:none;margin-top:8px">
            No quizzes match your filters yet. Create one with <span class="kbd">New Quiz</span>.
          </div>
        </div>
      </div>
</div>

<div id="quizEditorView" class="view">
      <!-- RIGHT: EDITOR (NEW STRUCTURE) -->
      <div class="card">
       <div class="hd">
  <div class="editorHeadLeft">
    <button class="btn ghost" id="btnBackToList" type="button">&larr; Back to quizzes</button>
    <h2 id="editorTitle">Quiz Editor</h2>
  </div>
  <div class="row">
    <span id="quizStatusChip" class="chip" style="display:none"></span>
    <span id="quizOpenChip" class="chip" style="display:none"></span>
  </div>
</div>

        <div class="subhd">
          <div class="tabs">
            <button class="tab active" id="tabSettings" type="button">Settings</button>
            <button class="tab" id="tabClasses" type="button" disabled>Classes</button>
            <button class="tab" id="tabQuestions" type="button" disabled>Questions</button>
            <button class="tab" id="tabPublish" type="button" disabled>Publish</button>
          </div>

          <div class="strip">
            <div class="left">
              <span class="chip"><span>Save:</span> <span class="kbd" id="stripSaveState">—</span></span>
              <span class="chip"><span>Draft:</span> <span class="kbd" id="stripDraftCount">0</span></span>
              <span class="chip"><span>Classes:</span> <span class="kbd" id="stripClassCount">0</span></span>
            </div>
            <div class="right">
              <span class="chip"><span>Next:</span> <span class="kbd" id="stripNextHint">Select a quiz</span></span>
            </div>
          </div>
        </div>

        <div class="bd" id="editorBody">
          <div id="notSelected" class="hint">
            Select a quiz from the left, or create a new one.
          </div>

          <div id="editor" style="display:none">

            <!-- Quiz meta (always visible) -->
            <div class="row" style="justify-content:space-between;align-items:flex-start">
              <div class="col" style="min-width:260px;flex:1">
                <div class="row" style="gap:8px;flex-wrap:wrap">
                  <span class="chip"><span>ID:</span> <span class="kbd" id="quizIdKbd">—</span></span>
                  <span class="chip"><span>Code:</span> <span class="kbd" id="quizCodeKbd">—</span></span>
                </div>
                <div class="subnote" style="margin-top:6px">
                  Draft quizzes can regenerate the code. Students only see quizzes via class linking + published state.
                </div>
              </div>

              <details style="min-width:220px">
                <summary class="btn ghost" style="list-style:none;display:inline-flex;align-items:center;gap:8px;user-select:none">
                  Advanced
                </summary>
                <div class="row" style="margin-top:10px;justify-content:flex-end">
                  <button class="btn" id="btnRegenCode" title="Draft only" type="button">Regenerate code</button>
                  <button class="btn danger" id="btnArchive" type="button">Archive</button>
                </div>
              </details>
            </div>

            <div class="hr"></div>

            <!-- ======================
                 PANE: SETTINGS
                 ====================== -->
            <div id="paneSettings" class="pane active">
              <div class="paneTitle">Settings</div>
              <!-- NEW: Preset selection cards -->
<div id="presetCards" style="margin: 0 0 20px 0;">
  <div style="font-weight:900; margin-bottom:10px;">Choose a Preset (recommended)</div>
