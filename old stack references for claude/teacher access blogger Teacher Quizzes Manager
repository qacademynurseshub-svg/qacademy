function applyPreset(presetKey) {
  const key = String(presetKey||'').trim().toUpperCase();
  if (!PRESET_DEFAULTS[key]) return;

  const defs = PRESET_DEFAULTS[key];

  elDuration.value = defs.duration_minutes;
  elMaxAttempts.value = defs.max_attempts;
  elShuffleQ.checked = !!defs.shuffle_questions;
  elShuffleOpt.checked = !!defs.shuffle_options;
  elShowReview.checked = !!defs.show_review;
  elShowResult.checked = !!defs.show_results;

  // Policy dropdown
  const policySelect = $('fResultsPolicy');
  if (policySelect && defs.results_release_policy) {
    policySelect.value = defs.results_release_policy;
    policySelect.dispatchEvent(new Event('change'));
  }

  // Clear scheduled release when applying a preset (teacher can set it explicitly)
  const releasedAtInput = $('fReleasedAt');
  if (releasedAtInput) releasedAtInput.value = '';

  currentPreset = key;
  presetDirty = false;

  setPresetHighlight(key);
  updateResetPresetButton();
  renderTopStrip();
}

  
  
  
function markPresetDirty() {
  if (currentPreset) {
    presetDirty = true;
    updateResetPresetButton();
  }
}

function updateResetPresetButton() {
  let btn = document.getElementById('resetPresetBtn');
  if (!btn) {
    // Create button if not exists (in sticky footer)
    const footerRow = document.querySelector('#paneSettings .stickyFooter .row');
    if (!footerRow) return;
    btn = document.createElement('button');
    btn.id = 'resetPresetBtn';
    btn.className = 'btn';
    btn.style.marginLeft = 'auto';
    btn.onclick = () => {
      applyPreset(currentPreset);
      toast('Reset', `Restored ${PRESET_DEFAULTS[currentPreset].label} defaults`);
    };
    footerRow.appendChild(btn);
  }

  if (currentPreset && presetDirty) {
    btn.textContent = `Reset to ${PRESET_DEFAULTS[currentPreset].label} defaults`;
    btn.style.display = '';
  } else {
    btn.style.display = 'none';
  }
}  

/* NEW: robust boolean parser + pick-first-defined (for show_result mismatch issues) */
function pickFirstDefined(){
  for (let i = 0; i < arguments.length; i++){
    const v = arguments[i];
    if (v !== undefined && v !== null) return v;
  }
  return undefined;
}

function asBool(v, fallback){
  if (v === true || v === false) return v;
  if (v == null) return fallback;
  if (typeof v === 'number') return v !== 0;

  const s = String(v).trim().toLowerCase();
  if (!s) return fallback;
  if (['true','t','yes','y','1'].includes(s)) return true;
  if (['false','f','no','n','0'].includes(s)) return false;
  return fallback;
}
