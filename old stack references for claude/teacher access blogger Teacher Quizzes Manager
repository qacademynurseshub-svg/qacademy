      </div>

      <div class="col row2" style="display:${f.type === 'select' ? '' : 'none'}">
        <label>Options (one per line)</label>
        <textarea data-k="optionsText" data-i="${idx}" placeholder="A\nB\nC">${escapeHtml(f.optionsText||'')}</textarea>
        <div class="hint">Only used if type = select.</div>
      </div>

      <div class="row" style="grid-column:1 / -1;justify-content:flex-end">
        <button class="btn danger" data-k="remove" data-i="${idx}" type="button">Remove</button>
      </div>
    `;

    elFieldsWrap.appendChild(row);

    const sel = row.querySelector(`select[data-k="type"][data-i="${idx}"]`);
    if (sel) sel.value = f.type || 'text';
    const cb = row.querySelector(`input[type="checkbox"][data-k="required"][data-i="${idx}"]`);
    if (cb) cb.checked = !!f.required;

    row.querySelectorAll('input,select,textarea,button').forEach(el => {
      el.addEventListener('input', onFieldChange);
      el.addEventListener('change', onFieldChange);
      el.addEventListener('click', onFieldClick);
    });
  });
}

function onFieldChange(e){
  const el = e.target;
  const i = parseInt(el.getAttribute('data-i')||'-1',10);
  const k = el.getAttribute('data-k') || '';
  if (i < 0 || !k) return;

  const cur = CUSTOM_FIELDS[i] || {};
  if (k === 'required'){
    cur.required = !!el.checked;
  }else if (k === 'type'){
    cur.type = String(el.value||'text');
    if (cur.type !== 'select') cur.optionsText = '';
  }else{
    cur[k] = String(el.value||'');
  }
  CUSTOM_FIELDS[i] = cur;

  if (k === 'type') renderCustomFields();
}

function onFieldClick(e){
  const el = e.target;
  if (el.tagName !== 'BUTTON') return;
  const i = parseInt(el.getAttribute('data-i')||'-1',10);
  const k = el.getAttribute('data-k') || '';
  if (k === 'remove' && i >= 0){
    CUSTOM_FIELDS.splice(i,1);
    renderCustomFields();
  }
}

function addField(){
  if (CUSTOM_FIELDS.length >= MAX_FIELDS) return;
  CUSTOM_FIELDS.push({ label:'', required:false, type:'text', optionsText:'' });
  renderCustomFields();
}

function buildCustomFieldsJson(){
  const fields = CUSTOM_FIELDS
    .map(f => ({
      label: String(f.label||'').trim(),
      required: !!f.required,
      type: String(f.type||'text').trim() || 'text',
      options: (String(f.type||'') === 'select')
        ? String(f.optionsText||'').split('\n').map(x=>x.trim()).filter(Boolean)
        : null
    }))
    .filter(f => !!f.label)
    .slice(0, MAX_FIELDS);

  return JSON.stringify({ fields });
}

