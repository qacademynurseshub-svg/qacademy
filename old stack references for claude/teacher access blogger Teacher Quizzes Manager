function qaDefaultBands(){
  return QA_DEFAULT_GRADE_BANDS.map(x => ({ min_pct: x.min_pct, label: x.label }));
}

function qaNormalizeBands(bands){
  let cleaned = [];
  (bands || []).forEach(b => {
    const label = String((b && b.label) || '').trim();
    const n = Number(b && b.min_pct);
    if (!label) return;
    if (!isFinite(n)) return;
    let min = Math.max(0, Math.min(100, n));
    min = Math.round(min * 100) / 100; // allow decimals safely
    cleaned.push({ min_pct: min, label });
  });

  if (!cleaned.length) cleaned = qaDefaultBands();

  cleaned.sort((a,b)=> a.min_pct - b.min_pct);

  // dedupe same min_pct (keep the last label)
  const ded = [];
  for (let i = 0; i < cleaned.length; i++){
    const cur = cleaned[i];
    if (!ded.length) { ded.push(cur); continue; }
    const prev = ded[ded.length - 1];
    if (prev.min_pct === cur.min_pct) prev.label = cur.label;
    else ded.push(cur);
  }

  // ensure 0 band exists
  if (!ded.length || ded[0].min_pct !== 0){
    ded.unshift({ min_pct: 0, label: 'Fail' });
  } else {
    if (!String(ded[0].label||'').trim()) ded[0].label = 'Fail';
  }

  return ded;
}

function qaParseBands(raw){
  const s = (raw == null) ? '' : raw;
  if (!s) return qaDefaultBands();

  let obj = null;
  try { obj = (typeof s === 'string') ? JSON.parse(s) : s; } catch(_){ obj = null; }

  if (Array.isArray(obj)) obj = { bands: obj };
  const bands = (obj && Array.isArray(obj.bands)) ? obj.bands : null;
  if (!bands) return qaDefaultBands();

  return qaNormalizeBands(bands);
}

function qaBandsJsonForSave(){
  const bands = qaNormalizeBands(GRADE_BANDS);
  return JSON.stringify({ bands });
}

function renderGradeBands(){
  if (!elGradeBandsWrap) return;

  // keep state canonical
  GRADE_BANDS = qaNormalizeBands(GRADE_BANDS);

  elGradeBandsWrap.innerHTML = GRADE_BANDS.map((b, i) => {
    const isZero = (i === 0 && Number(b.min_pct) === 0);
    return `
      <div class="bandRow" data-i="${i}">
        <div class="col">
          <label>Min %</label>
          <input type="number" step="1" min="0" max="100"
            data-k="min_pct" data-i="${i}"
            value="${escapeHtml(String(b.min_pct))}"
            ${isZero ? 'disabled' : ''}
          />
        </div>
        <div class="col">
          <label>Label</label>
          <input data-k="label" data-i="${i}" value="${escapeHtml(String(b.label||''))}" placeholder="e.g., Pass" />
        </div>
        <div class="bandActions">
          <button class="btn danger" data-k="remove" data-i="${i}" type="button" ${isZero ? 'disabled' : ''}>Remove</button>
        </div>
      </div>
    `;
  }).join('');

  // hint
  if (elGradeBandsHint){
    const preview = GRADE_BANDS.map(b => `${b.min_pct}%→${b.label}`).join(' • ');
    elGradeBandsHint.textContent = `Applied bands: ${preview}`;
  }

  // bind events
  elGradeBandsWrap.querySelectorAll('input').forEach(inp => {
    inp.addEventListener('input', onGradeBandChange);
    inp.addEventListener('change', onGradeBandChange);
  });
  elGradeBandsWrap.querySelectorAll('button[data-k="remove"]').forEach(btn => {
    btn.addEventListener('click', onGradeBandRemove);
  });
}

function onGradeBandChange(e){
  const el = e.target;
  const i = parseInt(el.getAttribute('data-i')||'-1', 10);
  const k = el.getAttribute('data-k') || '';
  if (i < 0 || !k) return;

  const cur = GRADE_BANDS[i] || { min_pct: 0, label: '' };

  if (k === 'min_pct'){
    const n = Number(el.value);
    cur.min_pct = isFinite(n) ? n : cur.min_pct;
  } else if (k === 'label'){
    cur.label = String(el.value||'').trim();
  }

  GRADE_BANDS[i] = cur;
  // don’t fully re-render on every keystroke; just update hint
  if (elGradeBandsHint){
    const preview = qaNormalizeBands(GRADE_BANDS).map(b => `${b.min_pct}%→${b.label}`).join(' | ');
    elGradeBandsHint.textContent = `Applied bands: ${preview}`;
  }
}

function onGradeBandRemove(e){
  const i = parseInt(e.target.getAttribute('data-i')||'-1', 10);
  if (i <= 0) return; // keep the 0% band
  GRADE_BANDS.splice(i, 1);
  renderGradeBands();
}

function addGradeBand(){
  // pick a reasonable next threshold
  const used = new Set(qaNormalizeBands(GRADE_BANDS).map(b => Number(b.min_pct)));
  let m = 50;
  while (used.has(m) && m <= 100) m += 5;
  if (m > 100) m = 100;

  GRADE_BANDS.push({ min_pct: m, label: 'New band' });
  renderGradeBands();
}

function resetGradingDefaults(){
