function uniqPreserve(arr){
  const out = [];
  const seen = new Set();
  (arr || []).forEach(x=>{
    const id = String(x||'').trim();
    if (!id || seen.has(id)) return;
    seen.add(id);
    out.push(id);
  });
  return out;
}

function loadDraftFromQuizRow(q){
  if (!SELECTED_ID){
