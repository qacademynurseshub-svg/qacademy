function computeOpenStateFromQuiz(q){
  const now = Date.now();
  const o = Date.parse(String(q.open_at||'').trim());
  const c = Date.parse(String(q.close_at||'').trim());
  const oMs = isNaN(o) ? null : o;
  const cMs = isNaN(c) ? null : c;

  if (oMs != null && oMs > now) return 'UPCOMING';
  if (cMs != null && now > cMs) return 'CLOSED';
  return 'OPEN';
}

