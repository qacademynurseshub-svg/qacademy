  const t = String(name||'settings').toLowerCase();
  ACTIVE_TAB = t;

  [tabSettings, tabClasses, tabQuestions, tabPublish].forEach(b=> b.classList.remove('active'));
  if (t === 'settings') tabSettings.classList.add('active');
  else if (t === 'classes') tabClasses.classList.add('active');
  else if (t === 'questions') tabQuestions.classList.add('active');
  else if (t === 'publish') tabPublish.classList.add('active');

  [paneSettings, paneClasses, paneQuestions, panePublish].forEach(p=> p.classList.remove('active'));
  if (t === 'settings') paneSettings.classList.add('active');
  else if (t === 'classes') paneClasses.classList.add('active');
  else if (t === 'questions') paneQuestions.classList.add('active');
  else if (t === 'publish') { panePublish.classList.add('active'); renderPublishPane(); }

  renderTopStrip();
}

function setActiveTool(name){
  const t = String(name||'bank').toLowerCase();
  ACTIVE_TOOL = t;

  [toolBank, toolCreate, toolPreview].forEach(b=> b.classList.remove('active'));
  toolPaneBank.classList.remove('active');
  toolPaneEditor.classList.remove('active');

  if (t === 'bank'){
    toolBank.classList.add('active');
    toolPaneBank.classList.add('active');
  }else if (t === 'create'){
    toolCreate.classList.add('active');
    toolPaneEditor.classList.add('active');
    qeNewInlineMode();
  }else if (t === 'preview'){
    toolPreview.classList.add('active');
    toolPaneEditor.classList.add('active');
    if (!QE_CURRENT_ID) qeWarn.textContent = 'Pick Preview from Draft or Bank to load a question here.';
  }

  renderTopStrip();
}

