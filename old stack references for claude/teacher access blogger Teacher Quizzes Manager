/** =========================
 * API
 * ========================= */
async function apiPost(action, payload){
  if (!API_URL || API_URL.indexOf('REPLACE_WITH') !== -1){
    throw new Error('API_URL_not_configured');
  }

  const body = Object.assign({}, payload || {}, {
    action: action,
    token: TOKEN
  });

  const res = await fetch(API_URL, {
    method: 'POST',
    mode: 'cors',
    body: JSON.stringify(body)
  });

  const txt = await res.text();
  let obj = null;
  try { obj = JSON.parse(txt); } catch(e){ obj = null; }

  const xsc = res.headers.get('X-Status-Code');
  const status = xsc ? parseInt(xsc,10) : res.status;

  if (!obj || obj.ok !== true){
    const err = (obj && (obj.error || obj.detail)) || ('http_' + status);
    return { ok:false, status, error: err, raw: obj, text: txt };
  }
  return { ok:true, status, data: obj };
}

