 * ========================= */
function setSelectValue(selectEl, rawValue){
  const v = normalizeField(rawValue);
  if (!v){
    selectEl.value = "";
    return;
  }
  const has = Array.from(selectEl.options).some(o => o.value === v);
  if (!has){
    const opt = document.createElement("option");
    opt.value = v;
    opt.textContent = v;
    selectEl.appendChild(opt);
  }
  selectEl.value = v;
}

function rebuildSubjectTopicOptions(items){
  const keepSubject = qb_subject.value;
  const keepTopic = qb_topic.value;

  const subjects = new Set();
  const topics = new Set();

  (items || []).forEach(it => {
    const s = normalizeField(it.subject);
    const t = normalizeField(it.topic);
    if (s) subjects.add(s);
    if (t) topics.add(t);
  });

  const subjArr = Array.from(subjects).sort((a,b) => a.localeCompare(b));
  const topicArr = Array.from(topics).sort((a,b) => a.localeCompare(b));

  qb_subject.innerHTML = `<option value="">Any</option>` + subjArr.map(v => `<option value="${escapeHtml(v)}">${escapeHtml(v)}</option>`).join("");
  qb_topic.innerHTML = `<option value="">Any</option>` + topicArr.map(v => `<option value="${escapeHtml(v)}">${escapeHtml(v)}</option>`).join("");

  setSelectValue(qb_subject, keepSubject);
  setSelectValue(qb_topic, keepTopic);
}

function renderBankRows(items){
  if (!items || !items.length){
    qbRows.innerHTML = `<tr><td colspan="3" class="hint" style="padding:12px">No results. Try different filters.</td></tr>`;
    return;
  }

  qbRows.innerHTML = items.map(it=>{
    const id = escapeHtml(it.bank_item_id||'');
    const stem = escapeHtml(shortStem(it.stem||''));
    const subj = escapeHtml(it.subject||'—');
    const topic = escapeHtml(it.topic||'—');
    const diff = escapeHtml(it.difficulty||'—');
    const stype = escapeHtml(it.source_type||'—');

    return `
      <tr>
        <td>
          <div style="font-weight:900">${stem || '<span class="muted">—</span>'}</div>
          <div class="muted mono" style="margin-top:6px">${id}</div>
        </td>
        <td>
          <div class="muted" style="font-size:12px">${subj} | ${topic}</div>
          <div class="muted" style="font-size:12px">${diff} | Source: ${stype}</div>
        </td>
        <td>
          <div class="qBtns">
            <button class="btn qSmall" data-bprev="${id}" type="button">Preview</button>
            <button class="btn qSmall primary" data-badd="${id}" type="button">Add</button>
          </div>
        </td>
      </tr>
    `;
  }).join('');

  qbRows.querySelectorAll('[data-bprev]').forEach(btn=>{
    btn.addEventListener('click', async (e)=>{
      e.stopPropagation();
      const id = btn.getAttribute('data-bprev');
      setActiveTab('questions');
      setActiveTool('preview');
      await qeLoadBankItem(id);
    });
  });

  qbRows.querySelectorAll('[data-badd]').forEach(btn=>{
    btn.addEventListener('click', (e)=>{
      e.stopPropagation();
      const id = btn.getAttribute('data-badd');
      addToDraft(id);
    });
  });
}

async function loadBankList(){
  if (!SELECTED_ID){
    toast('Save quiz first', 'Save the quiz to get an ID, then load bank items.');
    return;
  }

  qbHint.textContent = 'Loading…';

  const r = await apiPost('bank.items.list', {
    status: String(qb_status.value||'ACTIVE').trim(),
    q: String(qb_q.value||'').trim(),
    subject: String(qb_subject.value||'').trim(),
    topic: String(qb_topic.value||'').trim(),
    difficulty: String(qb_difficulty.value||'').trim(),
    source_type: String(qb_source_type.value||'').trim(),
    limit: String(qb_limit.value||'50').trim()
  });

  if (!r.ok){
    qbHint.textContent = '';
    toast('Bank list failed', String(r.error||'unknown'));
    return;
  }

  BANK_LIST_CACHE = Array.isArray(r.data.items) ? r.data.items : [];
  qbCountPill.textContent = `${BANK_LIST_CACHE.length} items`;
  qbHint.textContent = `Last load: ${nowIso()}`;

  BANK_LIST_CACHE.forEach(it=>{
    const id = String(it.bank_item_id||'').trim();
    if (id) BANK_CACHE_BY_ID.set(id, it);
  });

  rebuildSubjectTopicOptions(BANK_LIST_CACHE);
  renderBankRows(BANK_LIST_CACHE);
}

function clearBankFilters(){
  qb_q.value = '';
  qb_status.value = 'ACTIVE';
  qb_subject.value = '';
  qb_topic.value = '';
  qb_difficulty.value = '';
  qb_source_type.value = '';
  qb_limit.value = '50';
  qbHint.textContent = '';
}

/* =========================
 * QUESTION EDITOR
 * ========================= */
function qeSetMode(mode){
  const m = String(mode||'NEW').toUpperCase();
  if (m === 'EDIT'){
    qeModePill.textContent = 'EDIT';
    qeModePill.className = 'qPill warn';
    qeTitle.textContent = 'Question editor (bank item)';
  }else{
    qeModePill.textContent = 'NEW';
    qeModePill.className = 'qPill ok';
    qeTitle.textContent = 'Question editor (inline create)';
  }
}

function qeSetMeta(id, obj){
  qeBankId.textContent = id || '—';
  const c = obj && obj.created_at ? obj.created_at : '—';
  const u = obj && obj.updated_at ? obj.updated_at : '—';
  qeTimestamps.textContent = `Created: ${c} | Updated: ${u}`;
}

function qeReadForm(){
  return {
    stem: normalizeField(qe_stem.value),

    option_a: normalizeField(qe_option_a.value),
    fb_a: normalizeField(qe_fb_a.value),
    option_b: normalizeField(qe_option_b.value),
    fb_b: normalizeField(qe_fb_b.value),
    option_c: normalizeField(qe_option_c.value),
    fb_c: normalizeField(qe_fb_c.value),
    option_d: normalizeField(qe_option_d.value),
    fb_d: normalizeField(qe_fb_d.value),
    option_e: normalizeField(qe_option_e.value),
    fb_e: normalizeField(qe_fb_e.value),
    option_f: normalizeField(qe_option_f.value),
    fb_f: normalizeField(qe_fb_f.value),

    correct: normalizeField(qe_correct.value).toUpperCase(),

    rationale: normalizeField(qe_rationale.value),
    rationale_img: normalizeField(qe_rationale_img.value),

    subject: normalizeField(qe_subject.value),
    topic: normalizeField(qe_topic.value),
    difficulty: normalizeField(qe_difficulty.value),
    marks: normalizeField(qe_marks.value),

    source_type: normalizeField(qe_source_type.value),
    source_course_id: normalizeField(qe_source_course_id.value),
    source_sheet_id: normalizeField(qe_source_sheet_id.value),
    source_item_id: normalizeField(qe_source_item_id.value)
  };
}

function qeFillForm(obj){
  obj = obj || {};
  qe_stem.value = normalizeField(obj.stem);

  qe_option_a.value = normalizeField(obj.option_a);
  qe_fb_a.value = normalizeField(obj.fb_a);
  qe_option_b.value = normalizeField(obj.option_b);
  qe_fb_b.value = normalizeField(obj.fb_b);
  qe_option_c.value = normalizeField(obj.option_c);
  qe_fb_c.value = normalizeField(obj.fb_c);
  qe_option_d.value = normalizeField(obj.option_d);
  qe_fb_d.value = normalizeField(obj.fb_d);
  qe_option_e.value = normalizeField(obj.option_e);
  qe_fb_e.value = normalizeField(obj.fb_e);
  qe_option_f.value = normalizeField(obj.option_f);
  qe_fb_f.value = normalizeField(obj.fb_f);

  qe_correct.value = normalizeField(obj.correct).toUpperCase();

  qe_rationale.value = normalizeField(obj.rationale);
  qe_rationale_img.value = normalizeField(obj.rationale_img);

  qe_subject.value = normalizeField(obj.subject);
  qe_topic.value = normalizeField(obj.topic);

  setSelectValue(qe_difficulty, obj.difficulty);
  qe_marks.value = normalizeField(obj.marks || '1');

  setSelectValue(qe_source_type, obj.source_type);
  qe_source_course_id.value = normalizeField(obj.source_course_id);
  qe_source_sheet_id.value = normalizeField(obj.source_sheet_id);
  qe_source_item_id.value = normalizeField(obj.source_item_id);
}

function qeValidate(form){
  if (!form.stem) return 'Stem is required.';
  if (!form.option_a) return 'Option A is required.';
  if (!form.option_b) return 'Option B is required.';
  const allowed = ["A","B","C","D","E","F"];
  if (!form.correct || !allowed.includes(form.correct)) return 'Choose a correct option (A–F).';

  const map = { A: form.option_a, B: form.option_b, C: form.option_c, D: form.option_d, E: form.option_e, F: form.option_f };
  const nonEmpty = Object.keys(map).filter(k => !!map[k]);
  if (nonEmpty.length < 2) return 'Provide at least two options.';
  if (!map[form.correct]) return 'Correct option points to an empty option.';
  return '';
}

function qeDiffPatch(original, form){
  const patch = {};
  original = original || {};
  Object.keys(form).forEach(k=>{
    const a = normalizeField(original[k]);
    const b = normalizeField(form[k]);
    if (a !== b) patch[k] = b;
  });
  return patch;
}

function qeNewInlineMode(){
  QE_CURRENT_ID = '';
  QE_CURRENT_ORIG = null;
  qeSetMode('NEW');

  qeFillForm({
    stem:'',
    option_a:'', option_b:'', option_c:'', option_d:'', option_e:'', option_f:'',
    fb_a:'', fb_b:'', fb_c:'', fb_d:'', fb_e:'', fb_f:'',
    correct:'',
    rationale:'',
    rationale_img:'',
    subject:'',
    topic:'',
    difficulty:'',
    marks:'1',
    source_type:'QUIZ_INLINE',
    source_course_id: SELECTED_ID || '',
    source_sheet_id:'',
    source_item_id:''
  });

  qeSetMeta('', null);
  qeWarn.textContent = (!SELECTED_ID) ? 'Save the quiz first to start adding questions.' : '';
  qe_stem.focus();
}

async function qeLoadBankItem(bank_item_id){
  const id = String(bank_item_id||'').trim();
  if (!id) return;
  
QE_IS_LIB = false;
QE_LIB_REF = '';
qeSaveQuestion.disabled = false;
  
  const r = await apiPost('bank.item.get', { bank_item_id: id });
  if (!r.ok){
    toast('Preview failed', String(r.error||'unknown'));
    return;
  }

  const item = r.data.item || null;
  if (!item){
    toast('Preview failed', 'No item returned.');
    return;
  }

  BANK_CACHE_BY_ID.set(id, item);

  QE_CURRENT_ID = id;
  QE_CURRENT_ORIG = item;
  qeSetMode('EDIT');
  qeFillForm(item);
  qeSetMeta(id, item);

  qeWarn.textContent = 'Editing a bank item changes it for any quiz that uses it (before publish snapshots).';
  qe_stem.focus();
}

async function qeLoadLibRef(ref){
  const key = String(ref||'').trim();
  if (!key) return;

  // Ensure we have preview hydrated
  let it = DRAFT_PREVIEW_BY_REF.get(key);
  if (!it){
    await refreshDraftPreview(true);
    it = DRAFT_PREVIEW_BY_REF.get(key);
  }

  if (!it){
    toast('Preview failed', 'Library item not found in draft preview.');
    return;
  }

  QE_IS_LIB = true;
  QE_LIB_REF = key;
  QE_CURRENT_ID = '';
  QE_CURRENT_ORIG = null;

  qeSetMode('EDIT');
  qeFillForm(Object.assign({}, it, {
    source_type: 'LIB',
    source_course_id: (it.lib && it.lib.course_id) ? it.lib.course_id : '',
    source_sheet_id: '',
    source_item_id: (it.lib && it.lib.item_id) ? it.lib.item_id : ''
  }));

  qeBankId.textContent = (it.display && it.display.id) ? it.display.id : key;
  qeTimestamps.textContent = `Library: ${(it.lib && it.lib.course_id)||''} | Item: ${(it.lib && it.lib.item_id)||''}`;
  qeWarn.textContent = 'This is a QAcademy Library item (read-only). It will be snapshotted on publish.';
  qeSaveQuestion.disabled = true;
  qeAddToDraft.disabled = false;
}
  
async function qeSave(){
  if (!SELECTED_ID){
    toast('Save quiz first', 'Save the quiz to get an ID, then save questions.');
    return;
  }

  const form = qeReadForm();
  const err = qeValidate(form);
  if (err){
    toast('Fix required', err);
    return;
  }

  if (!QE_CURRENT_ID){
    if (!form.source_type) form.source_type = 'QUIZ_INLINE';
    if (String(form.source_type).toUpperCase() === 'QUIZ_INLINE' && !form.source_course_id){
      form.source_course_id = SELECTED_ID;
    }

    const r = await apiPost('bank.item.create', form);
    if (!r.ok){
      toast('Create failed', String(r.error||'unknown'));
      return;
    }

    const newId = String(r.data.bank_item_id||'').trim();
    if (!newId){
      toast('Create failed', 'No bank_item_id returned.');
      return;
    }

    toast('Created', `Saved to bank: ${newId}`);

    BANK_CACHE_BY_ID.set(newId, Object.assign({}, form, { bank_item_id:newId, stem: form.stem }));

    addToDraft(newId);

    setActiveTab('questions');
    setActiveTool('preview');
    await qeLoadBankItem(newId);
    return;
  }

  const patch = qeDiffPatch(QE_CURRENT_ORIG, form);
  if (!Object.keys(patch).length){
    toast('No changes', 'Nothing to save.');
    return;
  }

  const r = await apiPost('bank.item.update', Object.assign({ bank_item_id: QE_CURRENT_ID }, patch));
  if (!r.ok){
    toast('Update failed', String(r.error||'unknown'));
    return;
  }

  toast('Saved', 'Bank item updated.');
  await qeLoadBankItem(QE_CURRENT_ID);
}

function qeAddCurrentToDraft(){
  if (!SELECTED_ID){
    toast('Save quiz first', 'Save the quiz to get an ID, then add questions.');
    return;
  }

  // ✅ NEW: allow adding the current LIB ref
  if (QE_IS_LIB && QE_LIB_REF){
    addToDraft(QE_LIB_REF);
    return;
  }

  if (QE_CURRENT_ID){
    addToDraft(QE_CURRENT_ID);
    return;
  }

  toast('Save first', 'Save this inline question to bank first, then it can be added to draft.');
}

