  if (raw){
    const parsed = safeJsonParse(raw, null);
    if (Array.isArray(parsed)) ids = parsed;
    else if (parsed && Array.isArray(parsed.items)) ids = parsed.items;
  }

  if (!ids.length){
    const ls = localStorage.getItem(draftLsKey()) || '';
    if (ls){
      const parsed = safeJsonParse(ls, null);
      if (parsed && Array.isArray(parsed.items)) ids = parsed.items;
      if (ids.length){
        toast('Draft recovered', 'Loaded draft from this browser (local backup).');
      }
    }
  }

  DRAFT_IDS = uniqPreserve(ids);
  DRAFT_SET = new Set(DRAFT_IDS);

