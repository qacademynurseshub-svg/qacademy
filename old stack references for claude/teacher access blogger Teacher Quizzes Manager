function applyDraftPreviewPayload(payload){
  const items = (payload && Array.isArray(payload.items)) ? payload.items : [];
  const missing = (payload && Array.isArray(payload.missing)) ? payload.missing : [];

  DRAFT_PREVIEW_BY_REF = new Map();
  DRAFT_PREVIEW_MISSING = missing;

  // Prime your existing cache so Draft list can render stems/meta quickly
  items.forEach(it => {
    const ref = String(it.ref || '').trim();
    if (!ref) return;

    DRAFT_PREVIEW_BY_REF.set(ref, it);

    // Keep your existing Draft list logic intact by storing “bank-like” summary
    BANK_CACHE_BY_ID.set(ref, {
      bank_item_id: ref,
      stem: it.stem || '',
      subject: it.subject || '',
      topic: it.topic || '',
      difficulty: it.difficulty || '',
      _display_id: (it.display && it.display.id) ? it.display.id : ref,
      _badge: (it.display && it.display.badge) ? it.display.badge : '',
      _source: it.source || '',
      _readonly: !!it.readonly,
      _preview: it
    });
  });
}

