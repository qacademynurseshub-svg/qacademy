<script>
(function(){
  /* ================= CONFIG ================= */
  var WEB_APP_URL_QUIZ = 'https://script.google.com/macros/s/AKfycbx_QHvNJqm65XavV8FBtPGhdveTFP_bMMYY2mtKfp6uErNjYL9A01zQs2S9uGjCbP58/exec';
  var QUIZ_ID          = 'RN_MED-T1';   // ← set your quiz id
  var PAGE_SIZE        = 20;            // questions per page
  var ENABLE_GRID      = true;

  /* =============== STATE =============== */
  var data = null;
  var pageIndex = 0;                     // 0-based page index (relative to current view)
  var answers = {};                      // item_id -> letter
  var flags   = {};                      // item_id -> boolean
  var viewMode = 'ALL';                  // 'ALL' | 'FLAGGED'
  var timer   = { total:0, remaining:0, tick:null, running:false };
  var submitted = false;
  var started = false;                   // start only after pre-flight

  /* ===== Review paging config/state ===== */
  var REVIEW_PAGE_SIZE = 10;
  var reviewPage = 0;                 // 0-based feedback page
  var reviewItemsCache = [];          // array of HTML strings per question

  /* ===== Image overlay state ===== */
  var imgOverlayApi = { open:null, ready:false };

  /* =============== HELPERS =============== */
  function $(id){ return document.getElementById(id); }
  function show(el, yes){ if(!el) return; el.style.display = yes ? '' : 'none'; }
  function msg(t){ var m=$('qa-msg'); if(!m) return; m.textContent=t||''; show(m, !!t); }
  function pct(a,b){ return b ? Math.round((a/b)*100) : 0; }
  function fmtTime(s){ if (s<0) s=0; var m=Math.floor(s/60), ss=s%60; return (m<10?'0':'')+m+':' + (ss<10?'0':'')+ss; }
  function decodeHTML(s){ if(!s) return ''; var ta=document.createElement('textarea'); ta.innerHTML=s; return s ? ta.value.replace(/\u00A0/g,' ') : ''; }
  function asciiClean(s){
    return String(decodeHTML(s)||'')
      .replace(/[\u2018\u2019]/g,"'")
      .replace(/[\u201C\u201D]/g,'"')
      .replace(/[\u2013\u2014]/g,"-")
      .replace(/\u2022/g,"*");
  }
  function escAttr(s){
    return String(s==null ? '' : s)
      .replace(/&/g,'&amp;')
      .replace(/"/g,'&quot;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;');
  }
  function clamp(n,min,max){ return Math.max(min, Math.min(max, n)); }
  function storageKey(k){ return 'qa_timed_' + QUIZ_ID + '_' + k; }
  function saveDraft(){
    try{
      localStorage.setItem(storageKey('draft'), JSON.stringify({
        pageIndex: pageIndex,
        remaining_sec: timer.remaining,
        answers: answers,
        flags: flags,
        viewMode: viewMode,
        started: started
      }));
    }catch(e){}
  }
  function loadDraft(){
    try{ return JSON.parse(localStorage.getItem(storageKey('draft')) || 'null'); }catch(e){ return null; }
  }
  function saveSummary(obj){
    try{ localStorage.setItem(storageKey('summary'), JSON.stringify(obj||{})); }catch(e){}
  }
  function loadSummary(){
    try{ return JSON.parse(localStorage.getItem(storageKey('summary')) || 'null'); }catch(e){ return null; }
  }
  function clearAllStorage(){
    localStorage.removeItem(storageKey('draft'));
    localStorage.removeItem(storageKey('summary'));
    localStorage.removeItem(storageKey('attempts'));
  }

  function onceClick(btn, handler){
    if(!btn) return;
    btn.addEventListener('click', function(){
      if(btn._busy) return;
      btn._busy = true;
      try{ handler(); } finally {
        setTimeout(function(){ btn._busy = false; }, 500);
      }
    });
  }

  /* ===== STATUS CARD HELPERS (same style as other legacy templates) ===== */
  function formatDateTime(raw){
    if(!raw) return '';
    var d = new Date(raw);
    if(isNaN(d.getTime())) return String(raw);
    return d.toLocaleString('en-GB', {
      year:'numeric', month:'short', day:'2-digit',
      hour:'2-digit', minute:'2-digit'
    });
  }

  function renderHeadFromPayload(payload, statusText){
    var title =
      (payload && (payload.title || payload.quiz_title)) ||
      (payload.quiz && payload.quiz.title) ||
      (payload.meta && payload.meta.title) ||
      QUIZ_ID.replace(/_/g,' ');
    $('qa-title').textContent = asciiClean(title);
    $('qa-sub').textContent   = statusText || '';
  }

  function showStatusCard(status, payload){
    var box = $('qa-status-card');
    if(!box) return;

    // Hide main quiz UI
    show($('qa-pref'), false);
    show($('qa-hud'), false);
    show($('qa-questions'), false);
    show($('qa-actions'), false);
    show($('qa-pager-top'), false);
    show($('qa-pager-bottom'), false);
    show($('qa-result'), false);
    show($('qa-grid-fab'), false);
    msg('');

    var publishAt   = payload.publish_at   || payload.publishFrom   || payload.published_at || '';
    var unpublishAt = payload.unpublish_at || payload.unpublishes_at || payload.close_at    || '';

    var publishNice   = formatDateTime(publishAt);
    var unpublishNice = formatDateTime(unpublishAt);

    var title, body, bg, border, chip;

    if(status === 'scheduled'){
      bg     = '#fff7e6';
      border = '#facc15';
      chip   = '#92400e';
      title  = 'Quiz opens soon';
      body   = publishNice
        ? 'This quiz is scheduled to open on ' + publishNice + '. Please check back then.'
        : 'This quiz is scheduled but not yet open. Please check again later.';
    }else if(status === 'closed'){
      bg     = '#fee2e2';
      border = '#ef4444';
      chip   = '#991b1b';
      title  = 'Quiz closed';
      body   = unpublishNice
        ? 'This quiz closed on ' + unpublishNice + '. It is no longer available to attempt.'
        : 'This quiz is closed and no longer available to attempt.';
    }else{ // unpublished or anything else
      bg     = '#f3f4f6';
      border = '#9ca3af';
      chip   = '#111827';
      title  = 'Quiz not available';
      body   = 'This quiz is not currently published. Please check your course page or contact QAcademy if you think this is a mistake.';
    }

    box.innerHTML =
      '<div style="padding:12px 14px;border-radius:12px;border:1px solid '+border+';background:'+bg+';box-shadow:0 6px 16px rgba(0,0,0,.04);font-size:13px;color:#111827;">' +
        '<div style="font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:6px;">' +
          '<span style="display:inline-block;padding:2px 8px;border-radius:999px;border:1px solid '+border+';background:rgba(255,255,255,.7);font-size:11px;color:'+chip+';text-transform:uppercase;letter-spacing:.04em;">' +
            status.toUpperCase() +
          '</span>' +
          '<span>'+ title +'</span>' +
        '</div>' +
        '<p style="margin:0;color:#374151;line-height:1.5;">'+ body +'</p>' +
      '</div>';

    box.style.display = 'block';
    renderHeadFromPayload(payload, title);
  }

  /* ===== Review item (with optional rationale image) ===== */
  function reviewItemHTML(it, idxAbsolute){
    var sel = answers[it.item_id] || '';
    var ok  = (sel === it.correct);
    var CHECK = '✅', CROSS = '❌';
    var head = (ok?CHECK:CROSS) + ' ' + (it.number || idxAbsolute+1) + '. ' + asciiClean(it.stem||'') +
               ' - Your: ' + (sel||'-') + ' - Correct: ' + (it.correct || '-');

    var rat = asciiClean(it.rationale || '—');
    var optA = asciiClean(it.option_a || '');
    var optB = asciiClean(it.option_b || '');
    var optC = asciiClean(it.option_c || '');
    var optD = asciiClean(it.option_d || '');
    var fbA = asciiClean(it.fb_a || '-');
    var fbB = asciiClean(it.fb_b || '-');
    var fbC = asciiClean(it.fb_c || '-');
    var fbD = asciiClean(it.fb_d || '-');
    var alt = (idxAbsolute % 2 === 0) ? 'alt0' : 'alt1';

    var imgUrl = it.rationale_img || it.rationaleImage || it.rationaleImg || '';
    var imgBlock = '';
    if (imgUrl){
      imgBlock =
        '<div class="qa-rationale-img-wrap">'+
          '<img src="'+escAttr(imgUrl)+'" data-full-src="'+escAttr(imgUrl)+'" class="qa-rationale-thumb" alt="Rationale image">'+
          '<div class="qa-rationale-hint">Tap image to view full size. Tap outside the image or press Esc to close.</div>'+
        '</div>';
    }

    return ''+
    '<details class="qa-review-item '+alt+'">'+
      '<summary>'+head+'</summary>'+
      '<div class="qa-review-body">'+
        '<div><strong>Rationale:</strong> '+rat+'</div>'+
        imgBlock+
        '<div style="margin-top:6px"><strong>Why others are wrong:</strong></div>'+
        (optA ? '<div><strong>A.</strong> '+optA+' — '+fbA+'</div>' : '')+
        (optB ? '<div><strong>B.</strong> '+optB+' — '+fbB+'</div>' : '')+
        (optC ? '<div><strong>C.</strong> '+optC+' — '+fbC+'</div>' : '')+
        (optD ? '<div><strong>D.</strong> '+optD+' — '+fbD+'</div>' : '')+
      '</div>'+
    '</details>';
  }

  function renderReviewPage(){
    var wrap = $('qa-review'); if(!wrap) return;
    var total = reviewItemsCache.length;
    var from = reviewPage * REVIEW_PAGE_SIZE;
    var to   = Math.min(total, from + REVIEW_PAGE_SIZE);

    var introHTML =
      '<div class="qa-review-intro">'+
        '<strong>How to use:</strong> Tap a question to expand its full feedback. '+
        'Showing <span id="qa-r-range">'+(from+1)+'–'+to+'</span> of <span id="qa-r-total">'+total+'</span>.'+
      '</div>';

    var sliceHTML = reviewItemsCache.slice(from, to).join('');

    var totalPages = Math.max(1, Math.ceil(total/REVIEW_PAGE_SIZE));
    var ctrlsHTML =
      '<div id="qa-review-ctrls" style="display:flex;gap:8px;align-items:center;justify-content:center;margin-top:8px;flex-wrap:wrap">'+
        '<button id="qa-rprev" class="qa-btn-ghost" type="button">Prev</button>'+
        '<span id="qa-rinfo" style="font-weight:700;color:#0b7a75">Page '+(reviewPage+1)+' of '+ totalPages +'</span>'+
        '<button id="qa-rnext" class="qa-btn" type="button">Next</button>'+
      '</div>';

    wrap.innerHTML = introHTML + sliceHTML + ctrlsHTML;

    var btnPrev = $('qa-rprev'), btnNext = $('qa-rnext');
    if(btnPrev){ btnPrev.disabled = (reviewPage===0); }
    if(btnNext){ btnNext.disabled = (reviewPage>=totalPages-1); }

    onceClick(btnPrev, function(){
      reviewPage = clamp(reviewPage-1, 0, totalPages-1);
      renderReviewPage();
    });
    onceClick(btnNext, function(){
      reviewPage = clamp(reviewPage+1, 0, totalPages-1);
      renderReviewPage();
    });

    initRationaleImages();
  }

  function updateFlagNavVisibility(){
    var onFlagged = (viewMode === 'FLAGGED');
    show($('qa-prev-flag'), onFlagged);
    show($('qa-next-flag'), onFlagged);
  }

  /* =============== Image overlay setup =============== */
  function setupImageOverlay(){
    var overlay = $('qa-img-overlay');
    var overlayImg = $('qa-img-overlay-img');
    var inner = $('qa-img-overlay-inner');
    if(!overlay || !overlayImg || !inner) return;

    function close(){
      overlay.style.display = 'none';
      overlayImg.src = '';
    }
    function open(src){
      if(!src) return;
      overlayImg.src = src;
      overlay.style.display = 'flex';
    }

    overlay.addEventListener('click', function(e){
      if(!inner.contains(e.target)){
        close();
      }
    });

    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape'){
        close();
      }
    });

    imgOverlayApi.open = open;
    imgOverlayApi.ready = true;
  }

  function initRationaleImages(){
    if(!imgOverlayApi.ready) return;
    var thumbs = document.querySelectorAll('.qa-rationale-thumb');
    thumbs.forEach(function(img){
      img.addEventListener('click', function(e){
        e.stopPropagation();
        var src = img.getAttribute('data-full-src') || img.getAttribute('src');
        imgOverlayApi.open(src);
      });
    });
  }

  /* =============== BUILD =============== */
  function renderHead(){
    $('qa-title').textContent = asciiClean(data.quiz.title || 'Timed Quiz');
    $('qa-sub').textContent = 'Timed - ' + data.items.length + ' questions';
  }

  function answeredCount(){
    var n=0; (data.items||[]).forEach(function(it){ if(answers[it.item_id]) n++; }); return n;
  }

  function updateHUD(){
    var total = data ? data.items.length : 0;
    var ans = answeredCount();
    $('qa-progress-text').textContent = 'Answered: ' + ans + ' / ' + total;
    var p = pct(ans, total);
    $('qa-progress-bar').style.width = p + '%';
    $('qa-progress-label').textContent = p + '%';
  }

  /* ===== TIMER (fixed: fresh vs resume) ===== */
  function startTimer(totalSec, resume){
    timer.total = totalSec;

    var sum = loadSummary();
    if(sum && sum.completed){
      timer.remaining = 0;
      $('qa-timer').textContent = '00:00';
      timer.running = false;
      return;
    }

    var d = resume ? loadDraft() : null;
    var draftRemaining = d && typeof d.remaining_sec === 'number' ? d.remaining_sec : null;

    timer.remaining = (resume && Number.isFinite(draftRemaining) && draftRemaining > 0)
      ? draftRemaining
      : totalSec;

    $('qa-timer').textContent = fmtTime(timer.remaining);

    if(timer.tick) clearInterval(timer.tick);
    var tickCount = 0;
    timer.tick = setInterval(function(){
      timer.remaining -= 1;
      if (timer.remaining < 0) timer.remaining = 0;
      $('qa-timer').textContent = fmtTime(timer.remaining);

      // save draft less frequently
      tickCount++;
      if (tickCount % 5 === 0){ saveDraft(); }

      if(timer.remaining < 1){
        clearInterval(timer.tick);
        timer.running=false;
        submitAttempt(true);
      }
    },1000);

    timer.running = true;
  }

  function stopTimer(){ if(timer.tick){ clearInterval(timer.tick); timer.tick=null; } timer.running=false; }

  function currentSource(){
    if(viewMode==='FLAGGED'){
      var f = (data.items||[]).filter(function(it){ return !!flags[it.item_id]; });
      return (f.length? f : (data.items||[]));
    }
    return data.items||[];
  }

  function currentSlice(){
    var src = currentSource();
    var total = src.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (pageIndex < 0) pageIndex = 0;
    if (pageIndex >= totalPages) pageIndex = totalPages - 1;
    var start = pageIndex * PAGE_SIZE;
    var end   = Math.min(total, start + PAGE_SIZE);
    return { src: src, total: total, totalPages: totalPages, start: start, end: end, pageFrom:start+1, pageTo:end };
  }

  function cardHTML(it){
    var letters = ['A','B','C','D'];
    var opts = letters.map(function(L){
      var key = 'option_' + L.toLowerCase();
      var text = asciiClean(it[key] || '');
      if (!text) return '';
      return '<label class="qa-opt">'+
               '<input type="radio" name="q_'+it.item_id+'" value="'+L+'" '+(answers[it.item_id]===L?'checked':'')+'>'+
               '<span><strong>'+L+'.</strong> '+ text +'</span>'+
             '</label>';
    }).join('');
    var meta = it.topic ? '<p class="qa-meta">Topic: '+ asciiClean(it.topic) +'</p>' : '';
    return (
      '<section class="qa-card" data-id="'+it.item_id+'">'+
        '<div class="qa-badge">QAcademy</div>'+
        '<h2 class="qa-title">Question '+ it.number +'</h2>'+
        meta+
        '<p class="qa-stem">'+ asciiClean(it.stem||'') +'</p>'+
        '<div class="qa-opts">'+ opts +'</div>'+
        '<div style="margin-top:8px">'+
          '<button class="qa-flag qa-btn-ghost" type="button" style="padding:8px 12px;border-radius:10px">'+
            (flags[it.item_id]?'Unflag':'Flag')+
          '</button>'+
        '</div>'+
      '</section>'
    );
  }

  function buildPager(host){
    if(!host) return;
    var c = currentSlice();
    host.innerHTML = '';
    var wrap = document.createElement('div'); wrap.id='qa-pager';

    var prev = document.createElement('button');
    prev.className='qa-btn qa-btn-ghost'; prev.type='button'; prev.textContent='Prev';
    prev.disabled = (pageIndex===0);
    prev.onclick = function(){ pageIndex--; renderPage(); saveDraft(); };
    wrap.appendChild(prev);

    var info = document.createElement('span');
    info.id='qa-page-info';
    info.textContent = 'Page ' + (pageIndex+1) + ' of ' + c.totalPages + ' - ' + PAGE_SIZE + '/page';
    wrap.appendChild(info);

    if(pageIndex < c.totalPages - 1){
      var next = document.createElement('button');
      next.className='qa-btn'; next.type='button'; next.textContent='Next';
      next.onclick = function(){ pageIndex++; renderPage(); saveDraft(); };
      wrap.appendChild(next);
    }
    host.appendChild(wrap);
  }

  function flaggedPageIndexes(){
    var idxSet = new Set();
    (data.items||[]).forEach(function(it, i){
      if(flags[it.item_id]){
        var p = Math.floor(i / PAGE_SIZE);
        idxSet.add(p);
      }
    });
    return Array.from(idxSet).sort(function(a,b){ return a-b; });
  }
  function jumpToNextFlagged(){
    var pages = flaggedPageIndexes();
    if(!pages.length){ alert('No flagged questions.'); return; }
    var curAbs = pageIndex;
    var target = pages.find(function(p){ return p > curAbs; });
    pageIndex = (typeof target==='number') ? target : pages[0];
    viewMode='ALL'; renderPage(); saveDraft();
  }
  function jumpToPrevFlagged(){
    var pages = flaggedPageIndexes();
    if(!pages.length){ alert('No flagged questions.'); return; }
    var curAbs = pageIndex;
    var target = null;
    for(var i=pages.length-1;i>=0;i--){ if(pages[i] < curAbs){ target = pages[i]; break; } }
    pageIndex = (target!==null) ? target : pages[pages.length-1];
    viewMode='ALL'; renderPage(); saveDraft();
  }

  /* ===== Build Review (paged) ===== */
  function buildReview(){
    reviewItemsCache = [];
    var total = (data.items||[]).length, score=0;

    (data.items||[]).forEach(function(it, i){
      var sel = answers[it.item_id] || '';
      if (sel === it.correct) score++;
      reviewItemsCache.push(reviewItemHTML(it, i));
    });

    $('qa-result-text').textContent = 'Submitted - Score: ' + score + ' / ' + total + ' (' + pct(score,total) + '%)';
    reviewPage = 0;
    renderReviewPage();
  }

  /* ===== Render Page ===== */
  function renderPage(){
    var c = currentSlice();

    var html = '';
    for(var i=c.start;i<c.end;i++) html += cardHTML(c.src[i]);
    $('qa-questions').innerHTML = html;

    document.querySelectorAll('.qa-card').forEach(function(sec){
      var id = sec.getAttribute('data-id');
      sec.querySelectorAll('input[type="radio"]').forEach(function(r){
        r.addEventListener('change', function(){
          if(submitted) return;
          answers[id] = String(r.value || '').toUpperCase();
          updateHUD(); saveDraft();
        });
      });
      var flagBtn = sec.querySelector('.qa-flag');
      if(flagBtn){
        flagBtn.addEventListener('click', function(){
          flags[id] = !flags[id];
          flagBtn.textContent = flags[id] ? 'Unflag' : 'Flag';
          saveDraft();
        });
      }
    });

    buildPager($('qa-pager-top'));
    buildPager($('qa-pager-bottom'));

    updateHUD();

    var first = document.querySelector('.qa-card');
    if(first){
      var hudH = $('qa-hud').offsetHeight || 0;
      var y = first.getBoundingClientRect().top + window.scrollY - hudH - 10;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }

    if(ENABLE_GRID){ $('qa-grid-fab').style.display = 'inline-block'; }
    updateFlagNavVisibility();
  }

  /* ===== Submit / Reset ===== */
  function submitAttempt(auto){
    if(submitted) return;
    var total = (data.items||[]).length;
    var answered = answeredCount();
    if (!auto && answered < total){
      if (!confirm('You answered '+answered+'/'+total+'. Submit?')) return;
    }
    submitted = true;
    stopTimer();
    window.onbeforeunload = null;

    var rec = {
      completed:true,
      answers:answers,
      flags:flags,
      timestamp_iso:new Date().toISOString(),
      duration_sec:(timer.total - Math.max(0,timer.remaining))
    };
    saveSummary(rec);

    buildReview();
    show($('qa-result'), true);
    show($('qa-actions'), true);
    $('qa-submit').disabled = true; $('qa-submit-btm').disabled = true;
    msg('');

    setTimeout(function(){
      var hud = $('qa-hud');
      var hudH = hud ? (hud.offsetHeight || 0) : 0;
      var target = document.querySelector('#qa-review .qa-review-item') || $('qa-review');
      if(target){
        var y = target.getBoundingClientRect().top + window.scrollY - hudH - 10;
        window.scrollTo({ top: y, behavior: 'smooth' });
      }
    }, 0);
  }

  function resetAttempt(){
    if(!confirm('Reset answers and start timer again?')) return;
    submitted = false;
    answers = {}; flags = {}; pageIndex = 0;
    clearAllStorage();
    renderPage();
    updateHUD();
    stopTimer();
    var limit = (data.quiz && data.quiz.time_limit_sec) || 0;
    startTimer(limit, false);
    $('qa-submit').disabled = false; $('qa-submit-btm').disabled = false;
    show($('qa-result'), false);
    started = true;
    saveDraft();
  }

  /* ===== Pre-flight control ===== */
  function startUI(isResume){
    started = true;
    show($('qa-pref'), false);
    show($('qa-hud'), true);
    show($('qa-questions'), true);
    show($('qa-actions'), true);
    show($('qa-pager-top'), true);
    show($('qa-pager-bottom'), true);

    renderPage();
    updateHUD();
    $('qa-sub').textContent = 'Timed - ' + ((data.items||[]).length) + ' questions';

    var limit = (data.quiz && data.quiz.time_limit_sec) || 0;
    startTimer(limit, !!isResume);

    saveDraft();
  }

  function buildPreflight(){
    var t = asciiClean((data.quiz && data.quiz.title) || 'Timed Quiz');
    var n = (data.items||[]).length || 0;
    var mins = Math.round(((data.quiz && data.quiz.time_limit_sec) || 0)/60);
    $('qa-pref-title').textContent = t;
    $('qa-pref-meta').textContent  = 'Timed | ' + n + ' questions | Time: ' + mins + ' min | ' + PAGE_SIZE + '/page';

    var d = loadDraft() || {};
    var s = loadSummary() || {};
    var canResume = !!(d && d.started && !(s && s.completed));
    show($('qa-resume'), canResume);

    // Fresh start
    $('qa-start').onclick = function(){
      clearAllStorage();
      pageIndex = 0; answers = {}; flags = {}; viewMode = 'ALL'; submitted = false;
      startUI(false);
    };

    // Resume
    $('qa-resume').onclick = function(){
      var d = loadDraft(); var s = loadSummary();
      if(d){
        started  = !!d.started;
        pageIndex= d.pageIndex||0; answers = d.answers||{}; flags = d.flags||{}; viewMode = d.viewMode||'ALL';
      }
      if(s && s.completed){
        submitted = true;
        show($('qa-pref'), false);
        show($('qa-hud'), false);
        show($('qa-questions'), false);
        show($('qa-actions'), false);
        show($('qa-pager-top'), false);
        show($('qa-pager-bottom'), false);
        buildReview();
        show($('qa-result'), true);
      }else{
        startUI(true);
      }
    };

    // Land on pre-flight; hide everything else
    show($('qa-pref'), true);
    show($('qa-hud'), false);
    show($('qa-questions'), false);
    show($('qa-actions'), false);
    show($('qa-pager-top'), false);
    show($('qa-pager-bottom'), false);
    show($('qa-result'), false);
  }

  /* ===== Boot ===== */
  async function boot(){
    try{
      msg('Loading quiz...');
      var statusBox = $('qa-status-card');
      if(statusBox){
        statusBox.style.display = 'block';
        statusBox.innerHTML =
          '<div style="padding:10px 12px;border-radius:10px;background:#eef2ff;border:1px solid #c7d2fe;font-size:13px;color:#111827;">' +
            'Loading quiz…' +
          '</div>';
      }

      var res = await fetch(WEB_APP_URL_QUIZ + '?quiz_id=' + QUIZ_ID);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      var payload = await res.json();

      if (!payload){
        msg('Quiz not available');
        if(statusBox){
          statusBox.innerHTML =
            '<div style="padding:10px 12px;border-radius:10px;background:#fee2e2;border:1px solid #ef4444;font-size:13px;color:#111827;">' +
              'Quiz not available.' +
            '</div>';
        }
        return;
      }

      var status = payload.status || 'open';

      // Non-open → show status card and stop
      if(status !== 'open'){
        showStatusCard(status, payload);
        msg('');
        return;
      }

      // Open quiz → clear status card
      if(statusBox){
        statusBox.style.display = 'none';
        statusBox.innerHTML = '';
      }

      if (!payload.questions || !payload.questions.length){
        msg('Quiz is open but no questions were found for this quiz_id.');
        if(statusBox){
          statusBox.style.display = 'block';
          statusBox.innerHTML =
            '<div style="padding:10px 12px;border-radius:10px;background:#fee2e2;border:1px solid #ef4444;font-size:13px;color:#111827;">' +
              'Quiz is open but no questions were found for this quiz_id.' +
            '</div>';
        }
        return;
      }

      const apiTitle =
        payload.title ||
        payload.quiz_title ||
        (payload.quiz && payload.quiz.title) ||
        (payload.meta && payload.meta.title) ||
        null;

      data = {
        quiz: {
          title: (apiTitle ? String(apiTitle) : QUIZ_ID.replace(/_/g, ' ')),
          time_limit_sec: Number(payload.time_limit_sec) || 1200
        },
        items: payload.questions.map((q, i) => ({
          ...q,
          number: i + 1,
          options: { A: q.option_a || '', B: q.option_b || '', C: q.option_c || '', D: q.option_d || '' },
          feedback:{ A: q.fb_a || '', B: q.fb_b || '', C: q.fb_c || '', D: q.fb_d || '' }
        }))
      };

      renderHead();
      msg('');

      setupImageOverlay();

      // Bind controls (once)
      onceClick($('qa-submit'),     function(){ submitAttempt(false); });
      onceClick($('qa-submit-btm'), function(){ submitAttempt(false); });
      onceClick($('qa-saveexit'),   function(){
        saveDraft(); alert('Saved. You can return later.');
        location.replace('/p/dashboard_23.html');
      });

      $('qa-reset').onclick = resetAttempt;

      $('qa-view-all').onclick  = function(){ viewMode='ALL'; pageIndex=0; renderPage(); saveDraft(); updateFlagNavVisibility(); };
      $('qa-view-flag').onclick = function(){ viewMode='FLAGGED'; pageIndex=0; renderPage(); saveDraft(); updateFlagNavVisibility(); };
      $('qa-next-flag').onclick = jumpToNextFlagged;
      $('qa-prev-flag').onclick = jumpToPrevFlagged;

      if(ENABLE_GRID){
        show($('qa-grid-fab'), true);
        $('qa-grid-fab').onclick = function(){
          var body = $('qa-grid-float-body'); body.innerHTML='';
          (data.items||[]).forEach(function(it){
            var b = document.createElement('button');
            b.type='button';
            b.textContent = String(it.number);
            b.style.cssText='min-width:36px;height:36px;border:1px solid #e2e8f0;border-radius:8px;background:#fff;cursor:pointer;';
            function setState(){
              var sel = answers[it.item_id];
              var f   = !!flags[it.item_id];
              b.style.background = '#fff'; b.style.borderColor = '#e2e8f0';
              if (sel){ b.style.background = '#eef2ff'; b.style.borderColor='#c7d2fe'; }
              if (f){ b.style.background = '#fff7ed'; b.style.borderColor='#fdba74'; }
            }
            b.onclick = function(){
              var absPage = Math.floor((it.number-1)/PAGE_SIZE);
              viewMode='ALL'; pageIndex=absPage; renderPage(); saveDraft(); show($('qa-grid-float'), false);
            };
            b._setState = setState; setState(); body.appendChild(b);
          });
          show($('qa-grid-float'), true);
        };
        $('qa-grid-close').onclick = function(){ show($('qa-grid-float'), false); };
      }

      window.onbeforeunload = function(){
        if(timer.running && !submitted){ return 'You have an active timed quiz.'; }
      };

      buildPreflight();

    }catch(err){
      msg('Failed to load quiz: ' + err.message);
      var statusBox = $('qa-status-card');
      if(statusBox){
        statusBox.style.display = 'block';
        statusBox.innerHTML =
          '<div style="padding:10px 12px;border-radius:10px;background:#fee2e2;border:1px solid #ef4444;font-size:13px;color:#111827;">' +
            'Failed to load quiz: '+ escAttr(err.message || String(err)) +
          '</div>';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', boot);
})();
</script>
