async function loadMembers(opts={}){
  if (!S.selectedClassId) return;
  const btn = opts && opts.btn ? opts.btn : null;
if (btn) setBtnBusy(btn, true, 'Refreshing...');

  // ✅ Clear immediately so old class members never linger
  clearMembersUI('Loading members...');

  const status = el('memStatus').value;

  try{
    const res = await apiPost({
      action: 'teacher.class.members.list',
      token: S.token,
      class_id: S.selectedClassId,
      status: status,
      limit: '500'
    });

    S.members = Array.isArray(res.items) ? res.items : [];

    // use class custom fields for columns
    const fields = Array.isArray(S.selectedFields) ? S.selectedFields : [];
    renderMembersTable(fields);

  }catch(err){
    toast('Members failed', String(err.message||err), 'bad');
    el('memHint').textContent = 'Failed to load members.';
  }
  finally{
  if (btn) setBtnBusy(btn, false);
}
}

async function removeMember(class_id, user_id){
  try{
    await apiPost({
      action: 'teacher.class.member.remove',
      token: S.token,
      class_id,
      user_id
    });

    toast('Removed', 'Member removed.', 'ok');
    await loadMembers();
    await loadClasses({preserveSelection:true});
    return true;

  }catch(err){
    toast('Remove failed', String(err.message||err), 'bad');
    return false;
  }
}

/** =============================
 * Modal (create/edit)
 * ============================= */
function openModal(mode){
  S.modalMode = mode;
  // Reset modal UX each time it opens
setModalStatus(null, null);
setBtnBusy(el('modalSave'), false);
el('modalSave').disabled = false;
  const isEdit = mode === 'edit';
  el('modalTitle').textContent = isEdit ? 'Edit Class' : 'New Class';

  el('mTitle').value = isEdit ? (S.selectedClass.title || '') : '';
  el('mStatus').value = isEdit ? (String(S.selectedClass.status||'ACTIVE').toUpperCase()) : 'ACTIVE';

  const fields = isEdit ? (Array.isArray(S.selectedFields) ? S.selectedFields : []) : [];
  S.modalFields = fields.slice(0,4);

  renderModalFields();
  setModalStatus(null, null);
setBtnBusy(el('modalSave'), false);
el('modalSave').disabled = false;
  el('modalBackdrop').style.display = 'flex';
}

function closeModal(){
  el('modalBackdrop').style.display = 'none';
  setModalStatus(null, null);
  setBtnBusy(el('modalSave'), false);
  el('modalSave').disabled = false;
}

function renderModalFields(){
  const wrap = el('mFields');
  wrap.innerHTML = '';

  if (!S.modalFields.length){
    wrap.innerHTML = '<div class="muted">No custom fields yet. You can add up to 4.</div>';
    return;
  }

  S.modalFields.forEach((f, idx)=>{
    const card = document.createElement('div');
    card.className = 'cf-card';

    const left = document.createElement('div');
    left.className = 'cf-left';

    left.innerHTML = `
      <div class="field" style="margin:0 0 8px 0">
        <div class="label">Label</div>
        <input class="input" data-idx="${idx}" data-k="label" value="${escapeAttr(f.label||'')}" placeholder="e.g. Index Number" />
      </div>
      <div class="row wrap" style="gap:10px">
        <div class="toggle">
          <input type="checkbox" data-idx="${idx}" data-k="required" ${f.required ? 'checked' : ''} />
          <span>Required</span>
        </div>
        <span class="chip mini" title="Stored key"><span class="mono">${escapeHtml(f.key||'')}</span></span>
      </div>
    `;

    const actions = document.createElement('div');
    actions.className = 'cf-actions';

    const up = document.createElement('button');
    up.className = 'btn';
   up.innerHTML = '&uarr;';
    up.disabled = (idx === 0);
    up.onclick = ()=>{
      const tmp = S.modalFields[idx-1];
      S.modalFields[idx-1] = S.modalFields[idx];
      S.modalFields[idx] = tmp;
      renderModalFields();
    };

    const down = document.createElement('button');
    down.className = 'btn';
down.innerHTML = '&darr;';
    down.disabled = (idx === S.modalFields.length-1);
    down.onclick = ()=>{
      const tmp = S.modalFields[idx+1];
      S.modalFields[idx+1] = S.modalFields[idx];
      S.modalFields[idx] = tmp;
      renderModalFields();
    };

    const del = document.createElement('button');
    del.className = 'btn danger';
    del.textContent = 'Delete';
    del.onclick = ()=>{
      S.modalFields.splice(idx,1);
      renderModalFields();
    };

    actions.appendChild(up);
    actions.appendChild(down);
    actions.appendChild(del);

    card.appendChild(left);
    card.appendChild(actions);
    wrap.appendChild(card);
  });

  // bind changes
  wrap.querySelectorAll('input[data-idx]').forEach(inp=>{
    inp.addEventListener('input', ()=>{
      const i = parseInt(inp.getAttribute('data-idx'),10);
      const k = inp.getAttribute('data-k');
      if (isNaN(i) || !S.modalFields[i]) return;

      if (k === 'label'){
        S.modalFields[i].label = inp.value;
      }
    });
  });
  wrap.querySelectorAll('input[type="checkbox"][data-idx]').forEach(chk=>{
    chk.addEventListener('change', ()=>{
      const i = parseInt(chk.getAttribute('data-idx'),10);
      if (isNaN(i) || !S.modalFields[i]) return;
      S.modalFields[i].required = chk.checked;
    });
  });
}

function addModalField(){
  if (S.modalFields.length >= 4){
    toast('Limit reached', 'Max 4 custom fields.', 'bad');
    return;
  }
  const used = {};
  S.modalFields.forEach(f=>{ used[String(f.key||'').trim()] = true; });

  const key = 'f' + (S.modalFields.length + 1);
  const k2 = used[key] ? ('f' + (Math.floor(Math.random()*9000)+1000)) : key;

  S.modalFields.push({ label:'', key:k2, required:false });
  renderModalFields();
}

/** =============================
 * Invite message
 * ============================= */
function openInvite(){
  if (!S.selectedClass) return;

  const code = String(S.selectedClass.join_code||'').trim();
  const title = String(S.selectedClass.title||'').trim();
  const fields = Array.isArray(S.selectedFields) ? S.selectedFields : [];

  const lines = [];
  lines.push(`Hello! You've been invited to join: ${title}`);
  lines.push(`Class join code: ${code}`);
  lines.push('');
  lines.push('How to join:');
  lines.push('1) Log into QAcademy');
  lines.push('2) Open "My Classes" and choose "Join Class"');
  lines.push(`3) Enter this code: ${code}`);
  if (fields.length){
    lines.push('');
    lines.push('When joining, you will be asked for:');
    fields.forEach(f=>{
      lines.push(`- ${f.label}${f.required ? ' (required)' : ''}`);
    });
  }
  lines.push('');
  lines.push('If you have any issue, message your teacher.');

  el('inviteText').value = lines.join('\n');
  el('inviteBackdrop').style.display = 'flex';
}

function closeInvite(){
  el('inviteBackdrop').style.display = 'none';
}

async function copyText(text){
  const t = String(text||'');
  try{
    await navigator.clipboard.writeText(t);
    return true;
  }catch(_){
    // fallback
    const ta = document.createElement('textarea');
    ta.value = t;
    ta.style.position='fixed';
    ta.style.left='-9999px';
    document.body.appendChild(ta);
    ta.select();
    try{
      document.execCommand('copy');
      document.body.removeChild(ta);
      return true;
    }catch(err){
      document.body.removeChild(ta);
      return false;
    }
  }
}

/** =============================
 * Utilities
 * ============================= */
function escapeHtml(s){
  return String(s||'')
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}
function escapeAttr(s){ return escapeHtml(s).replace(/"/g,'&quot;'); }

