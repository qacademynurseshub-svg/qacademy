<script>
/** =============================
 * CONFIG
 * ============================= */
const API_URL = 'https://script.google.com/macros/s/AKfycbz54M_jWoRq4cOC2gUQeRhd55AeEJ5vnELJ0gkBSodO58fr7WGa9jwk6JNwPptf8p8X/exec'; // <-- set this
const LOGIN_URL = '/p/login_23.html';
const DASHBOARD_URL = '/p/teacher-dashboard.html';

/** =============================
 * State
 * ============================= */
const S = {
  token: '',
  teacher: null,
  classes: [],
  selectedClassId: '',
  selectedClass: null,
  selectedFields: [],
  members: [],
  modalMode: 'create', // create | edit
  modalClassId: '',
  modalFields: [],     // [{label,key,required}]
};

const el = (id) => document.getElementById(id);
function busyShow(title, sub){
  document.body.classList.add('qa-busy');
  el('qaBusy').style.display = 'flex';
  el('busyTitle').textContent = title || 'Working...';
  el('busySub').textContent = sub || 'Please wait.';
  el('qaBusy').setAttribute('aria-busy','true');
}
function busyUpdate(title, sub){
  if (el('qaBusy').style.display !== 'flex') busyShow(title, sub);
  else {
    el('busyTitle').textContent = title || el('busyTitle').textContent || 'Working...';
    el('busySub').textContent = sub || el('busySub').textContent || 'Please wait.';
  }
}
function busyHide(){
  el('qaBusy').style.display = 'none';
  document.body.classList.remove('qa-busy');
  el('qaBusy').setAttribute('aria-busy','false');
}

function setBtnBusy(btn, busy, label){
  if (!btn) return;
  if (!btn.dataset.label) btn.dataset.label = btn.textContent.trim();
  if (busy){
    btn.disabled = true;
    btn.innerHTML = `<span class="spinner sm" aria-hidden="true"></span><span>${escapeHtml(label || 'Working...')}</span>`;
  } else {
    btn.disabled = false;
    btn.textContent = btn.dataset.label;
  }
}
function setBtnDone(btn, label){
  if (!btn) return;
  if (!btn.dataset.label) btn.dataset.label = btn.textContent.trim();
  btn.disabled = true;
  btn.textContent = label || 'Done ✓';
}

function setModalStatus(type, msg){
  const box = el('modalStatus');
  if (!box) return;
  if (!msg){
    box.style.display = 'none';
    box.className = 'modal-status';
    box.textContent = '';
    return;
  }
  box.className = 'modal-status ' + (type || 'info');
  box.textContent = msg;
  box.style.display = '';
}
  
function toast(title, msg, type){
  const wrap = el('toasts');
  const t = document.createElement('div');
  t.className = 'toast' + (type === 'ok' ? ' ok' : type === 'bad' ? ' bad' : '');
  t.innerHTML = '<p class="t1"></p><p class="t2"></p>';
  t.querySelector('.t1').textContent = title || 'Info';
  t.querySelector('.t2').textContent = msg || '';
  wrap.appendChild(t);
  setTimeout(()=>{ t.style.opacity = '0'; t.style.transform='translateY(6px)'; }, 3200);
  setTimeout(()=>{ try{wrap.removeChild(t);}catch(_){ } }, 3800);
}

function qsParam(name){
  const u = new URL(location.href);
  return (u.searchParams.get(name) || '').trim();
}

function getToken(){
  // token priority: url ?token=, then localStorage
  const tUrl = qsParam('token');
  if (tUrl) return tUrl;
  try{
    return (localStorage.getItem('qa_token') || '').trim();
  }catch(_){ return ''; }
}

function setToken(t){
  S.token = String(t||'').trim();
  try{
    if (S.token) localStorage.setItem('qa_token', S.token);
    else localStorage.removeItem('qa_token');
  }catch(_){}
}

function fmtIso(iso){
  const s = String(iso||'').trim();
  if (!s) return '—';
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleString(undefined, {year:'numeric',month:'short',day:'2-digit',hour:'2-digit',minute:'2-digit'});
}

/** =============================
 * Gate overlay helpers
 * ============================= */
function currentRelativeUrl(){
  try{
    return (location.pathname || "/") + (location.search || "") + (location.hash || "");
  }catch(_){
    return "/";
  }
}

function buildLoginUrl(){
  const rt = encodeURIComponent(currentRelativeUrl());
  const sep = (String(LOGIN_URL || "").includes("?")) ? "&" : "?";
  return String(LOGIN_URL || "/p/login_23.html") + sep + "return_to=" + rt;
}

function stripTokenFromUrl(){
  try{
    const u = new URL(location.href);
    if (!u.searchParams.has("token")) return;

    u.searchParams.delete("token");

    const qs = u.searchParams.toString();
    const next = u.pathname + (qs ? ("?" + qs) : "") + (u.hash || "");
    history.replaceState({}, "", next);
  }catch(_){}
}

function gotoLogin(){
  location.href = buildLoginUrl();
}

function showGate({ title, msg, details, canRetry }){
   busyHide(); // ✅ ensure busy overlay is never left on behind gate
  el('gateTitle').textContent = title || 'Sign in required';
  el('gateMsg').textContent = msg || 'Please sign in to continue.';
  el('gateRetry').style.display = canRetry ? '' : 'none';

  const wrap = el('gateDetailsWrap');
  const pre = el('gateDetails');

  if (details){
    pre.textContent = String(details);
    wrap.style.display = '';
  } else {
    pre.textContent = '';
    wrap.style.display = 'none';
  }

  el('qaGate').style.display = 'flex';
}

function hideGate(){
  el('qaGate').style.display = 'none';
}

function safePayloadSnippet(payload){
  try{
    if (!payload) return '';
    return JSON.stringify(payload, null, 2);
  }catch(_){ return ''; }
}

function explainVerifyError(err){
  const msg = String((err && err.message) || err || '').toLowerCase();
  const p = err && err.payload ? err.payload : null;
  const pErr = String((p && (p.error || p.detail || p.reason)) || '').toLowerCase();

  // Common fetch/network issue
  if (msg.includes('failed to fetch') || msg.includes('network') || msg.includes('cors')){
    return 'Network error — please check your connection and try again.';
  }

  // Auth/session-ish errors
  if (pErr.includes('auth') || msg.includes('auth') || pErr.includes('token') || msg.includes('token')){
    return 'Your session looks expired or invalid. Please sign in again.';
  }
  if (pErr.includes('access') || msg.includes('access') || pErr.includes('forbidden') || msg.includes('forbidden')){
    return 'Access denied. Your teacher account may be pending approval or inactive.';
  }

  return 'Could not verify access. Please try again or return to login.';
}

/** =============================
 * API (form-urlencoded to avoid CORS preflight)
 * ============================= */
async function apiPost(params){
  if (!API_URL || API_URL.indexOf('REPLACE_WITH') !== -1) {
    throw new Error('API_URL_not_configured');
  }

  const p = new URLSearchParams();
  Object.keys(params || {}).forEach(k=>{
    const v = params[k];
    if (v === undefined || v === null) return;
    if (typeof v === 'object') p.append(k, JSON.stringify(v));
    else p.append(k, String(v));
  });

  const res = await fetch(API_URL, {
    method: 'POST',
    body: p,
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
      'Accept': 'application/json'
    },
    credentials: 'omit'
  });

  const text = await res.text();
  let obj = null;
  try { obj = JSON.parse(text); } catch(_) { obj = null; }

  if (!obj || obj.ok !== true) {
    const xStatus = res.headers.get('X-Status-Code');
    const status = xStatus ? parseInt(xStatus,10) : res.status;
    const err = (obj && (obj.error || obj.detail || obj.reason)) || ('http_' + status);
    const e = new Error(err);
    e.status = status;
    e.payload = obj;
    throw e;
  }
  return obj;
}

/** =============================
 * Auth / bootstrap
 * ============================= */
async function verifyTeacher(){
  const sub = el('subline');
  sub.textContent = 'Verifying access...';

  const t = getToken();
  if (!t) {
    busyHide(); // ✅ stop blur if we’re showing the gate
    sub.textContent = 'Sign in required.';
    toast('Sign in required', 'No active session found. Please sign in again.', 'bad');

    showGate({
      title: 'Sign in required',
      msg: 'Your session has ended. Please sign in again to continue.',
      details: 'token_missing',
      canRetry: false
    });

    return false;
  }
  setToken(t);
  stripTokenFromUrl();


  try{
    const v = await apiPost({ action:'teacher.verify', token:S.token });
    S.teacher = v.teacher || null;

    el('chipUser').style.display = '';
    el('userName').textContent = (v.user && v.user.name) ? v.user.name : 'Teacher';
    el('userEmail').textContent = (v.user && v.user.email) ? (' | ' + v.user.email) : '';

    el('chipPlan').style.display = '';
    el('planText').textContent = (v.teacher && v.teacher.plan_type) ? v.teacher.plan_type : 'FREE';

    sub.textContent = 'Ready';
    hideGate();
    return true;
  }catch(err){
    busyHide(); // ✅ stop blur if access denied gate will display
    sub.textContent = 'Access denied.';
    toast('Access denied', explainVerifyError(err), 'bad');

    const details =
      'message: ' + String((err && err.message) || err) +
      '\nstatus: ' + String(err && err.status ? err.status : '') +
      (err && err.payload ? '\n\npayload:\n' + safePayloadSnippet(err.payload) : '');

    showGate({
      title: 'Access denied',
      msg: explainVerifyError(err),
      details,
      canRetry: true
    });

    return false;
  }
}

/** =============================
 * Custom fields JSON helpers
 * ============================= */
function safeJsonParse(s, fallback){
  try{
    if (typeof s === 'object') return s;
    const t = String(s||'').trim();
    if (!t) return fallback;
    return JSON.parse(t);
  }catch(_){ return fallback; }
}

function normalizeFieldKey(label, used){
  const base = String(label||'').trim().toLowerCase()
    .replace(/[^a-z0-9]+/g,'_')
    .replace(/^_+|_+$/g,'')
    .slice(0,20);

  let key = base || '';
  if (!key) key = 'f' + (Object.keys(used).length + 1);

  if (used[key]) {
    let n = 2;
    while (used[key + '_' + n]) n++;
    key = key + '_' + n;
  }
  return key;
}

function buildCustomFieldsJson(fields){
  const cleaned = [];
  const used = {};
  (fields || []).forEach((f)=>{
    const label = String((f && f.label) || '').trim();
    if (!label) return;
    const required = !!f.required;

    let key = String((f && f.key) || '').trim();
    if (!key || used[key]) {
      key = normalizeFieldKey(label, used);
    }
    used[key] = true;

    cleaned.push({ key, label, required });
  });

  // cap to 4
  const cap = cleaned.slice(0,4);
  return JSON.stringify({ fields: cap });
}

function readFieldsFromCustomFieldsJson(custom_fields_json){
  const obj = safeJsonParse(custom_fields_json, {fields:[]});
  const arr = Array.isArray(obj.fields) ? obj.fields : [];
  const out = [];
  for (let i=0;i<arr.length && out.length<4;i++){
    const f = arr[i] || {};
    const label = String(f.label||'').trim();
    if (!label) continue;
    out.push({
      key: String(f.key||'').trim() || ('f' + (out.length+1)),
      label,
      required: (String(f.required||'').trim().toLowerCase() === 'true') || (f.required === true)
    });
  }
  return out;
}

function renderCustomFieldsPreview(container, fields){
  container.innerHTML = '';
  if (!fields || !fields.length) {
    container.innerHTML = '<div class="muted">No custom fields (students join with basic profile only).</div>';
    return;
  }
  fields.forEach(f=>{
    const div = document.createElement('div');
    div.className = 'badge';
    div.title = 'key: ' + f.key;
    div.innerHTML = '<span style="font-weight:850">'+escapeHtml(f.label)+'</span>' +
      (f.required ? ' <span class="chip mini ok">Required</span>' : ' <span class="chip mini">Optional</span>');
    container.appendChild(div);
  });
}

/** =============================
 * Classes
 * ============================= */
async function fetchClassGet(class_id){
  const res = await apiPost({
    action: 'teacher.class.get',
    token: S.token,
    class_id
  });

  // be tolerant to backend shape
  const cls = res.class || res.item || res.data || res || null;
  const fields = Array.isArray(res.fields)
    ? res.fields
    : readFieldsFromCustomFieldsJson((cls && cls.custom_fields_json) || '');

  return { cls, fields };
}

async function hydrateSelectedClass(class_id){
  const id = String(class_id || '').trim();
  if (!id) return false;

  const { cls, fields } = await fetchClassGet(id);
  if (!cls) throw new Error('class_get_failed');

  // update selected
  S.selectedClass = cls;
  S.selectedFields = Array.isArray(fields) ? fields : [];

  // also merge into list cache so renderClassesList() stays consistent
  const idx = S.classes.findIndex(x => x.class_id === id);
  if (idx >= 0){
    S.classes[idx] = Object.assign({}, S.classes[idx], cls);
  }

  return true;
}

function renderSelectedClassDetails(){
  if (!S.selectedClass){
    el('noSelection').style.display = '';
    el('details').style.display = 'none';
    el('btnEdit').disabled = true;
    el('btnInvite').disabled = true;
    return;
  }

  el('noSelection').style.display = 'none';
  el('details').style.display = '';

  el('dTitle').textContent = S.selectedClass.title || 'Untitled';
  el('dClassId').textContent = S.selectedClass.class_id || '';
  el('dUpdated').textContent = fmtIso(S.selectedClass.updated_at);
  el('dJoinCode').textContent = S.selectedClass.join_code || '';

  const st = String(S.selectedClass.status||'').toUpperCase() || 'ACTIVE';
  const chip = el('dStatusChip');
  chip.textContent = st;
  chip.className = 'chip mini ' + (st==='ACTIVE' ? 'ok' : st==='ARCHIVED' ? 'bad' : '');

  el('dMembers').textContent = String(S.selectedClass.member_count ?? '—');
  el('dQuizzes').textContent = String(S.selectedClass.quiz_count ?? '—');

  // custom fields preview (use authoritative)
  renderCustomFieldsPreview(el('dCustomFields'), S.selectedFields || []);
}

async function loadClasses({preserveSelection=true}={}){
  el('clsLoading').style.display = '';
  el('clsEmpty').style.display = 'none';
  el('clsList').innerHTML = '';

  const q = el('clsSearch').value.trim();
  const status = el('clsStatus').value;

  try{
    const res = await apiPost({
      action: 'teacher.classes.list',
      token: S.token,
      status: status,
      q: q,
      include_counts: 'true'
    });

    S.classes = Array.isArray(res.items) ? res.items : [];
    el('clsCount').textContent = String(S.classes.length);

    renderClassesList();

    el('clsLoading').style.display = 'none';
    if (!S.classes.length) el('clsEmpty').style.display = '';

    // restore selection
    if (preserveSelection){
      const saved = S.selectedClassId || (localStorage.getItem('qa_teacher_class_id')||'');
      if (saved) {
        const hit = S.classes.find(c => c.class_id === saved);
      if (hit) selectClass(saved, {shouldLoadMembers:true});
      }
    }
  }catch(err){
    el('clsLoading').style.display = 'none';
    el('clsEmpty').style.display = '';
    toast('Load failed', String(err.message||err), 'bad');
  }
}

function renderClassesList(){
  const list = el('clsList');
  list.innerHTML = '';

  S.classes.forEach(c=>{
    const card = document.createElement('div');
    card.className = 'class-card' + (c.class_id === S.selectedClassId ? ' active' : '');
    card.onclick = ()=>selectClass(c.class_id, {shouldLoadMembers:true});
    
    const st = String(c.status||'').toUpperCase() || 'ACTIVE';
    const stChip = (st === 'ACTIVE') ? 'ok' : (st === 'ARCHIVED') ? 'bad' : '';

    card.innerHTML = `
      <div class="row between">
        <p class="class-title">${escapeHtml(c.title||'Untitled')}</p>
        <span class="chip mini ${stChip}">${escapeHtml(st)}</span>
      </div>
      <div class="class-meta">
        <span class="kpi" title="Join code">🔑 <span class="mono">${escapeHtml(c.join_code||'')}</span></span>
        <span class="kpi" title="Members">👥 ${escapeHtml(String(c.member_count ?? '—'))}</span>
        <span class="kpi" title="Quizzes linked">🧩 ${escapeHtml(String(c.quiz_count ?? '—'))}</span>
      </div>
      <div class="muted" style="margin-top:8px">Updated: ${escapeHtml(fmtIso(c.updated_at))}</div>
    `;
    list.appendChild(card);
  });
}

/** ✅ Clear members table immediately to prevent “stale members” confusion */
function clearMembersUI(loadingText){
  S.members = [];
  const fields = Array.isArray(S.selectedFields) ? S.selectedFields : [];

  if (loadingText){
    setMembersLoading(fields, loadingText);
    return;
  }

  try{ el('memBody').innerHTML = ''; }catch(_){}
  try{ el('memHeadRow').innerHTML = ''; }catch(_){}
  el('memHint').textContent = '';
}

async function selectClass(classId, { shouldLoadMembers=false } = {}) {
  S.selectedClassId = String(classId||'').trim();
  try{ localStorage.setItem('qa_teacher_class_id', S.selectedClassId); }catch(_){}

  // highlight list immediately
  renderClassesList();

  // disable actions until hydration finishes (prevents “edit too fast” bug)
  el('btnEdit').disabled = true;
  el('btnInvite').disabled = true;

  // ✅ clear old members immediately when switching classes
  clearMembersUI(shouldLoadMembers ? 'Loading members...' : '');

  // show skeleton selection using summary row (optional)
  const summary = S.classes.find(x => x.class_id === S.selectedClassId) || null;
  S.selectedClass = summary;
  S.selectedFields = readFieldsFromCustomFieldsJson((summary && summary.custom_fields_json) || '');
  renderSelectedClassDetails();

  if (!S.selectedClassId){
    S.selectedClass = null;
    S.selectedFields = [];
    renderSelectedClassDetails();
    return;
  }

  // hydrate from backend (authoritative class + fields)
  try{
    await hydrateSelectedClass(S.selectedClassId);
    renderSelectedClassDetails();
  }catch(err){
    // keep summary if hydrate fails, but warn
    toast('Class load warning', 'Could not load full class details. Editing fields may be limited.', 'bad');
  }

  // enable actions after hydrate attempt
  el('btnEdit').disabled = !S.selectedClass;
  el('btnInvite').disabled = !S.selectedClass;

  // members (only after hydration attempt, so columns are correct)
  if (shouldLoadMembers) await loadMembers();
}

async function createClass({title, status, custom_fields_json}){
  const res = await apiPost({
    action: 'teacher.class.create',
    token: S.token,
    title,
    status,
    custom_fields_json
  });
  toast('Created', 'Class created successfully.', 'ok');
  await loadClasses({preserveSelection:false});
  if (res.class_id){
await selectClass(res.class_id, {shouldLoadMembers:true});
  }
}

async function updateClass({class_id, title, status, custom_fields_json}){
  await apiPost({
    action: 'teacher.class.update',
    token: S.token,
    class_id,
    title,
    status,
    custom_fields_json
  });

  toast('Saved', 'Class updated.', 'ok');

  // reload list without auto-reselect to avoid summary-only selection glitches
  await loadClasses({preserveSelection:false});

  // reselect (this will hydrate and refresh details)
await selectClass(class_id, {shouldLoadMembers:false});
}

async function regenerateJoinCode(class_id){
  const res = await apiPost({
    action: 'teacher.class.join_code.regenerate',
    token: S.token,
    class_id
  });
  toast('Updated', 'New join code generated.', 'ok');

  // update locally
  const idx = S.classes.findIndex(x=>x.class_id===class_id);
  if (idx>=0){
    S.classes[idx].join_code = res.join_code || S.classes[idx].join_code;
    S.classes[idx].updated_at = new Date().toISOString();
  }
  if (S.selectedClass && S.selectedClass.class_id === class_id){
    S.selectedClass.join_code = res.join_code || S.selectedClass.join_code;
    el('dJoinCode').textContent = S.selectedClass.join_code || '';
  }
  renderClassesList();
}

/** =============================
 * Members
 * ============================= */
function memberFieldValue(member, key){
  const k = String(key||'').trim();
  if (!k) return '';

  // Fast path: backend already provides parsed map
  if (member && member.member_fields && typeof member.member_fields === 'object') {
    const v = member.member_fields[k];
    return (v == null) ? '' : String(v).trim();
  }

  // Fallback: parse JSON and accept either {"fields":{...}} or flat {...}
  const obj = safeJsonParse(member && member.member_fields_json, null);
  if (!obj || typeof obj !== 'object') return '';

  if (obj.fields && typeof obj.fields === 'object') {
    const v2 = obj.fields[k];
    return (v2 == null) ? '' : String(v2).trim();
  }

  const v3 = obj[k];
  return (v3 == null) ? '' : String(v3).trim();
}

function buildMembersHead(fields){
  const tr = el('memHeadRow');
  tr.innerHTML = '';

  const cols = [
    {k:'display_name', label:'Name'},
    {k:'email', label:'Email'},
    {k:'user_id', label:'User ID'}
  ];

  // custom fields columns
  (fields || []).forEach(f=>{
    cols.push({k:'cf_' + f.key, label:f.label, cfKey:f.key});
  });

  cols.push({k:'status', label:'Status'});
  cols.push({k:'joined_at', label:'Joined'});
  cols.push({k:'actions', label:''});

  cols.forEach(c=>{
    const th = document.createElement('th');
    th.textContent = c.label;
    tr.appendChild(th);
  });

  return cols;
}

function setMembersLoading(fields, msg){
  const cols = buildMembersHead(fields || []);
  const body = el('memBody');
  body.innerHTML = '';

  const tr = document.createElement('tr');
  const td = document.createElement('td');
  td.colSpan = cols.length;

  td.innerHTML = `
    <div class="row" style="gap:10px; padding:6px 0">
      <span class="spinner" aria-hidden="true"></span>
      <span>${escapeHtml(msg || 'Loading...')}</span>
    </div>
  `;
  tr.appendChild(td);
  body.appendChild(tr);

  el('memHint').textContent = msg || 'Loading...';
}  
  
