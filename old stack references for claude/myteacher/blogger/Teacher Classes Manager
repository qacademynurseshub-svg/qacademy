el('modalSave').onclick = async ()=>{
  const title = el('mTitle').value.trim();
  const status = el('mStatus').value;

  if (!title){
    toast('Missing title', 'Please enter a class title.', 'bad');
    setModalStatus('bad', 'Please enter a class title.');
    return;
  }

  // normalize keys after label edits
  const used = {};
  const finalFields = [];
  (S.modalFields||[]).forEach((f)=>{
    const label = String((f&&f.label)||'').trim();
    if (!label) return;
    const required = !!f.required;

    let key = String((f&&f.key)||'').trim();
    if (!key || used[key]){
      key = normalizeFieldKey(label, used);
    }
    used[key] = true;
    finalFields.push({ key, label, required });
  });

  const custom_fields_json = buildCustomFieldsJson(finalFields);

  const btnSave   = el('modalSave');
  const btnCloseX = el('modalClose');
  const btnCancel = el('modalCancel');
  const btnAdd    = el('btnAddField');

  // lock modal controls during save
  setModalStatus('info', 'Saving...');
  setBtnBusy(btnSave, true, 'Saving...');
  btnCloseX.disabled = true;
  btnCancel.disabled = true;
  if (btnAdd) btnAdd.disabled = true;

  try{
    if (S.modalMode === 'create'){
      // Create mode: prevent double-create by leaving Save disabled after success
      await createClass({ title, status, custom_fields_json });

      setModalStatus('ok', 'Class created. You can close this window.');
      btnSave.innerHTML = 'Created ✓';
      btnSave.disabled = true;

    } else {
      // Edit mode: show “Saved ✓” briefly, then allow further edits/saves
      await updateClass({ class_id: S.selectedClassId, title, status, custom_fields_json });

      setModalStatus('ok', 'Saved. You can close this window, or keep editing and save again.');
      btnSave.innerHTML = 'Saved ✓';
      btnSave.disabled = true;

      setTimeout(()=>{
        // restore Save button for further edits
        try{
          setBtnBusy(btnSave, false);
          btnSave.disabled = false;
        }catch(_){}
      }, 900);
    }

  }catch(err){
    const msg = 'Save failed: ' + String(err.message || err);
    toast('Save failed', String(err.message||err), 'bad');
    setModalStatus('bad', msg);

    // restore Save button
    setBtnBusy(btnSave, false);
    btnSave.disabled = false;

  }finally{
    // unlock modal controls
    btnCloseX.disabled = false;
    btnCancel.disabled = false;
    if (btnAdd) btnAdd.disabled = false;
  }
};

  el('btnCopyCode').onclick = async ()=>{
