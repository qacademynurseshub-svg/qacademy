    toast('Signed out', 'Redirecting to login...', 'ok');
    setTimeout(()=>gotoLogin(), 250);
  };
}

function debounce(fn, ms){
  let t = null;
  return function(){
    clearTimeout(t);
    const args = arguments;
    t = setTimeout(()=>fn.apply(null, args), ms);
  }
}

