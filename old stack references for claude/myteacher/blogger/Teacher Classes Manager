<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Teacher Classes</title>

<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#1f2a28;
    --bg:#f6f8f7;
    --card:#ffffff;
    --line:rgba(0,0,0,.08);
    --soft:rgba(0,0,0,.04);
    --danger:#b42318;
    --ok:#027a48;

    --radius:16px;
    --shadow:0 10px 30px rgba(0,0,0,.08);
  }

  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  }

  /* Try to visually override Blogger container */
  .qa-app{
    min-height:100vh;
    width:100vw;
    position:relative;
    left:50%;
    right:50%;
    margin-left:-50vw;
    margin-right:-50vw;
  }

  .topbar{
    position:sticky;
    top:0;
    z-index:30;
    background:rgba(246,248,247,.92);
    backdrop-filter:saturate(1.2) blur(10px);
    border-bottom:1px solid var(--line);
  }

  .topbar-inner{
    max-width:1200px;
    margin:0 auto;
    padding:14px 14px;
    display:flex;
    gap:12px;
    align-items:center;
    justify-content:space-between;
  }

  .brand{
    display:flex; align-items:center; gap:10px;
    min-width:240px;
  }
  .logo{
    width:38px; height:38px; border-radius:12px;
    background:linear-gradient(135deg, rgba(11,122,117,.18), rgba(133,153,152,.10));
    border:1px solid rgba(11,122,117,.25);
    display:grid; place-items:center;
    box-shadow:0 10px 20px rgba(11,122,117,.10);
    color:var(--brand);
    font-weight:800;
  }
  .brand h1{font-size:16px; margin:0; line-height:1.1}
  .brand .sub{font-size:12px; color:rgba(31,42,40,.7)}

  .actions{
    display:flex; gap:10px; align-items:center; flex-wrap:wrap;
  }
  
.btn.icon{
  width:40px;
  padding:10px 0;
  justify-content:center;
  font-weight:900;
  line-height:1;
}
  .btn{
    border:1px solid var(--line);
    background:var(--card);
    color:var(--ink);
    padding:10px 12px;
    border-radius:12px;
    cursor:pointer;
    font-weight:650;
    font-size:13px;
    display:inline-flex;
    gap:8px;
    align-items:center;
  }
  .btn:hover{background:rgba(255,255,255,.92)}
  .btn.primary{
    background:var(--brand);
    border-color:rgba(11,122,117,.35);
    color:#fff;
  }
  .btn.primary:hover{filter:brightness(.98)}
  .btn.danger{
    border-color:rgba(180,35,24,.25);
    color:var(--danger);
    background:rgba(180,35,24,.04);
  }
  .btn.danger:hover{background:rgba(180,35,24,.06)}
  .btn.ghost{
    background:transparent;
    border-color:transparent;
  }
  .btn.ghost:hover{background:rgba(0,0,0,.04); border-color:var(--line)}
  .btn[disabled]{opacity:.55; cursor:not-allowed}

  .chip{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid var(--line);
    background:var(--card);
    font-size:12px;
    color:rgba(31,42,40,.75);
    white-space:nowrap;
  }
  .chip strong{color:var(--ink)}
  .chip.ok{border-color:rgba(2,122,72,.22); background:rgba(2,122,72,.06); color:rgba(2,122,72,.95)}
  .chip.warn{border-color:rgba(245,158,11,.25); background:rgba(245,158,11,.07); color:rgba(146,64,14,.95)}
  .chip.bad{border-color:rgba(180,35,24,.25); background:rgba(180,35,24,.06); color:rgba(180,35,24,.95)}
  .chip.mini{padding:4px 8px; font-size:11px}

  .container{
    max-width:1200px;
    margin:0 auto;
    padding:14px;
  }

  .grid{
    display:grid;
    grid-template-columns: 380px 1fr;
    gap:14px;
    align-items:start;
  }

  .panel{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    overflow:hidden;
  }

  .panel-header{
    padding:12px 12px;
    border-bottom:1px solid var(--line);
    display:flex;
    gap:10px;
    align-items:center;
    justify-content:space-between;
    background:linear-gradient(180deg, rgba(11,122,117,.05), rgba(255,255,255,0));
  }

  .panel-header h2{
    margin:0;
    font-size:14px;
  }

  .panel-body{padding:12px}

  .row{display:flex; gap:10px; align-items:center}
  .row.wrap{flex-wrap:wrap}
  .row.between{justify-content:space-between}
  .muted{color:rgba(31,42,40,.68); font-size:12px}

  .field{
    display:flex;
    flex-direction:column;
    gap:6px;
    margin-bottom:10px;
  }
  .label{font-size:12px; color:rgba(31,42,40,.78); font-weight:650}
  .input, .select, .textarea{
    width:100%;
    padding:10px 10px;
    border:1px solid var(--line);
    border-radius:12px;
    outline:none;
    background:#fff;
    color:var(--ink);
    font-size:13px;
  }
  .textarea{min-height:90px; resize:vertical}
  .input:focus, .select:focus, .textarea:focus{
    border-color:rgba(11,122,117,.35);
    box-shadow:0 0 0 3px rgba(11,122,117,.10);
  }

  .hr{height:1px; background:var(--line); margin:12px 0}

  .list{
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .class-card{
    border:1px solid var(--line);
    border-radius:14px;
    padding:10px;
    background:rgba(0,0,0,.01);
    cursor:pointer;
  }
  .class-card:hover{background:rgba(0,0,0,.02)}
  .class-card.active{
    border-color:rgba(11,122,117,.35);
    box-shadow:0 0 0 3px rgba(11,122,117,.10);
    background:rgba(11,122,117,.04);
  }
  .class-title{
    font-weight:800;
    margin:0;
    font-size:13px;
  }
  .class-meta{
    margin-top:6px;
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    align-items:center;
  }
  .kpi{
    display:inline-flex;
    gap:6px;
    align-items:center;
    padding:6px 9px;
    border-radius:999px;
    border:1px solid var(--line);
    background:#fff;
    font-size:12px;
    color:rgba(31,42,40,.75);
  }

  .codebox{
    display:flex;
    gap:10px;
    align-items:center;
    padding:10px;
    border:1px solid var(--line);
    border-radius:14px;
    background:rgba(0,0,0,.015);
  }
  .code{
    font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;
    font-size:16px;
    letter-spacing:1.5px;
    font-weight:900;
    color:var(--ink);
  }

  .table-wrap{
    border:1px solid var(--line);
    border-radius:14px;
    overflow:auto;
    background:#fff;
  }
  table{
    width:100%;
    border-collapse:separate;
    border-spacing:0;
    min-width:760px;
  }
  th, td{
    padding:10px 10px;
    border-bottom:1px solid var(--line);
    vertical-align:top;
    font-size:13px;
  }
  th{
    position:sticky;
    top:0;
    background:#fff;
    z-index:1;
    text-align:left;
    font-size:12px;
    color:rgba(31,42,40,.72);
    font-weight:800;
  }
  tr:hover td{background:rgba(0,0,0,.01)}
  td .small{font-size:12px; color:rgba(31,42,40,.72)}

  .badge{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:5px 9px;
    border-radius:999px;
    border:1px solid var(--line);
    background:#fff;
    font-size:12px;
    white-space:nowrap;
  }

  .toast-wrap{
    position:fixed;
    right:14px;
    bottom:14px;
    z-index:99;
    display:flex;
    flex-direction:column;
    gap:10px;
    pointer-events:none;
  }
  .toast{
    pointer-events:auto;
    background:var(--card);
    border:1px solid var(--line);
    border-radius:14px;
    box-shadow:var(--shadow);
    padding:10px 12px;
    min-width:260px;
  }
  .toast .t1{font-weight:900; font-size:13px; margin:0 0 3px 0}
  .toast .t2{font-size:12px; color:rgba(31,42,40,.72); margin:0}
  .toast.ok{border-color:rgba(2,122,72,.25); background:rgba(2,122,72,.04)}
  .toast.bad{border-color:rgba(180,35,24,.25); background:rgba(180,35,24,.04)}

  /* Modal */
  .modal-backdrop{
    position:fixed; inset:0;
    background:rgba(0,0,0,.35);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:120;
    padding:14px;
  }
  .modal{
    width:min(760px, 100%);
    background:var(--card);
    border-radius:18px;
    border:1px solid var(--line);
    box-shadow:var(--shadow);
    overflow:hidden;
  }
  .modal-head{
    padding:12px 12px;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    background:linear-gradient(180deg, rgba(11,122,117,.06), rgba(255,255,255,0));
  }
  .modal-head h3{margin:0; font-size:14px}
  .modal-body{padding:12px}
  .modal-foot{
    padding:12px;
    border-top:1px solid var(--line);
    display:flex;
    gap:10px;
    justify-content:flex-end;
    flex-wrap:wrap;
  }

  .field-grid{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:10px;
  }

  .cf-card{
    border:1px solid var(--line);
    border-radius:14px;
    padding:10px;
    background:rgba(0,0,0,.01);
    display:flex;
    gap:10px;
    align-items:flex-start;
    justify-content:space-between;
  }
  .cf-left{flex:1}
  .cf-actions{display:flex; gap:6px; align-items:center; flex-wrap:wrap}
  .cf-title{margin:0; font-weight:900; font-size:13px}
  .cf-sub{margin:4px 0 0 0; font-size:12px; color:rgba(31,42,40,.72)}
  .toggle{
    display:inline-flex; align-items:center; gap:8px;
    font-size:12px; color:rgba(31,42,40,.75);
    user-select:none;
  }
  .toggle input{transform:translateY(1px)}
  .mono{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace}

  /* ✅ Gate overlay (Auth required / access denied) */
  .qa-gate{
    position:fixed; inset:0;
    z-index:2147483647;
    background:rgba(246,248,247,.92);
    backdrop-filter:saturate(1.1) blur(10px);
    display:none;
    align-items:center;
    justify-content:center;
    padding:16px;
    overflow:auto;
    -webkit-overflow-scrolling:touch;
  }
  .qa-gate-card{
    width:min(520px, 100%);
    background:var(--card);
    border:1px solid var(--line);
    border-radius:18px;
    box-shadow:0 20px 60px rgba(0,0,0,.12);
    overflow:hidden;
  }
  .qa-gate-head{
    padding:14px 14px;
    border-bottom:1px solid var(--line);
    display:flex;
    gap:12px;
    align-items:center;
    background:linear-gradient(180deg, rgba(11,122,117,.07), rgba(255,255,255,0));
  }
  .qa-gate-logo{
    width:42px; height:42px; border-radius:14px;
    background:linear-gradient(135deg, rgba(11,122,117,.18), rgba(133,153,152,.10));
    border:1px solid rgba(11,122,117,.25);
    display:grid; place-items:center;
    color:var(--brand);
    font-weight:900;
    box-shadow:0 10px 20px rgba(11,122,117,.10);
    flex:0 0 auto;
  }
  .qa-gate-title{margin:0; font-size:15px; font-weight:950}
  .qa-gate-sub{margin:2px 0 0 0; font-size:12px; color:rgba(31,42,40,.72)}
  .qa-gate-body{padding:14px}
  .qa-gate-body p{margin:0; font-size:13px; color:rgba(31,42,40,.82); line-height:1.45}
  .qa-gate-details{
    margin-top:10px;
    border:1px solid var(--line);
    border-radius:14px;
    background:rgba(0,0,0,.015);
    padding:10px;
    display:none;
  }
  .qa-gate-details summary{
    cursor:pointer;
    font-weight:850;
    font-size:12px;
    color:rgba(31,42,40,.72);
    user-select:none;
  }
  .qa-gate-details pre{
    margin:8px 0 0 0;
    white-space:pre-wrap;
    word-break:break-word;
    font-size:12px;
    color:rgba(31,42,40,.72);
  }
  .qa-gate-foot{
    padding:14px;
    border-top:1px solid var(--line);
    display:flex;
    gap:10px;
    justify-content:flex-end;
    flex-wrap:wrap;
  }
/* ================================
 * Spinners + Global Busy Overlay
 * ================================ */
@keyframes qaSpin { to { transform: rotate(360deg); } }

.spinner{
  width:16px; height:16px;
  border-radius:999px;
  border:2px solid rgba(31,42,40,.18);
  border-top-color: rgba(11,122,117,.78);
  animation: qaSpin .8s linear infinite;
  flex:0 0 auto;
}
.spinner.sm{ width:14px; height:14px; border-width:2px; }
.spinner.lg{ width:18px; height:18px; border-width:2px; }

/* Global blur state (verify + load classes) */
body.qa-busy{
  overflow:hidden;
}
body.qa-busy .qa-app{
  filter: blur(3px);
  transform: translateZ(0);
  pointer-events:none;
  user-select:none;
}

/* Busy overlay card */
.qa-busy-overlay{
  position:fixed; inset:0;
  z-index:100; /* below qaGate (qaGate uses 2147483647) */
  display:none;
  align-items:center;
  justify-content:center;
  padding:16px;
  background:rgba(246,248,247,.78);
  backdrop-filter:saturate(1.1) blur(8px);
}
.qa-busy-card{
  width:min(420px, 100%);
  background:var(--card);
  border:1px solid var(--line);
  border-radius:18px;
  box-shadow:0 20px 60px rgba(0,0,0,.12);
  padding:14px;
  display:flex;
  gap:12px;
  align-items:center;
}
.qa-busy-text{ display:flex; flex-direction:column; gap:2px; }
.qa-busy-title{ margin:0; font-weight:950; font-size:14px; }
.qa-busy-sub{ margin:0; font-size:12px; color:rgba(31,42,40,.72); }

/* Modal status box (save success/fail) */
.modal-status{
  margin-top:12px;
  border:1px solid var(--line);
  border-radius:14px;
  padding:10px;
  background:rgba(0,0,0,.015);
  font-size:13px;
  color:rgba(31,42,40,.85);
  display:none;
}
.modal-status.ok{ border-color:rgba(2,122,72,.25); background:rgba(2,122,72,.05); }
.modal-status.bad{ border-color:rgba(180,35,24,.25); background:rgba(180,35,24,.05); }
.modal-status.info{ border-color:rgba(11,122,117,.25); background:rgba(11,122,117,.04); }
  /* Mobile */
  @media (max-width: 980px){
    .grid{grid-template-columns: 1fr}
    table{min-width:640px}
    .brand{min-width:auto}
  }
</style>
</head>

<body>

<!-- ✅ Gate Overlay -->
<div class="qa-gate" id="qaGate">
  <div class="qa-gate-card">
    <div class="qa-gate-head">
      <div class="qa-gate-logo">QA</div>
      <div>
        <p class="qa-gate-title" id="gateTitle">Sign in required</p>
        <p class="qa-gate-sub" id="gateSub">Teacher Assess</p>
      </div>
    </div>
    <div class="qa-gate-body">
      <p id="gateMsg">You need to sign in to continue.</p>

      <details class="qa-gate-details" id="gateDetailsWrap">
        <summary>Details</summary>
        <pre id="gateDetails"></pre>
      </details>
    </div>
    <div class="qa-gate-foot">
      <button class="btn" id="gateRetry" style="display:none">Try again</button>
      <button class="btn primary" id="gateLogin">Return to login</button>
    </div>
  </div>
</div>

<!-- ✅ Global Busy Overlay (verify/loading classes) -->
<div class="qa-busy-overlay" id="qaBusy" aria-live="polite" aria-busy="true">
  <div class="qa-busy-card" role="status">
    <span class="spinner lg" aria-hidden="true"></span>
    <div class="qa-busy-text">
      <p class="qa-busy-title" id="busyTitle">Working...</p>
      <p class="qa-busy-sub" id="busySub">Please wait.</p>
    </div>
  </div>
</div>  
  
<div class="qa-app">

  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="logo">QA</div>
        <div>
          <h1>Teacher Classes</h1>
          <div class="sub" id="subline">Checking access..</div>
        </div>
      </div>

      <div class="actions">
        <span class="chip" id="chipPlan" style="display:none"><strong>Plan</strong> <span id="planText"></span></span>
        <span class="chip" id="chipUser" style="display:none"><strong id="userName">Teacher</strong> <span id="userEmail" class="muted"></span></span>

        <!-- ✅ Added -->
        <button class="btn" id="btnDashboard">🏠 Dashboard</button>

        <button class="btn" id="btnRefresh">↻ Refresh classes</button>
        <button class="btn primary" id="btnNew">＋ New Class</button>
        <button class="btn ghost" id="btnSignOut" title="Sign out">Sign out</button>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="grid">

      <!-- Left: classes list -->
      <div class="panel">
        <div class="panel-header">
          <h2>Your Classes</h2>
          <span class="chip mini" id="clsCount">0</span>
        </div>

        <div class="panel-body">
          <div class="row wrap" style="gap:10px">
            <div style="flex:1; min-width:160px">
              <input class="input" id="clsSearch" placeholder="Search class title..." />
            </div>
            <div style="width:150px">
              <select class="select" id="clsStatus">
                <option value="ANY">All</option>
                <option value="ACTIVE">Active</option>
                <option value="ARCHIVED">Archived</option>
              </select>
            </div>
          </div>

          <div class="hr"></div>

          <div id="clsLoading" class="muted">Loading classes...</div>
          <div id="clsEmpty" class="muted" style="display:none">No classes found.</div>

          <div class="list" id="clsList" style="margin-top:10px"></div>
        </div>
      </div>

      <!-- Right: details + members -->
      <div class="panel">
        <div class="panel-header">
          <h2>Class Details</h2>
          <div class="row" style="gap:8px">
            <button class="btn" id="btnEdit" disabled>✎ Edit</button>
            <button class="btn" id="btnInvite" disabled>⤴ Invite</button>
          </div>
        </div>

        <div class="panel-body">
          <div id="noSelection" class="muted">
            Select a class to view members and manage settings.
          </div>

          <div id="details" style="display:none">
            <div class="row between wrap">
              <div>
                <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap">
                  <div style="font-weight:950; font-size:16px" id="dTitle"></div>
                  <span class="chip mini" id="dStatusChip"></span>
                </div>
                <div class="muted" style="margin-top:4px">
                  <span class="mono" id="dClassId"></span>
                  <span style="opacity:.55">•</span>
                  Updated: <span id="dUpdated"></span>
                </div>
              </div>
              <div class="row" style="gap:8px; flex-wrap:wrap">
                <span class="kpi" title="Members">
                  👥 <span id="dMembers">0</span>
                </span>
                <span class="kpi" title="Linked quizzes">
                  🧩 <span id="dQuizzes">0</span>
                </span>
              </div>
            </div>

            <div class="hr"></div>

            <div class="row between wrap" style="align-items:flex-start">
              <div style="flex:1; min-width:260px">
                <div class="label">Join code</div>
                <div class="codebox" style="margin-top:6px">
                  <div class="code" id="dJoinCode">—</div>
                  <div style="flex:1"></div>
                  <button class="btn" id="btnCopyCode">Copy</button>
                  <button class="btn danger" id="btnRegenCode">Regenerate</button>
                </div>
                <div class="muted" style="margin-top:8px">
                  Share this code with students. If you regenerate, the old code stops working.
                </div>
              </div>

              <div style="flex:1; min-width:260px">
                <div class="label">Student identifiers (teacher-defined)</div>
                <div class="muted" style="margin-top:6px">
                  These are the fields students will fill when joining this class.
                </div>
                <div id="dCustomFields" style="margin-top:10px"></div>
              </div>
            </div>

            <div class="hr"></div>

            <div class="row between wrap">
              <div>
                <div style="font-weight:900">Members</div>
                <div class="muted">Search, review, and remove members.</div>
              </div>

              <div class="row wrap" style="gap:10px">
                <div style="width:220px">
                  <input class="input" id="memSearch" placeholder="Search name/email/user_id..." />
                </div>
                <div style="width:150px">
                  <select class="select" id="memStatus">
                    <option value="ACTIVE">Active</option>
                    <option value="ALL">All</option>
                    <option value="REMOVED">Removed</option>
                  </select>
                </div>
                <button class="btn" id="btnMemRefresh">↻ Refresh members</button>
              </div>
            </div>

            <div style="margin-top:12px" class="table-wrap">
              <table>
                <thead>
                  <tr id="memHeadRow"></tr>
                </thead>
                <tbody id="memBody"></tbody>
              </table>
            </div>

