  rows.forEach(m=>{
    const tr = document.createElement('tr');

    cols.forEach(c=>{
      const td = document.createElement('td');

      if (c.k === 'actions'){
        const btn = document.createElement('button');
        btn.className = 'btn danger';
        btn.textContent = 'Remove';
btn.onclick = async (ev)=>{
