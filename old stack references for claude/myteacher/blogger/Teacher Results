function applyMarksFilter(){
  const q = String(el('qMarks').value||'').trim().toLowerCase();
  const all = S.roster_rows || [];
  let out = all;

  if (q){
    out = all.filter(r=>{
      const name = String(r.display_name||'').toLowerCase();
      const uid = String(r.user_id||'').toLowerCase();
      const mfj = String(r.member_fields_json||'').toLowerCase();
      const qfj = String(r.headline_fields_json||'').toLowerCase();
      const grade = String(r.grade_label||'').toLowerCase();
      const pf = String(r.pass_fail||'').toLowerCase();
      return name.includes(q) || uid.includes(q) || mfj.includes(q) || qfj.includes(q) || grade.includes(q) || pf.includes(q);
    });
  }
  S.roster_rows_filtered = out;
  renderMarksheet();
}

function renderMarksheet(){
  const rows = S.roster_rows_filtered || [];

  const classFields = Array.isArray(S.class_fields) ? S.class_fields : [];
  const quizFields  = Array.isArray(S.quiz_fields) ? S.quiz_fields : [];

  const pol = scorePolicy();
  const showRaw = policyShowRaw(pol);
  const showPct = policyShowPct(pol);

  const head = el('marksHead');
  head.innerHTML = '';

  const cols = [
    {k:'name', label:'Name'},
    ...classFields.map(f=>({k:'cf_'+keyOf(f), label: labelOrKey(f), fieldKey:keyOf(f), group:'class'})),
    ...quizFields.map(f=>({k:'qf_'+keyOf(f), label: labelOrKey(f), fieldKey:keyOf(f), group:'quiz'})),
    {k:'status', label:'Status'},
    {k:'attempts', label:'Attempts'},
    ...(showRaw ? [{k:'raw', label:'Score'}] : []),
    ...(showPct ? [{k:'pct', label:'%'}] : []),
    {k:'pass', label:'Pass'},
    {k:'grade', label:'Grade'},
    {k:'submitted', label:'Submitted'},
    {k:'actions', label:''}
  ];

  cols.forEach(c=>{
    const th = document.createElement('th');
    th.textContent = c.label;
    head.appendChild(th);
  });

  const body = el('marksBody');
  body.innerHTML = '';

  if (!rows.length){
    body.innerHTML = `<tr><td colspan="${cols.length}" class="muted">No rows.</td></tr>`;
    el('countChip').textContent = '0';
    return;
  }

  rows.forEach(r=>{
    const tr = document.createElement('tr');

    cols.forEach(c=>{
      const td = document.createElement('td');

      if (c.k==='name'){
        const qs = fieldsSummary(r.headline_fields || {}, quizFields);
        td.innerHTML = `
          <div style="font-weight:950">${esc(r.display_name||'—')}</div>
          <div class="muted mono">${esc(r.user_id||'')}</div>
          ${qs ? `<div class="muted">${esc(qs)}</div>` : ``}
        `;
      }
      else if (c.group==='class'){
        const mf = r.member_fields || {};
        const v = c.fieldKey ? (mf[c.fieldKey] || '') : '';
        td.textContent = v ? String(v) : '—';
      }
      else if (c.group==='quiz'){
        const hf = r.headline_fields || {};
        const v = c.fieldKey ? (hf[c.fieldKey] || '') : '';
        td.textContent = v ? String(v) : '—';
      }
      else if (c.k==='status'){
        td.innerHTML = pillStatus(r.status);
      }
      else if (c.k==='attempts'){
        td.textContent = String(r.attempts_used ?? '0');
      }
      else if (c.k==='raw'){
        td.textContent = fmtRaw(r.headline_score) || '—';
      }
      else if (c.k==='pct'){
        td.textContent = fmtPct(r.headline_score) || '—';
      }
      else if (c.k==='pass'){
        const sc = r.headline_score || null;
        const pct = sc && sc.percent!=null ? Number(sc.percent) : NaN;
        const pf = String(r.pass_fail || passFailFromPct(pct) || '').trim();
        td.innerHTML = pf
          ? `<span class="pill ${pf==='PASS'?'ok':'bad'}">${esc(pf)}</span>`
          : `<span class="muted">—</span>`;
      }
      else if (c.k==='grade'){
        const gl = String(r.grade_label||'').trim();
        td.innerHTML = gl
          ? `<span class="pill ${gl.toLowerCase().includes('fail')?'bad':'ok'}">${esc(gl)}</span>`
          : `<span class="muted">—</span>`;
      }
      else if (c.k==='submitted'){
        td.textContent = r.submitted_at ? fmtIso(r.submitted_at) : '—';
      }
      else if (c.k==='actions'){
        const aid = String(r.headline_attempt_id||'').trim();
        td.innerHTML = `
          <div class="row wrap">
            <button class="btn" data-act="attempts" data-user="${esc(r.user_id)}">Attempts</button>
            ${aid ? `<button class="btn primary" data-act="view" data-attempt="${esc(aid)}">View</button>` : ``}
          </div>
        `;
      }

      tr.appendChild(td);
    });

    body.appendChild(tr);
  });

  el('countChip').textContent = String(rows.length);
  el('marksHint').textContent = `${(S.roster_rows||[]).length} loaded • ${rows.length} shown`;
}

function renderItems(){
  const q = String(el('qItems').value||'').trim().toLowerCase();
  const items = (S.items||[]).filter(it=>{
    if (!q) return true;
    return String(it.topic||'').toLowerCase().includes(q) || String(it.stem_preview||'').toLowerCase().includes(q);
  });

  const body = el('itemsBody');
  body.innerHTML = '';

  if (!items.length){
    body.innerHTML = `<tr><td colspan="11" class="muted">No items.</td></tr>`;
    return;
  }

  items.forEach(it=>{
    const cd = it.common_distractor ? `${it.common_distractor.option} (${it.common_distractor.pct}%)` : '—';
