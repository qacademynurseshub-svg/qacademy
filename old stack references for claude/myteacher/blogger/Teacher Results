async function openAttempt(attempt_id){
  el('drawerTitle').textContent = 'Attempt view';
  el('drawerSub').textContent = attempt_id;
  el('drawerBody').innerHTML = '<div class="muted">Loading attempt…</div>';
  showDrawer();

  try{
    const obj = await apiPost({ action:'teacher.attempt.get', token:S.token, attempt_id });

    const attempt = obj.attempt || {};
    const score = obj.score || null;
    const pct = score && score.percent!=null ? Number(score.percent) : null;
    const gl = (pct!=null && isFinite(pct) && S.grade_bands_obj) ? gradeLabelFromBands(S.grade_bands_obj, pct) : '';

    const cfJson = obj.candidate_fields_json || attempt.candidate_fields_json || attempt.custom_fields_json || '';
    const cfObj = safeJsonParse(cfJson, null);
    const fields = (cfObj && cfObj.fields && typeof cfObj.fields==='object') ? cfObj.fields : (cfObj && typeof cfObj==='object' ? cfObj : {});
    const qsum = fieldsSummary(fields, S.quiz_fields);

    const review = obj.review_items || [];
    const byId = {};
    review.forEach(x=>{ byId[String(x.quiz_item_id||'').trim()] = x; });

    const items = obj.items || [];

    const header = `
      <div class="qCard">
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:space-between">
          <div>
            <div style="font-weight:950">Score: ${esc(fmtScore(score))} ${gl ? ` • ${esc(gl)}` : ''}</div>
            <div class="muted">Status: ${esc(String(attempt.status||''))} • Started: ${esc(attempt.started_at||'—')} • Submitted: ${esc(attempt.submitted_at||'—')}</div>
            ${qsum ? `<div class="muted"><b>Quiz fields:</b> ${esc(qsum)}</div>` : ``}
          </div>
          <div class="muted mono">Attempt: ${esc(attempt.attempt_id||'')}</div>
        </div>
      </div>
    `;

    const qHtml = items.map((it, idx)=>{
      const rid = String(it.quiz_item_id||'').trim();
      const r = byId[rid] || {};
      const chosen = String(r.chosen||'').trim().toUpperCase();
      const correct = String(r.correct||'').trim().toUpperCase();

      const opts = (it.options||[]).map(o=>{
        const key = String(o.key||'').toUpperCase();
        const text = String(o.text||'');
        let cls = 'opt';
        if (key===correct) cls += ' good';
        if (key===chosen && chosen && chosen!==correct) cls += ' bad';
        if (key===chosen && chosen===correct) cls += ' good';

        return `
          <div class="${cls}">
            <b>${esc(key)}.</b> ${esc(text)}
            ${key===chosen ? `<span class="pill warn" style="margin-left:8px">Selected</span>`:''}
            ${key===correct ? `<span class="pill ok" style="margin-left:8px">Correct</span>`:''}
          </div>
        `;
      }).join('');

      const rationale = String(r.rationale||'').trim();

      return `
        <div class="qCard">
          <div style="font-weight:950;margin-bottom:6px">Q${idx+1}. ${esc(it.stem||'')}</div>
          <div class="muted">Marks: ${esc(String(it.marks||1))} • Subject: ${esc(it.subject||'')}</div>
          ${opts}
          ${rationale ? `<div class="hr"></div><div class="muted"><b>Rationale:</b> ${esc(rationale)}</div>`:''}
        </div>
      `;
    }).join('');

    el('drawerBody').innerHTML = header + qHtml;
    setPrintPayload(
      'Student attempt',
      `${S.class_title || S.class_id} • ${S.quiz_title || S.teacher_quiz_id} • ${attempt_id}`,
      el('drawerBody').innerHTML
    );
  }catch(err){
    el('drawerBody').innerHTML = `<div class="pill bad">Failed: ${esc(err.message||String(err))}</div>`;
  }
}

function openItem(quiz_item_id){
  const qid = String(quiz_item_id||'').trim();
  const snap = S.snapshotsById[qid] || null;
  const it = (S.items||[]).find(x=>String(x.quiz_item_id||'').trim()===qid) || null;

  el('drawerTitle').textContent = 'Item details';
  el('drawerSub').textContent = it ? `Q${it.position||''}` : qid;

  const optCounts = (it && it.option_counts) ? it.option_counts : {};
  const countsLine = ['A','B','C','D','E','F'].map(L=>`${L}:${optCounts[L] ?? 0}`).join('  ');
  const flags = (it && it.flags) ? it.flags : [];

  const snapHtml = snap ? `
    <div class="qCard">
      <div style="font-weight:950;margin-bottom:6px">${esc(snap.snap_stem||'')}</div>
      ${['A','B','C','D','E','F'].map(L=>{
        const t = String(snap['snap_option_'+L.toLowerCase()]||'').trim();
        if (!t) return '';
        const good = (String(snap.snap_correct||'').trim().toUpperCase()===L);
        return `<div class="opt ${good?'good':''}"><b>${esc(L)}.</b> ${esc(t)} ${good?'<span class="pill ok" style="margin-left:8px">Correct</span>':''}</div>`;
      }).join('')}
      ${String(snap.snap_rationale||'').trim() ? `<div class="hr"></div><div class="muted"><b>Rationale:</b> ${esc(snap.snap_rationale)}</div>`:''}
    </div>
  ` : `<div class="muted">Snapshot not found.</div>`;

  el('drawerBody').innerHTML = `
    <div class="qCard">
      <div class="row wrap">
        <span class="pill ok">Correct: ${esc(it?.correct||'')}</span>
        <span class="pill">Attempts: ${esc(String(it?.attempts ?? 0))}</span>
        <span class="pill">Wrong: ${esc(String(it?.wrong_count ?? 0))}</span>
        <span class="pill">Blank: ${esc(String(it?.blank_count ?? 0))}</span>
        <span class="pill">Accuracy: ${esc(String(it?.pct_correct ?? 0))}%</span>
      </div>
      <div class="hr"></div>
      <div class="muted"><b>Option counts (canonical):</b> <span class="mono">${esc(countsLine)}</span></div>
      <div class="muted" style="margin-top:6px"><b>Flags:</b> ${flags.length ? flags.map(f=>`<span class="pill warn">${esc(f)}</span>`).join(' ') : '—'}</div>
    </div>
    ${snapHtml}
  `;
  setPrintPayload(
    'Item analysis',
    `${S.class_title || S.class_id} • ${S.quiz_title || S.teacher_quiz_id} • ${el('drawerSub').textContent || ''}`,
    el('drawerBody').innerHTML
  );
  showDrawer();
}

/** =============================
 * CSV export (client-side; Premium gated)
 * ============================= */
function exportCsv(){
  if (S.plan !== 'PREMIUM'){
    alert('CSV export is Premium.');
    return;
  }

  const rows = S.roster_rows_filtered || [];
  const classFields = Array.isArray(S.class_fields) ? S.class_fields : [];
  const quizFields  = Array.isArray(S.quiz_fields) ? S.quiz_fields : [];

  const pol = scorePolicy();
  const showRaw = policyShowRaw(pol);
  const showPct = policyShowPct(pol);

  const used = {};
  const header = [
    'display_name',
    ...classFields.map(f=>buildDisplayLabel('class_', f, used)),
    ...quizFields.map(f=>buildDisplayLabel('quiz_', f, used)),
    'status','attempts_used',
    ...(showRaw ? ['score_marks','total_marks'] : []),
    ...(showPct ? ['percent'] : []),
    'pass_fail','grade_label',
    'submitted_at','user_id','headline_attempt_id'
  ];

  const lines = [header.join(',')];

  rows.forEach(r=>{
    const mf = r.member_fields || {};
    const hf = r.headline_fields || {};
    const sc = r.headline_score || {};

    const pf = String(r.pass_fail || passFailFromPct(sc.percent) || '').trim();

    const vals = [
      r.display_name||'',
      ...classFields.map(f=> mf[keyOf(f)] || ''),
      ...quizFields.map(f=> hf[keyOf(f)] || ''),
      r.status||'',
      r.attempts_used ?? '',
      ...(showRaw ? [sc.score_marks ?? '', sc.total_marks ?? ''] : []),
      ...(showPct ? [sc.percent ?? ''] : []),
      pf,
      r.grade_label||'',
      r.submitted_at||'',
      r.user_id||'',
      r.headline_attempt_id||''
    ].map(v=>{
      const s = String(v ?? '');
      if (s.includes('"')||s.includes(',')||s.includes('\n')) return `"${s.replace(/"/g,'""')}"`;
      return s;
    });

    lines.push(vals.join(','));
  });

  const blob = new Blob([lines.join('\n')], {type:'text/csv;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `marksheet_${(S.class_title||S.class_id||'class').replace(/[^a-z0-9_-]+/gi,'_')}_${(S.quiz_title||S.teacher_quiz_id||'quiz').replace(/[^a-z0-9_-]+/gi,'_')}.csv`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}

/** =============================
 * UI wiring
 * ============================= */
function bindUI(){
  el('btnRefresh').onclick = async ()=>{
    const ok = await verifyTeacher();
    if (!ok) return;
    await loadFilters();

    const cid = qsParam('class_id');
    const qid = qsParam('teacher_quiz_id');
    if (cid) {
      el('selClass').value = cid;
      await loadQuizzesForClass(cid, { preselect_quiz_id: qid });
    }
  };

  el('btnSignOut').onclick = ()=>{
    setToken('');
    alert('Signed out (token cleared).');
    setTimeout(()=>location.reload(), 200);
  };

  el('btnLoad').onclick = async ()=>{
    S.attemptsCache = null;
    await loadReport({append:false});
  };

  el('btnLoadMore').onclick = async ()=>{
    await loadReport({append:true});
  };

  el('qMarks').addEventListener('input', ()=>applyMarksFilter());
  el('qItems').addEventListener('input', ()=>renderItems());

  el('btnRefreshItems').onclick = async ()=>{
    await loadItems({force:true});
  };

  document.querySelectorAll('.tab').forEach(t=>{
    t.onclick = async ()=>{
      document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
      t.classList.add('active');
      const key = t.getAttribute('data-tab');
      el('tabMarks').style.display = (key==='marks') ? '' : 'none';
      el('tabItems').style.display = (key==='items') ? '' : 'none';
      if (key === 'items') await loadItems({force:false});
    };
  });

  el('selClass').addEventListener('change', async ()=>{
    const class_id = String(el('selClass').value||'').trim();
    S.attemptsCache = null;
    el('selQuiz').value = '';
    await loadQuizzesForClass(class_id);

    S.class_id = class_id;
    S.teacher_quiz_id = '';
    setScopeUI();
  });

  el('marksBody').addEventListener('click', async (e)=>{
    const b = e.target.closest('button');
    if (!b) return;
    const act = b.getAttribute('data-act');
    if (act==='attempts'){
      await openAttempts(b.getAttribute('data-user'));
    }else if (act==='view'){
      await openAttempt(b.getAttribute('data-attempt'));
    }
  });

  el('itemsBody').addEventListener('click', (e)=>{
    const b = e.target.closest('button');
    if (!b) return;
    const act = b.getAttribute('data-act');
    if (act==='item'){
      openItem(b.getAttribute('data-qid'));
    }
  });

  el('drawerBody').addEventListener('click', async (e)=>{
    const b = e.target.closest('button');
    if (!b) return;
    const act = b.getAttribute('data-act');
    if (act==='viewAttempt'){
      await openAttempt(b.getAttribute('data-attempt'));
    }
  });

  el('btnClose').onclick = closeDrawer;
  el('drawerBackdrop').addEventListener('click', (e)=>{
    if (e.target === el('drawerBackdrop')) closeDrawer();
  });

  el('btnPrint').onclick = ()=>printFromPayload();

  el('btnPrintSummary').onclick = ()=>{
    el('drawerTitle').textContent = 'Print summary';
    el('drawerSub').textContent = `${S.class_title || S.class_id} • ${S.quiz_title || S.teacher_quiz_id}`;

    const rows = S.roster_rows_filtered || [];
    const classFields = Array.isArray(S.class_fields) ? S.class_fields : [];
    const quizFields  = Array.isArray(S.quiz_fields) ? S.quiz_fields : [];

    const pol = scorePolicy();
    const showRaw = policyShowRaw(pol);
    const showPct = policyShowPct(pol);

    const headArr = [
      'Name',
      ...classFields.map(f=>labelOrKey(f)),
      ...quizFields.map(f=>labelOrKey(f)),
      'Status','Attempts',
      ...(showRaw ? ['Score'] : []),
      ...(showPct ? ['%'] : []),
      'Pass','Grade'
    ];

    const head = headArr.map(x=>`<th>${esc(x)}</th>`).join('');

    const body = rows.map(r=>{
      const mf = r.member_fields || {};
      const hf = r.headline_fields || {};
      const gl = String(r.grade_label||'').trim();

      const sc = r.headline_score || {};
      const pf = String(r.pass_fail || passFailFromPct(sc.percent) || '').trim();

      return `<tr>
        <td>${esc(r.display_name||'')}</td>
        ${classFields.map(f=>`<td>${esc(mf[keyOf(f)]||'')}</td>`).join('')}
        ${quizFields.map(f=>`<td>${esc(hf[keyOf(f)]||'')}</td>`).join('')}
        <td>${esc(String(r.status||''))}</td>
        <td>${esc(String(r.attempts_used ?? '0'))}</td>
        ${showRaw ? `<td>${esc(fmtRaw(r.headline_score) || '—')}</td>` : ``}
        ${showPct ? `<td>${esc(fmtPct(r.headline_score) || '—')}</td>` : ``}
        <td>${esc(pf||'')}</td>
        <td>${esc(gl||'')}</td>
      </tr>`;
    }).join('');

    const colCount = headArr.length;

    el('drawerBody').innerHTML = `
      <div class="qCard">
        <div style="font-weight:950">Headline rule: ${esc(S.headline_rule||'—')}</div>
        <div class="muted">Rows: ${rows.length} • Policy: ${esc(scorePolicy())} • Pass threshold: ${policyShowPct(scorePolicy()) ? esc(String(S.pass_threshold_pct)) + '%' : 'hidden'}</div>
      </div>
      <div class="table-wrap">
        <table style="min-width:1100px">
          <thead><tr>${head}</tr></thead>
          <tbody>${body || `<tr><td colspan="${colCount}" class="muted">No rows.</td></tr>`}</tbody>
        </table>
      </div>
    `;
    setPrintPayload(
      'Marksheet summary',
      `${S.class_title || S.class_id} • ${S.quiz_title || S.teacher_quiz_id}`,
      el('drawerBody').innerHTML
    );
    showDrawer();
  };

  el('btnExportCsv').onclick = exportCsv;
}

/** =============================
 * Init
 * ============================= */
(async function init(){
  bindUI();
  const ok = await verifyTeacher();
  if (!ok) return;

  await loadFilters();

  const class_id = qsParam('class_id');
  const teacher_quiz_id = qsParam('teacher_quiz_id');

  if (class_id){
    el('selClass').value = class_id;
    await loadQuizzesForClass(class_id, { preselect_quiz_id: teacher_quiz_id });
  }

  if (class_id && teacher_quiz_id){
    await loadReport({append:false});
  }
})();
</script>

