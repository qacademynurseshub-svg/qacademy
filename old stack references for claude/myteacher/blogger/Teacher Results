<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Teacher Results</title>

<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#1f2a28;
    --bg:#f6f8f7;
    --card:#ffffff;
    --line:rgba(0,0,0,.08);
    --soft:rgba(0,0,0,.04);
    --danger:#b42318;
    --ok:#027a48;
    --warn:#b45309;

    --radius:16px;
    --shadow:0 10px 30px rgba(0,0,0,.08);
    --pageMax:1400px;
  }

  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  }

  .qa-app{
    min-height:100vh;
    width:100vw;
    position:relative;
    left:50%;
    right:50%;
    margin-left:-50vw;
    margin-right:-50vw;
  }

  a{color:var(--brand);text-decoration:none}

  .topbar{
    position:sticky; top:0; z-index:30;
    background:rgba(246,248,247,.92);
    backdrop-filter:saturate(1.2) blur(10px);
    border-bottom:1px solid var(--line);
  }
  .topbar-inner{
    max-width:var(--pageMax);
    margin:0 auto;
    padding:14px 14px;
    display:flex;
    gap:12px;
    align-items:center;
    justify-content:space-between;
  }

  .brand{display:flex; align-items:center; gap:10px; min-width:240px;}
  .logo{
    width:38px; height:38px; border-radius:12px;
    background:linear-gradient(135deg, rgba(11,122,117,.18), rgba(133,153,152,.10));
    border:1px solid rgba(11,122,117,.25);
    display:grid; place-items:center;
    box-shadow:0 10px 20px rgba(11,122,117,.10);
    color:var(--brand);
    font-weight:900;
    letter-spacing:.2px;
  }
  .brand h1{font-size:16px; margin:0; line-height:1.1}
  .brand .sub{font-size:12px; color:rgba(31,42,40,.7)}

  .actions{display:flex; gap:10px; align-items:center; flex-wrap:wrap; justify-content:flex-end;}

  .btn{
    border:1px solid var(--line);
    background:var(--card);
    color:var(--ink);
    padding:10px 12px;
    border-radius:12px;
    cursor:pointer;
    font-weight:750;
    font-size:13px;
    display:inline-flex;
    gap:8px;
    align-items:center;
  }
  .btn:hover{background:rgba(255,255,255,.92)}
  .btn.primary{
    background:var(--brand);
    border-color:rgba(11,122,117,.35);
    color:#fff;
  }
  .btn.primary:hover{filter:brightness(.98)}
  .btn.danger{
    border-color:rgba(180,35,24,.25);
    color:var(--danger);
    background:rgba(180,35,24,.04);
  }
  .btn.danger:hover{background:rgba(180,35,24,.06)}
  .btn.ghost{
    background:transparent;
    border-color:transparent;
  }
  .btn.ghost:hover{background:rgba(0,0,0,.04); border-color:var(--line)}
  .btn[disabled]{opacity:.55; cursor:not-allowed}

  .chip{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid var(--line);
    background:var(--card);
    font-size:12px;
    color:rgba(31,42,40,.75);
    white-space:nowrap;
  }
  .chip strong{color:var(--ink)}
  .chip.ok{border-color:rgba(2,122,72,.22); background:rgba(2,122,72,.06); color:rgba(2,122,72,.95)}
  .chip.warn{border-color:rgba(245,158,11,.25); background:rgba(245,158,11,.07); color:rgba(146,64,14,.95)}
  .chip.bad{border-color:rgba(180,35,24,.25); background:rgba(180,35,24,.06); color:rgba(180,35,24,.95)}
  .chip.mini{padding:4px 8px; font-size:11px}

  .container{max-width:var(--pageMax); margin:0 auto; padding:14px;}

  .grid{
    display:grid;
    grid-template-columns: 380px 1fr;
    gap:14px;
    align-items:start;
  }

  .panel{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    overflow:hidden;
  }

  .panel-header{
    padding:12px 12px;
    border-bottom:1px solid var(--line);
    display:flex;
    gap:10px;
    align-items:center;
    justify-content:space-between;
    background:linear-gradient(180deg, rgba(11,122,117,.05), rgba(255,255,255,0));
  }
  .panel-header h2{margin:0;font-size:14px}
  .panel-body{padding:12px}

  .muted{color:rgba(31,42,40,.68); font-size:12px}
  .mono{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace}

  .field{display:flex; flex-direction:column; gap:6px; margin-bottom:10px;}
  .label{font-size:12px; color:rgba(31,42,40,.78); font-weight:800}
  .input, .select{
    width:100%;
    padding:10px 10px;
    border:1px solid var(--line);
    border-radius:12px;
    outline:none;
    background:#fff;
    color:var(--ink);
    font-size:13px;
  }
  .input:focus, .select:focus{
    border-color:rgba(11,122,117,.35);
    box-shadow:0 0 0 3px rgba(11,122,117,.10);
  }

  .hr{height:1px; background:var(--line); margin:12px 0}

  .tabs{display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;}
  .tab{
    padding:8px 10px;
    border-radius:999px;
    border:1px solid var(--line);
    background:#fff;
    cursor:pointer;
    font-size:12px;
    font-weight:800;
  }
  .tab.active{
    background:rgba(11,122,117,.10);
    border-color:rgba(11,122,117,.30);
    color:var(--brand);
  }

  .stats{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:10px;
  }
  @media (max-width:1100px){ .stats{grid-template-columns:repeat(2,1fr)} }
  .stat{
    border:1px solid var(--line);
    border-radius:14px;
    padding:10px;
    background:linear-gradient(180deg,#fff,rgba(246,248,247,.85));
  }
  .stat .k{font-size:12px;color:rgba(31,42,40,.72);font-weight:800}
  .stat .v{margin-top:6px;font-size:18px;font-weight:950}
  .stat .s{margin-top:4px;font-size:12px;color:rgba(31,42,40,.68)}

  .table-wrap{
    border:1px solid var(--line);
    border-radius:14px;
    overflow:auto;
    background:#fff;
  }
  table{
    width:100%;
    border-collapse:separate;
    border-spacing:0;
    min-width:980px;
  }
  th, td{
    padding:10px 10px;
    border-bottom:1px solid var(--line);
    vertical-align:top;
    font-size:13px;
  }
  th{
    position:sticky;
    top:0;
    background:#fff;
    z-index:1;
    text-align:left;
    font-size:12px;
    color:rgba(31,42,40,.72);
    font-weight:900;
    white-space:nowrap;
  }
  tr:hover td{background:rgba(0,0,0,.01)}

  .pill{
    display:inline-flex;align-items:center;gap:6px;
    padding:5px 9px;border-radius:999px;border:1px solid var(--line);
    background:#fff;font-size:12px;white-space:nowrap;font-weight:850;
  }
  .pill.ok{border-color:rgba(2,122,72,.25);background:rgba(2,122,72,.06);color:rgba(2,122,72,.95)}
  .pill.warn{border-color:rgba(245,158,11,.25);background:rgba(245,158,11,.07);color:rgba(146,64,14,.95)}
  .pill.bad{border-color:rgba(180,35,24,.25);background:rgba(180,35,24,.06);color:rgba(180,35,24,.95)}

  .row{display:flex;gap:10px;align-items:center}
  .row.wrap{flex-wrap:wrap}
  .between{justify-content:space-between}

  /* Drawer */
  .drawer-backdrop{
    position:fixed; inset:0;
    background:rgba(0,0,0,.35);
    display:none;
    align-items:flex-end;
    justify-content:center;
    z-index:120;
    padding:12px;
  }
  .drawer{
    width:min(var(--pageMax), 100%);
    background:var(--card);
    border:1px solid var(--line);
    border-radius:18px 18px 0 0;
    box-shadow:0 -20px 50px rgba(0,0,0,.18);
    max-height:92vh;
    overflow:auto;
  }
  .drawer-head{
    position:sticky; top:0;
    background:rgba(255,255,255,.92);
    backdrop-filter:saturate(1.2) blur(10px);
    border-bottom:1px solid var(--line);
    padding:12px;
    display:flex;gap:10px;align-items:center;justify-content:space-between;
  }
  .drawer-body{padding:12px}

  .qCard{
    border:1px solid var(--line);
    border-radius:14px;
    padding:10px;
    background:rgba(0,0,0,.01);
    margin-bottom:10px;
    break-inside:avoid;
  }
  .opt{
    border:1px solid var(--line);
    border-radius:12px;
    padding:8px 10px;
    margin-top:8px;
    background:#fff;
  }
  .opt.good{border-color:rgba(2,122,72,.25);background:rgba(2,122,72,.05)}
  .opt.bad{border-color:rgba(180,35,24,.25);background:rgba(180,35,24,.05)}

  @media (max-width: 980px){
    .grid{grid-template-columns:1fr}
    table{min-width:860px}
    .brand{min-width:auto}
  }
  /* =========================
   * Print Root (Option A)
   * ========================= */
  #printRoot{ display:none; }

  #printRoot .print-page{
    max-width:100%;
    padding:0;
    margin:0;
  }
  #printRoot .print-h1{
    font-size:18px;
    font-weight:950;
    margin:0;
  }
  #printRoot .print-sub{
    margin-top:4px;
    font-size:12px;
    color:rgba(31,42,40,.72);
  }
  #printRoot .print-meta{
    margin-top:4px;
    font-size:12px;
    color:rgba(31,42,40,.72);
  }
  #printRoot .print-hr{
    height:1px;
    background:#e5e7eb;
    margin:10px 0;
  }

  @media print{
    @page{ margin: 12mm; }

    body{ background:#fff !important; }

    /* Hide EVERYTHING by default */
    body *{ visibility:hidden !important; }

    /* Show only printRoot */
    #printRoot, #printRoot *{ visibility:visible !important; }
    #printRoot{
      display:block !important;
      position:static !important;
      width:100% !important;
      margin:0 !important;
      left:auto !important;
      right:auto !important;
    }

    /* Make sure UI layers never leak into print */
    .qa-app{ display:none !important; }
    .drawer-backdrop{ display:none !important; }

    /* Print-friendly containers */
    #printRoot .table-wrap{
      overflow:visible !important;
      border:none !important;
    }

    /* Print-friendly table */
    #printRoot table{
      min-width:0 !important;
      width:100% !important;
      border-collapse:collapse !important;
    }
    #printRoot th, #printRoot td{
      font-size:12px !important;
      padding:6px 6px !important;
      border:1px solid #e5e7eb !important;
      vertical-align:top !important;
    }
    #printRoot th{
      position:static !important;
      background:#fff !important;
    }
    #printRoot thead{ display:table-header-group; }

    /* Avoid splitting cards/rows */
    #printRoot .qCard,
    #printRoot .opt,
    #printRoot tr{
      break-inside:avoid !important;
      page-break-inside:avoid !important;
    }

    /* Remove effects that can print as blocks */
    #printRoot *{
      box-shadow:none !important;
      filter:none !important;
      backdrop-filter:none !important;
    }
  }
</style>
</head>

<body>
<div class="qa-app">

  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="logo">QA</div>
        <div>
          <h1>Teacher Results</h1>
          <div class="sub" id="subline">Checking access…</div>
        </div>
      </div>

      <div class="actions">
        <span class="chip" id="chipPlan" style="display:none"><strong>Plan</strong> <span id="planText"></span></span>
        <span class="chip" id="chipUser" style="display:none"><strong id="userName">Teacher</strong> <span id="userEmail" class="muted"></span></span>

        <button class="btn" id="btnRefresh">↻ Refresh</button>
        <button class="btn danger" id="btnSignOut" title="Sign out">Sign out</button>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="grid">

      <!-- Left: selectors -->
      <div class="panel">
        <div class="panel-header">
          <h2>Report scope</h2>
          <span class="chip mini" id="scopeChip">—</span>
        </div>

        <div class="panel-body">
          <div class="field">
            <div class="label">Class</div>
            <select class="select" id="selClass"></select>
          </div>

          <div class="field">
            <div class="label">Quiz</div>
            <select class="select" id="selQuiz"></select>
          </div>

          <div class="field">
            <div class="label">Roster</div>
            <select class="select" id="selRoster">
              <option value="0">Active members only</option>
              <option value="1">Include removed members</option>
            </select>
            <div class="muted" style="margin-top:6px">Uses class members as the roster, so you get NOT_STARTED rows too.</div>
          </div>

          <div class="field">
            <div class="label">Sort marksheet</div>
            <select class="select" id="selSort">
              <option value="name_asc">Name A→Z</option>
              <option value="score_desc">Score high→low</option>
              <option value="score_asc">Score low→high</option>
              <option value="status_asc">Status</option>
            </select>
          </div>

          <!-- NEW: status + date filters -->
          <div class="field">
            <div class="label">Status filter</div>
            <select class="select" id="selStatus">
              <option value="ANY">All</option>
              <option value="SUBMITTED" selected>Submitted only</option>
              <option value="IN_PROGRESS">In progress</option>
              <option value="NOT_STARTED">Not started</option>
            </select>
          </div>

          <div class="field">
            <div class="label">Date from (optional)</div>
            <input class="input" id="dateFrom" type="date" />
          </div>

          <div class="field">
            <div class="label">Date to (optional)</div>
            <input class="input" id="dateTo" type="date" />
          </div>

          <button class="btn primary" id="btnLoad" style="width:100%;justify-content:center">Load report</button>

          <div class="hr"></div>

          <div class="muted" id="hintBox">
            This page uses your saved token (same as other Teacher pages).<br/>
            If you see “Missing token”, open from the portal after login.
          </div>

          <div class="hr"></div>

          <div class="muted">
            Premium features (gated by plan):
            <br/>• CSV export
            <br/>• Advanced analytics (later)
          </div>
        </div>
      </div>

      <!-- Right: report -->
      <div class="panel">
        <div class="panel-header">
          <h2 id="reportTitle">Report</h2>
          <div class="row wrap" style="gap:8px">
            <span class="chip mini" id="headlineChip">Headline: —</span>
            <button class="btn" id="btnPrintSummary">🖨 Print summary</button>
            <button class="btn" id="btnExportCsv" disabled>⬇ Export CSV</button>
          </div>
        </div>

        <div class="panel-body">
          <div class="stats">
            <div class="stat"><div class="k">Roster</div><div class="v" id="sRoster">—</div><div class="s" id="sRosterSub">—</div></div>
            <div class="stat"><div class="k">Submitted</div><div class="v" id="sSubmitted">—</div><div class="s" id="sSubmittedSub">—</div></div>
            <div class="stat"><div class="k">Average</div><div class="v" id="sAvg">—</div><div class="s" id="sAvgSub">—</div></div>
            <div class="stat"><div class="k">Pass rate</div><div class="v" id="sPass">—</div><div class="s" id="sPassSub">—</div></div>
          </div>

          <div class="tabs">
            <div class="tab active" data-tab="marks">Marksheet</div>
            <div class="tab" data-tab="items">Item analysis</div>
          </div>

          <div id="tabMarks" style="margin-top:12px">
            <div class="row between wrap" style="margin-bottom:10px">
              <div class="row wrap">
                <input class="input" id="qMarks" placeholder="Search name / identifiers / quiz fields / user_id…" style="width:320px" />
                <span class="chip mini" id="countChip">0</span>
              </div>
              <div class="row wrap">
                <button class="btn" id="btnLoadMore" style="display:none">Load more</button>
              </div>
            </div>

            <div class="table-wrap">
              <table>
                <thead><tr id="marksHead"></tr></thead>
                <tbody id="marksBody"></tbody>
              </table>
            </div>

            <div class="muted" id="marksHint" style="margin-top:10px">—</div>
          </div>

          <div id="tabItems" style="display:none;margin-top:12px">
            <div class="row between wrap" style="margin-bottom:10px">
              <div class="row wrap">
                <input class="input" id="qItems" placeholder="Search topic / stem preview…" style="width:280px" />
                <span class="chip mini" id="scanChip">Scanned: —</span>
              </div>
              <div class="row wrap">
                <button class="btn" id="btnRefreshItems">↻ Refresh items</button>
              </div>
            </div>

            <div class="table-wrap">
              <table style="min-width:980px">
                <thead>
                  <tr>
                    <th>#</th><th>Topic</th><th>% Correct</th><th>Correct</th>
                    <th>Attempts</th><th>Wrong</th><th>Blank</th><th>Common wrong</th>
                    <th>Flags</th><th>Preview</th><th></th>
                  </tr>
                </thead>
                <tbody id="itemsBody"></tbody>
              </table>
            </div>

            <div class="muted" id="itemsHint" style="margin-top:10px">—</div>
          </div>

        </div>
      </div>

    </div>
  </div>

</div>

<!-- Drawer -->
<div class="drawer-backdrop" id="drawerBackdrop">
  <div class="drawer">
    <div class="drawer-head">
      <div>
        <div style="font-weight:950" id="drawerTitle">Details</div>
        <div class="muted" id="drawerSub"></div>
      </div>
      <div class="row wrap">
        <button class="btn" id="btnPrint">🖨 Print</button>
        <button class="btn danger" id="btnClose">Close</button>
      </div>
    </div>
    <div class="drawer-body" id="drawerBody"></div>
  </div>
</div>

<!-- Print Root (Option A) -->
<div id="printRoot" aria-hidden="true"></div>

<script>
/** =============================
 * CONFIG
 * ============================= */
const API_URL = 'https://script.google.com/macros/s/AKfycbz54M_jWoRq4cOC2gUQeRhd55AeEJ5vnELJ0gkBSodO58fr7WGa9jwk6JNwPptf8p8X/exec'; // <-- replace once

/** =============================
 * State
 * ============================= */
const S = {
  token: '',
  teacher: null,
  plan: 'FREE',
  classes: [],
  quizzes: [],

  class_id: '',
  teacher_quiz_id: '',
  class_title: '',
  quiz_title: '',

  headline_rule: '',
  grade_bands_json: '',
  grade_bands_obj: null,

  pass_threshold_pct: 50,
  score_display_policy: 'PCT_ONLY',

  // schemas (ordered + labeled)
  class_fields: [],     // [{key,label,...}]
  quiz_fields: [],      // [{key,label,...}]

  cursor: '0',
  next_cursor: '',

  roster_rows: [],
  roster_rows_filtered: [],

  itemsLoaded: false,
  items: [],
  snapshotsById: {},

  attemptsCache: null,
  print_payload: null
};

const el = (id)=>document.getElementById(id);
const esc = (s)=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');

/** =============================
 * Print Root (Option A)
 * ============================= */
function setPrintPayload(title, sub, html){
  S.print_payload = {
    title: String(title||'').trim(),
    sub: String(sub||'').trim(),
    html: String(html||'')
  };
}

function buildPrintDoc(payload){
  const now = new Date().toLocaleString();
  return `
    <div class="print-page">
      <div class="print-h1">${esc(payload.title||'')}</div>
      ${payload.sub ? `<div class="print-sub">${esc(payload.sub)}</div>` : ``}
      <div class="print-meta">Printed: ${esc(now)}</div>
      <div class="print-hr"></div>
      ${payload.html || ''}
    </div>
  `;
}

function printFromPayload(){
  if (!S.print_payload || !String(S.print_payload.html||'').trim()){
    alert('Nothing to print yet. Open a summary, attempt, or item first.');
    return;
  }
  el('printRoot').innerHTML = buildPrintDoc(S.print_payload);
  window.print();
}

window.addEventListener('afterprint', ()=>{
  const pr = el('printRoot');
  if (pr) pr.innerHTML = '';
});

function qsParam(name){
  const u = new URL(location.href);
  return (u.searchParams.get(name) || '').trim();
}
function getToken(){
  const tUrl = qsParam('token');
  if (tUrl) return tUrl;
  try{ return (localStorage.getItem('qa_token') || '').trim(); }catch(_){ return ''; }
}
function setToken(t){
  S.token = String(t||'').trim();
  try{
    if (S.token) localStorage.setItem('qa_token', S.token);
    else localStorage.removeItem('qa_token');
  }catch(_){}
}
function safeJsonParse(s, fallback){
  try{
    if (typeof s === 'object') return s;
    const t = String(s||'').trim();
    if (!t) return fallback;
    return JSON.parse(t);
  }catch(_){ return fallback; }
}
function fmtIso(iso){
  const s = String(iso||'').trim();
  if (!s) return '—';
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleString(undefined, {year:'numeric',month:'short',day:'2-digit',hour:'2-digit',minute:'2-digit'});
}
function pillStatus(st){
  const u = String(st||'').toUpperCase();
  if (u==='SUBMITTED' || u==='TIMED_OUT') return `<span class="pill ok">${esc(u)}</span>`;
  if (u==='IN_PROGRESS') return `<span class="pill warn">${esc(u)}</span>`;
  if (u==='NOT_STARTED') return `<span class="pill">${esc(u)}</span>`;
  return `<span class="pill">${esc(u||'—')}</span>`;
}

/** =============================
 * Score display policy
 * ============================= */
function scorePolicy(){
  const p = String(S.score_display_policy || 'PCT_ONLY').toUpperCase();
  return p || 'PCT_ONLY';
}
function policyShowRaw(p){ return p === 'RAW_ONLY' || p === 'RAW_AND_PCT'; }
function policyShowPct(p){ return p === 'PCT_ONLY' || p === 'RAW_AND_PCT'; }

function fmtRaw(score){
  if (!score) return '';
  const a = score.score_marks, b = score.total_marks;
  if (a == null || b == null) return '';
  return `${a}/${b}`;
}
function fmtPct(score){
  if (!score) return '';
  if (score.percent == null) return '';
  return `${Math.round(Number(score.percent))}%`;
}
function fmtScore(score, policy){
  const p = String(policy || scorePolicy()).toUpperCase();
  if (p === 'HIDE') return '—';

  const raw = fmtRaw(score);
  const pct = fmtPct(score);

  if (p === 'RAW_ONLY') return raw || '—';
  if (p === 'PCT_ONLY') return pct || '—';

  if (raw && pct) return `${raw} • ${pct}`;
  return raw || pct || '—';
}
function passFailFromPct(pct){
  const n = Number(pct);
  if (!isFinite(n)) return '';
  const thr = isFinite(Number(S.pass_threshold_pct)) ? Number(S.pass_threshold_pct) : 50;
  return (n >= thr) ? 'PASS' : 'FAIL';
}

function gradeLabelFromBands(bandsObj, percent){
  const p0 = Number(percent);
  const p = isFinite(p0) ? Math.max(0, Math.min(100, p0)) : 0;
  const bands = (bandsObj && Array.isArray(bandsObj.bands)) ? bandsObj.bands : [];
  if (!bands.length) return '';
  let label = String(bands[0].label||'').trim();
  for (let i=0;i<bands.length;i++){
    const b = bands[i]||{};
    const min = Number(b.min_pct);
    const lab = String(b.label||'').trim();
    if (!lab || !isFinite(min)) continue;
    if (p >= min) label = lab;
    else break;
  }
  return label;
}

function labelOrKey(f){
  const k = String(f?.key||'').trim();
  const l = String(f?.label||'').trim();
  return l || k || '';
}
function keyOf(f){
  return String(f?.key||'').trim();
}
function buildDisplayLabel(prefix, f, used){
  const base = labelOrKey(f);
  const k = keyOf(f);
  let name = base ? `${prefix}${base}` : `${prefix}${k||'field'}`;
  if (used[name.toLowerCase()]) {
    name = `${prefix}${base} (${k||'key'})`;
  }
  used[name.toLowerCase()] = true;
  return name;
}
function fieldsSummary(fieldsObj, schema){
  const o = fieldsObj || {};
  const fs = (schema||[]).slice(0,4).map(f=>{
    const k = keyOf(f);
    const lab = labelOrKey(f);
    const v = (k && (k in o)) ? String(o[k]||'').trim() : '';
    if (!v) return '';
    return `${lab}: ${v}`;
  }).filter(Boolean);
  return fs.join(' • ');
}

/** =============================
 * API
 * ============================= */
async function apiPost(params){
  if (!API_URL || API_URL.indexOf('YOUR_') !== -1) throw new Error('API_URL_not_configured');

  const p = new URLSearchParams();
  Object.keys(params||{}).forEach(k=>{
    const v = params[k];
    if (v === undefined || v === null) return;
    if (typeof v === 'object') p.append(k, JSON.stringify(v));
    else p.append(k, String(v));
  });

  const res = await fetch(API_URL, {
    method:'POST',
    body:p,
    headers:{
      'Content-Type':'application/x-www-form-urlencoded;charset=UTF-8',
      'Accept':'application/json'
    },
    credentials:'omit'
  });

  const text = await res.text();
  let obj=null;
  try{ obj = JSON.parse(text); }catch(_){ obj=null; }

  if (!obj || obj.ok !== true){
    const xStatus = res.headers.get('X-Status-Code');
    const status = xStatus ? parseInt(xStatus,10) : res.status;
    const err = (obj && (obj.error || obj.detail || obj.reason)) || ('http_' + status);
    const e = new Error(err);
    e.status = status;
    e.payload = obj;
    throw e;
  }
  return obj;
}

