async function loadReport({append=false}={}){
  const class_id = String(el('selClass').value||'').trim();
  const teacher_quiz_id = String(el('selQuiz').value||'').trim();
  if (!class_id || !teacher_quiz_id){
    el('subline').textContent = 'Select class and quiz.';
    return;
  }

  S.class_id = class_id;
  S.teacher_quiz_id = teacher_quiz_id;
  setScopeUI();

  const include_removed = (String(el('selRoster').value)==='1') ? '1' : '0';
  const sort = String(el('selSort').value||'name_asc');

  // NEW: filters
  const status = String(el('selStatus').value || 'ANY').trim().toUpperCase();

  const df = String(el('dateFrom').value || '').trim(); // YYYY-MM-DD
  const dt = String(el('dateTo').value || '').trim();

  const date_from = df ? `${df}T00:00:00.000Z` : '';
  const date_to   = dt ? `${dt}T23:59:59.999Z` : '';

  let cursor = append ? (S.next_cursor || '') : '0';
  if (!cursor) cursor = '0';

  el('btnLoad').disabled = true;
  el('btnLoad').textContent = append ? 'Loading more…' : 'Loading…';
  el('subline').textContent = 'Loading report…';

  try{
    const [sum, list] = await Promise.all([
      apiPost({ action:'teacher.results.summary', token:S.token, teacher_quiz_id, class_id, include_removed, date_from, date_to }),
      apiPost({ action:'teacher.results.list', token:S.token, teacher_quiz_id, class_id, include_removed, sort, cursor, limit:'200', status, date_from, date_to })
    ]);

    // headline + grade bands + policy
    S.headline_rule = String(list.headline_rule || '');
    S.grade_bands_json = String((list.quiz && list.quiz.grade_bands_json) || '');
    S.grade_bands_obj = safeJsonParse(S.grade_bands_json, null);

    S.score_display_policy = String((list.quiz && list.quiz.score_display_policy) || 'PCT_ONLY').toUpperCase();
    // backend patch will provide list.quiz.pass_threshold_pct; until then fallback to summary
    const pt = (list.quiz && (list.quiz.pass_threshold_pct != null)) ? Number(list.quiz.pass_threshold_pct) : Number(sum.pass_threshold_pct);
    S.pass_threshold_pct = isFinite(pt) ? pt : 50;

    // schemas (labels + order)
    S.class_fields = Array.isArray(list.class_fields) ? list.class_fields : [];
    S.quiz_fields  = Array.isArray(list.quiz_fields) ? list.quiz_fields : [];

    el('headlineChip').textContent = `Headline: ${S.headline_rule || '—'}`;

    // Summary cards
    el('sRoster').textContent = String(sum.roster_total ?? '0');
    el('sRosterSub').textContent = `${sum.not_started_count ?? 0} not started`;
    el('sSubmitted').textContent = String(sum.submitted_count ?? '0');
    el('sSubmittedSub').textContent = `${sum.in_progress_count ?? 0} in progress`;

    const pol = scorePolicy();
    const showPct = policyShowPct(pol);

    el('sAvg').textContent = showPct ? `${sum.avg_pct ?? 0}%` : '—';
    el('sAvgSub').textContent = showPct ? `Median ${sum.median_pct ?? 0}%` : `Hidden by policy (${pol})`;

    el('sPass').textContent = showPct ? `${sum.pass_rate_pct ?? 0}%` : '—';
    el('sPassSub').textContent = showPct ? `Pass ≥ ${S.pass_threshold_pct}%` : `Pass threshold hidden`;

    // marks rows
    const rows = Array.isArray(list.rows) ? list.rows : [];
    if (!append) S.roster_rows = rows.slice();
    else S.roster_rows = (S.roster_rows||[]).concat(rows);

    S.next_cursor = String(list.next_cursor || '');
    el('btnLoadMore').style.display = S.next_cursor ? '' : 'none';

    applyMarksFilter();

    // reset items cache when changing report
    if (!append){
      S.itemsLoaded = false;
      S.items = [];
      S.snapshotsById = {};
      el('scanChip').textContent = 'Scanned: —';
      el('itemsBody').innerHTML = `<tr><td colspan="11" class="muted">Open the Item analysis tab to load.</td></tr>`;
      el('itemsHint').textContent = '—';
    }

    el('subline').textContent = 'Ready';
  }catch(err){
    el('subline').textContent = 'Load failed.';
    console.error(err);
    alert(`Load failed: ${err.message || err}`);
  }finally{
    el('btnLoad').disabled = false;
    el('btnLoad').textContent = 'Load report';
  }
}

async function loadItems({force=false}={}){
  if (!S.class_id || !S.teacher_quiz_id) return;
  if (S.itemsLoaded && !force) return;

  el('subline').textContent = 'Loading item analysis…';
  el('itemsBody').innerHTML = `<tr><td colspan="11" class="muted">Loading…</td></tr>`;

  try{
    const [items, snaps] = await Promise.all([
      apiPost({ action:'teacher.results.items', token:S.token, teacher_quiz_id:S.teacher_quiz_id, class_id:S.class_id, attempt_limit:'4000' }),
      apiPost({ action:'teacher.quiz.items.list', token:S.token, teacher_quiz_id:S.teacher_quiz_id })
    ]);

    S.items = Array.isArray(items.items) ? items.items : [];
    el('scanChip').textContent = `Scanned: ${items.scanned_attempts ?? 0}${items.truncated ? ' (truncated)' : ''}`;

    S.snapshotsById = {};
    (snaps.items||[]).forEach(s=>{
      const id = String(s.quiz_item_id||'').trim();
      if (id) S.snapshotsById[id] = s;
    });

    S.itemsLoaded = true;
    renderItems();
    el('subline').textContent = 'Ready';
  }catch(err){
    console.error(err);
    el('itemsBody').innerHTML = `<tr><td colspan="11" class="muted">Failed: ${esc(err.message||String(err))}</td></tr>`;
    el('subline').textContent = 'Load failed.';
  }
}

