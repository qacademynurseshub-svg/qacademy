    function renderFields() {
      const host = $('#uiFields');
      host.innerHTML = '';
      const fields = state.quiz?.custom_fields?.fields || [];
      if (!fields.length) return;
      fields.forEach(f => {
        const key = f.key?.trim() || '';
        if (!key) return;
        const div = document.createElement('div');
        div.style.marginBottom = '20px';
        div.innerHTML = `
          <label style="display:block; margin-bottom:6px; font-weight:800;">
            ${escapeHtml(f.label || key)}${f.required ? ' <span style="color:var(--danger)">*</span>' : ''}
          </label>
          <input id="field_${key}" placeholder="${escapeHtml(f.label || key)}" style="width:100%; padding:12px; border:1px solid var(--border); border-radius:10px;" />
        `;
        host.appendChild(div);
      });
    }

    function readFields() {
      const fields = state.quiz?.custom_fields?.fields || [];
      const out = {};
      let missing = [];
      fields.forEach(f => {
        const key = f.key?.trim();
        if (!key) return;
        const val = $(`#field_${key}`)?.value?.trim() || '';
        if (f.required && !val) missing.push(f.label || key);
        out[key] = val;
      });
      return { ok: missing.length === 0, missing, json: JSON.stringify({ fields: out }) };
    }

    function renderProgress() {
      const total = state.items.length;
      const answered = Object.keys(state.answers).length;
      $('#uiProg').textContent = `${answered}/${total} answered`;
      $('#uiBar').style.width = total ? (answered / total * 100) + '%' : '0%';
      syncViewUI();
    }

    function buildNavInto(containerEl, { closeOnPick = false } = {}) {
      if (!containerEl) return;
      containerEl.innerHTML = '';
      const visibleItems = getVisibleItems();
      clampActivePage();
      visibleItems.forEach((it, idx) => {
        const btn = document.createElement('button');
        btn.className = 'qbtn';
        btn.textContent = state.items.indexOf(it) + 1;
        if (state.answers[it.quiz_item_id]) btn.classList.add('answered');
        if (state.flags[it.quiz_item_id]) btn.classList.add('flagged');
        if (state.activePage === idx) btn.classList.add('active');
        btn.onclick = () => {
          state.activePage = idx;
          renderNav();
          renderQuestions();
          if (closeOnPick) closeGrid();
        };
        containerEl.appendChild(btn);
      });
    }

    function renderNav() {
      buildNavInto($('#uiNav'));
      buildNavInto($('#uiNavFloat'), { closeOnPick: true });
      syncViewUI();
