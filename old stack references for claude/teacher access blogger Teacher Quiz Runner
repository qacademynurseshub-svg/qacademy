    function setShowFlaggedOnly(on) {
      state.showFlaggedOnly = !!on;
      state.activePage = 0;
      syncViewUI();
      renderNav();
      renderQuestions();
    }

    /* ===== Submission UX helpers (NEW) ===== */
    function qaPlural(n, singular, plural) {
      return (n === 1) ? singular : (plural || (singular + 's'));
    }

    function getUnansweredStats() {
      let count = 0;
      let firstIdx = -1;
      for (let i = 0; i < (state.items || []).length; i++) {
        const qid = state.items[i]?.quiz_item_id;
        if (!qid) continue;
        if (!state.answers[qid]) {
          count++;
          if (firstIdx === -1) firstIdx = i;
        }
      }
      return { count, firstIdx };
    }

    function getFlaggedStats() {
      let count = 0;
      let firstIdx = -1;
      for (let i = 0; i < (state.items || []).length; i++) {
        const qid = state.items[i]?.quiz_item_id;
        if (!qid) continue;
        if (!!state.flags[qid]) {
          count++;
          if (firstIdx === -1) firstIdx = i;
        }
      }
      return { count, firstIdx };
    }

    function switchToAllAndJump(idx) {
      const target = Math.max(0, Math.min(idx, (state.items.length || 1) - 1));
      state.showFlaggedOnly = false;
      state.activePage = target;
      syncViewUI();
      renderNav();
      renderQuestions();
    }

    function switchToFlaggedAndJumpFirst() {
      state.showFlaggedOnly = true;
      state.activePage = 0;
      syncViewUI();
      renderNav();
      renderQuestions();
    }

    function showSubmitReviewPrompt({ unanswered, flagged }) {
      return new Promise(resolve => {
        const OVER_ID = 'qaSubmitReviewOverlay';
        const closeExisting = () => {
          const old = document.getElementById(OVER_ID);
          if (old) old.remove();
        };
        closeExisting();

        const msg =
          `You have ${unanswered} unanswered ${qaPlural(unanswered,'question','questions')} ` +
          `and ${flagged} flagged ${qaPlural(flagged,'question','questions')}.`;

        const ov = document.createElement('div');
        ov.id = OVER_ID;
        ov.className = 'overlay';
        ov.style.display = 'flex';
        ov.style.alignItems = 'center';   /* center modal (not bottom sheet) */
        ov.style.justifyContent = 'center';
        ov.innerHTML = `
          <div class="panel" style="max-width:560px;">
            <div class="panelHead">
              <div>
                <div class="panelTitle">Review before submitting</div>
                <div class="panelSub">${escapeHtml(msg)} What would you like to do?</div>
              </div>
              <button class="btn btn-outline" id="${OVER_ID}__close" type="button">Close</button>
            </div>

            <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end;">
              ${unanswered > 0 ? `<button class="btn btn-outline" id="${OVER_ID}__unanswered" type="button">Go to first unanswered</button>` : ``}
              ${flagged > 0 ? `<button class="btn btn-flag" id="${OVER_ID}__flagged" type="button">Review flagged</button>` : ``}
              <button class="btn btn-primary" id="${OVER_ID}__submit" type="button">Submit anyway</button>
            </div>

            <div style="margin-top:10px; color:var(--text-light); font-size:.9rem; font-weight:650;">
              Tip: Use the grid to jump quickly if you’re scanning.
            </div>
          </div>
        `;
        document.body.appendChild(ov);

        const cleanup = (val) => {
          document.removeEventListener('keydown', onKey);
          closeExisting();
          resolve(val);
        };

        const onKey = (e) => { if (e.key === 'Escape') cleanup('cancel'); };
        document.addEventListener('keydown', onKey);

        // close on backdrop click
        ov.addEventListener('click', (e) => { if (e.target === ov) cleanup('cancel'); });

        const closeBtn = document.getElementById(`${OVER_ID}__close`);
        const uBtn = document.getElementById(`${OVER_ID}__unanswered`);
        const fBtn = document.getElementById(`${OVER_ID}__flagged`);
        const sBtn = document.getElementById(`${OVER_ID}__submit`);

        if (closeBtn) closeBtn.onclick = () => cleanup('cancel');
        if (uBtn) uBtn.onclick = () => cleanup('unanswered');
        if (fBtn) fBtn.onclick = () => cleanup('flagged');
        if (sBtn) sBtn.onclick = () => cleanup('submit');
      });
    }
    /* ===== end helpers ===== */

    function updatePagerButtons() {
      const prev = $('#btnPrev');
      const next = $('#btnNext');
      const submit = $('#btnSubmit');
      if (!prev || !next || !submit) return;

      const visibleCount = getVisibleItems().length;

      if (state.showFlaggedOnly && visibleCount === 0) {
        prev.disabled = true;
        next.disabled = true;
        submit.style.display = 'none';
        submit.classList.remove('pulse');
        return;
      }

      prev.disabled = (state.activePage <= 0);
      next.disabled = (state.activePage >= visibleCount - 1);

      /* ✅ Submit is ONLY in All view, on the TRUE last question of the full list */
      const inAllView = !state.showFlaggedOnly;
      const totalCount = state.items.length || 0;
      const onTrueLastAll = inAllView && totalCount > 0 && state.activePage >= (totalCount - 1);

      submit.style.display = onTrueLastAll ? 'inline-block' : 'none';
      submit.disabled = state.submitting;

      /* Pulse only when visible, last question, and not submitting */
      submit.classList.toggle('pulse', onTrueLastAll && !state.submitting);
    }

