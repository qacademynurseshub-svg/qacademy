    /* Question swap with subtle fade/slide */
    function swapQuestionsContainer(doBuild) {
      const container = $('#questionsContainer');
      if (!container) return doBuild();

      const hasRenderedBefore = container.dataset.ready === '1';
      if (!hasRenderedBefore) {
        doBuild();
        container.dataset.ready = '1';
        return;
      }

      container.classList.add('swap-out');
      setTimeout(() => {
        doBuild();
        requestAnimationFrame(() => {
          container.classList.remove('swap-out');
        });
      }, 140);
    }

    function renderQuestions() {
      const container = $('#questionsContainer');

      const visibleItems = getVisibleItems();
      clampActivePage();

      // empty flagged view
      if (state.showFlaggedOnly && visibleItems.length === 0) {
        swapQuestionsContainer(() => {
          container.innerHTML = `
            <div class="notice">
              <strong>No flagged questions yet.</strong><br>
              Flag a question, then come back to “Flagged”.
              <div style="margin-top:12px;">
                <button class="btn btn-primary" id="btnBackToAll" type="button">Show all questions</button>
              </div>
            </div>
          `;
        });

        $('#uiQPos').textContent = `Flagged questions`;
        $('#uiQMarks').textContent = '';
        updatePagerButtons();

        setTimeout(() => {
          const back = $('#btnBackToAll');
          if (back) back.onclick = () => setShowFlaggedOnly(false);
        }, 0);

        const flagBtn = $('#btnFlag');
        if (flagBtn) { flagBtn.textContent = 'Flag'; flagBtn.classList.remove('active'); }
        return;
      }

      const currentItem = visibleItems[state.activePage];
      if (!currentItem) return;

      const qid = currentItem.quiz_item_id;
      const visibleTotal = visibleItems.length;

      swapQuestionsContainer(() => {
        container.innerHTML = '';

        const div = document.createElement('div');
        div.className = 'question';
        div.innerHTML = `
          <div class="stem">${escapeHtml(currentItem.stem || '')}</div>
          <div class="options"></div>
        `;
        const optsDiv = div.querySelector('.options');

        (currentItem.options || []).forEach(opt => {
          const checked = state.answers[qid] === opt.key;
          const label = document.createElement('label');
          label.className = 'opt' + (checked ? ' is-selected' : '');
          label.innerHTML = `
            <input type="radio" name="q_${qid}" value="${opt.key}" ${checked ? 'checked' : ''} />
            <span class="opt-tag">${opt.key}.</span>
            <span class="opt-label">${escapeHtml(opt.text)}</span>
          `;

          const input = label.querySelector('input');
          input.onchange = () => {
            state.answers[qid] = opt.key;

            // Update strong selected UI instantly without re-render
            const all = optsDiv.querySelectorAll('.opt');
            all.forEach(el => el.classList.remove('is-selected'));
            label.classList.add('is-selected');

            scheduleSave();
            renderProgress();
            renderNav();
          };

          optsDiv.appendChild(label);
        });

        container.appendChild(div);
      });

      $('#uiQPos').textContent = `Question ${state.activePage + 1} of ${visibleTotal}${state.showFlaggedOnly ? ' (flagged)' : ''}`;
      $('#uiQMarks').textContent = `${currentItem.marks || 1} mark${(currentItem.marks || 1) !== 1 ? 's' : ''}`;

      updatePagerButtons();

      const flagBtn = $('#btnFlag');
      if (state.flags[qid]) {
        flagBtn.textContent = 'Unflag';
        flagBtn.classList.add('active');
      } else {
        flagBtn.textContent = 'Flag';
        flagBtn.classList.remove('active');
      }
    }

    function scheduleSave() {
      if (state.saveTimer) clearTimeout(state.saveTimer);
      state.saveTimer = setTimeout(doSave, 800);
    }

async function doSave() {
  if (!state.attempt || String(state.attempt.status || '').toUpperCase() !== 'IN_PROGRESS') return;

  const res = await apiCall('candidate.attempt.save', {
    attempt_id: state.attempt.attempt_id,
    answers_json: JSON.stringify(state.answers),
    flags_json: JSON.stringify(state.flags)
  });

  if (!res.ok) {
    toast('Save failed: ' + (res.error || 'unknown'), 'warn');
    return;
  }

  // If backend ended the attempt (CLOSED / TIMED_OUT / SUBMITTED), reflect it immediately
  const a = res.attempt || null;
  const st = String((res.status || (a && a.status) || '')).toUpperCase();
  const ended = !!res.ended || (st && st !== 'IN_PROGRESS');

  if (a) state.attempt = a;

  if (ended) {
    stopTimer();
    renderCompletedScreen(
      res.message || (res.results && res.results.message) || 'This attempt has ended.',
      (state.attempt && state.attempt.attempt_id) || ''
    );
  }
}

    async function submitAttempt({ auto = false } = {}) {
      if (state.submitting) return;
      if (!state.attempt || String(state.attempt.status || '').toUpperCase() !== 'IN_PROGRESS') return;

      const { count: unansweredCount, firstIdx: firstUnansweredIdx } = getUnansweredStats();
      const { count: flaggedCount } = getFlaggedStats();

      /* ✅ One combined review decision prompt (manual submit only). No stacked prompts. */
      if (!auto && (unansweredCount > 0 || flaggedCount > 0)) {
        const choice = await showSubmitReviewPrompt({ unanswered: unansweredCount, flagged: flaggedCount });

        if (choice === 'unanswered') {
          if (firstUnansweredIdx >= 0) switchToAllAndJump(firstUnansweredIdx);
          return;
        }

        if (choice === 'flagged') {
          if (flaggedCount > 0) switchToFlaggedAndJumpFirst();
          return;
        }

        if (choice !== 'submit') {
          return; // cancel/close/backdrop
        }
        // else: "Submit anyway" -> proceed to final confirm below
      }

      /* ✅ Keep final confirmation for manual submit */
      if (!auto) {
        if (!confirm('Final submit? You cannot change answers after this.')) return;
      }

      state.submitting = true;
      updatePagerButtons();

      const res = await busy.run(
        () => apiCall('candidate.attempt.submit', { attempt_id: state.attempt.attempt_id }),
        'Submitting attempt...',
        { delay: 200 }
      );

      if (res.ok) {
        state.attempt = res.attempt || state.attempt;
        stopTimer();
        renderCompletedScreen(
          res.message || (res.results && res.results.message) || 'Your attempt is complete.',
          (state.attempt && state.attempt.attempt_id) || (res.attempt && res.attempt.attempt_id) || ''
        );
        return;
      }

      state.submitting = false;
      updatePagerButtons();
      toast('Submit failed: ' + (res.error || 'unknown'), 'warn');
    }

    function setTimerChipState(leftMs) {
      const chip = $('#timerChip');
      if (!chip) return;
      chip.classList.remove('timer--warn', 'timer--danger');

      if (leftMs <= 0) return;
      if (leftMs <= 2 * 60 * 1000) chip.classList.add('timer--danger');
      else if (leftMs <= 5 * 60 * 1000) chip.classList.add('timer--warn');
    }

    function startTimer() {
      stopTimer();
      state.tickTimer = setInterval(() => {
        if (!state.dueMs) { $('#uiTimer').textContent = '--:--'; setTimerChipState(999999999); return; }
        const left = state.dueMs - Date.now();
        $('#uiTimer').textContent = fmtTime(left);
        setTimerChipState(left);

        if (left <= 0) {
          stopTimer();
          toast('Time up - submitting automatically', 'warn');
          submitAttempt({ auto: true });
        }
      }, 1000);
    }

    function stopTimer() { if (state.tickTimer) clearInterval(state.tickTimer); state.tickTimer = null; }

    function openGrid() { const ov = $('#gridOverlay'); if (!ov) return; syncViewUI(); renderNav(); ov.style.display = 'flex'; }
    function closeGrid() { const ov = $('#gridOverlay'); if (!ov) return; ov.style.display = 'none'; }

    function showStartView(label) {
      setCompleteLayout(false);
      $('#uiStartBlock').style.display = 'block';
      $('#uiQuizBlock').style.display = 'none';
      $('#uiEndBlock').style.display = 'none';
      stopTimer();
      $('#btnStart').textContent = label || 'Start Attempt';
    }

    function applyAttemptResponse(res) {
      if (!res?.ok) {
        toast('Failed to load attempt: ' + (res?.error || 'unknown'), 'warn');
        return;
      }

      if (!res.attempt) {
        state.attempt = null;
        state.items = [];
        state.answers = {};
        state.flags = {};
        state.dueMs = null;
        showStartView(state.forceNew ? 'Start New Attempt' : 'Start Attempt');
        return;
      }

      state.attempt = res.attempt;
      state.items = res.items || [];
      state.answers = res.answers || {};
      state.flags = res.flags || {};
      state.dueMs = res.due_ms;

      const st = String(state.attempt.status || '').toUpperCase();

      if (st === 'IN_PROGRESS') {
        state.activePage = 0;
        state.showFlaggedOnly = false;
        setCompleteLayout(false);

        $('#uiEndBlock').style.display = 'none';
        $('#uiStartBlock').style.display = 'none';
        $('#uiQuizBlock').style.display = 'block';

        renderProgress();
        renderNav();
        renderQuestions();
        startTimer();
      } else {
        stopTimer();
        renderCompletedScreen(
          (res.results && res.results.message) || 'This attempt is already completed.',
          (state.attempt && state.attempt.attempt_id) || (res.attempt && res.attempt.attempt_id) || ''
        );
      }
    }

    async function startAttempt() {
      const fields = readFields();
      if (!fields.ok) return toast('Please complete required fields', 'warn');

      const payload = {
        class_id: state.class_id,
        teacher_quiz_id: state.teacher_quiz_id,
        candidate_fields_json: fields.json
      };
      if (state.forceNew) payload.force_new = '1';

      const res = await busy.run(
        () => apiCall('candidate.attempt.start', payload),
        'Starting attempt...',
        { delay: 200 }
      );

      if (!res.ok) return toast('Failed to start: ' + (res.error || 'unknown'), 'warn');

      // once started, clear forceNew intent locally
      state.forceNew = false;

      applyAttemptResponse(res);
      toast('Attempt started - good luck!', 'success');
    }

    (async function init() {
      state.class_id = getParam('class_id');
      state.teacher_quiz_id = getParam('teacher_quiz_id');
      state.token = readToken();

      state.urlAttemptId = getParam('attempt_id');
      state.forceNew = (getParam('force_new') === '1');

      if (!state.token) return toast('Please sign in first', 'warn');
      if (!state.class_id || !state.teacher_quiz_id) return toast('Invalid quiz link', 'warn');

      const qres = await busy.run(
        () => apiCall('candidate.quiz.get', { class_id: state.class_id, teacher_quiz_id: state.teacher_quiz_id }),
        'Loading quiz..',
        { delay: 220 }
      );
      if (!qres.ok) return toast('Failed to load quiz: ' + (qres.error || 'unknown'), 'warn');

      state.quiz = qres.quiz;
      renderMeta();
      renderFields();

      // Wire start button
      const startBtn = $('#btnStart');
      if (startBtn) startBtn.onclick = startAttempt;

      // If deep-linking to a specific attempt
      if (state.urlAttemptId) {
        const ares = await busy.run(
          () => apiCall('candidate.attempt.get', {
            class_id: state.class_id,
            teacher_quiz_id: state.teacher_quiz_id,
            attempt_id: state.urlAttemptId
          }),
          'Loading attempt...',
          { delay: 220 }
        );
        if (ares?.ok) applyAttemptResponse(ares);
      } else {
        // force_new intent: check if an in-progress exists; if yes, resume it; otherwise show start view
        if (state.forceNew) {
          const cur = await busy.run(
            () => apiCall('candidate.attempt.get', { class_id: state.class_id, teacher_quiz_id: state.teacher_quiz_id }),
            'Checking active attempt..',
            { delay: 260 }
          );
          if (cur?.ok && cur.attempt && String(cur.attempt.status || '').toUpperCase() === 'IN_PROGRESS') {
            state.forceNew = false;
            applyAttemptResponse(cur);
            toast('You already have an active attempt - resuming it.', 'warn');
          } else {
            showStartView('Start New Attempt');
          }
        } else {
          const ares = await busy.run(
            () => apiCall('candidate.attempt.get', { class_id: state.class_id, teacher_quiz_id: state.teacher_quiz_id }),
            'Loading attempt...',
            { delay: 240 }
          );
          if (ares?.ok) applyAttemptResponse(ares);
        }
      }

      const quitBtn = $('#btnQuit');
      if (quitBtn) {
        quitBtn.onclick = () => {
          if (confirm('Quit? Progress is saved but attempt remains open.')) window.location.href = DASHBOARD_URL;
        };
      }

      const btnAll = $('#btnViewAll');
      const btnFlagged = $('#btnViewFlagged');
      if (btnAll) btnAll.onclick = () => setShowFlaggedOnly(false);
      if (btnFlagged) btnFlagged.onclick = () => setShowFlaggedOnly(true);

      const tSide = $('#toggleFlaggedSidebar');
      if (tSide) tSide.onchange = (e) => setShowFlaggedOnly(!!e.target.checked);

      const tGrid = $('#toggleFlaggedGrid');
      if (tGrid) tGrid.onchange = (e) => setShowFlaggedOnly(!!e.target.checked);

      $('#btnPrev').onclick = () => {
        if ($('#btnPrev').disabled) return;
        state.activePage = Math.max(0, state.activePage - 1);
        renderNav();
        renderQuestions();
      };

      $('#btnNext').onclick = () => {
        if ($('#btnNext').disabled) return;
        const visibleCount = getVisibleItems().length;
        state.activePage = Math.min(Math.max(0, visibleCount - 1), state.activePage + 1);
        renderNav();
        renderQuestions();
      };

      $('#btnSubmit').onclick = () => submitAttempt({ auto: false });

      $('#btnFlag').onclick = () => {
        const visibleItems = getVisibleItems();
        const current = visibleItems[state.activePage];
        if (!current) return;
        const qid = current.quiz_item_id;
        state.flags[qid] = !state.flags[qid];
        scheduleSave();
        clampActivePage();
        renderProgress();
        renderNav();
        renderQuestions();
      };

      const gridBtn = $('#btnGrid');
      const gridClose = $('#btnGridClose');
      const overlay = $('#gridOverlay');
      if (gridBtn) gridBtn.onclick = openGrid;
      if (gridClose) gridClose.onclick = closeGrid;
      if (overlay) overlay.addEventListener('click', (e) => { if (e.target === overlay) closeGrid(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeGrid(); });

      syncViewUI();
      updatePagerButtons();
    })();
  </script>
</body>
</html>
