      const flgBtn = $('#btnViewFlagged');
      if (allBtn && flgBtn) {
        allBtn.classList.toggle('active', !state.showFlaggedOnly);
        flgBtn.classList.toggle('active', state.showFlaggedOnly);
      }

      const total = state.items.length || 0;
