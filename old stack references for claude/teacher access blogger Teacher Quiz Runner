          </p>

          <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
            <a href="${DASHBOARD_URL}" class="btn btn-outline" style="text-decoration:none;">Back to My Classes</a>
            <button class="btn btn-primary" id="btnGoResultsNow" type="button">View Results</button>
            ${allowReview ? `<button class="btn btn-outline" id="btnGoReviewNow" type="button">Review Questions</button>` : ``}
          </div>

          ${allowReview ? `` : `<div style="margin-top:14px; color:var(--text-light); font-size:.95rem; font-weight:700;">Review is not available for this quiz.</div>`}
        </div>
      `;

      const b1 = $('#btnGoResultsNow');
      if (b1) b1.onclick = () => goToResults(attemptId);

