        html +=
          '<li onclick="location.href=\'' + qaHref('learning_history') + '\';" ' +
              'style="padding:10px 0;border-bottom:1px solid rgba(148,163,184,.35);cursor:pointer;">' +
            '<div style="font-size:14.5px;font-weight:600;color:#0f172a;margin-bottom:2px;">' +
              label +
            '</div>' +
            '<div style="font-size:12.5px;color:#64748b;display:flex;flex-wrap:wrap;gap:6px;align-items:center;">' +
              (courseId ? ('<span>' + courseId + '</span>') : '') +
              (modeNice ? ('<span>• ' + modeNice + '</span>') : '') +
              (scoreStr ? ('<span>• ' + scoreStr + '</span>') : '') +
              (tsStr ? ('<span>• ' + tsStr + '</span>') : '') +
            '</div>' +
          '</li>';
      });

      html += '</ul>';
      elRecentBody.innerHTML = html;
    }

    function loadRecentAttempts(){
      if(!elRecentBody || !BUILDER_API_URL){
        if(elRecentSub){
          elRecentSub.textContent = "Quiz history is not available right now.";
        }
        return;
      }

      var token = null;
      try{
        token = localStorage.getItem("qa_token");
      }catch(e){
        token = null;
      }

      if(!token){
        if(elRecentSub){
          elRecentSub.textContent = "Unable to load history (missing session).";
        }
        return;
      }

      if(elRecentSub){
        elRecentSub.textContent = "Loading your recent attempts…";
      }

      var url = BUILDER_API_URL +
        "?action=attempts.list" +
        "&token=" + encodeURIComponent(token) +
        "&status=completed";

      fetch(url)
        .then(function(res){ return res.json(); })
        .then(function(data){
          if(data && data.ok === false){
            if(elRecentSub){
              elRecentSub.textContent = "Could not load your quiz history.";
            }
            elRecentBody.innerHTML =
              '<p style="margin:6px 0 0;font-size:13.5px;color:#b91c1c;">' +
                'There was a problem loading your quiz history. Please reload this page and try again.' +
              '</p>';
            return;
          }

          var attempts = Array.isArray(data && data.attempts) ? data.attempts.slice() : [];

          attempts.sort(function(a, b){
            var ta = a.ts_iso || "";
            var tb = b.ts_iso || "";
            if(ta > tb) return -1;
            if(ta < tb) return 1;
            return 0;
          });

          renderRecentAttempts(attempts.slice(0, 5));
        })
        .catch(function(err){
          console.error("Dashboard attempts.list error", err);
          if(elRecentSub){
            elRecentSub.textContent = "Could not load your quiz history.";
          }
          elRecentBody.innerHTML =
            '<p style="margin:6px 0 0;font-size:13.5px;color:#b91c1c;">' +
              'There was a network problem while loading your quiz history.' +
            '</p>';
        });
    }

    /* ===== Announcement HTML Sanitizer (Dashboard) ===== */
    function qaIsSafeHref(href){
      if(!href) return false;

      href = String(href).trim();

      // allow hash placeholder (used by fixed-quiz buttons)
      if(href === '#') return true;

      // allow same-site relative links
      if(href.startsWith('/') || href.startsWith('?') || href.startsWith('#')) {
        return true;
      }

      // block dangerous protocols explicitly
      var lower = href.replace(/\s+/g,'').toLowerCase();
      if(
        lower.startsWith('javascript:') ||
        lower.startsWith('data:') ||
        lower.startsWith('vbscript:')
      ){
        return false;
      }

      // allow http, https, mailto, tel
      try{
        var u = new URL(href, window.location.origin);
        return (
          u.protocol === 'http:' ||
          u.protocol === 'https:' ||
          u.protocol === 'mailto:' ||
          u.protocol === 'tel:'
        );
      }catch(e){
        return false;
      }
    }

    function qaIsSafeSrc(src){
      if(!src) return false;
      src = String(src).trim();

      // allow relative
      if(src[0] === '/' || src[0] === '?') return true;

      // block javascript:/data:/vbscript:
      var lower = src.replace(/\s+/g,'').toLowerCase();
      if(lower.startsWith('javascript:') || lower.startsWith('data:') || lower.startsWith('vbscript:')) return false;

      try{
        var u = new URL(src, window.location.origin);
        return (u.protocol === 'http:' || u.protocol === 'https:');
      }catch(e){
        return false;
      }
    }

    function qaDecodeHtmlEntities(html){
      var t = document.createElement('textarea');
      t.innerHTML = html;
      return t.value;
    }

    function qaSanitizeHtmlToFragment(html){
      var template = document.createElement('template');
      template.innerHTML = qaDecodeHtmlEntities(html);

      var allowedTags = {
        P:1, BR:1, STRONG:1, B:1, EM:1, I:1,
        UL:1, OL:1, LI:1,
        A:1, IMG:1,
        CODE:1, PRE:1, DIV:1
      };

      var walker = document.createTreeWalker(template.content, NodeFilter.SHOW_ELEMENT, null);

      var toRemove = [];
      while(walker.nextNode()){
        var el = walker.currentNode;
        if(!allowedTags[el.tagName]){
          toRemove.push(el);
          continue;
        }

        // Strip unsafe attributes
        [].slice.call(el.attributes).forEach(function(attr){
          var n = attr.name.toLowerCase();
          var v = attr.value;

          if(el.tagName === 'A'){
            if(n === 'href' && qaIsSafeHref(v)) return;

            // keep styling marker
            if(n === 'data-qa') return;

            // ✅ allow fixed-quiz launcher markers (so interceptor can detect them)
            if(n === 'data-qa-fixed-quiz') return;
            if(n === 'data-qa-mode') return;
          }

          if(el.tagName === 'IMG'){
            if(n === 'src' && qaIsSafeSrc(v)) return;
            if(n === 'alt') return;
          }

          if(n === 'class') return;
          el.removeAttribute(attr.name);
        });
      }

      toRemove.forEach(function(el){
        el.replaceWith(document.createTextNode(el.textContent || ''));
      });

      return template.content;
    }

    function qaRenderAnnouncementBody(container, a){
      container.innerHTML = '';

      var html = (a.body_html || '').trim();
      var text = (a.body_text || '').trim();
      var raw  = (a.body || '').trim();

      if(html){
        container.appendChild(qaSanitizeHtmlToFragment(html));
        return;
      }

      var fallback = text || raw;
      if(fallback){
        var p = document.createElement('p');
        p.textContent = fallback;
        container.appendChild(p);
      }
    }

    /* ========== Announcements (Dashboard – shared behaviour) ========== */
    function renderAnnouncementsEmpty() {
      if (!elAnnSub || !elAnnBody) return;

      elAnnSub.textContent = "You have seen all the latest announcements.";

      elAnnBody.innerHTML =
        '<p style="margin:6px 0 10px;font-size:13.5px;color:#5b6a68;">' +
          'For older updates, pinned messages, and your full announcement archive, open the announcements page.' +
        '</p>' +
        '<div style="display:flex;flex-wrap:wrap;gap:8px;">' +
          '<a href="' + qaHref('announcements') + '" ' +
            'style="display:inline-block;padding:8px 12px;border-radius:999px;' +
                   'border:1px solid #0b7a75;background:#0b7a75;color:#ffffff;' +
                   'font-weight:700;font-size:13px;text-decoration:none;">' +
            'View all announcements →' +
          '</a>' +
        '</div>';
    }

    function parseDate(val){
      if(!val && val !== 0) return null;
      var d = (val instanceof Date) ? val : new Date(val);
      if(isNaN(d.getTime())) return null;
      return d;
    }

    function fmtDateShort(d){
      if(!d) return '';
      var now = new Date();
      var opts = { day:'2-digit', month:'short' };
      if(d.getFullYear() !== now.getFullYear()) opts.year = 'numeric';
      return d.toLocaleDateString('en-GB', opts);
    }

    function priorityLevel(a){
      var n = Number(a && a.priority);
      return Number.isFinite(n) ? n : 1;
    }
    function isUrgent(a){ return priorityLevel(a) >= 3; }

    function stateOf(statesById, id){
      var s = statesById && statesById[id];
      return s && s.state ? String(s.state).toLowerCase() : '';
    }

    function buildPillsMini(a, statesById, lifecycle){
      var pills = [];

      if (a.pinned){
        pills.push('<span style="font-size:11px;font-weight:600;color:#0b7a75;background:#e0f2f1;border-radius:999px;padding:2px 8px;white-space:nowrap;">Pinned</span>');
      }
      if (isUrgent(a)){
        pills.push('<span style="font-size:11px;font-weight:600;color:#b91c1c;background:#fef2f2;border:1px solid #fecaca;border-radius:999px;padding:2px 8px;white-space:nowrap;">Urgent</span>');
      }

      var id = (a._id || a.announcement_id || a.id || a.ann_id || '').trim();
      var st = stateOf(statesById, id);
      if (!st) pills.push('<span style="font-size:11px;font-weight:600;color:#3730a3;background:#eef2ff;border:1px solid #c7d2fe;border-radius:999px;padding:2px 8px;white-space:nowrap;">New</span>');
      else if (st === 'seen') pills.push('<span style="font-size:11px;font-weight:600;color:#6b7280;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:999px;padding:2px 8px;white-space:nowrap;">Seen</span>');
      else if (st === 'dismissed') pills.push('<span style="font-size:11px;font-weight:600;color:#9a3412;background:#fff7ed;border:1px solid #fed7aa;border-radius:999px;padding:2px 8px;white-space:nowrap;">Dismissed</span>');

      if (lifecycle === 'UPCOMING'){
        pills.push('<span style="font-size:11px;font-weight:600;color:#a16207;background:#fef9c3;border:1px solid #fde68a;border-radius:999px;padding:2px 8px;white-space:nowrap;">Upcoming</span>');
      } else if (lifecycle === 'LIVE'){
        pills.push('<span style="font-size:11px;font-weight:600;color:#166534;background:#ecfdf3;border:1px solid #bbf7d0;border-radius:999px;padding:2px 8px;white-space:nowrap;">Live</span>');
      }

      return pills.join(' ');
    }

    function classifyLifecycle(a){
      var now = new Date();
      var start = parseDate(a.start_at || a.created_at);
      var end   = parseDate(a.end_at);
      var status = String(a.status || '').toLowerCase();

      if (status === 'draft') return 'HIDDEN';
      if (start && now < start) return 'UPCOMING';
      if (end && now > end) return 'ENDED';
      return 'LIVE';
    }

    function renderAnnouncementsDashboard(items, statesById){
      if (!elAnnSub || !elAnnBody) return;

      if (!items || !items.length){
        renderAnnouncementsEmpty();
        return;
      }

      var filtered = items.filter(function(a){
        var id = (a.announcement_id || a.id || '').trim();
        var st = stateOf(statesById, id);
        return st !== 'dismissed' && st !== 'seen';
      });

      if (!filtered.length){
        renderAnnouncementsEmpty();
        return;
      }

      filtered.sort(function(a,b){
        if(isUrgent(a) !== isUrgent(b)) return isUrgent(a) ? -1 : 1;
        if(!!a.pinned !== !!b.pinned) return a.pinned ? -1 : 1;
        return new Date(b.created_at || 0) - new Date(a.created_at || 0);
      });

      elAnnSub.textContent = "Latest updates from QAcademy.";
      elAnnBody.innerHTML = '';
      elAnnBody.classList.add('qa-ann-body');

      var ul = document.createElement('ul');
      ul.style.listStyle = 'none';
      ul.style.margin = '0';
      ul.style.padding = '0';

      filtered.slice(0,5).forEach(function(a){
        var li = document.createElement('li');
        li.style.padding = '10px 12px';
        li.style.borderRadius = '12px';
        li.style.margin = '8px 0';
        li.style.border = isUrgent(a)
          ? '1px solid rgba(185,28,28,.18)'
          : '1px solid rgba(148,163,184,.35)';
        li.style.background = isUrgent(a) ? '#fff7f7' : '#ffffff';

        var title = document.createElement('div');
        title.style.fontSize = '14px';
        title.style.fontWeight = '650';
        title.style.marginBottom = '4px';
        title.textContent = a.title || 'Announcement';

        var body = document.createElement('div');
        body.style.fontSize = '13px';
        body.style.color = '#4b5563';
        qaRenderAnnouncementBody(body, a);

        var footer = document.createElement('div');
        footer.style.display = 'flex';
        footer.style.flexWrap = 'wrap';
        footer.style.gap = '6px';
        footer.style.justifyContent = 'space-between';
        footer.style.marginTop = '6px';

        var pills = document.createElement('div');
        pills.innerHTML = buildPillsMini(a, statesById, classifyLifecycle(a));

        footer.appendChild(pills);

        var id = (a.announcement_id || '').trim();
        if(id && !stateOf(statesById, id)){
          var btn = document.createElement('button');
          btn.textContent = 'Mark as read';
          btn.setAttribute('data-ann-action','markread');
          btn.setAttribute('data-ann-id', id);
          btn.style.cssText =
            'border:1px solid #0b7a75;background:#0b7a75;color:#fff;' +
            'padding:6px 10px;border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;';
          footer.appendChild(btn);
        }

        li.appendChild(title);
        li.appendChild(body);
        li.appendChild(footer);
        ul.appendChild(li);
      });

      elAnnBody.appendChild(ul);
    }

    function markAnnouncementSeen(announcementId, btn){
      if(!announcementId) return;

      var token = null;
      try { token = localStorage.getItem("qa_token"); } catch(e){ token = null; }
      if(!token) return;

      if(btn){
        btn.disabled = true;
        btn.textContent = "Marking...";
        btn.style.opacity = "0.85";
      }

      var body = new URLSearchParams();
      body.set("action", "announcements.markseen");
      body.set("token", token);
      body.set("payload", JSON.stringify({ items: [announcementId] }));

      fetch(ANNOUNCEMENTS_URL, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: body
      })
      .then(function(res){ return res.json(); })
      .then(function(data){
        if(!data || data.ok !== true){
          throw new Error((data && data.error) || "markseen_failed");
        }

        __annStates = __annStates || {};
        __annStates[announcementId] = Object.assign({}, __annStates[announcementId] || {}, {
          state: "seen",
          seen_at: (new Date()).toISOString()
        });

        renderAnnouncementsDashboard(__annItems || [], __annStates);
      })
      .catch(function(err){
        console.error("announcements.markseen error", err);
        if(btn){
          btn.disabled = false;
          btn.textContent = "Mark as read";
          btn.style.opacity = "1";
        }
      });
    }

    if(elAnnBody){
      elAnnBody.addEventListener("click", function(ev){
        var t = ev.target;
        if(!t) return;

        var btn = (t.closest) ? t.closest('button[data-ann-action]') : null;
        if(!btn) return;

        var action = btn.getAttribute("data-ann-action");
        var id = btn.getAttribute("data-ann-id");

        if(action === "markread"){
          ev.preventDefault();
          ev.stopPropagation();
          markAnnouncementSeen((id || "").trim(), btn);
        }
      });
    }

    /* ==========================
       ✅ Fixed-Quiz Button Interceptor (Dashboard)
       ========================== */

    // CLONING: runner URLs come from QA_CONFIG.PAGES (or optional cfg.INSTANT_RUNNER_URL override)
    var INSTANT_RUNNER_URL = cfg.INSTANT_RUNNER_URL || qaHref('instant_runner');
    var TIMED_RUNNER_URL   = cfg.TIMED_RUNNER_URL   || qaHref('timed_runner');

    function qaGetToken(){
      try { return localStorage.getItem('qa_token') || ''; } catch(e){ return ''; }
    }

    function qaGoToAttemptId(attemptId, mode){
      var m = String(mode || '').toLowerCase();
      var base = (m === 'timed') ? TIMED_RUNNER_URL : INSTANT_RUNNER_URL;
      var sep = base.indexOf('?') === -1 ? '?' : '&';
      window.location.href = base + sep + 'quiz_id=' + encodeURIComponent(attemptId);
    }

    function qaOpenFixedQuizFromAnnouncementSmart_DASH(quizId, preferredMode){
      quizId = String(quizId || '').trim();
      if(!quizId) return;

      if(!BUILDER_API_URL){
        console.warn('Missing BUILDER_API_URL');
        return;
      }

      var token = qaGetToken();
      if(!token){
        if(elAnnSub) elAnnSub.textContent = "Session expired — please sign in again.";
        return;
      }

      if(elAnnSub) elAnnSub.textContent = "Opening quiz…";

      var urlList = BUILDER_API_URL +
        '?action=attempts.list' +
        '&token=' + encodeURIComponent(token);

      fetch(urlList)
        .then(function(r){ return r.json(); })
        .then(function(res){
          var attempts = Array.isArray(res && res.attempts) ? res.attempts : [];

          var mine = attempts.filter(function(a){
            return String(a.quiz_id || '').trim() === quizId;
          });

          mine.sort(function(a,b){
            var da = new Date(a.ts_iso || a.timestamp || 0).getTime();
            var db = new Date(b.ts_iso || b.timestamp || 0).getTime();
            return (db||0) - (da||0);
          });

          var inProg = mine.find(function(a){
            return String(a.status || '').toLowerCase() === 'in_progress';
          });

          if(inProg && inProg.attempt_id){
            qaGoToAttemptId(inProg.attempt_id, inProg.mode || preferredMode);
            return;
          }

          var payload = { quiz_id: quizId, source: 'fixed' };

          var body = new URLSearchParams();
          body.set('action','fixed.spawn');
          body.set('token', token);
          body.set('payload', JSON.stringify(payload));

          return fetch(BUILDER_API_URL, {
            method:'POST',
            headers:{ 'Content-Type':'application/x-www-form-urlencoded' },
            body: body
          })
          .then(function(r){ return r.json(); })
          .then(function(data){
            if(!data || data.ok === false) throw new Error((data && data.error) || 'spawn_failed');
            if(!data.attempt_id) throw new Error('missing_attempt_id');
            qaGoToAttemptId(data.attempt_id, (data.mode || preferredMode));
          });
        })
        .catch(function(err){
          console.error('Dashboard fixed-quiz open error', err);
          if(elAnnSub) elAnnSub.textContent = "Could not open quiz. Please try again.";
        });
    }

    if(elAnnBody){
      elAnnBody.addEventListener('click', function(ev){
        var a = ev.target && ev.target.closest ? ev.target.closest('a[data-qa-fixed-quiz]') : null;
        if(!a) return;

        ev.preventDefault();
        ev.stopPropagation();

        if(a.dataset.busy === '1') return;
        a.dataset.busy = '1';

        var quizId = a.getAttribute('data-qa-fixed-quiz');
        var mode   = a.getAttribute('data-qa-mode');

        qaOpenFixedQuizFromAnnouncementSmart_DASH(quizId, mode);

        setTimeout(function(){ try{ a.dataset.busy = ''; }catch(_e){} }, 4000);
      });
    }

    function loadAnnouncements() {
      if (!elAnnBody || !elAnnSub) return;

      if (!ANNOUNCEMENTS_URL) {
        renderAnnouncementsEmpty();
        return;
      }

      var token = null;
      try { token = localStorage.getItem("qa_token"); } catch (e) { token = null; }

      if (!token) {
        elAnnSub.textContent = "Announcements are not available right now.";
        elAnnBody.innerHTML =
          '<p style="margin:6px 0 0;font-size:13.5px;color:#b91c1c;">' +
            'We could not verify your session to load announcements. Please sign in again and reload this page.' +
          '</p>';
        return;
      }

      elAnnSub.textContent = "Checking for announcements...";
      elAnnBody.innerHTML =
        '<p style="margin:6px 0 0;font-size:13.5px;color:#5b6a68;">' +
          'Please wait while we load the latest updates.' +
        '</p>';

      var params = new URLSearchParams();
      params.set("action", "announcements.list");
      params.set("token", token);
      params.set("mode", "archive");
      params.set("limit", "5");

      fetch(ANNOUNCEMENTS_URL + "?" + params.toString())
        .then(function(res){ return res.json(); })
        .then(function(data){
          if (data && data.ok === false) {
            console.warn("Announcements backend error:", data.error || data);
            renderAnnouncementsEmpty();
            return;
          }

          var items  = Array.isArray(data && data.items) ? data.items : [];
          var states = (data && data.states && typeof data.states === 'object') ? data.states : {};

          __annItems = items;
          __annStates = states || {};
          renderAnnouncementsDashboard(__annItems, __annStates);
        })
        .catch(function(err){
          console.error("Dashboard announcements error", err);
          renderAnnouncementsEmpty();
        });
    }

    /* ========== Header: name, role, programme ========== */
    function setFullNameWithRole(){
      var safeName =
        (user.name || "").trim() ||
        [user.forename, user.surname].filter(Boolean).join(" ").trim() ||
        localStorage.getItem("qa_full_name") ||
        "Welcome back";

      elFullname.textContent = safeName;

      var role = (user.role || "").trim();
      if(role){
        var span = document.createElement("span");
        span.textContent = " (" + role + ")";
        span.style.fontWeight = "500";
        span.style.color = "#5b6a68";
        span.style.fontSize = "16px";
        elFullname.appendChild(span);
      }

      try{
        localStorage.setItem("qa_full_name", safeName);
      }catch(e){}
    }

    function setProgram(){
      var direct = (user.program_id || "").trim();
      var prog   = direct;

      if(!prog && Array.isArray(access.courseIds) && access.courseIds.length){
        var ids = access.courseIds.map(function(id){ return String(id||"").toUpperCase(); });

        if(ids.some(function(id){ return id.startsWith("RN_") || id === "RN"; }))         prog = "RN";
        else if(ids.some(function(id){ return id.startsWith("RM_") || id === "RM"; }))    prog = "RM";
        else if(ids.some(function(id){ return id.startsWith("RPHN_"); }))                prog = "RPHN";
        else if(ids.some(function(id){ return id.startsWith("RMHN_") || id === "MHN"; }))prog = "MHN";
        else if(ids.some(function(id){ return id.startsWith("NAC_") || id.startsWith("NAP_"); })) prog = "NAC/NAP";
        else if(ids.some(function(id){ return id === "GP"; }))                           prog = "GP";
      }

      if(!prog){
        try{
          prog = localStorage.getItem("qa_program") || "";
        }catch(e){}
      }
      if(prog){
        try{ localStorage.setItem("qa_program", prog); }catch(e){}
      }

      elProgram.textContent = "Programme: " + (prog || "—");
    }

    /* ========== Courses grid ========== */
    function normalize(id){ return (id || "").toUpperCase().replace(/\s+/g,""); }

    function sortCourses(list, mode){
      var arr = list.slice();
      if(mode === "az"){
        return arr.sort(function(a,b){
          var ta = (a.title || a.course_id || "");
          var tb = (b.title || b.course_id || "");
          return ta.localeCompare(tb);
        });
      }
      var gp = arr.filter(function(c){ return normalize(c.course_id) === "GP"; });
      var rest = arr.filter(function(c){ return normalize(c.course_id) !== "GP"; })
                    .sort(function(a,b){
                      var ta = (a.title || a.course_id || "");
                      var tb = (b.title || b.course_id || "");
                      return ta.localeCompare(tb);
                    });
      return gp.concat(rest);
    }

    function render(){
      var q    = (elSearch && elSearch.value || "").toLowerCase().trim();
      var mode = elSort ? elSort.value : "gp-first";

      var visible = rawCourses
        .filter(function(c){ return String(c.status || "").toLowerCase() === "active"; })
        .filter(function(c){
          if(!q) return true;
          var title = (c.title || "").toLowerCase();
          var cid   = (c.course_id || "").toLowerCase();
          return title.indexOf(q) !== -1 || cid.indexOf(q) !== -1;
        });

      var sorted = sortCourses(visible, mode);
      elGrid.innerHTML = "";

      if(!sorted.length){
        elTools.style.display = "none";
        elAlert.style.display = "block";

        // CLONING: welcome page URL comes from QA_CONFIG.PAGES.welcome
        var WELCOME_URL = qaHref('welcome');

        if(!hasCourseIds){
          if(
            signupSource === "self_onboard" ||
            signupSource === "self-onboard" ||
            signupSource === "self"
          ){
            elSub.textContent = "No active courses yet — please complete your registration.";
            elAlert.innerHTML =
              "Your QAcademy account is active, but no courses are linked to you yet." +
              "<br><br><strong>Next step:</strong> complete your registration so that your subscription can be created." +
              "<br><br>" +
              "<a href=\"" + WELCOME_URL + "\" " +
              "style=\"display:inline-block;margin-top:4px;padding:8px 12px;border-radius:10px;" +
              "background:#0b7a75;color:#ffffff;font-weight:600;font-size:13px;text-decoration:none;\">" +
              "Go to Welcome / Registration Page →</a>";
          } else {
            elSub.textContent = "No active courses available for your current account.";
            elAlert.textContent =
              "You are logged in, but we couldn't find any active courses linked to your account yet. " +
              "If your school, class representative, or the QAcademy team registered you, they may still be activating your subscription.";
          }
        } else {
          elSub.textContent = "Your courses are currently inactive or expired.";
          elAlert.textContent =
            "We found courses linked to your account, but none are currently active. " +
            "This usually means your subscription has not started yet or has expired. " +
            "Please contact QAcademy support if you think this is a mistake.";
        }

        return;
      }

      elTools.style.display = "flex";
      elAlert.style.display = "none";
      elSub.textContent = "You currently have " + sorted.length + " active course" + (sorted.length>1?"s":"") + ". Select a course to continue.";

      sorted.forEach(function(c){
        var slug = (c.page_slug || "").trim() || (c.course_id || "").toLowerCase();
        var courseUrl = "/p/" + slug + ".html";
        var courseId  = c.course_id || "";

        var card = document.createElement("div");
        card.style.cssText =
          "display:block;text-decoration:none;color:inherit;" +
          "border:1px solid rgba(0,0,0,.08);background:#fff;border-radius:14px;" +
          "padding:14px;box-shadow:0 6px 16px rgba(0,0,0,.04);" +
          "transition:transform .06s ease;cursor:default;";

        card.onmouseenter = function(){ card.style.transform = "translateY(-2px)"; };
        card.onmouseleave = function(){ card.style.transform = "translateY(0)"; };

        card.innerHTML =
          '<div style="font-weight:600;font-size:16px;margin-bottom:4px;">' +
            (c.title || courseId) +
          '</div>' +
          '<div style="color:#6b7b79;font-size:13px;margin-bottom:10px;">' +
            'Course ID: ' + courseId +
          '</div>' +
          '<a href="' + courseUrl + '" ' +
            'style="display:inline-block;padding:8px 10px;border-radius:10px;' +
                   'border:1px solid #0b7a75;background:#0b7a75;' +
                   'color:#ffffff;font-weight:600;font-size:13px;text-decoration:none;">' +
            'Open course page' +
          '</a>';

        elGrid.appendChild(card);
      });
    }



    /* ========== Init calls ========== */
    setFullNameWithRole();
    setExpiry();
    setProgram();
    render();

    loadRecentAttempts();
    loadAnnouncements();
    loadUnreadThreadsCount();

    if(elSearch) elSearch.addEventListener("input", render);
    if(elSort)   elSort.addEventListener("change", render);
  }

  if(window.qaGuardReady){
    window.qaGuardReady
      .then(function(state){
        if(state && state.ok && !state.blocked){
          initDashboard();
        }
      })
      .catch(function(err){
        console.error("Dashboard guard error", err);
      });
  }
})();
</script>
