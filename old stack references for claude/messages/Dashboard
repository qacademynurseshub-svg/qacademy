          '<div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:8px;">' +
            '<a href="' + qaHref('quiz_builder') + '" ' +
              'style="display:inline-block;padding:8px 12px;border-radius:10px;' +
                     'background:#0b7a75;color:#ffffff;font-weight:600;font-size:13px;text-decoration:none;">' +
              'Create Custom Quiz' +
            '</a>' +
            '<a href="#qa-grid" ' +
              'style="display:inline-block;padding:8px 12px;border-radius:10px;border:1px solid #0b7a75;' +
                     'color:#0b7a75;font-weight:600;font-size:13px;text-decoration:none;background:#f3faf9;">' +
              'Go to Your Courses' +
            '</a>' +
          '</div>';
        return;
      }

      elRecentSub.textContent = "Here are your latest quiz attempts.";

      var html = '<ul style="list-style:none;margin:0;padding:0;">';

      attempts.forEach(function(att){
        var label = (att.display_label || "").trim();
        if(!label && att.quiz_id){
