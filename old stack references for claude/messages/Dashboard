    /* ========== Messages unread badge (Dashboard top bar) ========== */
    function loadUnreadThreadsCount(){
      if(!elMsgChip || !elMsgBadge) return;
      if(!MESSAGING_URL) return;

      var token = null;
      try{ token = localStorage.getItem("qa_token"); }catch(e){ token = null; }
      if(!token) return;

      // ✅ Always show entry point
      elMsgChip.style.display = "inline-flex";

      // Default state: 0 (muted)
      elMsgBadge.textContent = "0";
      elMsgBadge.style.background = "#94a3b8"; // muted when 0
      elMsgBadge.style.color = "#ffffff";

      var body = new URLSearchParams();
      body.set("action", "message.unread.count");
      body.set("token", token);

      fetch(MESSAGING_URL, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: body.toString()
      })
      .then(function(res){ return res.json(); })
      .then(function(data){
        if(!data || data.ok !== true) return;

        var n = Number(data.new_threads || 0);
        if(!isFinite(n) || n <= 0){
          // keep 0 + muted
          elMsgBadge.textContent = "0";
          elMsgBadge.style.background = "#94a3b8";
          return;
        }

        elMsgBadge.textContent = (n > 99) ? "99+" : String(n);
        // ✅ active highlight when >0
        elMsgBadge.style.background = "#0b7a75";
      })
      .catch(function(_err){
        // fail silent: keep chip + 0
      });
    }

    /* ========== My Recent Quizzes / History ========== */
    function formatDateTime(ts){
      if(!ts) return "—";
      var d = new Date(ts);
      if(isNaN(d.getTime())) return "—";
      var date = d.toLocaleDateString("en-GB", { day:"2-digit", month:"short", year:"numeric" });
      var time = d.toLocaleTimeString("en-GB", { hour:"2-digit", minute:"2-digit" });
      return date + " · " + time;
    }

    function niceMode(mode){
      var m = String(mode || "").toLowerCase();
      if(m === "timed")   return "Timed";
      if(m === "instant") return "Instant";
      return "";
    }

    function formatScore(att){
      var raw   = Number(att.score_raw   || 0);
      var total = Number(att.score_total || 0);
      var pct   = Number(att.score_pct   || 0);
      var status= String(att.status || "").toLowerCase();

      if(raw > 0 && total > 0){
        var shownPct = pct || Math.round((raw * 100) / total);
        return raw + "/" + total + " (" + shownPct + "%)";
      }
      if(status === "completed"){
        if(pct > 0) return pct + "%";
        return "Completed";
      }
      if(status === "in_progress") return "In progress";
      return "—";
    }

    function renderRecentAttempts(attempts){
      if(!elRecentBody || !elRecentSub) return;

      if(!attempts || !attempts.length){
        elRecentSub.textContent = "No completed quizzes yet.";
        elRecentBody.innerHTML =
          '<p style="margin:6px 0 0;font-size:13.5px;color:#5b6a68;">' +
