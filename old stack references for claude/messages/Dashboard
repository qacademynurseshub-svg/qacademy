  // =========================
  function qaPageUrl(slug){
    slug = String(slug || '').trim();
    if(!slug) return '#';
    // allow full URLs if ever needed
    if(/^https?:\/\//i.test(slug)) return slug;
    if(slug[0] === '/') return slug;
    return '/p/' + slug + '.html';
  }
  function qaHref(key){
    var pages = (cfg.PAGES && typeof cfg.PAGES === 'object') ? cfg.PAGES : {};
    return qaPageUrl(pages[key]);
