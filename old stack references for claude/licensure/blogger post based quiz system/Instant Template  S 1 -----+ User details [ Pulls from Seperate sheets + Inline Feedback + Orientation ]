<!-- 3) ENGINE -->
<script>
(function(){
  /* ================= CONFIG ================= */
  var WEB_APP_URL_QUIZ = 'https://script.google.com/macros/s/AKfycbx_QHvNJqm65XavV8FBtPGhdveTFP_bMMYY2mtKfp6uErNjYL9A01zQs2S9uGjCbP58/exec';
  var QUIZ_ID          = 'RN_MED-I1';   // ← set your quiz id
  var PAGE_SIZE        = 5;             // questions per page
  var ENABLE_GRID      = true;
  var DASHBOARD_SLUG   = 'dashboard_23';

  /* =============== STATE =============== */
  var data = null;
  var pageIndex = 0;
  var answers = {};
  var flags   = {};
  var attempts= {};
  var firstTryCorrect = {};
  var viewMode = 'ALL';
  var submitted = false;
  var started = false;

  /* =============== HELPERS =============== */
  function $(id){ return document.getElementById(id); }
  function show(el, yes){ if(!el) return; el.style.display = yes ? '' : 'none'; }
  function msg(t){ var m=$('qa-sub'); if(!m) return; m.textContent=t||''; }
  function decodeHTML(s){ if(!s) return ''; var ta=document.createElement('textarea'); ta.innerHTML=s; return s ? ta.value.replace(/\u00A0/g,' ') : ''; }
  function asciiClean(s){
    return String(decodeHTML(s)||'')
      .replace(/[\u2018\u2019]/g,"'")
      .replace(/[\u201C\u201D]/g,'"')
      .replace(/[\u2013\u2014]/g,"-")
      .replace(/\u2022/g,"*");
  }
  function esc(s){
    s = (s==null?'':String(s));
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
  function clean(s){ return esc(asciiClean(s)); }
  function storageKey(k){ return 'qa_instant_' + QUIZ_ID + '_' + k; }

  function saveDraft(){ try{
    localStorage.setItem(storageKey('draft'), JSON.stringify({
      started: started,
      pageIndex: pageIndex,
      answers: answers,
      flags: flags,
      attempts: attempts,
      firstTryCorrect: firstTryCorrect,
      viewMode: viewMode
    }));
  }catch(e){} }
  function loadDraft(){ try{ return JSON.parse(localStorage.getItem(storageKey('draft')) || 'null'); }catch(e){ return null; } }
  function clearAllStorage(){ localStorage.removeItem(storageKey('draft')); }
  function answeredCount(){ var n=0; (data.items||[]).forEach(function(it){ if(answers[it.item_id]) n++; }); return n; }

  // ===== STATUS HELPERS (same as timed) =====
  function formatDateTime(raw){
    if(!raw) return '';
    var d = new Date(raw);
    if(isNaN(d.getTime())) return String(raw);
    return d.toLocaleString('en-GB', {
      year:'numeric', month:'short', day:'2-digit',
      hour:'2-digit', minute:'2-digit'
    });
  }

  function renderHeadFromPayload(payload, statusText){
    $('qa-title').textContent = asciiClean(
      payload.title ||
      payload.quiz_title ||
      (payload.quiz && payload.quiz.title) ||
      QUIZ_ID.replace(/_/g,' ')
    );
    $('qa-sub').textContent = statusText || '';
  }

  function showStatusCard(status, payload){
    var box = $('qa-status-card');
    if(!box) return;

    // Hide quiz UI
    show($('qa-pref'), false);
    show($('qa-hud'), false);
    show($('qa-questions'), false);
    show($('qa-actions'), false);
    show($('qa-pager-top'), false);
    show($('qa-pager-bottom'), false);
    show($('qa-grid-fab'), false);
    window.onbeforeunload = null;

    var publishAt   = payload.publish_at   || payload.publishFrom   || payload.published_at || '';
    var unpublishAt = payload.unpublish_at || payload.unpublishes_at || payload.close_at    || '';

    var publishNice   = formatDateTime(publishAt);
    var unpublishNice = formatDateTime(unpublishAt);

    var title, body, bg, border, chip;

    if(status === 'scheduled'){
      bg     = '#fff7e6';
      border = '#facc15';
      chip   = '#92400e';
      title  = 'Quiz opens soon';
      body   = publishNice
        ? 'This quiz is scheduled to open on ' + publishNice + '. Please check back then.'
        : 'This quiz is scheduled but not yet open. Please check again later.';
    }else if(status === 'closed'){
      bg     = '#fee2e2';
      border = '#ef4444';
      chip   = '#991b1b';
      title  = 'Quiz closed';
      body   = unpublishNice
        ? 'This quiz closed on ' + unpublishNice + '. It is no longer available to attempt.'
        : 'This quiz is closed and no longer available to attempt.';
    }else{ // unpublished or anything else
      bg     = '#f3f4f6';
      border = '#9ca3af';
      chip   = '#111827';
      title  = 'Quiz not available';
      body   = 'This quiz is not currently published. Please check your course page or contact QAcademy if you think this is a mistake.';
    }

    box.innerHTML =
      '<div style="padding:12px 14px;border-radius:12px;border:1px solid '+border+';background:'+bg+';box-shadow:0 6px 16px rgba(0,0,0,.04);font-size:13px;color:#111827;">' +
        '<div style="font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:6px;">' +
          '<span style="display:inline-block;padding:2px 8px;border-radius:999px;border:1px solid '+border+';background:rgba(255,255,255,.7);font-size:11px;color:'+chip+';text-transform:uppercase;letter-spacing:.04em;">' +
            status.toUpperCase() +
          '</span>' +
          '<span>'+ title +'</span>' +
        '</div>' +
        '<p style="margin:0;color:#374151;line-height:1.5;">'+ body +'</p>' +
      '</div>';

    box.style.display = 'block';

    // Header
    renderHeadFromPayload(payload, title);
  }

  // === Adapter for Web App payload (includes rationale_img) ===
  function adaptWebAppPayload(raw){
    if (!raw || !Array.isArray(raw.questions)) {
      return { quiz:{ title: (raw && raw.title) || 'Instant Quiz' }, items: [] };
    }
    var items = raw.questions.map(function(r, i){
      var correct = String(r.correct || '').trim().toUpperCase();
      if (!/^[ABCD]$/.test(correct)) correct = '';
      return {
        item_id: String(r.item_id || ('row' + (i+1))),
        number:  i + 1,
        stem:    r.stem || r.question || '',
        options: {
          A: r.option_a || r.A || '',
          B: r.option_b || r.B || '',
          C: r.option_c || r.C || '',
          D: r.option_d || r.D || ''
        },
        feedback: {
          A: r.fb_a || r.feedback_a || r.fbA || '',
          B: r.fb_b || r.feedback_b || r.fbB || '',
          C: r.fb_c || r.feedback_c || r.fbC || '',
          D: r.fb_d || r.feedback_d || r.fbD || ''
        },
        correct:       correct,
        rationale:     r.rationale || '',
        topic:         r.topic || '',
        difficulty:    r.difficulty || '',
        subject:       r.subject || '',
        rationale_img: r.rationale_img || r.rationaleImage || r.rationaleImg || ''
      };
    });
    return {
      quiz: {
        title:       raw.title || 'Instant Quiz',
        course_id:   raw.course_id,
        type:        raw.type,
        items_count: raw.items_count,
        warning:     raw.warning
      },
      items: items
    };
  }

  function renderHead(){
    $('qa-title').textContent = asciiClean(data.quiz && data.quiz.title ? data.quiz.title : 'Instant Quiz');
    $('qa-sub').textContent = 'Instant Feedback Practice | ' + (data.items ? data.items.length : 0) + ' questions';
    if (data.quiz && data.quiz.warning){
      var w = $('qa-warn');
      w.textContent = data.quiz.warning;
      w.style.display = 'block';
    }
  }
  function updateHUD(){
    var total = data ? data.items.length : 0;
    var ans = answeredCount();
    $('qa-hud-left').textContent = 'Answered: ' + ans + ' / ' + total + (viewMode==='FLAGGED' ? ' • Flagged view' : '');
  }
  function currentSource(){
    if(viewMode==='FLAGGED'){
      var f = (data.items||[]).filter(function(it){ return !!flags[it.item_id]; });
      return (f.length? f : data.items);
    }
    return data.items || [];
  }
  function currentSlice(){
    var src = currentSource();
    var total = src.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (pageIndex < 0) pageIndex = 0;
    if (pageIndex >= totalPages) pageIndex = totalPages - 1;
    var start = pageIndex * PAGE_SIZE;
    var end   = Math.min(total, start + PAGE_SIZE);
    return { src: src, total: total, totalPages: totalPages, start: start, end: end, pageFrom:start+1, pageTo:end };
  }
  function pageAllAnswered(){
    var c = currentSlice();
    for (var i=c.start;i<c.end;i++){ if (!answers[c.src[i].item_id]) return false; }
    return true;
  }

  /* ================== CARD ================== */
  function cardHTML(it){
    var letters = ['A','B','C','D'];
    var sel = (answers[it.item_id] || '').toUpperCase();
    var isLocked = !!sel;
    var correct = String(it.correct || '').toUpperCase();

    var summary = '';
    if (sel){
      summary = (sel === correct)
        ? '<div class="qa-summary" aria-live="polite">✅ You chose <strong>'+esc(sel)+'</strong> — Correct. <span style="opacity:.8">🔒 Answer locked.</span></div>'
        : '<div class="qa-summary" aria-live="polite">❌ You chose <strong>'+esc(sel)+'</strong>. <span style="opacity:.8">🔒 Answer locked.</span> Tap “Show answer” to highlight the correct choice.</div>';
    }

    var opts = letters.map(function(L){
      var optText = clean(it.options && it.options[L]);
      var fbText  = clean(it.feedback && it.feedback[L]);
      var classes = ['qa-opt'];
      if (sel){
        if (L === correct) classes.push('is-correct');
        if (L === sel && L !== correct) classes.push('is-selected','is-wrong');
        if (L === sel && L === correct) classes.push('is-selected');
      }
      var fbHTML = (sel && fbText) ? ('<div class="qa-fb">'+ fbText +'</div>') : '';
      return ''+
        '<label class="'+classes.join(' ')+'">'+
          '<div class="qa-opt-text">'+
            '<input type="radio" name="q_'+esc(it.item_id)+'" value="'+esc(L)+'" '+(sel===L?'checked':'')+' '+(isLocked?'disabled':'')+'>' +
            '<span><strong>'+L+'.</strong> '+ optText +'</span>'+
          '</div>'+ fbHTML +
        '</label>';
    }).join('');

    var meta = it.topic ? '<p class="qa-meta">Topic: '+ clean(it.topic) +'</p>' : '';

    // Rationale (text + optional picture thumbnail, only after answer)
    var rationaleHTML = '';
    if (sel){
      var hasText = !!(it.rationale && String(it.rationale).trim());
      var hasImg  = !!(it.rationale_img);
      if (hasText || hasImg){
        rationaleHTML = '<div class="qa-rationale">' +
          '<strong>Rationale: </strong>' +
          (hasText ? '<span class="qa-rationale-text"> ' + clean(it.rationale || '') + '</span>' : '') +
          (hasImg ? (
            '<div class="qa-rationale-img-wrap">' +
              '<img src="'+ esc(it.rationale_img) +'" alt="Rationale image" ' +
              'class="qa-rationale-img" data-full="'+ esc(it.rationale_img) +'" />' +
            '</div>' +
            '<div class="qa-rationale-hint">Tap picture to enlarge. Tap outside the picture to close.</div>'
          ) : '') +
        '</div>';
      }
    }

    var controls = (PAGE_SIZE === 1)
      ? '<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap">'+
          (it.number>1 ? '<button class="qa-btn-ghost qa-prev" type="button">Prev</button>' : '')+
          '<button class="qa-btn-ghost qa-show" type="button">Show answer</button>'+
          '<button class="qa-btn qa-next" type="button" '+(sel?'':'disabled')+'>Next</button>'+
          '<button class="qa-btn-ghost qa-flag" type="button">'+(flags[it.item_id]?'Unflag':'Flag')+'</button>'+
        '</div>'
      : '<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap">'+
          '<button class="qa-btn-ghost qa-show" type="button">Show answer</button>'+
          '<button class="qa-btn-ghost qa-flag" type="button">'+(flags[it.item_id]?'Unflag':'Flag')+'</button>'+
        '</div>';

    return (
      '<section class="qa-card" data-id="'+esc(it.item_id)+'">'+
        '<div class="qa-badge">QAcademy</div>'+
        '<h2 class="qa-title">Question '+ esc(it.number) +'</h2>'+
        meta+
        '<p class="qa-stem">'+ clean(it.stem||'') +'</p>'+
        summary+
        '<div class="qa-opts">'+ opts +'</div>'+
        rationaleHTML+
        controls+
      '</section>'
    );
  }

  /* ============== SCROLL HELPERS ============== */
  function scrollToCard(anchorId, behavior){
    var hud = $('qa-hud'); var hudH = (hud && hud.offsetHeight) || 0;
    var sel = anchorId ? document.querySelector('.qa-card[data-id="'+anchorId+'"]') : null;
    if (sel){
      var y = sel.getBoundingClientRect().top + window.scrollY - hudH - 10;
      window.scrollTo({ top: y, behavior: behavior || 'instant' });
    }
  }
  function scrollToFirstCard(behavior){
    var hud = $('qa-hud'); var hudH = (hud && hud.offsetHeight) || 0;
    var first = document.querySelector('.qa-card');
    if (first){
      var y = first.getBoundingClientRect().top + window.scrollY - hudH - 10;
      window.scrollTo({ top: y, behavior: behavior || 'instant' });
    }
  }

  /* ============== PAGER ============== */
  function buildPager(host){
    if(!host) return;
    var c = currentSlice();
    host.innerHTML = '';
    var wrap = document.createElement('div'); wrap.className='qa-pager';

    var prev = document.createElement('button');
    prev.className='qa-btn qa-btn-ghost'; prev.type='button'; prev.textContent='Prev';
    prev.disabled = (pageIndex===0);
    prev.onclick = function(){
      pageIndex--; renderPage(); saveDraft();
      scrollToFirstCard('smooth');
    };
    wrap.appendChild(prev);

    var info = document.createElement('span');
    info.textContent = 'Page ' + (pageIndex+1) + ' of ' + c.totalPages + ' [' + PAGE_SIZE + '/page ]';
    wrap.appendChild(info);

    if(pageIndex < c.totalPages - 1){
      var next = document.createElement('button');
      next.className='qa-btn'; next.type='button'; next.textContent='Next';
      if (PAGE_SIZE > 1) next.disabled = !pageAllAnswered();
      next.onclick = function(){
        pageIndex++; renderPage(); saveDraft();
        scrollToFirstCard('smooth');
      };
      wrap.appendChild(next);
    }
    host.appendChild(wrap);
  }

  /* ============== RENDER ============== */
  function renderPage(opts){
    opts = opts || {};
    var anchorId = opts.anchorId || null;
    var doScroll = !!opts.scroll;

    var c = currentSlice();
    var html = '';
    for(var i=c.start;i<c.end;i++) html += cardHTML(c.src[i]);
    $('qa-questions').innerHTML = html;

    document.querySelectorAll('.qa-card').forEach(function(sec){
      var id  = sec.getAttribute('data-id');
      var item = (data.items || []).find(function(it){ return it.item_id === id; });
      if(!item) return;

      // radio change → LOCK on first pick
      sec.querySelectorAll('input[type="radio"]').forEach(function(r){
        r.addEventListener('change', function(){
          if (answers[id]) return;
          var picked = String(r.value||'').toUpperCase();
          attempts[id] = 1;
          firstTryCorrect[id] = (picked === String(item.correct).toUpperCase());
          answers[id] = picked;
          saveDraft();
          renderPage({ anchorId:id, scroll:true });
          updateHUD();
        });
      });

      // Show answer
      var showBtn = sec.querySelector('.qa-show');
      if(showBtn){
        showBtn.addEventListener('click', function(){
          if (!answers[id]){
            var corr = String(item.correct).toUpperCase();
            attempts[id] = 1;
            firstTryCorrect[id] = false;
            answers[id] = corr;
            saveDraft();
          }
          renderPage({ anchorId:id, scroll:true });
          updateHUD();
        });
      }

      // Per-card Next/Prev only when PAGE_SIZE === 1
      if (PAGE_SIZE === 1){
        var nextBtn = sec.querySelector('.qa-next');
        if(nextBtn){
          nextBtn.addEventListener('click', function(){
            var c = currentSlice();
            var nextPage = Math.min(c.totalPages-1, pageIndex+1);
            pageIndex = nextPage; renderPage(); saveDraft();
            scrollToFirstCard('smooth');
          });
        }
        var prevBtn = sec.querySelector('.qa-prev');
        if(prevBtn){
          prevBtn.addEventListener('click', function(){
            var prevPage = Math.max(0, pageIndex-1);
            pageIndex = prevPage; renderPage(); saveDraft();
            scrollToFirstCard('smooth');
          });
        }
      }

      // Flag
      var flagBtn = sec.querySelector('.qa-flag');
      if(flagBtn){
        flagBtn.addEventListener('click', function(){
          flags[id] = !flags[id];
          flagBtn.textContent = flags[id] ? 'Unflag' : 'Flag';
          saveDraft(); updateHUD();
        });
      }
    });

    buildPager($('qa-pager-top'));
    buildPager($('qa-pager-bottom'));
    updateHUD();

    if (doScroll){
      if (anchorId){ scrollToCard(anchorId, 'smooth'); }
      else { scrollToFirstCard('smooth'); }
    }

    $('qa-grid-fab').style.display = ENABLE_GRID ? 'inline-block' : 'none';
  }

  /* ============== FLOW ============== */
  function startQuizUI(){
    started = true;
    show($('qa-pref'), false);   // keep preflight visible above if you want; or hide if preferred
    show($('qa-hud'), true);
    show($('qa-questions'), true);
    show($('qa-actions'), true);
    show($('qa-pager-top'), true);
    show($('qa-pager-bottom'), true);
    saveDraft();
    renderPage();
    updateHUD();
    msg('Self paced quiz | No timer | ' + (data.items.length||0) + ' questions');
  }

  function buildPreflight(){
    var t = asciiClean(data.quiz && data.quiz.title ? data.quiz.title : 'Instant Quiz');
    var n = (data.items||[]).length || 0;
    $('qa-pref-title').textContent = t;
    $('qa-pref-meta').textContent  = 'Instant feedback practice | ' + n + ' questions | 3 or 4 options';

    var d = loadDraft() || {};
    show($('qa-resume'), !!(d && d.started));

    $('qa-start').onclick  = function(){
      clearAllStorage();
      pageIndex = 0; answers = {}; flags = {}; attempts = {}; firstTryCorrect = {};
      startQuizUI();
    };
    $('qa-resume').onclick = function(){
      var d = loadDraft();
      if(d){
        started         = !!d.started;
        pageIndex       = d.pageIndex||0;
        answers         = d.answers||{};
        flags           = d.flags||{};
        attempts        = d.attempts||{};
        firstTryCorrect = d.firstTryCorrect||{};
        viewMode        = d.viewMode||'ALL';
      }
      startQuizUI();
    };

    show($('qa-pref'), true);
    show($('qa-hud'), false);
    show($('qa-questions'), false);
    show($('qa-actions'), false);
    show($('qa-pager-top'), false);
    show($('qa-pager-bottom'), false);
  }

  async function boot(){
    try{
      // Simple loading info in status card (same style as timed)
      var statusBox = $('qa-status-card');
      if(statusBox){
        statusBox.style.display = 'block';
        statusBox.innerHTML =
          '<div style="padding:10px 12px;border-radius:10px;background:#eef2ff;border:1px solid #c7d2fe;font-size:13px;color:#111827;">' +
            'Loading quiz…' +
          '</div>';
      }

      var url = WEB_APP_URL_QUIZ + '?quiz_id=' + encodeURIComponent(QUIZ_ID);
      var res = await fetch(url, { method:'GET', headers:{ 'Accept':'application/json' }});
      if (!res.ok) throw new Error('HTTP ' + res.status);
      var raw = await res.json();

      if (raw && raw.error){
        if(statusBox){
          statusBox.style.display = 'block';
          statusBox.innerHTML =
            '<div style="padding:10px 12px;border-radius:10px;background:#fee2e2;border:1px solid #ef4444;font-size:13px;color:#111827;">' +
              esc(raw.error || 'Quiz not available.') +
            '</div>';
        }
        renderHeadFromPayload(raw, 'Quiz not available');
        return;
      }

      var status = raw.status || 'open';

      // If quiz not open → show friendly card and stop
      if(status !== 'open'){
        showStatusCard(status, raw);
        return;
      }

      // Quiz is open → clear status card
      if(statusBox){
        statusBox.style.display = 'none';
        statusBox.innerHTML = '';
      }

      // Normalize payload to renderer shape
      data = adaptWebAppPayload(raw);

      renderHead();
      msg('Ready');

      buildPreflight();

      $('qa-view-all').onclick  = function(){ viewMode='ALL'; pageIndex=0; renderPage(); saveDraft(); };
      $('qa-view-flag').onclick = function(){ viewMode='FLAGGED'; pageIndex=0; renderPage(); saveDraft(); };

      $('qa-reset').onclick = function(){
        if(!confirm('Reset progress and start again?')) return;
        clearAllStorage();
        pageIndex = 0; answers = {}; flags = {}; attempts = {}; firstTryCorrect = {}; started = false;
        buildPreflight();
      };

      if(ENABLE_GRID){
        $('qa-grid-fab').style.display = 'inline-block';
        $('qa-grid-fab').onclick = function(){
          var panel = $('qa-grid-float');
          var body  = $('qa-grid-float-body');
          body.innerHTML = '';
          (data.items||[]).forEach(function(it){
            var b = document.createElement('button');
            b.type='button'; b.textContent = String(it.number);
            b.style.cssText='min-width:36px;height:36px;border:1px solid #e2e8f0;border-radius:8px;background:#fff;cursor:pointer;';
            function setState(){
              var sel = answers[it.item_id], f = !!flags[it.item_id];
              b.style.background = '#fff'; b.style.borderColor = '#e2e8f0'; b.style.boxShadow = 'none';
              if (sel){ b.style.background = '#eef2ff'; b.style.borderColor='#c7d2fe'; }
              if (f){ b.style.boxShadow='inset 0 0 0 2px #f59e0b'; }
            }
            b.onclick = function(){
              if(!started){ startQuizUI(); }
              pageIndex = Math.floor((it.number-1)/PAGE_SIZE);
              renderPage({ anchorId: it.item_id, scroll:true }); saveDraft();
              panel.style.display='none';
            };
            setState(); body.appendChild(b);
          });
          panel.style.display='block';
        };
        $('qa-grid-close').onclick = function(){ $('qa-grid-float').style.display='none'; };
      }

      window.onbeforeunload = function(){
        if(started && !submitted){ return 'You have an active instant quiz session.'; }
      };

    }catch(err){
      var statusBox = $('qa-status-card');
      if(statusBox){
        statusBox.style.display = 'block';
        statusBox.innerHTML =
          '<div style="padding:10px 12px;border-radius:10px;background:#fee2e2;border:1px solid #ef4444;font-size:13px;color:#111827;">' +
            'Failed to load quiz: '+ esc(err.message || String(err)) +
          '</div>';
      }
      renderHeadFromPayload({ title:'Instant Quiz' }, 'Error loading quiz');
    }
  }

  document.addEventListener('DOMContentLoaded', function(){
    var saveBtn = $('qa-saveexit');
    if (saveBtn){
      saveBtn.onclick = function(){
        saveDraft();
        location.replace('/p/' + DASHBOARD_SLUG + '.html');
      };
    }

    // Picture rationale overlay wiring
    var overlay    = document.getElementById('qa-img-overlay');
    var overlayImg = document.getElementById('qa-img-overlay-img');

    document.addEventListener('click', function(e){
      var thumb = e.target.closest('.qa-rationale-img');
      if (!thumb) return;
      if (!overlay || !overlayImg) return;
      overlayImg.src = thumb.getAttribute('data-full') || thumb.src || '';
      overlay.classList.add('qa-open');
    });

    if (overlay){
      overlay.addEventListener('click', function(e){
        if (e.target === overlay){
          overlay.classList.remove('qa-open');
        }
      });
    }

    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape' && overlay){
        overlay.classList.remove('qa-open');
      }
    });

    boot();
  });
})();
</script>
