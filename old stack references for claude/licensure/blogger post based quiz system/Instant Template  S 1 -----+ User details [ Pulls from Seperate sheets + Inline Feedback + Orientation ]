<!-- =================== QAcademy — INSTANT QUIZ (Guard + Web App + Status Handling + User Line) =================== -->

<script>
(function(){
  var WEB_APP_URL_AUTH = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";
  var TOKEN_KEY        = "qa_token";
  var LOGIN_SLUG       = "login_23";
  var DASHBOARD_SLUG   = "dashboard_23";
  var COURSE_ID        = "RN_MED"; // ← change per post

  function go(path){ location.replace(path); }

  // Helper to render "You are taking this quiz as..."
  function applyUserLine(info){
    var el = document.getElementById("qa-user");
    if(!el) return;
    if(!info || (!info.name && !info.email)){
      el.style.display = "none";
      el.textContent = "";
      return;
    }
    var name  = info.name  ? String(info.name).trim()  : "";
    var email = info.email ? String(info.email).trim() : "";
    var text = "";
    if(name && email){
      text = "You are taking this quiz as: " + name + " (" + email + ")";
    }else if(name){
      text = "You are taking this quiz as: " + name;
    }else if(email){
      text = "You are taking this quiz as: " + email;
    }
    el.textContent = text;
    el.style.display = text ? "block" : "none";
  }

  async function verify(token){
    var res = await fetch(WEB_APP_URL_AUTH, {
      method:"POST",
      headers:{ "Content-Type":"application/x-www-form-urlencoded" },
      body: new URLSearchParams({ action:"verify", token:token })
    });
    if(!res.ok) throw new Error("HTTP " + res.status);
    var payload = await res.json();

    // If backend signals invalid token
    if(!payload || payload.ok === false){
      throw new Error("Invalid token");
    }
    return payload;
  }

  (async function(){
    var token = localStorage.getItem(TOKEN_KEY);
    if(!token){
      go("/p/" + LOGIN_SLUG + ".html");
      return;
    }

    try{
      var payload = await verify(token);

      // Normalise course_ids (array OR comma-separated string)
      var courseIds = payload.course_ids || payload.courses || [];
      if(typeof courseIds === "string"){
        courseIds = courseIds.split(",").map(function(s){ return s.trim(); });
      }

      var allowed = new Set(courseIds.map(function(x){
        return String(x).toUpperCase();
      }));

      if(!allowed.has(String(COURSE_ID).toUpperCase())){
        // Token is fine, just not enrolled for this course → send to dashboard, but DO NOT clear token
        go("/p/" + DASHBOARD_SLUG + ".html");
        return;
      }

      // Extract user name/email from payload and expose for this page
      var name  =
        (payload.name) ||
        (payload.full_name) ||
        (payload.display_name) ||
        (payload.user && (payload.user.name || payload.user.full_name || payload.user.display_name)) ||
        "";
      var email =
        (payload.email) ||
        (payload.user && payload.user.email) ||
        "";

      window.qaUserSummary = {
        name:  name,
        email: email
      };

      // Render the "You are taking this quiz as..." line immediately
      applyUserLine(window.qaUserSummary);

      var app = document.getElementById("qa-app");
      if(app) app.style.display = "block";

    }catch(e){
      // Only here for truly bad / expired token or network failure
      console && console.warn && console.warn("Guard verify failed:", e);
      // If you want to be less aggressive, you can comment out the next line:
      localStorage.removeItem(TOKEN_KEY);
      go("/p/" + LOGIN_SLUG + ".html");
    }
  })();
})();
</script>

