<script>
/* ========= Shared tiny helpers ========= */
(function(){
  'use strict';
  window.QA_UTIL = window.QA_UTIL || {};

  function cfgObj(){
    return (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};
  }
  function buildPageUrl(slug){
    slug = String(slug || '').replace(/^\s+|\s+$/g,'');
    if (!slug) return '/';
    return '/p/' + slug + '.html';
  }
  function getToken(){
    try { return localStorage.getItem('qa_token'); } catch(e){ return null; }
  }
  function parseDate(val){
    if (!val && val !== 0) return null;
    var d = (val instanceof Date) ? val : new Date(val);
    if (isNaN(d.getTime())) return null;
    return d;
  }
  function fmtShortDate(d){
    if (!(d instanceof Date) || isNaN(d.getTime())) return '';
    return d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
  }

  window.QA_UTIL.cfgObj = cfgObj;
  window.QA_UTIL.buildPageUrl = buildPageUrl;
  window.QA_UTIL.getToken = getToken;
  window.QA_UTIL.parseDate = parseDate;
  window.QA_UTIL.fmtShortDate = fmtShortDate;
})();

/* ========= Course header ========= */
function qaInitCourseHeader() {
  var cid = window.QA_COURSE_ID || 'GP';
  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};

  var elCid = document.getElementById('qa-course-id-text');
  if (elCid) elCid.textContent = cid;

  var elBuilder = document.getElementById('qa-builder-link');
  if (elBuilder) {
    elBuilder.href = (window.QA_UTIL ? window.QA_UTIL.buildPageUrl(cfg.BUILDER_SLUG || 'quiz-builder') : '/p/quiz-builder.html')
      + '?course_id=' + encodeURIComponent(cid);
  }

  var elHistoryTop = document.getElementById('qa-top-history');
  if (elHistoryTop) {
    elHistoryTop.href = (window.QA_UTIL ? window.QA_UTIL.buildPageUrl(cfg.HISTORY_SLUG || 'learning-history') : '/p/learning-history.html')
      + '?course_id=' + encodeURIComponent(cid);
  }

  var u      = window.QA_USER   || {};
  var access = window.QA_ACCESS || {};
  var elUser = document.getElementById('qa-course-user-line');
  var elAcc  = document.getElementById('qa-course-access-line');
  var elChip = document.getElementById('qa-course-status-chip');

  function buildDisplayName(user) {
    if (user.name) return user.name;
    var fn = (user.forename || '').trim();
    var sn = (user.surname  || '').trim();
    if (fn || sn) return (fn + ' ' + sn).trim();
    if (user.email) return user.email;
    if (user.username) return user.username;
    return '';
  }

  var name     = buildDisplayName(u);
  var tailBits = [];
  if (u.program_id) tailBits.push(String(u.program_id).toUpperCase());
  if (u.cohort)     tailBits.push('Cohort ' + u.cohort);

  if (elUser) {
    if (name) {
      var tail = tailBits.length ? (' > ' + tailBits.join(' . ')) : '';
      elUser.textContent = 'You are studying as: ' + name + tail;
    } else {
      elUser.textContent = '';
    }
  }

  var rawExpiry = (access && access.access_expires_utc) || u.user_expires_utc || '';
  var status    = 'ACTIVE';
  var accessText = '';

  if (rawExpiry) {
    var d = (window.QA_UTIL ? window.QA_UTIL.parseDate(rawExpiry) : new Date(rawExpiry));
    if (d && !isNaN(d.getTime())) {
      var now      = new Date();
      var diffMs   = d.getTime() - now.getTime();
      var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

      if (diffDays < 0) status = 'EXPIRED';
      else if (diffDays <= 14) status = 'EXPIRING_SOON';
      else status = 'ACTIVE';

      var fmt = window.QA_UTIL ? window.QA_UTIL.fmtShortDate(d) : d.toDateString();
      accessText = 'Access valid until: ' + fmt;
    }
  }

  if (!accessText) {
    accessText = 'Access: Active';
    status     = 'ACTIVE';
  }

  if (elAcc) elAcc.textContent = accessText;

  if (elChip) {
    elChip.classList.remove('gp-status--active', 'gp-status--expiring', 'gp-status--expired');

    if (status === 'EXPIRED') {
      elChip.textContent = 'Expired';
      elChip.classList.add('gp-status--expired');
    } else if (status === 'EXPIRING_SOON') {
      elChip.textContent = 'Expiring soon';
      elChip.classList.add('gp-status--expiring');
    } else {
      elChip.textContent = 'Active';
      elChip.classList.add('gp-status--active');
    }
  }

  /* ✅ Wire Messages chip (course context) */
  (function(){
    var elMsgChip  = document.getElementById('qa-msg-chip');
    var elMsgBadge = document.getElementById('qa-msg-badge');

    if (!elMsgChip) return;

    var messagesSlug = cfg.MESSAGES_SLUG || 'messages';
    var base = (window.QA_UTIL ? window.QA_UTIL.buildPageUrl(messagesSlug) : '/p/messages.html');

    // pass course context for future routing (and for "course" threads)
    var sep = base.indexOf('?') === -1 ? '?' : '&';
    elMsgChip.href = base + sep
      + 'context_type=course'
      + '&course_id=' + encodeURIComponent(String(cid || '').trim().toUpperCase());

    // optional unread badge (silent fail if backend/endpoint not available)
    var MESSAGING_URL = cfg.MESSAGING_URL || '';
    if (!MESSAGING_URL || !elMsgBadge) return;

    var token = (window.QA_UTIL ? window.QA_UTIL.getToken() : null);
    if (!token) return;

    elMsgBadge.textContent = '0';
    elMsgBadge.style.background = '#94a3b8';

    var body = new URLSearchParams();
    body.set('action', 'message.unread.count');
    body.set('token', token);
    body.set('context_type', 'course');
    body.set('course_id', String(cid || '').trim().toUpperCase());

    fetch(MESSAGING_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: body.toString()
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(!data || data.ok !== true) return;
      var n = Number(data.new_threads || 0);
      if(!isFinite(n) || n <= 0){
        elMsgBadge.textContent = '0';
        elMsgBadge.style.background = '#94a3b8';
        return;
      }
      elMsgBadge.textContent = (n > 99) ? '99+' : String(n);
      elMsgBadge.style.background = '#0b7a75';
    })
    .catch(function(){ /* silent */ });
  })();

  function openMainForDesktop() {
    if (window.matchMedia('(min-width: 900px)').matches) {
      var builder = document.getElementById('gp-main-builder');
      var fixed   = document.getElementById('gp-main-fixed');
      if (builder) builder.open = true;
      if (fixed)   fixed.open   = true;
    }
  }
  openMainForDesktop();
  window.addEventListener('resize', openMainForDesktop);
}

/* ========= Back-to-top ========= */
function qaInitBackToTop() {
  var btn = document.getElementById('qa-back-top-btn');
  if (!btn) return;

  var threshold = 220;

  function onScroll() {
    var y = window.scrollY || window.pageYOffset || 0;
    if (y > threshold) btn.classList.add('qa-back-top-btn--visible');
    else btn.classList.remove('qa-back-top-btn--visible');
  }

  btn.addEventListener('click', function (ev) {
    ev.preventDefault();
    try { window.scrollTo({ top: 0, behavior: 'smooth' }); }
    catch (e) { window.scrollTo(0, 0); }
  });

  window.addEventListener('scroll', onScroll);
  onScroll();
}
</script>

