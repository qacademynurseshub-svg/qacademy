<script>
function qaInitCourseAnnouncements() {
  (function () {
    'use strict';

    var COURSE_ID = String(window.QA_COURSE_ID || 'GP').trim().toUpperCase();
    var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};
    var API_URL = cfg.ANNOUNCEMENTS_URL || cfg.BUILDER_API_URL || '';

    var elCard    = document.getElementById('qa-course-ann-card');
    var elSub     = document.getElementById('qa-course-ann-sub');
    var elBody    = document.getElementById('qa-course-ann-body');
    var elViewAll = document.getElementById('qa-course-ann-view-all');

    if (!elCard || !elSub || !elBody) return;

    // View-all
    if (elViewAll) {
      var annSlug = cfg.ANNOUNCEMENTS_SLUG || 'announcement';
      elViewAll.href = (window.QA_UTIL ? window.QA_UTIL.buildPageUrl(annSlug) : '/p/announcement.html')
        + '?course_id=' + encodeURIComponent(COURSE_ID);
      elViewAll.style.display = 'inline-block';
    }

    var statesById = {};
    var lastItems  = [];

    function stateOf(id){
      var s = statesById && statesById[id];
      return s && s.state ? String(s.state).toLowerCase() : '';
    }

    function priorityLevel(a){
      var n = Number(a && a.priority);
      return Number.isFinite(n) ? n : 1;
    }
    function isUrgent(a){ return priorityLevel(a) >= 3; }

    function postAction(action, payloadObj){
      var token = window.QA_UTIL ? window.QA_UTIL.getToken() : null;
      if (!token) return Promise.reject(new Error('Missing session token.'));

      var body = new URLSearchParams();
      body.set('action', action);
      body.set('token', token);

      if (payloadObj){
        Object.keys(payloadObj).forEach(function(k){
          body.set(k, (payloadObj[k] == null) ? '' : String(payloadObj[k]));
        });
      }

      return fetch(API_URL, {
        method:'POST',
        headers:{ 'Content-Type':'application/x-www-form-urlencoded' },
        body: body
      }).then(function(r){ return r.json(); });
    }

    function renderEmpty() {
      elSub.textContent = 'You are up to date.';
      elBody.innerHTML =
        '<div style="margin-top:6px;font-size:13px;color:#5b6a68;line-height:1.5;">' +
          '<p style="margin:0 0 6px;">You have seen all the latest announcements for this course.</p>' +
          '<p style="margin:0;">You can view all past announcements on the ' +
            '<a href="' + (elViewAll ? elViewAll.href : '#') + '" style="color:#0b7a75;font-weight:600;text-decoration:none;">Announcements page</a>.' +
          '</p>' +
        '</div>';
    }

    function renderError(msg){
      elSub.textContent = 'Announcements not available right now.';
      elBody.innerHTML =
        '<div style="margin-top:8px;font-size:13px;color:#b91c1c;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:8px 10px;">' +
          (msg || 'Could not load announcements.') +
        '</div>';
    }

    /* ---- Safe rich rendering ---- */
    function qaIsSafeHref(href){
      if(!href) return false;

      href = String(href).trim();

      // allow placeholder/JS-free buttons
      if (href === '#') return true;

      // allow internal Blogger page links
      if (href.indexOf('/p/') === 0) return true;

      // allow absolute safe links
      return /^(https?:|mailto:)/i.test(href);
    }

    function qaIsSafeSrc(src){
      if(!src) return false;
      return /^(https?:|data:image\/)/i.test(src);
    }
    function qaDecodeHtmlEntities(html){
      var t = document.createElement('textarea');
      t.innerHTML = html;
      return t.value;
    }
    function qaSanitizeHtmlToFragment(html){
      var template = document.createElement('template');
      template.innerHTML = qaDecodeHtmlEntities(html);

      var allowedTags = {
        P:1, BR:1, STRONG:1, B:1, EM:1, I:1,
        UL:1, OL:1, LI:1,
        A:1, IMG:1,
        CODE:1, PRE:1, DIV:1
      };

      var walker = document.createTreeWalker(template.content, NodeFilter.SHOW_ELEMENT, null);
      var toRemove = [];

      while(walker.nextNode()){
        var el = walker.currentNode;

        if(!allowedTags[el.tagName]){
          toRemove.push(el);
          continue;
        }

        // strip dangerous attrs
        [].slice.call(el.attributes).forEach(function(attr){
          var n = attr.name.toLowerCase();
          var v = attr.value;

          // never allow event handlers or styles
          if (n.indexOf('on') === 0 || n === 'style') {
            el.removeAttribute(attr.name);
            return;
          }

          if(el.tagName === 'A'){
            if(n === 'href' && qaIsSafeHref(v)) return;

            // keep styling + action metadata
            if(n === 'data-qa') return;                 // button styling hook
            if(n === 'data-qa-fixed-quiz') return;      // quiz id hook
            if(n === 'data-qa-quiz-id') return;         // (optional alias)
            if(n === 'data-qa-mode') return;            // instant|timed
            if(n === 'data-qa-action') return;          // generic action hook if you use it later

            if(n === 'target' || n === 'rel') return;
          }

          if(el.tagName === 'IMG'){
            if(n === 'src' && qaIsSafeSrc(v)) return;
            if(n === 'alt') return;
          }

          // only allow class (for our own styling hooks)
          if(n === 'class') return;

          el.removeAttribute(attr.name);
        });

        if (el.tagName === 'A') {
          var href = el.getAttribute('href') || '';
          href = String(href).trim();

          var isExternal = /^(https?:|mailto:)/i.test(href);
          if (isExternal) {
            el.setAttribute('target', '_blank');
            el.setAttribute('rel', 'noopener noreferrer');
          } else {
            // keep internal links and action buttons in same tab
            el.removeAttribute('target');
            el.removeAttribute('rel');
          }
        }

      }

      toRemove.forEach(function(el){
        el.replaceWith(document.createTextNode(el.textContent || ''));
      });

      return template.content;
    }

    function qaRenderAnnouncementBody(container, a){
      container.innerHTML = '';
      var html = (a.body_html || '').trim();
      var text = (a.body_text || '').trim();
      var raw  = (a.body || '').trim();

      if(html){
        container.appendChild(qaSanitizeHtmlToFragment(html));
        return;
      }

      var fallback = text || raw;
      if(fallback){
        var p = document.createElement('p');
        p.textContent = fallback;
        container.appendChild(p);
      }
    }

    function renderAnnouncements(items) {
      lastItems = Array.isArray(items) ? items.slice() : [];

      if (!lastItems.length) { renderEmpty(); return; }

      // hide SEEN + DISMISSED
      var visibleItems = lastItems.filter(function (a) {
        var id = String(a.announcement_id || a.id || a.ann_id || '').trim();
        if (!id) return false;
        var st = stateOf(id);
        return st !== 'seen' && st !== 'dismissed';
      });

      if (!visibleItems.length) { renderEmpty(); return; }

      elSub.textContent = 'Latest updates for this course.';
      elBody.innerHTML = '';
      elBody.classList.add('qa-ann-body');

      var ul = document.createElement('ul');
      ul.style.listStyle = 'none';
      ul.style.margin = '0';
      ul.style.padding = '0';

      visibleItems.sort(function(a,b){
        if (isUrgent(a) !== isUrgent(b)) return isUrgent(a) ? -1 : 1;
        if (!!a.pinned !== !!b.pinned) return a.pinned ? -1 : 1;
        return new Date(b.created_at || 0) - new Date(a.created_at || 0);
      });

      visibleItems.forEach(function (a) {
        var id = String(a.announcement_id || a.id || a.ann_id || '').trim();
        var titleTxt = (a.title || '').trim() || 'Update';

        var start = window.QA_UTIL ? window.QA_UTIL.parseDate(a.start_at || a.created_at) : new Date(a.start_at || a.created_at);
        var end   = window.QA_UTIL ? window.QA_UTIL.parseDate(a.end_at) : new Date(a.end_at);
        if (start && isNaN(start.getTime())) start = null;
        if (end && isNaN(end.getTime())) end = null;

        var when  = start ? (window.QA_UTIL ? window.QA_UTIL.fmtShortDate(start) : start.toDateString()) : '';
        var urgent = isUrgent(a);
        var pinned = !!a.pinned;

        var li = document.createElement('li');
        li.setAttribute('data-ann-id', id);
        li.style.padding = '10px 12px';
        li.style.borderRadius = '12px';
        li.style.margin = '0 0 10px';
        li.style.border = urgent ? '1px solid #fecaca' : '1px solid rgba(148,163,184,.35)';
        li.style.background = urgent ? '#fff7f7' : '#ffffff';

        var top = document.createElement('div');
        top.style.display = 'flex';
        top.style.justifyContent = 'space-between';
        top.style.gap = '8px';
        top.style.flexWrap = 'wrap';

        var left = document.createElement('div');
        left.style.flex = '1';
        left.style.minWidth = '220px';

        var title = document.createElement('div');
        title.style.fontSize = '14px';
        title.style.fontWeight = '700';
        title.style.color = '#0f172a';
        title.style.marginBottom = '3px';
        title.textContent = titleTxt;

        var body = document.createElement('div');
        body.style.fontSize = '13px';
        body.style.color = '#4b5563';
        body.style.lineHeight = '1.45';
        body.style.marginBottom = '4px';
        qaRenderAnnouncementBody(body, a);

        var metaTxt = '';
        if (when) metaTxt += ('From: ' + when);
        if (end)  metaTxt += (metaTxt ? ' • ' : '') + 'Until: ' + (window.QA_UTIL ? window.QA_UTIL.fmtShortDate(end) : end.toDateString());

        var meta = document.createElement('div');
        meta.style.fontSize = '12px';
        meta.style.color = '#94a3b8';
        meta.textContent = metaTxt;

        left.appendChild(title);
        left.appendChild(body);
        if (metaTxt) left.appendChild(meta);

        var right = document.createElement('div');
        right.style.display = 'flex';
        right.style.gap = '6px';
        right.style.flexWrap = 'wrap';
        right.style.alignItems = 'flex-start';

        function chip(txt, fg, bg, bd){
          var s = document.createElement('span');
          s.textContent = txt;
          s.style.fontSize = '11px';
          s.style.fontWeight = '600';
          s.style.borderRadius = '999px';
          s.style.padding = '2px 8px';
          s.style.color = fg;
          s.style.background = bg;
          if (bd) s.style.border = '1px solid ' + bd;
          return s;
        }

        if (pinned) right.appendChild(chip('Pinned', '#0b7a75', '#e0f2f1'));
        if (urgent) right.appendChild(chip('Urgent', '#b91c1c', '#fef2f2'));
        right.appendChild(chip('New', '#3730a3', '#eef2ff', '#c7d2fe'));

        top.appendChild(left);
        top.appendChild(right);

        var actions = document.createElement('div');
        actions.style.marginTop = '8px';

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('data-action', 'markread');
        btn.style.padding = '6px 10px';
        btn.style.borderRadius = '10px';
        btn.style.border = '1px solid rgba(11,122,117,.35)';
        btn.style.background = '#e0f2f1';
        btn.style.color = '#0b7a75';
        btn.style.fontSize = '12px';
        btn.style.fontWeight = '650';
        btn.style.cursor = 'pointer';
        btn.textContent = 'Mark as read';

        actions.appendChild(btn);

        li.appendChild(top);
        li.appendChild(actions);
        ul.appendChild(li);
      });

      elBody.appendChild(ul);
    }

    // Mark as read (delegated)
    elBody.addEventListener('click', function(ev){
      var btn = ev.target && ev.target.closest ? ev.target.closest('button[data-action="markread"]') : null;
      if (!btn) return;

      var li = btn.closest('li[data-ann-id]');
      var id = li ? (li.getAttribute('data-ann-id') || '').trim() : '';
      if (!id) return;

      btn.disabled = true;
      btn.textContent = 'Marking...';

      postAction('announcements.markseen', { payload: JSON.stringify({ items: [id] }) })
        .then(function(resp){
          if (!resp || resp.ok !== true) throw new Error((resp && resp.error) || 'markSeen_failed');
          statesById[id] = Object.assign({}, statesById[id] || {}, { state:'seen' });
          renderAnnouncements(lastItems);
        })
        .catch(function(e){
          btn.disabled = false;
          btn.textContent = 'Mark as read';
          renderError('Could not mark as read: ' + e.message);
        });
    });

    // Fixed-quiz + button links (delegated)
    elBody.addEventListener('click', function(ev){
      var a = ev.target && ev.target.closest ? ev.target.closest('a') : null;
      if (!a) return;

      // 1) Fixed quiz button inside announcement
      var quizId = a.getAttribute('data-qa-fixed-quiz') || a.getAttribute('data-qa-quiz-id');
      if (quizId) {
        ev.preventDefault();
        ev.stopPropagation();

        var mode = (a.getAttribute('data-qa-mode') || '').trim().toLowerCase();
        if (mode !== 'timed') mode = 'instant';

        // UI lock
        var oldText = a.textContent;
        a.style.opacity = '0.7';
        a.style.pointerEvents = 'none';
        a.textContent = 'Starting…';

        // Spawn attempt (send both flat fields + payload for compatibility)
        var uid = (window.QA_USER && window.QA_USER.user_id) || (function(){
          try { return localStorage.getItem('qa_user_id'); } catch(e){ return ''; }
        })();

        postAction('fixed.spawn', {
          quiz_id: quizId,
          mode: mode,
          user_id: uid,
          payload: JSON.stringify({
            quiz_id: quizId,
            mode: mode,
            course_id: COURSE_ID,
            user_id: uid
          })
        })
        .then(function(resp){
          // ✅ Treat attempt_id as success even if ok=false
          var attemptId = resp && (resp.attempt_id || resp.attemptId || resp.id) || '';
          if (!attemptId) {
            throw new Error((resp && resp.error) || 'fixed_spawn_failed');
          }

          var instantUrl = (cfg.INSTANT_RUNNER_URL || 'https://nursing2000a.blogspot.com/p/instant-ruuner-for-quiz-builder.html');
          var timedUrl   = (cfg.TIMED_RUNNER_URL   || 'https://nursing2000a.blogspot.com/p/timed-ruuner-for-quiz-builder.html');

          var runner = (mode === 'timed') ? timedUrl : instantUrl;
          var sep = runner.indexOf('?') === -1 ? '?' : '&';
          window.location.href = runner + sep + 'quiz_id=' + encodeURIComponent(attemptId);
        })
        .catch(function(e){
          // ✅ Restore the link (don’t wipe the whole announcements list)
          a.style.opacity = '';
          a.style.pointerEvents = '';
          a.textContent = oldText || 'Start';

          // show a small inline error under this announcement only
          var host = a.closest('li[data-ann-id]') || elBody;
          var prev = host.querySelector('.qa-inline-quiz-error');
          if (prev) prev.remove();

          var div = document.createElement('div');
          div.className = 'qa-inline-quiz-error';
          div.style.marginTop = '8px';
          div.style.fontSize = '12px';
          div.style.color = '#8f2727';
          div.style.background = '#fff5f5';
          div.style.border = '1px solid #ffb3b3';
          div.style.borderRadius = '10px';
          div.style.padding = '8px 10px';
          div.textContent = 'Could not start quiz: ' + (e && e.message ? e.message : 'fixed_spawn_failed');

          host.appendChild(div);
        });

        return;
      }

      // 2) General internal button links behave normally (same tab)
    });

    function loadAnnouncements() {
      if (!API_URL) { renderEmpty(); return; }

      var token = window.QA_UTIL ? window.QA_UTIL.getToken() : null;
      if (!token) { renderError('Missing session token. Please sign in again.'); return; }

      elSub.textContent = 'Checking for announcements...';
      elBody.innerHTML =
        '<p style="margin:6px 0 0;font-size:13px;color:#5b6a68;">Please wait while we load the latest updates for this course.</p>';

      var params = new URLSearchParams();
      params.set('action', 'announcements.list');
      params.set('token', token);
      params.set('mode', 'archive');
      params.set('limit', '5');
      params.set('course_id', COURSE_ID);

      fetch(API_URL + '?' + params.toString())
        .then(function(res){ return res.json(); })
        .then(function(data){
          if (data && data.ok === false) { renderEmpty(); return; }
          statesById = (data && data.states && typeof data.states === 'object') ? data.states : {};
          var items = Array.isArray(data && data.items) ? data.items : [];
          renderAnnouncements(items);
        })
        .catch(function(err){
          console.error('Course announcements error', err);
          renderEmpty();
        });
    }

    loadAnnouncements();
  })();
}
</script>

<!-- 3B) FIXED QUIZZES PREVIEW -->
<script>
function qaLoadFixedQuizzes() {
  (function () {
    'use strict';

    var COURSE_ID = window.QA_COURSE_ID || 'GP';
    var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};
    var API_URL = cfg.BUILDER_API_URL || '';

    var elMsg         = document.getElementById('qa-fixed-msg');
    var elListsWrap   = document.getElementById('qa-fixed-lists');
    var elPreviewList = document.getElementById('qa-fixed-preview-list');
    var elViewAllWrap = document.getElementById('qa-fixed-view-all-wrap');
    var elViewAllBtn  = document.getElementById('qa-fixed-view-all-btn');

    if (!elMsg || !elListsWrap || !elPreviewList) return;

    var MAX_PREVIEW = 4;

    function setMsg(text, isError) {
      elMsg.style.display = text ? 'block' : 'none';
      if (!text) return;
      elMsg.textContent       = text;
      elMsg.style.borderColor = isError ? '#ffb3b3' : 'rgba(0,0,0,.06)';
      elMsg.style.background  = isError ? '#fff5f5' : '#ffffff';
      elMsg.style.color       = isError ? '#8f2727' : '#4a5a56';
    }

    function parseDate(val) { return window.QA_UTIL ? window.QA_UTIL.parseDate(val) : new Date(val); }
    function formatShort(d) { return window.QA_UTIL ? window.QA_UTIL.fmtShortDate(d) : (d ? d.toDateString() : ''); }

    function formatDateInfo(q) {
      var pub    = parseDate(q.publish_at);
      var unpub  = parseDate(q.unpublish_at);
      var status = String(q.status || '').toUpperCase();

      if (pub && isNaN(pub.getTime())) pub = null;
      if (unpub && isNaN(unpub.getTime())) unpub = null;

      if (status === 'UPCOMING') {
        if (pub) return 'Opens: ' + formatShort(pub);
        return 'Opens soon';
      }
      if (status === 'ACTIVE') {
        if (pub && unpub) return 'Open: ' + formatShort(pub) + ' – ' + formatShort(unpub);
        if (pub) return 'Open since: ' + formatShort(pub);
        if (unpub) return 'Closes: ' + formatShort(unpub);
        return 'Currently open';
      }
      if (status === 'CLOSED') {
        if (unpub) return 'Closed: ' + formatShort(unpub);
        return 'Closed';
      }
      return '';
    }

    function createStatusChip(statusUpper) {
      var chip = document.createElement('span');
      chip.style.display      = 'inline-block';
      chip.style.borderRadius = '999px';
      chip.style.padding      = '1px 7px';
      chip.style.fontSize     = '10px';
      chip.style.fontWeight   = '600';
      chip.style.marginLeft   = '6px';

      if (statusUpper === 'ACTIVE') {
        chip.textContent      = 'Active now';
        chip.style.background = '#ecfbf8';
        chip.style.border     = '1px solid #c7ebe1';
        chip.style.color      = '#0a6c67';
      } else if (statusUpper === 'UPCOMING') {
        chip.textContent      = 'Opens soon';
        chip.style.background = '#fff9ea';
        chip.style.border     = '1px solid #f2ddaa';
        chip.style.color      = '#6a4a0a';
      } else if (statusUpper === 'CLOSED') {
        chip.textContent      = 'Closed';
        chip.style.background = '#f4f5f7';
        chip.style.border     = '1px solid #d4d7de';
        chip.style.color      = '#4b5563';
      } else {
        chip.textContent      = statusUpper || 'Unknown';
        chip.style.background = '#eceff1';
        chip.style.border     = '1px solid #cfd8dc';
        chip.style.color      = '#374151';
      }
      return chip;
    }

    function applyCardStatusStyle(wrapper, statusUpper) {
      if (statusUpper === 'ACTIVE') wrapper.style.borderColor = '#0b7a75';
      else if (statusUpper === 'UPCOMING') wrapper.style.borderColor = '#f3d9a5';
      else if (statusUpper === 'CLOSED') wrapper.style.borderColor = '#d8dfdd';
      else wrapper.style.borderColor = 'rgba(0,0,0,.08)';
    }

    function sortQuizzes(quizzes) {
      var STATUS_ORDER = { 'ACTIVE': 0, 'UPCOMING': 1, 'CLOSED': 2 };

      return quizzes.slice().sort(function (a, b) {
        var sa = String(a.status || '').toUpperCase();
        var sb = String(b.status || '').toUpperCase();
        var ra = (sa in STATUS_ORDER) ? STATUS_ORDER[sa] : 99;
        var rb = (sb in STATUS_ORDER) ? STATUS_ORDER[sb] : 99;
        if (ra !== rb) return ra - rb;

        var da = parseDate(a.publish_at);
        var db = parseDate(b.publish_at);
        if (da && db && !isNaN(da.getTime()) && !isNaN(db.getTime())) return db - da;
        if (da && !isNaN(da.getTime()) && (!db || isNaN(db.getTime()))) return -1;
        if ((!da || isNaN(da.getTime())) && db && !isNaN(db.getTime())) return 1;
        return 0;
      });
    }

    function buildPreviewCard(q, fixedPageUrl) {
      var statusUpper = String(q.status || '').toUpperCase();
      var tUpper      = String(q.type   || '').toUpperCase();

      var card = document.createElement('div');
      card.className = 'gp-card gp-card-fixed ' + ((tUpper === 'TIMED') ? 'gp-card--timed' : 'gp-card--instant');

      applyCardStatusStyle(card, statusUpper);

      card.style.cursor = 'pointer';
      card.addEventListener('click', function () {
        window.location.href = fixedPageUrl;
      });

      var topRow = document.createElement('div');
      topRow.style.display        = 'flex';
      topRow.style.alignItems     = 'center';
      topRow.style.justifyContent = 'space-between';
      topRow.style.gap            = '6px';

      var title = document.createElement('div');
      title.style.fontWeight   = '700';
      title.style.fontSize     = '14px';
      title.style.marginBottom = '4px';
      title.textContent        = q.title || q.quiz_id || 'Untitled quiz';

      topRow.appendChild(title);
      topRow.appendChild(createStatusChip(statusUpper));

      var metaRow = document.createElement('div');
      metaRow.className = 'gp-meta';

      var typeLabel = (tUpper === 'TIMED') ? 'Timed exam' : 'Instant review';
      var parts     = [typeLabel];
      if (q.n) parts.push(q.n + ' questions');
      var dateInfo = formatDateInfo(q);
      if (dateInfo) parts.push(dateInfo);

      metaRow.textContent = parts.join(' - ');

      var hint = document.createElement('div');
      hint.style.marginTop = '4px';
      hint.style.fontSize  = '11px';
      hint.style.color     = '#6b7b79';
      hint.textContent     = 'Tap to open all fixed quizzes for this course.';

      card.appendChild(topRow);
      card.appendChild(metaRow);
      card.appendChild(hint);

      return card;
    }

    function renderPreview(quizzes) {
      elPreviewList.innerHTML = '';

      if (!quizzes.length) {
        elListsWrap.style.display = 'none';
        setMsg('No fixed quizzes are published for this course yet.', false);
        if (elViewAllWrap) elViewAllWrap.style.display = 'none';
        return;
      }

      var sorted  = sortQuizzes(quizzes);
      var preview = sorted.slice(0, MAX_PREVIEW);

      var fixedSlug = cfg.FIXED_QUIZZES_SLUG || 'fixed-quizzes';
      var fixedPageUrl = (window.QA_UTIL ? window.QA_UTIL.buildPageUrl(fixedSlug) : '/p/fixed-quizzes.html')
        + '?course_id=' + encodeURIComponent(COURSE_ID);

      preview.forEach(function (q) {
        elPreviewList.appendChild(buildPreviewCard(q, fixedPageUrl));
      });

      if (elViewAllWrap && elViewAllBtn) {
        elViewAllWrap.style.display = 'block';
        elViewAllBtn.href           = fixedPageUrl;
      }

      elListsWrap.style.display = 'block';
      setMsg('', false);
    }

    function loadFixedQuizzes() {
      if (!API_URL) {
        setMsg('Fixed quizzes are not available right now (API not configured).', true);
        return;
      }

      setMsg('Loading fixed quizzes...', false);

      var token = (window.QA_UTIL ? window.QA_UTIL.getToken() : null);
      var url = API_URL
        + '?action=coursequizzes'
        + '&course_id=' + encodeURIComponent(COURSE_ID)
        + (token ? ('&token=' + encodeURIComponent(token)) : '');

      fetch(url)
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.json();
        })
        .then(function (data) {
          if (!data || !Array.isArray(data.quizzes)) throw new Error('Invalid response shape');
          renderPreview(data.quizzes);
        })
        .catch(function (err) {
          setMsg('Failed to load fixed quizzes: ' + err.message, true);
          elListsWrap.style.display = 'none';
          if (elViewAllWrap) elViewAllWrap.style.display = 'none';
        });
    }

    loadFixedQuizzes();
  })();
}
</script>

<!-- 3C) LEGACY BLOGGER QUIZ LIST -->
<script>
function qaBootLegacyQuizzes() {
  (function () {
    'use strict';

    var COURSE_ID  = window.QA_COURSE_ID || 'GP';
    var PAGE_SIZE  = 20;
    var FEED_PATH  = '/feeds/posts/summary/-/' + encodeURIComponent(COURSE_ID);
    var LBL_TIMED   = 'QUIZ_TIMED_DEFERRED';
    var LBL_INSTANT = 'QUIZ_UNTIMED_INSTANT';

    var elMsg      = document.getElementById('qa-msg');
    var elMoreW    = document.getElementById('qa-more-wrap');
    var elMore     = document.getElementById('qa-more');
    var elSearch   = document.getElementById('qa-search');
    var elSort     = document.getElementById('qa-sort');
    var elTimed    = document.getElementById('qa-list-timed');
    var elInstant  = document.getElementById('qa-list-instant');
    var elEmptyT   = document.getElementById('qa-empty-timed');
    var elEmptyI   = document.getElementById('qa-empty-instant');

    if (!elMsg || !elSearch || !elSort || !elTimed || !elInstant) return;

    function syncOpen() {
      var wide = window.matchMedia('(min-width: 900px)').matches;
      document.querySelectorAll('.gp-sec').forEach(function (sec) {
        if (wide && !sec.open) sec.open = true;
      });
    }
    syncOpen();
    window.addEventListener('resize', syncOpen);

    document.querySelectorAll('.gp-sec > summary').forEach(function (sum) {
      sum.addEventListener('click', function () {
        if (window.matchMedia('(min-width: 900px)').matches) return;
        var parent = sum.parentElement;
        setTimeout(function () {
          if (parent.open) {
            document.querySelectorAll('.gp-sec').forEach(function (sib) {
              if (sib !== parent) sib.open = false;
            });
          }
        }, 0);
      });
    });

    var startIndex = 1;
    var allTimed   = [];
    var allInstant = [];
    var done       = false;

    function showMsg(t) { elMsg.textContent = t; elMsg.style.display = 'block'; }
    function hideMsg()  { elMsg.style.display = 'none'; }

    function fmtDate(iso) {
      var d = new Date(iso);
      if (isNaN(d)) return '';
      return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
    }

    function getLabels(entry) {
      return (entry.category || []).map(function (c) {
        return String(c.term || '').trim().toUpperCase();
      });
    }

    function extractEntry(entry) {
      var title = (entry.title && entry.title.$t) || 'Untitled';
      var href  = '#';
      if (entry.link && entry.link.length) {
        var alt = entry.link.find(function (l) { return l.rel === 'alternate'; });
        if (alt && alt.href) href = alt.href;
      }
      var published = (entry.published && entry.published.$t) || '';
      var labels    = getLabels(entry);
      return { title: title, url: href, published: published, labels: labels };
    }

    function card(item) {
      var li = document.createElement('li');
      li.className = 'gp-card';

      var a  = document.createElement('a');
      a.href = item.url;
      a.textContent = item.title;

      var d = fmtDate(item.published);
      var meta = document.createElement('div');
      meta.className = 'gp-meta';
      meta.textContent = d ? ('Published: ' + d) : '';

      li.appendChild(a);
      if (d) li.appendChild(meta);
      return li;
    }

    function sortItems(items, mode) {
      var arr = items.slice();
      if (mode === 'title') {
        arr.sort(function (a, b) { return String(a.title || '').localeCompare(String(b.title || '')); });
      } else if (mode === 'oldest') {
        arr.sort(function (a, b) { return new Date(a.published) - new Date(b.published); });
      } else {
        arr.sort(function (a, b) { return new Date(b.published) - new Date(a.published); });
      }
      return arr;
    }

    function applyFilters() {
      var q    = (elSearch.value || '').trim().toLowerCase();
      var mode = elSort.value;

      var timed   = allTimed.slice();
      var instant = allInstant.slice();

      if (q) {
        timed   = timed.filter(function (it) { return it.title.toLowerCase().indexOf(q) > -1; });
        instant = instant.filter(function (it) { return it.title.toLowerCase().indexOf(q) > -1; });
      }

      timed   = sortItems(timed, mode);
      instant = sortItems(instant, mode);

      elTimed.innerHTML = '';
      if (timed.length) {
        timed.forEach(function (it) { elTimed.appendChild(card(it)); });
        elEmptyT.style.display = 'none';
      } else {
        elEmptyT.style.display = 'block';
      }

      elInstant.innerHTML = '';
      if (instant.length) {
        instant.forEach(function (it) { elInstant.appendChild(card(it)); });
        elEmptyI.style.display = 'none';
      } else {
        elEmptyI.style.display = 'block';
      }

      if (!timed.length && !instant.length) showMsg('No quizzes published here yet.');
      else hideMsg();
    }

    async function fetchPage() {
      var url = FEED_PATH + '?alt=json&max-results=' + PAGE_SIZE + '&start-index=' + startIndex;
      var res = await fetch(url);
      if (!res.ok) throw new Error('Feed HTTP ' + res.status);
      var data = await res.json();

      var entries = (data.feed && data.feed.entry) || [];
      var items   = entries.map(extractEntry);

      items.forEach(function (it) {
        var hasTimed   = it.labels.indexOf(LBL_TIMED) > -1;
        var hasInstant = it.labels.indexOf(LBL_INSTANT) > -1;

        // keep your original behaviour: if both, treat as timed
        if (hasTimed) allTimed.push(it);
        else if (hasInstant) allInstant.push(it);
      });

      var total = Number(
        data.feed &&
        data.feed.openSearch$totalResults &&
        data.feed.openSearch$totalResults.$t
      ) || 0;

      startIndex += entries.length;
      if ((allTimed.length + allInstant.length) >= total || entries.length === 0) done = true;
      elMoreW.style.display = done ? 'none' : 'block';
    }

    async function boot() {
      try {
        await fetchPage();
        elSort.value = 'newest';
        applyFilters();
        if (!done) elMoreW.style.display = 'block';
        if (!allTimed.length && !allInstant.length) showMsg('No quizzes published here yet.');
        else hideMsg();
      } catch (err) {
        showMsg('Failed to load quizzes: ' + err.message);
      }
    }

    if (elMore) elMore.addEventListener('click', async function () {
      elMore.disabled    = true;
      elMore.textContent = 'Loading...';
      try {
        await fetchPage();
        applyFilters();
      } catch (err) {
        showMsg('Failed to load more: ' + err.message);
      } finally {
        elMore.disabled    = false;
        elMore.textContent = 'Load more';
      }
    });

    elSearch.addEventListener('input', applyFilters);
    elSort.addEventListener('change', applyFilters);

    boot();
  })();
}
</script>

