<!-- =================== QAcademy — Reset Password (Polished v2) =================== -->
<meta name="viewport" content="width=device-width, initial-scale=1" />

<style>
  :root{
    --brand:#0b7a75;
    --brand-soft:#e0f2f1;
    --muted:#6b7b7a;
    --paper:#ffffff;
    --bg:#f5f7fa;
    --danger:#b42318;
    --danger-soft:#fef2f2;
    --ok:#166534;
    --ok-soft:#ecfdf3;
  }

  body{
    margin:0;
    padding:0;
    background:var(--bg);
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  }

  .qa-rp-shell{
    min-height:70vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px 12px;
  }

  .qa-rp-card{
    width:100%;
    max-width:420px;
    background:var(--paper);
    border-radius:16px;
    box-shadow:0 16px 40px rgba(15,23,42,0.08);
    padding:20px 20px 18px;
    box-sizing:border-box;
  }

  .qa-rp-header{
    margin-bottom:12px;
  }

  .qa-rp-tag{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:4px 10px;
    border-radius:999px;
    background:var(--brand-soft);
    color:var(--brand);
    font-size:11px;
    font-weight:600;
    letter-spacing:.03em;
    text-transform:uppercase;
  }

  .qa-rp-title{
    margin:10px 0 4px;
    font-size:22px;
    font-weight:700;
    color:#0f172a;
  }

  .qa-rp-sub{
    margin:0;
    font-size:13px;
    color:var(--muted);
    line-height:1.5;
  }

  .qa-rp-info-box{
    margin:14px 0 16px;
    padding:10px 10px 10px;
    border-radius:10px;
    background:#f9fafb;
    border:1px solid #e5e7eb;
    font-size:12px;
    color:#4b5563;
  }

  .qa-rp-form-group{
    margin-bottom:12px;
  }

  .qa-rp-label{
    display:block;
    font-size:12px;
    font-weight:600;
    color:#111827;
    margin-bottom:4px;
  }

  .qa-rp-input{
    width:100%;
    box-sizing:border-box;
    padding:8px 10px;
    border-radius:10px;
    border:1px solid #d1d5db;
    font-size:13px;
    outline:none;
    transition:border-color .15s, box-shadow .15s;
  }
  .qa-rp-input:focus{
    border-color:var(--brand);
    box-shadow:0 0 0 1px rgba(11,122,117,0.2);
  }

  .qa-rp-help{
    font-size:11px;
    color:#6b7280;
    margin-top:4px;
  }

  .qa-rp-actions{
    margin-top:10px;
    display:flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }

  .qa-rp-btn-main{
    border:none;
    outline:none;
    padding:9px 16px;
    border-radius:999px;
    background:var(--brand);
    color:#ffffff;
    font-size:13px;
    font-weight:600;
    cursor:pointer;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }
  .qa-rp-btn-main[disabled]{
    opacity:.7;
    cursor:default;
  }

  .qa-rp-btn-link{
    border:none;
    background:none;
    padding:0;
    font-size:12px;
    color:var(--muted);
    text-decoration:underline;
    cursor:pointer;
  }

  .qa-rp-status{
    margin-top:12px;
    font-size:12px;
    border-radius:10px;
    padding:8px 10px;
    display:none;
  }

  .qa-rp-status.ok{
    display:block;
    background:var(--ok-soft);
    color:var(--ok);
    border:1px solid #86efac;
  }

  .qa-rp-status.error{
    display:block;
    background:var(--danger-soft);
    color:var(--danger);
    border:1px solid #fecaca;
  }

  .qa-rp-footer-note{
    margin-top:14px;
    font-size:11px;
    color:#9ca3af;
    text-align:center;
  }

  .qa-rp-loading{
    font-size:12px;
    color:#6b7280;
    display:flex;
    align-items:center;
    gap:8px;
    margin-top:10px;
  }

  .qa-rp-dot{
    width:8px;
    height:8px;
    border-radius:999px;
    background:var(--brand);
    animation:qa-rp-pulse 1.4s infinite ease-in-out;
  }

  @keyframes qa-rp-pulse{
    0%,80%,100%{ transform:scale(1); opacity:0.4; }
    40%{ transform:scale(1.4); opacity:1; }
  }

  /* ===== Reset Password: polished live validation UI ===== */
  .qa-rp-field-row{
    position: relative;
    display: flex;
    align-items: center;
  }

  .qa-rp-field-row .qa-rp-input{
    padding-right: 74px; /* space for the toggle button */
  }

  .qa-rp-toggle{
    position:absolute;
    right:8px;
    top:50%;
    transform:translateY(-50%);
    border:1px solid #d1d5db;
    background:#ffffff;
    color:#374151;
    border-radius:999px;
    padding:6px 10px;
    font-size:12px;
    font-weight:600;
    cursor:pointer;
  }
  .qa-rp-toggle:active{ transform:translateY(-50%) scale(0.98); }
.qa-rp-field-row{ position:relative; }
.qa-rp-field-row .qa-rp-input{ position:relative; z-index:1; }
.qa-rp-toggle{ z-index:5; }

  .qa-rp-inline-msg{
    margin-top:6px;
    font-size:12px;
    color:#6b7280;
  }
  .qa-rp-inline-msg.ok{ color: var(--ok); }
  .qa-rp-inline-msg.bad{ color: var(--danger); }

  .qa-rp-checklist{
    margin-top:8px;
    display:grid;
    gap:6px;
    font-size:12px;
    color:#4b5563;
  }

  .qa-rp-checkitem{
    display:flex;
    align-items:center;
    gap:8px;
  }

  .qa-rp-dotmini{
    width:10px;
    height:10px;
    border-radius:999px;
    background:#e5e7eb;
    border:1px solid #d1d5db;
    flex: 0 0 auto;
  }

  .qa-rp-checkitem.ok .qa-rp-dotmini{
    background: #bbf7d0;
    border-color: #86efac;
  }
  .qa-rp-checkitem.bad .qa-rp-dotmini{
    background: #fecaca;
    border-color: #fca5a5;
  }

  .qa-rp-meter{
    margin-top:10px;
    height:10px;
    border-radius:999px;
    background:#eef2f7;
    border:1px solid #e5e7eb;
    overflow:hidden;
  }

  .qa-rp-meterbar{
    height:100%;
    width:0%;
    background: var(--brand);
    transition: width .18s ease;
  }
</style>

<div class="qa-rp-shell">
  <div class="qa-rp-card" id="qa-rp-root">
    <!-- Header -->
    <div class="qa-rp-header">
      <div class="qa-rp-tag">
        <span style="width:7px;height:7px;border-radius:999px;background:var(--brand);display:inline-block;"></span>
        QAcademy - Secure reset
      </div>
      <h2 class="qa-rp-title">Reset your password</h2>
      <p class="qa-rp-sub">
        Choose a new password for your QAcademy account.
      </p>
    </div>

    <!-- LOADING STATE -->
    <div id="qa-rp-loading-block" class="qa-rp-loading">
      <div class="qa-rp-dot"></div>
      <div>Checking your reset link...</div>
    </div>

    <!-- ERROR BLOCK (invalid/expired link) -->
    <div id="qa-rp-error-block" style="display:none;">
      <div class="qa-rp-status error" style="display:block;margin-top:4px;">
        This reset link is invalid or has expired.
      </div>
      <div style="margin-top:10px;font-size:12px;color:#4b5563;">
        Password reset links can only be used once and expire after a short time.
        Please request a new reset link and try again.
      </div>
      <div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap;">
        <button type="button" class="qa-rp-btn-main" id="qa-rp-error-forgot">
          Request new reset link
        </button>
        <button type="button" class="qa-rp-btn-link" id="qa-rp-error-login">
          Back to login
        </button>
      </div>
    </div>

    <!-- MAIN FORM BLOCK (new password) -->
    <div id="qa-rp-form-block" style="display:none;">
      <div class="qa-rp-info-box">
        Use a strong password that you haven't used on QAcademy before.
        It should be at least 8 characters and include a letter, a number, and a symbol.
      </div>

      <div class="qa-rp-form-group">
        <label class="qa-rp-label" for="qa-rp-pass">New password</label>

        <div class="qa-rp-field-row">
          <input
            id="qa-rp-pass"
            class="qa-rp-input"
            type="password"
            autocomplete="new-password"
            placeholder="Enter a new password"
          />
          <button type="button" class="qa-rp-toggle" data-target="qa-rp-pass" aria-pressed="false">Show</button>
        </div>

        <div class="qa-rp-help">
          Minimum 8 characters, including at least one letter, one number, and one symbol.
        </div>

        <div id="qa-rp-checklist" class="qa-rp-checklist" aria-live="polite"></div>

        <div class="qa-rp-meter" aria-hidden="true">
          <div id="qa-rp-meterbar" class="qa-rp-meterbar"></div>
        </div>
        <div id="qa-rp-strength" class="qa-rp-help"></div>
      </div>

      <div class="qa-rp-form-group">
        <label class="qa-rp-label" for="qa-rp-pass2">Confirm new password</label>

        <div class="qa-rp-field-row">
          <input
            id="qa-rp-pass2"
            class="qa-rp-input"
            type="password"
            autocomplete="new-password"
            placeholder="Re-type the new password"
          />
          <button type="button" class="qa-rp-toggle" data-target="qa-rp-pass2" aria-pressed="false">Show</button>
        </div>

        <div id="qa-rp-match" class="qa-rp-inline-msg" aria-live="polite"></div>
      </div>

      <div class="qa-rp-actions">
        <button id="qa-rp-submit" class="qa-rp-btn-main" disabled="disabled">
          <span id="qa-rp-btn-text">Set new password</span>
          <span id="qa-rp-btn-spinner" style="display:none;">Saving...</span>
        </button>
        <button type="button" class="qa-rp-btn-link" id="qa-rp-cancel-login">
          Cancel and go to login
        </button>
      </div>

      <!-- Status message (validation / backend errors) -->
      <div id="qa-rp-status" class="qa-rp-status"></div>
    </div>

    <!-- SUCCESS BLOCK -->
    <div id="qa-rp-success-block" style="display:none;">
      <div class="qa-rp-status ok" style="display:block;margin-top:4px;">
        Your password has been changed successfully.
      </div>
      <div style="margin-top:10px;font-size:12px;color:#4b5563;">
        You can now sign in to QAcademy with your new password.
      </div>
      <div style="margin-top:16px;text-align:center;">
        <button type="button" class="qa-rp-btn-main" id="qa-rp-success-login">
          Go to login
        </button>
      </div>
    </div>

    <div class="qa-rp-footer-note">
      For your security, this link can only be used once.
    </div>
  </div>
</div>

<script>
  // ================== CONFIG ==================
  // Same Auth v3 WebApp URL used by login/guard:
  const AUTH_URL = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";

  // Slugs (adjust to your real pages)
  const LOGIN_SLUG  = "login_23";          // login page slug
  const FORGOT_SLUG = "forgot-password";   // forgot password page slug (update to your slug)

  const LOGIN_URL   = "/p/" + LOGIN_SLUG + ".html";
  const FORGOT_URL  = "/p/" + FORGOT_SLUG + ".html";

  // ================== HELPERS ==================
  function qaRpShowStatus(kind, msg){
    const box = document.getElementById("qa-rp-status");
    if(!box) return;
    box.classList.remove("ok","error");
    if(!msg){
      box.style.display = "none";
      return;
    }
    box.textContent = msg;
    box.classList.add(kind === "error" ? "error" : "ok");
  }

  function qaRpShowBlock(id){
    const ids = ["qa-rp-loading-block","qa-rp-error-block","qa-rp-form-block","qa-rp-success-block"];
    ids.forEach(function(x){
      const el = document.getElementById(x);
      if(!el) return;
      el.style.display = (x === id) ? (x === "qa-rp-loading-block" ? "flex" : "block") : "none";
    });
  }

  function qaRpGetParam(name){
    const params = new URLSearchParams(window.location.search || "");
    return params.get(name) || "";
  }

  // Password rule: 8+ chars, letter + number + symbol
  function qaRpValidatePassword(pw){
    if(!pw || pw.length < 8){
      return "Password must be at least 8 characters long.";
    }
    if(!/[A-Za-z]/.test(pw)){
      return "Password must include at least one letter.";
    }
    if(!/[0-9]/.test(pw)){
      return "Password must include at least one number.";
    }
    if(!/[^A-Za-z0-9]/.test(pw)){
      return "Password must include at least one symbol (e.g. ! @ # ?).";
    }
    return "";
  }

  // ===== Live validation helpers =====
  function qaRpSignals(pw){
    return {
      len: (pw || "").length >= 8,
      letter: /[A-Za-z]/.test(pw || ""),
      number: /[0-9]/.test(pw || ""),
      symbol: /[^A-Za-z0-9]/.test(pw || "")
    };
  }

  function qaRpStrengthScore(pw){
    const s = qaRpSignals(pw);
    let score = 0;
    if (s.len) score++;
    if (s.letter) score++;
    if (s.number) score++;
    if (s.symbol) score++;
    if ((pw || "").length >= 12) score = Math.min(5, score + 1);
    return score; // 0..5
  }

  function qaRpRenderChecklist(pw){
    const box = document.getElementById("qa-rp-checklist");
    if (!box) return;

    const s = qaRpSignals(pw);

    const items = [
      { ok: s.len,    text: "At least 8 characters" },
      { ok: s.letter, text: "Contains a letter (A-Z)" },
      { ok: s.number, text: "Contains a number (0-9)" },
      { ok: s.symbol, text: "Contains a symbol (e.g. ! @ # ?)" }
    ];

    box.innerHTML = items.map(function(it){
      return (
        '<div class="qa-rp-checkitem ' + (it.ok ? 'ok' : 'bad') + '">' +
          '<span class="qa-rp-dotmini" aria-hidden="true"></span>' +
          '<span>' + it.text + '</span>' +
        '</div>'
      );
    }).join("");
  }

  function qaRpRenderStrength(pw){
    const bar = document.getElementById("qa-rp-meterbar");
    const txt = document.getElementById("qa-rp-strength");
    if (!bar || !txt) return;

    const score = qaRpStrengthScore(pw); // 0..5
    const pct = Math.round((score / 5) * 100);

    bar.style.width = pct + "%";

    let label = "";
    if (!pw) label = "";
    else if (score <= 2) label = "Strength: Weak";
    else if (score === 3) label = "Strength: Fair";
    else if (score === 4) label = "Strength: Good";
    else label = "Strength: Strong";

    txt.textContent = label;
  }

  function qaRpUpdateMatch(pw1, pw2){
    const el = document.getElementById("qa-rp-match");
    if (!el) return;

    if (!pw2){
      el.textContent = "";
      el.classList.remove("ok","bad");
      return;
    }

    if (pw1 === pw2){
      el.textContent = "Passwords match.";
      el.classList.remove("bad");
      el.classList.add("ok");
    } else {
      el.textContent = "Passwords do not match.";
      el.classList.remove("ok");
      el.classList.add("bad");
    }
  }

  function qaRpIsReady(){
    const passEl  = document.getElementById("qa-rp-pass");
    const pass2El = document.getElementById("qa-rp-pass2");
    if (!passEl || !pass2El) return false;

    const pw1 = passEl.value || "";
    const pw2 = pass2El.value || "";

    const ruleMsg = qaRpValidatePassword(pw1);
    const matchOk = (!!pw2 && pw1 === pw2);
    return (!ruleMsg && matchOk);
  }

  function qaRpSetSubmitEnabled(enabled){
    const btn = document.getElementById("qa-rp-submit");
    if (!btn) return;
    if (enabled) btn.removeAttribute("disabled");
    else btn.setAttribute("disabled","disabled");
  }

  function qaRpLiveValidate(){
    const passEl  = document.getElementById("qa-rp-pass");
    const pass2El = document.getElementById("qa-rp-pass2");
    if (!passEl || !pass2El) return;

    const pw1 = passEl.value || "";
    const pw2 = pass2El.value || "";

    qaRpRenderChecklist(pw1);
    qaRpRenderStrength(pw1);
    qaRpUpdateMatch(pw1, pw2);

    qaRpSetSubmitEnabled(qaRpIsReady());
    qaRpShowStatus("", "");
  }

let _qaRpTogglesBound = false;

function qaRpWireToggles(){
  if (_qaRpTogglesBound) return;
  _qaRpTogglesBound = true;

  document.addEventListener("click", function(ev){
    const btn = ev.target && ev.target.closest ? ev.target.closest(".qa-rp-toggle") : null;
    if(!btn) return;

    ev.preventDefault();
    ev.stopPropagation();

    const id = btn.getAttribute("data-target");
    const input = document.getElementById(id);
    if(!input) return;

    const isPw = (input.getAttribute("type") === "password");
    input.setAttribute("type", isPw ? "text" : "password");
    btn.textContent = isPw ? "Hide" : "Show";
    btn.setAttribute("aria-pressed", isPw ? "true" : "false");
    input.focus();
  }, true);
}



  function qaRpSetLoading(isLoading){
    const btn      = document.getElementById("qa-rp-submit");
    const textSpan = document.getElementById("qa-rp-btn-text");
    const spinSpan = document.getElementById("qa-rp-btn-spinner");
    if(!btn || !textSpan || !spinSpan) return;

    if(isLoading){
      btn.setAttribute("disabled","disabled");
      textSpan.style.opacity = ".6";
      spinSpan.style.display = "inline";
    } else {
      // do NOT force-enable; restore according to current validity
      textSpan.style.opacity = "1";
      spinSpan.style.display = "none";
      qaRpSetSubmitEnabled(qaRpIsReady());
    }
  }

  // ================== API CALLS ==================
  async function qaRpCheckLink(rid, rt){
    qaRpShowBlock("qa-rp-loading-block");
    qaRpShowStatus("", "");

    if(!rid || !rt){
      qaRpShowBlock("qa-rp-error-block");
      return;
    }

    const body = new URLSearchParams();
    body.append("action","reset_check");
    body.append("request_id", rid);
    body.append("reset_token", rt);
    body.append("ua", navigator.userAgent || "");
    body.append("ip", "browser");

    try{
      const resp = await fetch(AUTH_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body
      });

      const text = await resp.text();
      let json = null;
      try{ json = JSON.parse(text); } catch(e){}

      // Expectation: json = { ok:true, status:"valid"|"expired"|"used"|... }
      if(json && json.ok && (json.status === "valid" || !json.status)){
        qaRpShowBlock("qa-rp-form-block");
        setTimeout(function(){
          const p = document.getElementById("qa-rp-pass");
          if (p) p.focus();
          qaRpWireToggles();
          qaRpLiveValidate();
        }, 0);
      } else {
        qaRpShowBlock("qa-rp-error-block");
      }
    } catch(err){
      qaRpShowBlock("qa-rp-error-block");
    }
  }

  async function qaRpSubmitNewPassword(rid, rt){
    const passEl  = document.getElementById("qa-rp-pass");
    const pass2El = document.getElementById("qa-rp-pass2");
    if(!passEl || !pass2El) return;

    // IMPORTANT: do NOT trim passwords
    const pw1 = (passEl.value || "");
    const pw2 = (pass2El.value || "");

    // Client-side validation
    const ruleMsg = qaRpValidatePassword(pw1);
    if(ruleMsg){
      qaRpShowStatus("error", ruleMsg);
      return;
    }
    if(pw1 !== pw2){
      qaRpShowStatus("error","Passwords do not match. Please try again.");
      return;
    }

    if(!rid || !rt){
      qaRpShowStatus("error","This reset link is missing required information. Please request a new link.");
      return;
    }

    qaRpShowStatus("", "");
    qaRpSetLoading(true);

    const body = new URLSearchParams();
    body.append("action","reset_apply");
    body.append("request_id", rid);
    body.append("reset_token", rt);
    body.append("new_password", pw1);
    body.append("ua", navigator.userAgent || "");
    body.append("ip", "browser");

    try{
      const resp = await fetch(AUTH_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body
      });

      const text = await resp.text();
      let json = null;
      try{ json = JSON.parse(text); } catch(e){}

      if(json && json.ok){
        qaRpShowBlock("qa-rp-success-block");
        passEl.value = "";
        pass2El.value = "";
      } else if(json && json.error){
        const code = String(json.error || "").toLowerCase();
        if(code === "link_expired" || code === "reset_expired" || code === "invalid_token" || code === "invalid_request"){
          qaRpShowStatus("", "");
          qaRpShowBlock("qa-rp-error-block");
        } else if(code === "password_policy_failed"){
          qaRpShowStatus("error","Your new password does not meet the security requirements. Please choose a stronger password.");
        } else {
          qaRpShowStatus("error","We could not change your password. Please try again or request a new link.");
        }
      } else {
        qaRpShowStatus("error","We could not change your password. Please try again or request a new link.");
      }
    } catch(err){
      qaRpShowStatus("error","We could not contact the server. Please try again in a few minutes.");
    } finally {
      qaRpSetLoading(false);
    }
  }

  // ================== INIT ==================
  (function(){
    const rid = qaRpGetParam("rid");
    const rt  = qaRpGetParam("rt");

    // Start by checking the link
    qaRpCheckLink(rid, rt);

    const submitBtn       = document.getElementById("qa-rp-submit");
    const cancelLoginBtn  = document.getElementById("qa-rp-cancel-login");
    const successLoginBtn = document.getElementById("qa-rp-success-login");
    const errorForgotBtn  = document.getElementById("qa-rp-error-forgot");
    const errorLoginBtn   = document.getElementById("qa-rp-error-login");
    const passInput       = document.getElementById("qa-rp-pass");
    const pass2Input      = document.getElementById("qa-rp-pass2");

    // Submit disabled until requirements are met
    qaRpSetSubmitEnabled(false);

    // Live validation
    if(passInput)  passInput.addEventListener("input", qaRpLiveValidate);
    if(pass2Input) pass2Input.addEventListener("input", qaRpLiveValidate);

    // Initial render (in case form becomes visible quickly)
    qaRpLiveValidate();

    if(submitBtn){
      submitBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        qaRpSubmitNewPassword(rid, rt);
      });
    }

    if(cancelLoginBtn){
      cancelLoginBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        window.location.href = LOGIN_URL;
      });
    }

    if(successLoginBtn){
      successLoginBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        window.location.href = LOGIN_URL;
      });
    }

    if(errorForgotBtn){
      errorForgotBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        window.location.href = FORGOT_URL;
      });
    }

    if(errorLoginBtn){
      errorLoginBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        window.location.href = LOGIN_URL;
      });
    }

    // Enter key support
    if(pass2Input){
      pass2Input.addEventListener("keyup", function(ev){
        if(ev.key === "Enter"){
          qaRpSubmitNewPassword(rid, rt);
        }
      });
    }
    if(passInput && pass2Input){
      passInput.addEventListener("keyup", function(ev){
        if(ev.key === "Enter"){
          pass2Input.focus();
        }
      });
    }
  })();
</script>
