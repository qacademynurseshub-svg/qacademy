<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Quiz Builder (Paged + Concept Mode)</title>
<style>
  :root{
    --brand:#0b7a75; --muted:#859998; --ink:#1f2a28; --bg:#f6f8f7; --card:#ffffff; --soft:rgba(0,0,0,.06);
    --warn:#8f2727; --ok:#0a6c67;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:system-ui,Segoe UI,Roboto,sans-serif}
  .wrap{max-width:960px;margin:28px auto;padding:0 16px}
  .card{background:var(--card);border:1px solid var(--soft);border-radius:16px;box-shadow:0 10px 24px rgba(0,0,0,.06);padding:18px;margin-bottom:14px}
  h1{margin:0 0 6px;font-size:24px;color:#0b7a75;font-weight:800;letter-spacing:.2px}
  .sub{color:#576663;font-size:13px;margin-bottom:12px}
  .hint{font-size:12px;color:#5a6a67}
  label{font-weight:700}
  input[type="number"], input[type="text"], select{
    width:100%;padding:10px 12px;border:1px solid #d8dfdd;border-radius:12px;background:#fff;outline:none
  }
  .btn{background:var(--brand);color:#fff;border:none;border-radius:12px;padding:10px 14px;font-weight:700;cursor:pointer}
  .btn.ghost{background:#e6f2f0;color:#0a6c67}
  .btn.small{padding:6px 10px;font-size:12px}
  .pill{padding:6px 10px;border-radius:999px;background:#eef3f2;color:#25413d;border:1px solid #dbe4e2;font-size:12px;display:inline-block}
  .bar{display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap}
  .toolbar{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0}
  .topics{border:1px solid #d8dfdd;border-radius:12px;background:#fff;padding:10px;max-height:260px;overflow:auto;transition:opacity .2s ease}
  .topic-item{display:flex;gap:8px;align-items:center;padding:8px;border-radius:10px;cursor:pointer}
  .topic-item:hover{background:#f4f7f6}
  .topic-item input{margin:0}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
  .check{display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid #d8dfdd;border-radius:12px;background:#fff}
  .disabled{opacity:.45;pointer-events:none;filter:grayscale(.2)}
  .step-body{padding:14px 16px 4px 16px}
  .badge{font-size:11px;padding:4px 8px;border-radius:999px;background:#eef3f2;border:1px solid #dbe4e2;color:#25413d}
  .status{font-family:ui-monospace,Consolas,monospace;background:#0a302e;color:#dbfff8;border-radius:12px;padding:12px;white-space:pre-wrap}
  .sticky-cta{position:sticky;bottom:0;z-index:3;background:linear-gradient(180deg, rgba(246,248,247,0), var(--bg) 40%);padding-top:8px}
  .cta-bar{display:flex;gap:10px;align-items:center;justify-content:space-between;background:#fff;border:1px solid #e6ecea;box-shadow:0 10px 22px rgba(0,0,0,.06);border-radius:14px;padding:10px 12px}
  .cta-left{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .err{color:var(--warn);font-size:12px;margin-top:6px}
  .builder-restore-strip{
    margin-top:8px;
    padding:8px 10px;
    border-radius:12px;
    background:#f3f7f6;
    border:1px dashed #c7d4d1;
    display:none; /* default hidden */
    align-items:center;
    justify-content:space-between;
    gap:6px;
    flex-wrap:wrap;
    font-size:12px;
  }
  .builder-restore-main{
    color:#42524f;
  }
  .builder-restore-actions{
    display:flex;
    gap:6px;
    flex-wrap:wrap;
  }

  /* Stepper layout */
  .progress-card{margin-top:-4px;margin-bottom:16px}
  .progress-label{font-size:12px;color:#4d5c59;margin-bottom:6px}
  .progress-bar{width:100%;height:6px;border-radius:999px;background:#dde5e3;overflow:hidden}
  .progress-inner{height:100%;width:0%;background:var(--brand);border-radius:999px;transition:width .25s ease-out}
  .steps-container{margin-top:4px}
  .step{
    display:none;
    background:var(--card);
    border:1px solid #e6ecea;
    border-radius:16px;
    box-shadow:0 8px 18px rgba(0,0,0,.04);
    margin-bottom:14px;
    padding-bottom:10px;
  }
  .step.active{display:block}
  .step-header{
    padding:14px 16px 0 16px;
    border-bottom:1px solid #eef3f2;
    margin-bottom:4px;
  }
  .step-title{
    margin:0;
    font-size:16px;
    font-weight:800;
    color:#16302c;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .step-sub{
    margin:4px 0 10px 0;
    font-size:13px;
    color:#5a6a67;
  }
  .step-nav-global{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:8px;
    margin:4px 0 10px 0;
  }
  .step-nav-global .btn{min-width:90px;text-align:center}
  .step-nav-global .btn[disabled]{opacity:.5;cursor:not-allowed}

  /* Review summary */
  .review-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
    margin-top:6px;
  }
  .review-item{
    background:#f7faf9;
    border:1px solid #e1e9e6;
    border-radius:12px;
    padding:8px 10px;
    font-size:13px;
  }
  .review-head-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:2px;
  }
  .review-label{font-weight:700;font-size:12px;color:#4a5a56}
  .review-edit{
    border:none;
    background:transparent;
    color:var(--brand);
    font-size:11px;
    font-weight:600;
    cursor:pointer;
    padding:0 0 0 8px;
  }
  .review-edit:hover{text-decoration:underline}
  .review-value{font-size:13px;color:#1f2a28}

  /* Concept suggestions */
  .concept-wrapper{margin-top:10px;}
  .concept-suggest{
    margin-top:6px;
    background:#ffffff;
    border:1px solid #d8dfdd;
    border-radius:10px;
    max-height:180px;
    overflow:auto;
    font-size:13px;
  }
  .concept-item{
    padding:6px 10px;
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:6px;
  }
  .concept-item:hover{
    background:#f4f7f6;
  }
  .concept-empty{
    padding:6px 10px;
    color:#7b8986;
  }

  @media (max-width:820px){.grid3{grid-template-columns:1fr 1fr}}
  @media (max-width:560px){
    .grid2,.grid3{grid-template-columns:1fr}
    .step-body{padding:12px 12px 4px 12px}
    .step-header{padding:12px 12px 0 12px}
    .review-grid{grid-template-columns:1fr}
    /* hide top pill bar on small screens to reduce duplication */
    .bar{display:none;}
  }

  /* Collapsible panels for Step 2 (Topics vs Concept) */
  .collapsible-panel{
    max-height:1000px;
    overflow:hidden;
    transition:
      max-height .22s ease,
      margin .22s ease,
      opacity .18s ease;
  }
  .collapsible-panel.collapsed{
    max-height:0;
    margin-top:0;
    margin-bottom:0;
    opacity:0;
    pointer-events:none;
  }
  
    /* ===== Builder page loader (light overlay, not auth) ===== */
  .qa-page-loader{
    position:fixed;
    inset:0;
    z-index:9999;
    background:rgba(246,248,247,0.75);
    display:none;
    align-items:center;
    justify-content:center;
    pointer-events:auto;
  }
  .qa-page-loader-inner{
    background:#ffffff;
    border-radius:16px;
    padding:14px 18px;
    box-shadow:0 16px 34px rgba(15,23,42,0.18);
    max-width:320px;
    width:86%;
    text-align:center;
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  }
  .qa-page-loader-title{
    font-size:15px;
    font-weight:700;
    color:#0b7a75;
    margin-bottom:4px;
  }
  .qa-page-loader-body{
    font-size:13px;
    color:#4b5c58;
  }
  .qa-spinner{
    width:26px;
    height:26px;
    border-radius:999px;
    border:3px solid rgba(11,122,117,0.18);
    border-top-color:#0b7a75;
    margin:0 auto 10px auto;
    animation:qa-spin .7s linear infinite;
  }
  @keyframes qa-spin{
    to{ transform:rotate(360deg); }
  }


</style>
</head>
<body>

<!-- Mark this page as Builder for Guard v3 -->
<script>
  window.QA_PAGE_KIND = 'builder';
</script>

<!-- =================== QAcademy — Guard v3 (Auth v3 + Products + Subscriptions) =================== -->
<script>
(function(){
  'use strict';

  /* ============== CONFIG (PER SITE + PER PAGE) ============== */

  // 1) Default config (can be overridden by window.QA_CONFIG)
  var DEFAULT_AUTH_URL       = 'https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec';
  var DEFAULT_LOGIN_SLUG     = 'login_23';
  var DEFAULT_DASHBOARD_SLUG = 'dashboard_23';

  // 2) Optional global config object
  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};

  var AUTH_URL       = cfg.AUTH_URL       || DEFAULT_AUTH_URL;
  var LOGIN_SLUG     = cfg.LOGIN_SLUG     || DEFAULT_LOGIN_SLUG;
  var DASHBOARD_SLUG = cfg.DASHBOARD_SLUG || DEFAULT_DASHBOARD_SLUG;

  // 3) Per-page flags (set these BEFORE including this snippet if you want to override)
  var PAGE_KIND     = window.QA_PAGE_KIND || 'course';
  var COURSE_ID     = window.QA_COURSE_ID || null;
  var REQUIRE_ADMIN = (typeof window.QA_REQUIRE_ADMIN === 'boolean')
    ? window.QA_REQUIRE_ADMIN
    : (String(PAGE_KIND).toLowerCase() === 'admin');

  /* ============== EXPORTED STATE ============== */

  window.QA_GUARD_STATE      = 'pending'; // 'pending' | 'ready' | 'blocked' | 'error'
  window.QA_GUARD_BLOCK_TYPE = null;      // 'session_expired' | 'account_issue' | 'no_course_access' | 'admin_required' | ...

  var guardResolve, guardReject;
  window.qaGuardReady = new Promise(function(resolve, reject){
    guardResolve = resolve;
    guardReject  = reject;
  });

  function persistGuardState(state, blockType){
    window.QA_GUARD_STATE      = state;
    window.QA_GUARD_BLOCK_TYPE = blockType || null;
  }

  /* ============== NAVIGATION HELPERS ============== */

  function buildPageUrl(slug){
    slug = String(slug || '').replace(/^\s+|\s+$/g, '');
    if(!slug) return '/';
    return '/p/' + slug + '.html';
  }

  function go(url){
    window.location.replace(url);
  }

  function qaGoToLogin(reason){
    var url = buildPageUrl(LOGIN_SLUG);
    if(reason){
      var sep = url.indexOf('?') === -1 ? '?' : '&';
      url += sep + 'reason=' + encodeURIComponent(reason);
    }
    go(url);
  }

  function qaGoToDashboard(){
    go(buildPageUrl(DASHBOARD_SLUG));
  }

  function qaLogout(){
    try{
      localStorage.removeItem('qa_token');
      localStorage.removeItem('qa_user_id');
    }catch(e){}
    qaGoToLogin('logout');
  }

  window.qaGoToLogin    = qaGoToLogin;
  window.qaGoToDashboard = qaGoToDashboard;
  window.qaLogout       = qaLogout;

  /* ============== OVERLAY (LOADER + BLOCKED UI) ============== */

  var overlayId = 'qa-guard-overlay';

  function ensureOverlay(){
    var el = document.getElementById(overlayId);
    if(el) return el;

    el = document.createElement('div');
    el.id = overlayId;
    el.style.position = 'fixed';
    el.style.inset = '0';
    el.style.zIndex = '99999';
    el.style.background = 'rgba(15,23,42,0.86)';
    el.style.display = 'flex';
    el.style.alignItems = 'center';
    el.style.justifyContent = 'center';
    el.style.fontFamily = 'system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
    el.style.padding = '16px';
    el.style.boxSizing = 'border-box';

    el.innerHTML =
      '<div id="qa-guard-overlay-inner" style="max-width:420px;width:100%;background:#ffffff;border-radius:16px;padding:18px 20px;box-shadow:0 18px 45px rgba(15,23,42,0.45);text-align:center;">' +
        '<div id="qa-guard-overlay-title" style="font-size:18px;font-weight:600;margin-bottom:6px;color:#0b7a75;">Checking your access...</div>' +
        '<div id="qa-guard-overlay-body" style="font-size:14px;color:#475569;margin-bottom:14px;">Please wait a moment.</div>' +
        '<div id="qa-guard-overlay-actions" style="font-size:13px;color:#94a3b8;"></div>' +
      '</div>';

    document.body.appendChild(el);
    return el;
  }

  function showOverlay(title, body, actionsHtml){
    var el = ensureOverlay();
    var t = el.querySelector('#qa-guard-overlay-title');
    var b = el.querySelector('#qa-guard-overlay-body');
    var a = el.querySelector('#qa-guard-overlay-actions');

    if(t && typeof title === 'string') t.textContent = title;
    if(b && typeof body === 'string')  b.textContent = body;
    if(a) a.innerHTML = actionsHtml || '';

    el.style.display = 'flex';
  }

  function hideOverlay(){
    var el = document.getElementById(overlayId);
    if(el) el.style.display = 'none';
  }

  function buildBlockedActions(type){
    var btnStyle = 'display:inline-flex;align-items:center;justify-content:center;padding:8px 14px;border-radius:999px;border:none;background:#0b7a75;color:#ffffff;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;';
    if(type === 'no_course_access' || type === 'admin_required' || type === 'account_issue'){
      return '<button type="button" onclick="qaGoToDashboard()" style="' + btnStyle + '">Go to Dashboard</button>';
    }
    if(type === 'session_expired'){
      return '<button type="button" onclick="qaGoToLogin(\'session_expired\')" style="' + btnStyle + '">Go to Login</button>';
    }
    return '';
  }

  function handleBlocked(type, title, body){
    persistGuardState('blocked', type);
    var actionsHtml = buildBlockedActions(type);
    showOverlay(title, body, actionsHtml);
    guardResolve({ ok:false, blocked:true, type:type });
  }

  /* ============== MAIN GUARD LOGIC ============== */

  function runGuard(){
    showOverlay('Checking your access...', 'Please wait while we verify your session.', '');

    var token = null;
    try{
      token = localStorage.getItem('qa_token');
    }catch(e){
      token = null;
    }

    if(!token){
      handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
      qaGoToLogin('no_token');
      return;
    }

    if(!AUTH_URL){
      hideOverlay();
      persistGuardState('error', 'missing_auth_url');
      var err = new Error('Guard misconfigured: AUTH_URL is missing.');
      guardReject(err);
      console.error(err);
      return;
    }

    fetch(AUTH_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: 'verify', token: token })
    })
    .then(function(res){ return res.json(); })
    .then(function(data){
      if(!data || data.ok !== true){
        var errCode = (data && data.error) || 'unknown_error';

        if(errCode === 'missing_token' || errCode === 'not_found' || errCode === 'expired'){
          try{
            localStorage.remove('qa_token');
            localStorage.remove('qa_user_id');
          }catch(e){}
          handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
          qaGoToLogin('session_expired');
          return;
        }

        if(errCode === 'user_missing' || errCode === 'user_inactive' || errCode === 'user_expired'){
          handleBlocked('account_issue', 'Account issue', 'There is a problem with your account. Please contact QAcademy support.');
          return;
        }

        persistGuardState('error', errCode);
        hideOverlay();
        var err = new Error('Guard verify failed: ' + errCode);
        guardReject(err);
        console.error(err);
        return;
      }

      // Success: build QA_USER + QA_ACCESS
      var u      = data.user   || {};
      var flags  = data.flags  || {};
      var access = (data.access && typeof data.access === 'object') ? data.access : {};
      var courseIds = Array.isArray(access.courses) ? access.courses.slice() : [];
      var upperIds  = courseIds.map(function(c){
        return String(c || '').trim().toUpperCase();
      }).filter(Boolean);
      var coursesMeta = Array.isArray(data.courses) ? data.courses : [];

      var QA_USER = {
        id:        u.user_id || '',
        user_id:   u.user_id || '',
        username:  u.username || '',
        email:     u.email || '',
        name:      u.name || '',
        forename:  u.forename || '',
        surname:   u.surname || '',
        phone_number: u.phone_number || '',
        program_id:   u.program_id || '',
        cohort:       u.cohort || '',
        avatar_url:   u.avatar_url || '',
        role:         u.role || '',
        is_admin:     !!(flags && flags.is_admin),
        must_change_password: !!u.must_change_password,
        user_expires_utc: u.expires_utc || ''
      };

      var QA_ACCESS = {
        courseIds: upperIds,
        access_expires_utc: access.expires_utc || '',
        coursesMeta: coursesMeta,
        hasCourse: function(courseId){
          var cid = String(courseId || '').trim().toUpperCase();
          if(!cid) return false;
          return this.courseIds.indexOf(cid) !== -1;
        }
      };

      window.QA_USER   = QA_USER;
      window.QA_ACCESS = QA_ACCESS;

      try{
        if(QA_USER.user_id){
          localStorage.setItem('qa_user_id', QA_USER.user_id);
        }
      }catch(e){}

      var kind = String(PAGE_KIND || '').toLowerCase();
      var cid  = COURSE_ID ? String(COURSE_ID).trim().toUpperCase() : '';

      // Dashboard: any verified user OK
      if(kind === 'dashboard'){
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      // Admin pages
      if(kind === 'admin' || REQUIRE_ADMIN){
        if(!QA_USER.is_admin){
          handleBlocked('admin_required', 'Admin access required', 'This page is only available to QAcademy admins.');
          return;
        }
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      // Course-tied pages
      // NOTE: 'builder' is handled at feature level (inside Builder JS),
      // so it is deliberately NOT treated as a course-tied page here.
      if(
        kind === 'course' ||
        kind === 'runner_instant' ||
        kind === 'runner_timed' ||
        kind === 'history_course'
      ){
        if(!cid){
          persistGuardState('error', 'missing_course_id');
          hideOverlay();
          var err2 = new Error('Guard misconfigured: QA_COURSE_ID is missing for course-tied page.');
          guardReject(err2);
          console.error(err2);
          return;
        }

        if(!QA_ACCESS.hasCourse(cid)){
          handleBlocked(
            'no_course_access',
            'No access to this course',
            'Your current subscription does not include this course. Please go back to your dashboard to see the courses you have access to.'
          );
          return;
        }

        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind, course_id:cid });
        return;
      }

      // General history page
      if(kind === 'history'){
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      // Default: any verified user allowed
      persistGuardState('ready', null);
      hideOverlay();
      guardResolve({ ok:true, blocked:false, kind:kind });
    })
    .catch(function(err){
      persistGuardState('error', 'network');
      console.error('Guard network/error', err);
      showOverlay(
        'Network problem',
        'We could not verify your access due to a network error. Please check your connection and reload this page.',
        ''
      );
      guardReject(err);
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', runGuard);
  } else {
    runGuard();
  }

})();
</script>

