  // ====== Spawn ======  
  async function spawn(){
    if (el.spawnBtn.disabled) return;

    const course_id = el.course.value || 'RN_MED';

    // Extra safety: user must have this course
    if (!userHasCourse(course_id)){
      setStatus('You do not have access to this course. Please choose a course from your subscriptions.');
      el.spawnBtn.disabled = true;
      return;
    }

    const modeSel = selectionMode();

    let topics   = [];
    let concept  = '';  // single-string free-text query
    let concepts = [];  // selected concept chips

    if (modeSel === 'topics'){
      topics   = el.useAll.checked ? TOPICS.slice() : selectedTopics();
      concepts = [];
      concept  = '';

      if (!topics.length){
        setStatus('Error: Select at least one topic or enable "Use all topics".');
        return;
      }

    } else {
      topics   = [];
      concepts = selectedConcepts();
      const query = (conceptValue || '').trim();

      if (!concepts.length && !query){
        setStatus('Error: Type or select a concept.');
        return;
      }

      if (query){
        addSearchTermFromCurrentInput();
      }

      concept = query;
    }

    const difficulties = pickDiffs();
    let n = +el.n.value || 10;
    const max = +el.n.max || 50;
    if (n > max) n = max;

    const mode    = el.modeTimed.checked ? 'timed' : 'instant';
    const user_id = getCurrentUserId();

    const payload = {
      course_id,
      topics,
      difficulties,
      n,
      mode,
      source: 'builder',
      user_id: user_id,
      concept: concept,
      concepts: concepts
    };

    el.spawnBtn.disabled = true;
    el.attemptLink.style.display = 'none';

    if (DEBUG_MODE){
      setStatus({ stage: 'spawning', payload });
    } else {
      setStatus('Building your quiz...');
    }

    // Show Builder loader while we spawn quiz
    const loaderMsg = (mode === 'timed')
      ? 'Preparing your timed exam with the selected topics and difficulty...'
      : 'Preparing your instant-feedback practice quiz...';
    showPageLoader('Building your quiz...', loaderMsg);

    try{
      const res = await fetch(`${WEB_APP_URL_BUILDER}?action=builder.spawn`, {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body:'payload='+encodeURIComponent(JSON.stringify(payload))
      });
      const out = await res.json();
      el.spawnBtn.disabled = false;

      savePrefs();

      if (DEBUG_MODE){
        setStatus(JSON.stringify(out,null,2));
      } else {
        if (out && out.attempt_id){
          setStatus('Quiz ready! Opening runner...');
        } else {
          setStatus('We could not build your quiz. Please try again.');
        }
      }

      if (out && out.attempt_id){
        const base = mode==='timed' ? RUNNER_TIMED_URL : RUNNER_INSTANT_URL;
        const mins = (mode==='timed') ? (out.n || n) : undefined;
        const runnerUrl = (mode==='timed')
          ? `${base}?quiz_id=${encodeURIComponent(out.attempt_id)}&mins=${encodeURIComponent(mins)}`
          : `${base}?quiz_id=${encodeURIComponent(out.attempt_id)}`;

        el.attemptLink.href = runnerUrl;
        el.attemptLink.style.display = 'inline-block';

        try{ window.top.location.href = runnerUrl; }
        catch(e){ try{ window.location.assign(runnerUrl); } catch(e2){} }
      }

      hidePageLoader();
    }catch(err){
      hidePageLoader();
      setStatus('Error: ' + (err.message || String(err)));
      el.spawnBtn.disabled = false;
    }
  }

  // ====== Restore prefs ======  
  function restoreSelectedTopics(){
    const p = loadPrefs(); if (!p) return new Set();
    if (!META) return new Set();
    const valid = new Set((META.topics_main||[]));
    const arr = (Array.isArray(p.topics) ? p.topics.filter(t => valid.has(t)) : []);
    return new Set(arr);
  }

  function restorePrefsAfterMeta(){
    const p = loadPrefs(); if (!p) { updateConceptBucketLine(); return; }

    if (p.mode === 'timed'){ el.modeTimed.checked = true; el.modeInstant.checked = false; }
    else { el.modeInstant.checked = true; el.modeTimed.checked = false; }

    if (Number.isFinite(+p.n) && +p.n>0) el.n.value = +p.n;
    if (p.diffs){
      el.easy.checked=!!p.diffs.easy;
      el.moderate.checked=!!p.diffs.moderate;
      el.hard.checked=!!p.diffs.hard;
    }
    if (typeof p.filter === 'string') el.topicFilter.value = p.filter;

    // Restore concept search text (new key first, then old fallback)
    if (typeof p.conceptQuery === 'string'){
      conceptValue = p.conceptQuery;
      el.conceptInput.value = p.conceptQuery;
    } else if (typeof p.concept === 'string'){
      conceptValue = p.concept;
      el.conceptInput.value = p.concept;
    }

    // Restore selected concepts (multi)
    if (Array.isArray(p.concepts) && p.concepts.length){
      setSelectedConcepts(p.concepts);
    } else if (typeof p.concept === 'string' && p.concept.trim()){
      setSelectedConcepts([p.concept.trim()]);
    }

    // Restore search history if present
    if (Array.isArray(p.searchTerms)){
      SEARCH_TERMS = p.searchTerms.slice();
    } else {
      SEARCH_TERMS = [];
    }

    if (p.selMode === 'concept'){
      SELECT_MODE = 'concept';
      el.modeByConcept.checked = true;
      el.modeByTopics.checked = false;
    } else {
      SELECT_MODE = 'topics';
      el.modeByTopics.checked = true;
      el.modeByConcept.checked = false;
    }

    reflectModeUI();
    updateModeSections();
    renderConceptSuggestions();
    updateSelectedBadge();
    updateAvailEstimate();
    updateConceptBucketLine();
    updateRestoreStripVisibility();
    
  }
  
    function hardResetCurrentCourse(){
    const cid = el.course.value || 'RN_MED';

    // 1) Clear saved prefs + useAll
    clearPrefsForCourse(cid);

    // 2) Reset state
    SELECT_MODE = 'topics';
    el.modeByTopics.checked = true;
    el.modeByConcept.checked = false;

    SELECTED.clear();
    setSelectedConcepts([]);
    SEARCH_TERMS = [];
    conceptValue = '';

    el.useAll.checked = false;
    el.topicFilter.value = '';
    el.conceptInput.value = '';

    el.easy.checked = false;
    el.moderate.checked = false;
    el.hard.checked = false;

    el.n.value = 20;

    // 3) Re-render UI
    updateModeSections();
    setTopicsBoxInteractivity();
    renderTopics();
    renderConceptSuggestions();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectDiffUI();
    reflectSummary();
    validateAll();
    updateStepperUI();
    updateConceptBucketLine();

    // 4) Hide strip (no prefs now)
    updateRestoreStripVisibility();

    setStatus('Reset to a fresh setup for this course.');
  }

  

  // ====== Mode (topics vs concept) UI ======  
  function updateModeSections(){
    const isTopics = (selectionMode() === 'topics');

    if (isTopics){
      // Topics mode: show topics, collapse concept
      el.topicSection.classList.remove('disabled', 'collapsed');
      el.conceptSection.classList.add('disabled', 'collapsed');

      setTopicsBoxInteractivity();
      el.conceptSuggestBox.style.display = 'none';
    } else {
      // Concept mode: show concept, collapse topics
      el.topicSection.classList.add('disabled', 'collapsed');
      el.conceptSection.classList.remove('disabled', 'collapsed');

      // Topics are not interactive in concept mode
      el.topicsBox.querySelectorAll('input.tchk').forEach(chk => chk.disabled = true);
      el.useAll.disabled = true;

      renderConceptSuggestions();
    }

    updateSelectedBadge();
    updateAvailEstimate();
    updateConceptBucketLine();
  }

  // ====== Events ======  
  el.course.addEventListener('change', ()=>{
    el.courseBadge.textContent = courseLabel(el.course.value) || '—';
    el.sumCourse.textContent = `Course: ${courseLabel(el.course.value) || '—'}`;
    savePrefs();
    updateRestoreStripVisibility();
    loadMeta().then(()=>{
      restorePrefsAfterMeta();
      renderTopics();
      reflectDiffUI();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();

      // Clear any old "Loading…" message for course switches too
      setStatus('Course loaded. Adjust your filters, then build your quiz.');
    });
  });


  el.modeInstant.addEventListener('change', ()=>{
    reflectModeUI();
    savePrefs();
    validateAll();
    updateStepperUI();
  });
  el.modeTimed.addEventListener('change', ()=>{
    reflectModeUI();
    savePrefs();
    validateAll();
    updateStepperUI();
  });

  el.topicFilter.addEventListener('input', ()=>{
    renderTopics();
    savePrefs();
  });

  // TOPIC MODE: select/clear only visible (filtered) topics
  el.selectAll.addEventListener('click', ()=>{
    if (selectionMode()!=='topics') return;
    el.useAll.checked = false;
    saveUseAll(el.course.value || 'RN_MED', false);
    setTopicsBoxInteractivity();

    const boxes = el.topicsBox.querySelectorAll('input.tchk');
    boxes.forEach(chk=>{
      chk.checked = true;
      SELECTED.add(chk.value);
    });

    renderTopics();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    reflectDiffUI();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.clearAll.addEventListener('click', ()=>{
    if (selectionMode()!=='topics') return;
    el.useAll.checked = false;
    saveUseAll(el.course.value || 'RN_MED', false);
    setTopicsBoxInteractivity();

    const boxes = el.topicsBox.querySelectorAll('input.tchk');
    boxes.forEach(chk=>{
      chk.checked = false;
      SELECTED.delete(chk.value);
    });

    renderTopics();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    reflectDiffUI();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.sortToggle.addEventListener('click', ()=>{
    sortMode = (sortMode==='name') ? 'count' : 'name';
    el.sortToggle.textContent = `Sort: ${sortMode==='name' ? 'Name' : 'Count'}`;
    renderTopics();
  });

  [el.easy, el.moderate, el.hard].forEach(cb=>{
    cb.addEventListener('change', ()=>{
      reflectDiffUI();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  });

  ['change','input'].forEach(ev=>{
    el.n.addEventListener(ev, ()=>{
      reflectEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  });

  el.useAll.addEventListener('change', ()=>{
    saveUseAll(el.course.value || 'RN_MED', el.useAll.checked);
    if (el.useAll.checked) SELECTED.clear();
    setTopicsBoxInteractivity();
    renderTopics(); updateAvailEstimate(); reflectSummary(); reflectDiffUI(); validateAll(); updateStepperUI(); savePrefs();
  });

  // concept input
  el.conceptInput.addEventListener('input', ()=>{
    conceptValue = el.conceptInput.value || '';
    renderConceptSuggestions();
    updateConceptBucketLine();
    savePrefs();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    validateAll();
    updateStepperUI();
  });

  // Concept tools: select all shown / clear shown / reset search / clear all
  if (el.conceptSelectShown){
    el.conceptSelectShown.addEventListener('click', ()=>{
      if (selectionMode()!=='concept') return;
      const boxes = el.conceptSuggestBox.querySelectorAll('input.concept-choice');
      if (!boxes.length) return;
      boxes.forEach(input=>{
        input.checked = true;
        toggleConceptSelection(input.value, true);
      });
      addSearchTermFromCurrentInput();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
      renderConceptSuggestions();
    });
  }

  if (el.conceptClearShown){
    el.conceptClearShown.addEventListener('click', ()=>{
      if (selectionMode()!=='concept') return;
      const boxes = el.conceptSuggestBox.querySelectorAll('input.concept-choice');
      if (!boxes.length) return;
      boxes.forEach(input=>{
        input.checked = false;
        toggleConceptSelection(input.value, false);
      });
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
      renderConceptSuggestions();
    });
  }

  if (el.resetConceptSearch){
    el.resetConceptSearch.addEventListener('click', ()=>{
      conceptValue = '';
      el.conceptInput.value = '';
      renderConceptSuggestions();
      updateConceptBucketLine();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  }

  if (el.clearAllConcepts){
    el.clearAllConcepts.addEventListener('click', ()=>{
      setSelectedConcepts([]);
      SEARCH_TERMS = [];
      conceptValue = '';
      el.conceptInput.value = '';
      renderConceptSuggestions();
      updateConceptBucketLine();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  }

  // selection mode toggles
  el.modeByTopics.addEventListener('change', ()=>{
    if (!el.modeByTopics.checked) return;
    SELECT_MODE = 'topics';
    updateModeSections();
    reflectSummary();
    validateAll();
    updateStepperUI();
    savePrefs();
  });
  el.modeByConcept.addEventListener('change', ()=>{
    if (!el.modeByConcept.checked) return;
    SELECT_MODE = 'concept';
    updateModeSections();
    reflectSummary();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  // Presets
  el.presetMixed.addEventListener('click', ()=>{
    SELECT_MODE = 'topics';
    el.modeByTopics.checked = true;
    el.modeByConcept.checked = false;
    updateModeSections();

    el.useAll.checked = true;
    saveUseAll(el.course.value || 'RN_MED', true);
    SELECTED.clear();
    setTopicsBoxInteractivity();
    renderTopics();

    el.easy.checked = true;
    el.moderate.checked = true;
    el.hard.checked = false;
    el.n.value = Math.min(20, +el.n.max || 20);

    reflectDiffUI();
    reflectEstimate();
    reflectSummary();
    updateSelectedBadge();
    updateAvailEstimate();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.presetExam.addEventListener('click', ()=>{
    SELECT_MODE = 'topics';
    el.modeByTopics.checked = true;
    el.modeByConcept.checked = false;
    updateModeSections();

    el.useAll.checked = true;
    saveUseAll(el.course.value || 'RN_MED', true);
    SELECTED.clear();
    setTopicsBoxInteractivity();
    renderTopics();

    el.easy.checked = false;
    el.moderate.checked = true;
    el.hard.checked = true;
    el.n.value = Math.min(50, +el.n.max || 50);

    reflectDiffUI();
    reflectEstimate();
    reflectSummary();
    updateSelectedBadge();
    updateAvailEstimate();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.presetTarget.addEventListener('click', ()=>{
    SELECT_MODE = 'topics';
    el.modeByTopics.checked = true;
    el.modeByConcept.checked = false;
    updateModeSections();

    el.useAll.checked = false;
    saveUseAll(el.course.value || 'RN_MED', false);
    setTopicsBoxInteractivity();
    renderTopics();

    el.easy.checked = true;
    el.moderate.checked = true;
    el.hard.checked = true;
    el.n.value = Math.min(15, +el.n.max || 15);

    reflectDiffUI();
    reflectEstimate();
    reflectSummary();
    updateSelectedBadge();
    updateAvailEstimate();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.spawnBtn.addEventListener('click', spawn);
  el.btnNext.addEventListener('click', goNext);
  el.btnBack.addEventListener('click', goBack);

  document.querySelectorAll('.review-edit').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const stepId = btn.getAttribute('data-edit-step');
      const idx = STEPS.indexOf(stepId);
      if (idx >= 0){
        currentStepIndex = idx;
        updateStepperUI();
        const panel = document.querySelector('.step[data-step="'+stepId+'"]');
        if (panel) scrollInto(panel);
      }
    });
  });

   if (el.btnRestorePrefs){
    el.btnRestorePrefs.addEventListener('click', ()=>{
      // Only do something if prefs exist
      const cid = el.course.value || 'RN_MED';
      const prefs = loadPrefs(cid);
      if (!prefs){
        updateRestoreStripVisibility();
        return;
      }
      restorePrefsAfterMeta();
      renderTopics();
      reflectDiffUI();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      setStatus('Previous setup applied for this course.');
    });
  }

  if (el.btnResetPrefs){
    el.btnResetPrefs.addEventListener('click', ()=>{
      hardResetCurrentCourse();
    });
  }
 
  
  // ====== Init (using Guard v3) ======  
  (async function init(){
    try{
      const guardResult = await window.qaGuardReady;
      if (!guardResult || guardResult.blocked){
        setStatus('Access blocked. Please return to your dashboard.');
        return;
      }
    }catch(e){
      setStatus('Could not verify your access. Please reload this page.');
      return;
    }

    const access = window.QA_ACCESS || {};
    ALLOWED_COURSE_IDS = Array.isArray(access.courseIds) ? access.courseIds.slice() : [];

    const ctxRaw = getQueryParam("course_id") || getQueryParam("cid");
    if (ctxRaw && ALLOWED_COURSE_IDS.length){
      const ctxNorm = ctxRaw.trim().toUpperCase();
      const matchId = ALLOWED_COURSE_IDS.find(id => String(id).trim().toUpperCase() === ctxNorm);
      if (matchId){
        CONTEXT_COURSE_ID = matchId;
        COURSE_LOCKED = true;
      } else {
        setStatus('Note: you do not have access to that course. Showing your available courses instead.');
      }
    }

    await loadCourses();
    if (!ALLOWED_COURSE_IDS || !ALLOWED_COURSE_IDS.length){
      return;
    }

    await loadMeta();
    restorePrefsAfterMeta();
    renderTopics();
    reflectDiffUI();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    validateAll();
    updateStepperUI();

    // Reset status once everything is ready
    setStatus('Ready. Set up your quiz using the steps above.');
  })();


})();
</script>
</body>
</html>
