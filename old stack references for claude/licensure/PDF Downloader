  // ===== Topics =====
  function renderTopics(){
    if (!META){
      el.topicsBox.innerHTML = '<div class="hint" style="padding:8px;">No topics.</div>';
      return;
    }
    const counts = META.topic_counts || {};
    const filter = (el.topicFilter.value || '').toLowerCase().trim();

    let list = TOPICS.slice();
    if (sortMode === 'count'){
      list.sort((a,b)=>(counts[b]||0)-(counts[a]||0) || a.localeCompare(b));
    } else {
      list.sort((a,b)=>a.localeCompare(b));
    }
    if (filter) list = list.filter(t => t.toLowerCase().includes(filter));

    el.topicsBox.innerHTML = '';
    if (!list.length){
      el.topicsBox.innerHTML = '<div class="hint" style="padding:8px;">No topics match your filter.</div>';
      return;
    }

    list.forEach(t=>{
      const c = counts[t] || 0;
      const row = document.createElement('label');
      row.className = 'topic-item';
      row.title = `${t}: ${c} question(s) available`;
      row.innerHTML = `<input type="checkbox" class="tchk" value="${t}"><span>${t} (${c})</span>`;
      const chk = row.querySelector('input');
      chk.checked = SELECTED.has(t);
      chk.disabled = el.useAll.checked || selectionMode()==='concept';

      chk.addEventListener('change', ()=>{
        if (chk.checked) SELECTED.add(t); else SELECTED.delete(t);
        if (el.useAll.checked){
          el.useAll.checked = false;
          saveUseAll(el.course.value,false);
          setTopicsBoxInteractivity();
        }
        updateSelectedBadge();
        updateAvailEstimate();
        reflectSummary();
        reflectDiffUI();
        validateAll();
        updateStepperUI();
        savePrefs();
      });

      el.topicsBox.appendChild(row);
    });

