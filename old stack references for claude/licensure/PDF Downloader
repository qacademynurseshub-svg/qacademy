  async function loadMeta(){
    showPageLoader('Loading questions...', 'Fetching topics and difficulty data for this course.');

    el.topicsBox.innerHTML = '<div class="hint" style="padding:8px;">Loading topics...</div>';
    el.downloadBtn.disabled = true;

    const cid = el.course.value || 'RN_MED';
    const key = LS.META_PREFIX + cid;

    let meta = null;
    const cached = readLS(key);
    if (fresh(cached) && cached.data && cached.data.topics_main){
      meta = cached.data;
    }

    if (!meta){
      try{
        const r = await fetch(`${WEB_APP_URL}?action=builder.meta&course_id=${encodeURIComponent(cid)}`);
        meta = await r.json();
        if (meta && meta.topics_main) saveLS(key, meta);
      }catch(_){}
    }

    if (!meta || !meta.topics_main){
      hidePageLoader();
      setStatus('Failed to load topics and difficulty data. Please reload this page or try again.');
      return;
    }

    applyMeta(meta);
    hidePageLoader();
  }

  function applyMeta(meta){
    META = meta;
    TOPICS = meta.topics_main.slice();
    SELECTED = restoreSelectedTopics();

    const cid = el.course.value || 'RN_MED';
    el.useAll.checked = loadUseAll(cid);
    setTopicsBoxInteractivity();

const total = meta.total || meta.maxN || 0;
el.maxPill.textContent = `Total: ${total} | MaxN: ${getMaxN()}`;


    const dc = meta.difficulty_counts || {};
    const diffList = (meta.difficulties||[]).map(d => `${d} ${dc[d] ?? 0}`).join(' | ');
    el.diffPill.textContent = diffList ? `Difficulties: ${diffList}` : 'Difficulties: -';

const maxN = getMaxN();
el.n.max = maxN;
el.nHint.textContent = `Max available: ${maxN}`;

if (el.numSub) el.numSub.textContent = `Choose how many questions you want in this pack (max ${maxN}).`;


