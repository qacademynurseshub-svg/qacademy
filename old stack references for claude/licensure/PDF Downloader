<script>
(function(){
  // ====== CONFIG ======
  const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbxT6cV424Ppes5DdZxtqdqPDCS9d-TKWDO4RV5ZTtlMOxz3ygkoOdTrrXTOCxJ32WDF/exec";

  // Allowance is enforced by Auth (PortalAuthv2) because it depends on products/subscriptions (e.g., TRIAL via products.kind)
const AUTH_URL = (window.QA_CONFIG && window.QA_CONFIG.AUTH_URL)
  ? window.QA_CONFIG.AUTH_URL
  : "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";

 
  const MY_DOWNLOADS_URL = "/p/my-downloads.html";
  const OFFLINE_RENDERER_URL = "/p/offline-pack-renderer.html";


  const CACHE_TTL_MS  = 2 * 60 * 60 * 1000;
  const CHOICE_TTL_MS = 12 * 60 * 60 * 1000;

  const COURSE_LABELS = {
    "GP":"General Paper",
    "RN_MED":"Medicine & Medical Nursing(RN)",
    "RN_SURG":"Surgery & Surgical Nursing(RN)",
    "RM_PED_OBS_HRN":"Paediatric, Obstetric Anatomy, & High-Risk Neonates(RM)",
    "RM_MID":"Midwifery(RM)",
    "RPHN_PPHN":"Principles of Public Health Nursing(RPHN)",
    "RPHN_DISEASE_CTRL":"Principles of Disease Management & Control(RPHN)",
    "RMHN_PSYCH_NURS":"Principles & Practice of Psychiatric Nursing(RMHN)",
    "RMHN_PSYCH_PPHARM":"Psychiatry, Psychopathology & Psychopharmacology(RMHN)",
    "NAC_BASIC_CLIN":"Basic Clinical Nursing(NACNAP)",
    "NAC_BASIC_PREV":"Basic Preventive Nursing(NACNAP)"
  };

  const STEPS = ["course","topics","difficulty","number","review"];
  const STEP_LABELS = {
    course: "Step 1 of 5 - Choose Course",
    topics: "Step 2 of 5 - Choose by Topics or Concept",
    difficulty: "Step 3 of 5 - Choose Difficulty",
    number: "Step 4 of 5 - Number of Questions",
    review: "Step 5 of 5 - Review & Download"
  };
  let currentStepIndex = 0;

  const LS = {
    META_PREFIX: "qa_builder:meta:",
    PREFS_PREFIX: "qa_builder:prefs:",
    USEALL_PREFIX: "qa_builder:useall:",
    LAST_COURSE: "qa_builder:lastCourse"
  };

  function byId(id){ return document.getElementById(id); }

  // ===== Local page loader =====
  function showPageLoader(title, body){
    try{
      var wrap  = byId('qa-page-loader');
      var tNode = byId('qa-page-loader-title');
      var bNode = byId('qa-page-loader-body');
      if(!wrap) return;
      if(tNode && typeof title === 'string') tNode.textContent = title;
      if(bNode && typeof body === 'string')  bNode.textContent = body;
      wrap.style.display = 'flex';
    }catch(_){}
  }
  function hidePageLoader(){
    try{ var wrap = byId('qa-page-loader'); if(wrap) wrap.style.display = 'none'; }catch(_){}
  }

  // ====== Elements ======
  const el = {
    out: byId('out'),

    maxPill: byId('maxPill'),
    diffPill: byId('diffPill'),
    selectedPill: byId('selectedPill'),
    numSub: byId('numSub'),


    stepLabel: byId('stepLabel'),
    progressInner: byId('progressInner'),
    btnBack: byId('btnBack'),
    btnNext: byId('btnNext'),

    courseBadge: byId('courseBadge'),
    topicsBadge: byId('topicsBadge'),
    diffBadge: byId('diffBadge'),
    numBadge: byId('numBadge'),

    course: byId('course'),
    courseErr: byId('courseErr'),

    restoreStrip: byId('restoreStrip'),
    btnRestorePrefs: byId('btnRestorePrefs'),
    btnResetPrefs: byId('btnResetPrefs'),

    modeByTopics: byId('modeByTopics'),
    modeByConcept: byId('modeByConcept'),
    topicSection: byId('topicSection'),
    conceptSection: byId('conceptSection'),

    topicFilter: byId('topicFilter'),
    topicsBox: byId('topicsBox'),
    selectAll: byId('selectAll'),
    clearAll: byId('clearAll'),
    sortToggle: byId('sortToggle'),
    useAll: byId('useAll'),
    topicsErr: byId('topicsErr'),

    conceptInput: byId('conceptInput'),
    conceptSuggestBox: byId('conceptSuggestBox'),
    conceptBucketLine: byId('conceptBucketLine'),
    conceptSelectShown: byId('conceptSelectShown'),
    conceptClearShown: byId('conceptClearShown'),
    resetConceptSearch: byId('resetConceptSearch'),
    clearAllConcepts: byId('clearAllConcepts'),

    easy: byId('easy'),
    moderate: byId('moderate'),
    hard: byId('hard'),
    diffHint: byId('diffHint'),
    diffErr: byId('diffErr'),

    n: byId('n'),
    nHint: byId('nHint'),
    availHint: byId('availHint'),
    numErr: byId('numErr'),

    downloadBtn: byId('downloadBtn'),

    sumCourse: byId('sumCourse'),
    sumTopics: byId('sumTopics'),
    sumDiffs: byId('sumDiffs'),
    sumN: byId('sumN'),

    revCourse: byId('revCourse'),
    revSelMode: byId('revSelMode'),
    revTopics: byId('revTopics'),
    revConcept: byId('revConcept'),
    revDiffs: byId('revDiffs'),
    revN: byId('revN'),

    // modal
    dlModal: byId('dlModal'),
    dlCloseBtn: byId('dlCloseBtn'),
    dlCancelBtn: byId('dlCancelBtn'),
    dlCreateBtn: byId('dlCreateBtn'),
    packName: byId('packName'),
    dlErr: byId('dlErr'),
    dlCoursePill: byId('dlCoursePill'),
    dlCountPill: byId('dlCountPill'),
    dlAllowancePill: byId('dlAllowancePill')
  };

  // ====== State ======
  let META = null;
  let TOPICS = [];
  let SELECTED = new Set();
  let sortMode = 'name';

  let SELECT_MODE = "topics";
  let conceptValue = '';
  let SELECTED_CONCEPTS = [];
  let SEARCH_TERMS = [];

  let ALLOWED_COURSE_IDS = [];
  let CONTEXT_COURSE_ID = null;
  let COURSE_LOCKED = false;

  // downloads allowance cache
  let ALLOWANCE = null; // {remaining, limit, can_create, reason}

  // ====== Utils ======
  function setStatus(msg){
    el.out.textContent = (typeof msg === 'string') ? msg : JSON.stringify(msg, null, 2);
  }
  
  function getMaxN(){
  const v = META && Number.isFinite(+META.maxN) ? +META.maxN : 50;
  return Math.max(1, v);
}

  function now(){ return Date.now(); }
  function saveLS(key, data){ try{ localStorage.setItem(key, JSON.stringify({ts:now(), data})) }catch(_){ } }
  function readLS(key){
    try{
      const raw = localStorage.getItem(key);
      if(!raw) return null;
      const j = JSON.parse(raw);
      return j && j.data !== undefined ? j : null;
    }catch(_){ return null; }
  }
  function fresh(entry, ttl=CACHE_TTL_MS){ return entry && (now()-entry.ts) < ttl; }
  function courseLabel(id){
    const idTrim = (id || '').trim();
    return COURSE_LABELS[idTrim] || idTrim;
  }
  function getQueryParam(name){
    try{ return new URLSearchParams(window.location.search || '').get(name); }
    catch(_){ return null; }
  }
  function prefsKeyForCourse(courseId){ return LS.PREFS_PREFIX + (courseId || 'RN_MED'); }
  function selectionMode(){ return SELECT_MODE; }
  function selectedTopics(){ return Array.from(SELECTED); }
  function selectedConcepts(){ return Array.isArray(SELECTED_CONCEPTS) ? SELECTED_CONCEPTS.slice() : []; }
  function setSelectedConcepts(arr){ SELECTED_CONCEPTS = Array.isArray(arr) ? arr.slice() : []; }
  function hasConcept(){
    const hasChips = Array.isArray(SELECTED_CONCEPTS) && SELECTED_CONCEPTS.length > 0;
    const hasText  = (conceptValue || '').trim().length > 0;
    return hasChips || hasText;
  }

  function getToken(){
    try{ return localStorage.getItem('qa_token') || ''; }catch(_){ return ''; }
  }

  function userHasCourse(courseId){
    const cid = (courseId || '').trim().toUpperCase();
    if (!cid) return false;
    const list = Array.isArray(ALLOWED_COURSE_IDS) ? ALLOWED_COURSE_IDS : [];
    return list.map(x => String(x).trim().toUpperCase()).includes(cid);
  }

  function getUserDisplayName(){
    const u = window.QA_USER || {};
    const name = (u.name || '').trim();
    if (name) return name;
    const fn = (u.forename || '').trim();
    const sn = (u.surname || '').trim();
    return (fn || sn) ? `${fn}${fn && sn ? ' ' : ''}${sn}`.trim() : 'Student';
  }

  function getUserProgram(){
    const u = window.QA_USER || {};
    return (u.program_id || '').trim() || 'Program';
  }

  function yyyy_mm_dd_utc(){
    const d = new Date();
    const yyyy = d.getUTCFullYear();
    const mm = String(d.getUTCMonth()+1).padStart(2,'0');
    const dd = String(d.getUTCDate()).padStart(2,'0');
    return `${yyyy}-${mm}-${dd}`;
  }

  function watermarkSnapshot(){
    // Choice B: Name • Program • Date
    return `${getUserDisplayName()} • ${getUserProgram()} • ${yyyy_mm_dd_utc()}`;
  }

  function saveUseAll(courseId, value){
    try{ localStorage.setItem(LS.USEALL_PREFIX+courseId, JSON.stringify({value, ts:now()})) }catch(_){}
  }
  function loadUseAll(courseId){
    try{
      const raw = localStorage.getItem(LS.USEALL_PREFIX+courseId);
      if(!raw) return false;
      const obj = JSON.parse(raw);
      if(!fresh({ts:obj.ts}, CHOICE_TTL_MS)) return false;
      return !!obj.value;
    }catch(_){ return false; }
  }

  function summariseItems(list, maxItems){
    if (!Array.isArray(list) || !list.length) return '';
    const shown = list.slice(0, maxItems);
    const remaining = list.length - shown.length;
    const base = shown.join(', ');
    return remaining > 0 ? `${base} +${remaining} more` : base;
  }

  // ====== Prefs ======
  function savePrefs(){
    const cid = el.course.value || 'RN_MED';
    const prefs = {
      n: +el.n.value || 20,
      topics: Array.from(SELECTED),
      diffs: { easy:!!el.easy.checked, moderate:!!el.moderate.checked, hard:!!el.hard.checked },
      filter: el.topicFilter.value || '',
      conceptQuery: conceptValue || '',
      concepts: selectedConcepts(),
      selMode: SELECT_MODE,
      searchTerms: Array.isArray(SEARCH_TERMS) ? SEARCH_TERMS.slice() : []
    };
    saveLS(prefsKeyForCourse(cid), prefs);
    saveUseAll(cid, !!el.useAll.checked);
    try{ localStorage.setItem(LS.LAST_COURSE, cid); }catch(_){}
  }
  function loadPrefs(courseId){
    const cid = courseId || (el.course ? (el.course.value || 'RN_MED') : 'RN_MED');
    const p = readLS(prefsKeyForCourse(cid));
    return p ? p.data : null;
  }
  function clearPrefsForCourse(courseId){
    const cid = courseId || (el.course ? el.course.value : '');
    if (!cid) return;
    try{
      localStorage.removeItem(prefsKeyForCourse(cid));
      localStorage.removeItem(LS.USEALL_PREFIX + cid);
    }catch(_){}
  }
  function updateRestoreStripVisibility(){
    if (!el.restoreStrip) return;
    const cid = el.course.value || '';
    if (!cid){ el.restoreStrip.style.display = 'none'; return; }
    const prefs = loadPrefs(cid);
    el.restoreStrip.style.display = prefs ? 'flex' : 'none';
  }

  // ====== Stepper ======
  function currentStepId(){ return STEPS[currentStepIndex]; }

  function updateReviewPanel(){
    if (currentStepId() !== 'review') return;

    const diffs = pickDiffs();
    const n = +el.n.value || 0;
    const modeSel = selectionMode();
    const selModeLabel = modeSel==='concept' ? 'Concept keyword' : 'Topic groups';

    el.revCourse.textContent = courseLabel(el.course.value) || '-';
    el.revSelMode.textContent = selModeLabel;

    if (modeSel === 'topics'){
      if (el.useAll.checked){
        el.revTopics.textContent = 'All topics';
      } else if (SELECTED.size){
        el.revTopics.textContent = `${SELECTED.size} topic(s)`;
      } else {
        el.revTopics.textContent = 'None';
      }
      el.revConcept.textContent = 'None';
    } else {
      el.revTopics.textContent = 'Not used (concept mode)';
      const concepts = selectedConcepts();
      const searches = Array.isArray(SEARCH_TERMS) ? SEARCH_TERMS : [];
      const q = (conceptValue || '').trim();

      let conceptLine = '';
      let searchLine  = '';

      if (concepts.length){
        const conceptSummary = summariseItems(concepts, 3);
        conceptLine = `Concepts: ${conceptSummary}`;
      } else if (q){
        conceptLine = 'Concepts: None (using free-text search)';
      } else {
        conceptLine = 'Concepts: None';
      }

      if (searches.length){
        const quoted = searches.map(s => `"${s}"`);
        const searchSummary = summariseItems(quoted, 3);
        searchLine = `Searches: ${searchSummary}`;
      } else if (q){
        searchLine = `Searches: "${q}"`;
      } else {
        searchLine = 'Searches: None';
      }

      el.revConcept.innerHTML = conceptLine + '<br>' + searchLine;
    }

    el.revDiffs.textContent = diffs.length ? diffs.join(', ') : 'All';
    el.revN.textContent = n>0 ? String(n) : '-';
  }

  function updateStepperUI(){
    STEPS.forEach(id=>{
      const panel = document.querySelector('.step[data-step="'+id+'"]');
      if (panel) panel.classList.toggle('active', id === currentStepId());
    });

    const sid = currentStepId();
    if (el.stepLabel && STEP_LABELS[sid]) el.stepLabel.textContent = STEP_LABELS[sid];

    const percent = (currentStepIndex)/(STEPS.length-1) * 100;
    if (el.progressInner) el.progressInner.style.width = percent + '%';

    el.btnBack.disabled = currentStepIndex === 0;
    el.btnBack.style.visibility = currentStepIndex === 0 ? 'hidden' : 'visible';

    if (currentStepIndex === STEPS.length-1){
      el.btnNext.style.display = 'none';
      el.downloadBtn.style.display = 'inline-block';
    } else {
      el.btnNext.style.display = 'inline-block';
      el.downloadBtn.style.display = 'none';
    }

    if (currentStepIndex < STEPS.length-1){
      el.btnNext.disabled = !isStepValid(currentStepId());
    }

    updateReviewPanel();
  }

  function goNext(){
    const sid = currentStepId();
    validateAll();
    if (!isStepValid(sid)){
      updateStepperUI();
      return;
    }
    if (currentStepIndex < STEPS.length-1){
      currentStepIndex++;
      updateStepperUI();
    }
  }

  function goBack(){
    if (currentStepIndex > 0){
      currentStepIndex--;
      updateStepperUI();
    }
  }

  function isStepValid(stepId){
    const n = +el.n.value || 0;
    const approx = estimatePool();
    const maxN = getMaxN();
    const modeSel = selectionMode();

    switch(stepId){
      case 'course':
        return !!el.course.value;

      case 'topics': {
        const hasTopics = el.useAll.checked || SELECTED.size > 0;
        return (modeSel === 'topics') ? hasTopics : hasConcept();
      }

      case 'difficulty':
        return true;

      case 'number':
        if (!(n>0 && n<=maxN && (approx===0 ? true : n<=approx))) return false;
        return true;

      case 'review': {
        const okCourse = !!el.course.value;
        const hasTopics = el.useAll.checked || SELECTED.size > 0;
        const okSelection = (modeSel === 'topics') ? hasTopics : hasConcept();
        const okNum = n>0 && n<=maxN && (approx===0 ? true : n<=approx);
        return okCourse && okSelection && okNum;
      }

      default:
        return true;
    }
  }

  // ====== Courses & Meta ======
  async function loadCourses(){
    setStatus('Loading courses for your enrolments...');
    const list = (ALLOWED_COURSE_IDS && ALLOWED_COURSE_IDS.length) ? ALLOWED_COURSE_IDS.slice() : [];
    renderCourses(list);
  }

  function renderCourses(list){
    el.course.innerHTML = '';
    let useList = list.slice();
    if (COURSE_LOCKED && CONTEXT_COURSE_ID){
      useList = useList.filter(id => id === CONTEXT_COURSE_ID);
    }

    if (!useList.length){
      el.course.disabled = true;
      el.courseBadge.textContent = '-';
      el.sumCourse.textContent = 'Course: -';
      setStatus('You currently have no active courses. Please go to your dashboard to add a subscription.');
      el.btnNext.disabled = true;
      el.downloadBtn.disabled = true;
      return;
    }

    useList.forEach(id=>{
      const opt = document.createElement('option');
      opt.value = id;
      opt.textContent = courseLabel(id);
      el.course.appendChild(opt);
    });

    let initialId = '';
    let lastCourseId = '';
    try{ lastCourseId = localStorage.getItem(LS.LAST_COURSE) || ''; }catch(_){}

    if (COURSE_LOCKED && CONTEXT_COURSE_ID) initialId = CONTEXT_COURSE_ID;
    else if (lastCourseId && useList.includes(lastCourseId)) initialId = lastCourseId;
    else if (useList.length) initialId = useList[0];

    if (initialId) el.course.value = initialId;
    el.course.disabled = COURSE_LOCKED;

    el.courseBadge.textContent = courseLabel(el.course.value) || '-';
    el.sumCourse.textContent = `Course: ${courseLabel(el.course.value) || '-'}`;

    el.btnNext.disabled = false;
