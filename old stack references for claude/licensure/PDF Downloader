  // ===== Difficulty =====
  function pickDiffs(){
    const d=[];
    if (el.easy.checked) d.push('Easy');
    if (el.moderate.checked) d.push('Moderate');
    if (el.hard.checked) d.push('Hard');
    return d;
  }
  
  function allDiffs(){
  // Prefer meta-driven list (in case future courses add new difficulty levels)
  if (META && Array.isArray(META.difficulties) && META.difficulties.length) {
    return META.difficulties.slice();
  }
  // Fallback to your fixed UI set
  return ['Easy','Moderate','Hard'];
}

function pickDiffsOrAll(){
  const picked = pickDiffs();
  return picked.length ? picked : allDiffs();
}


  function difficultyAvailabilityForSelection(){
    if (!META) return { Easy:0, Moderate:0, Hard:0 };
    const td = META.topic_difficulty_counts || null;

    if (selectionMode()==='concept'){
      const dc = META.difficulty_counts || {};
      return { Easy: dc.Easy || 0, Moderate: dc.Moderate || 0, Hard: dc.Hard || 0 };
    }

    if (td){
      const useAll = el.useAll.checked;
      const topicsList = useAll ? Object.keys(td) : selectedTopics();
      if (!topicsList.length){
        const dc = META.difficulty_counts || {};
        return { Easy: dc.Easy || 0, Moderate: dc.Moderate || 0, Hard: dc.Hard || 0 };
      }
      let e=0,m=0,h=0;
      topicsList.forEach(main=>{
        const bucket = td[main];
        if (!bucket) return;
        e += bucket.Easy     || 0;
        m += bucket.Moderate || 0;
        h += bucket.Hard     || 0;
      });
      return { Easy:e, Moderate:m, Hard:h };
    }

    const dc = META.difficulty_counts || {};
    return { Easy: dc.Easy || 0, Moderate: dc.Moderate || 0, Hard: dc.Hard || 0 };
  }

  function reflectDiffUI(){
    const da = difficultyAvailabilityForSelection();
    el.diffHint.textContent = `Available - Easy ${da.Easy || 0} | Moderate ${da.Moderate || 0} | Hard ${da.Hard || 0}`;
    const picked = pickDiffs();
    const label = picked.length ? picked.join(', ') : 'All';
    el.diffBadge.textContent = label;
    el.sumDiffs.textContent = `Difficulty: ${label}`;
  }

  // ===== Estimate =====
  function estimatePool(){
    if (!META) return 0;

    const ds = pickDiffs();
    const td = META.topic_difficulty_counts || null;
    const counts = META.topic_counts || {};

    if (selectionMode() === 'concept'){
      if (!hasConcept()) return 0;
      const concepts = selectedConcepts();
      if (!concepts.length) return 0;
      let total = 0;
      concepts.forEach(c => { total += conceptCountFor(c) || 0; });
      return total;
    }

    const useAll = el.useAll.checked;
    const selected = selectedTopics();

    if (td){
      const topicsList = useAll ? Object.keys(td) : (selected.length ? selected : []);
      if (!topicsList.length) return 0;

      let Easy = 0, Moderate = 0, Hard = 0;
      topicsList.forEach(t => {
        const bucket = td[t];
        if (!bucket) return;
        Easy     += bucket.Easy     || 0;
        Moderate += bucket.Moderate || 0;
        Hard     += bucket.Hard     || 0;
      });

      if (!ds.length) return Easy + Moderate + Hard;
      let total = 0;
      ds.forEach(d => {
        if (d === 'Easy') total += Easy;
        else if (d === 'Moderate') total += Moderate;
        else if (d === 'Hard') total += Hard;
      });
      return total;
    }

    let base = 0;
    if (useAll){
      base = (META.total || META.maxN || 0);
    } else {
      if (!selected.length) return 0;
      selected.forEach(t => base += (counts[t]||0));
    }

    if (!ds.length) return base;
    const dc = META.difficulty_counts || {};
    const totalDiff = (dc.Easy||0) + (dc.Moderate||0) + (dc.Hard||0);
    if (!totalDiff || base===0) return base;

    const share = ds.reduce((acc,d)=> acc + (dc[d]||0), 0) / totalDiff;
    return Math.floor(base * share);
  }

  function updateAvailEstimate(){
    const approx = estimatePool();

    if (selectionMode() === 'concept'){
      const concepts = selectedConcepts();
      const q = (conceptValue || '').trim();
      if (!concepts.length){
        el.availHint.textContent = q
          ? `Search "${q}" - count unknown (we will search all questions for this concept).`
          : 'Selected pool ≈ ? (type or select at least one concept to see estimated count).';
      } else {
        const label = concepts.slice(0,3).join(', ');
        const more = concepts.length > 3 ? ` +${concepts.length - 3} more` : '';
        el.availHint.textContent = approx > 0
          ? `Concepts (${label}${more}) ≈ ${approx} question(s) available`
          : `Concepts (${label}${more}) - count unknown (we will fetch exact items when building)`;
      }
      return;
    }

    el.availHint.textContent = `Selected pool  - ${approx}`;
  }

  function reflectSummary(){
    const diffs = pickDiffs();
    el.sumDiffs.textContent = `Difficulty: ${diffs.length?diffs.join(', '):'All'}`;
    el.sumN.textContent = `N: ${+el.n.value||0}`;
  }

  // ===== Validation =====
  function validateAll(){
    const okCourse = !!el.course.value;
    el.courseErr.style.display = okCourse ? 'none' : 'block';
    if (!okCourse) el.courseErr.textContent = 'Please choose a course.';

    const modeSel = selectionMode();
    const hasTopics = el.useAll.checked || SELECTED.size > 0;

    if (modeSel === 'topics'){
      if (!hasTopics){
        el.topicsErr.style.display='block';
        el.topicsErr.textContent='Select at least one topic or enable "Use all topics".';
      } else {
        el.topicsErr.style.display='none';
      }
    } else {
      if (!hasConcept()){
        el.topicsErr.style.display='block';
        el.topicsErr.textContent='Type or select a concept keyword.';
      } else {
        el.topicsErr.style.display='none';
      }
    }

    const n = +el.n.value || 0;
    const approx = estimatePool();
    const maxN = +el.n.max || 50;
    const okNum = n>0 && n<=maxN && (approx===0 ? true : n<=approx);

    el.numErr.style.display = okNum ? 'none' : 'block';
    if (!okNum){
      if (n>maxN) el.numErr.textContent = `Reduce your input to ${maxN} or less.`;
      else if (approx && n>approx) el.numErr.textContent = `Based on your filters, try  ${approx} or less.`;
      else el.numErr.textContent = 'Enter a valid number of questions.';
    }

    el.numBadge.textContent = n>0 ? `${n}` : '-';
    el.courseBadge.textContent = courseLabel(el.course.value) || '-';
    el.sumCourse.textContent = `Course: ${courseLabel(el.course.value) || '-'}`;

    // Allowance gate is enforced in modal; here we just ensure inputs are valid
    const okSelection = (modeSel==='topics') ? hasTopics : hasConcept();
    el.downloadBtn.disabled = !(okCourse && okSelection && okNum);
  }

  // ===== Restore prefs =====
  function restoreSelectedTopics(){
    const p = loadPrefs(); if (!p) return new Set();
    if (!META) return new Set();
    const valid = new Set((META.topics_main||[]));
    const arr = (Array.isArray(p.topics) ? p.topics.filter(t => valid.has(t)) : []);
    return new Set(arr);
  }

  function restorePrefsAfterMeta(){
    const p = loadPrefs(); if (!p) { updateConceptBucketLine(); return; }

    if (Number.isFinite(+p.n) && +p.n>0) el.n.value = +p.n;
    if (p.diffs){
      el.easy.checked=!!p.diffs.easy;
      el.moderate.checked=!!p.diffs.moderate;
      el.hard.checked=!!p.diffs.hard;
    }
    if (typeof p.filter === 'string') el.topicFilter.value = p.filter;

    if (typeof p.conceptQuery === 'string'){
      conceptValue = p.conceptQuery;
      el.conceptInput.value = p.conceptQuery;
    } else if (typeof p.concept === 'string'){
      conceptValue = p.concept;
      el.conceptInput.value = p.concept;
    }

    if (Array.isArray(p.concepts) && p.concepts.length){
      setSelectedConcepts(p.concepts);
    } else if (typeof p.concept === 'string' && p.concept.trim()){
      setSelectedConcepts([p.concept.trim()]);
    }

    if (Array.isArray(p.searchTerms)){
      SEARCH_TERMS = p.searchTerms.slice();
    } else {
      SEARCH_TERMS = [];
    }

    if (p.selMode === 'concept'){
      SELECT_MODE = 'concept';
      el.modeByConcept.checked = true;
      el.modeByTopics.checked = false;
    } else {
      SELECT_MODE = 'topics';
      el.modeByTopics.checked = true;
      el.modeByConcept.checked = false;
    }

    updateModeSections();
    renderConceptSuggestions();
    updateSelectedBadge();
    updateAvailEstimate();
    updateConceptBucketLine();
    updateRestoreStripVisibility();
  }

