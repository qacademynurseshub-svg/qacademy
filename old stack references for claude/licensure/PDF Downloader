    // ===== Allowance + modal: Reason → message mapping =====
  function allowanceMessageForReason(reason, allowance){
    const r = String(reason || '').trim().toLowerCase();
    const limit = allowance && allowance.limit != null ? allowance.limit : 3;
    const rem   = allowance && allowance.remaining != null ? allowance.remaining : null;

    switch(r){
      case 'trial_not_allowed':
        return 'Downloads are not available on Trial. Upgrade to Premium to unlock offline packs.';

      case 'renew_required':
        return 'Your subscription is not active or has expired. Renew to unlock offline downloads.';

      case 'not_subscribed':
        return 'You do not have an active subscription that includes this course.';

      case 'limit_reached':
        return `You have used all ${limit} offline pack downloads for this course in the current period.`;
        
        case 'allowance_check_failed':
  return 'We could not confirm your allowance due to a network issue. You can still try to create a pack - the server will validate it.';


      case 'no_items_match':
        return 'No questions matched your selection. Broaden your topics/difficulty or switch to “All topics”.';

      // fallback
      default:
        // If backend didn't provide a reason but remaining is 0, show the limit message.
        if (rem === 0) return `You have used all ${limit} offline pack downloads for this course in the current period.`;
        return 'Downloads are not available right now. Please check your subscription and try again.';
    }
  }

  
async function fetchAllowance(course_id){
  const token = getToken();
  if (!token) return null;

  try{
    const url =
      `${WEB_APP_URL}?action=downloads.allowance` +
      `&course_id=${encodeURIComponent(course_id)}` +
      `&token=${encodeURIComponent(token)}`;

    const r = await fetch(url, { method: 'GET' });
    const out = await r.json();

    // ✅ If server says OK, normalize into the same frontend shape
    if (out && out.ok === true){
      const limit = (out.downloads_per_course != null) ? Number(out.downloads_per_course) : 3;
      const remaining = (out.remaining != null) ? Number(out.remaining) : 0;

      return {
        remaining,
        limit,
        can_create: remaining > 0,
        reason: null
      };
    }

    // ❌ Not OK: normalize error/reason into the same shape
    const limit = (out && out.downloads_per_course != null) ? Number(out.downloads_per_course) : 3;
    const remaining = (out && out.remaining != null) ? Number(out.remaining) : 0;

    return {
      remaining,
      limit,
      can_create: false,
      reason: (out && (out.blocked_reason || out.error)) ? (out.blocked_reason || out.error) : 'not_allowed'
    };

  }catch(_){
    // Network failure: allow UI to proceed, but label it so modal message can explain.
    return { remaining: null, limit: 3, can_create: true, reason: 'allowance_check_failed' };
  }
}


  function buildDownloadPayload(){
    const course_id = el.course.value || 'RN_MED';

    const modeSel = selectionMode();
    let topics   = [];
    let concept  = '';
    let concepts = [];
    let search_terms = Array.isArray(SEARCH_TERMS) ? SEARCH_TERMS.slice() : [];

    if (modeSel === 'topics'){
topics = el.useAll.checked ? ["__ALL_TOPICS__"] : selectedTopics();
      concepts = [];
      concept  = '';
} else {
  // Concept mode: store "intent tokens" in topics column
  const conceptsArr = selectedConcepts();
  const query = (conceptValue || '').trim();

  if (query) addSearchTermFromCurrentInput();
  const searchesArr = Array.isArray(SEARCH_TERMS) ? SEARCH_TERMS.slice() : [];

  topics = [
    ...conceptsArr.map(c => `CONCEPT:${String(c).trim()}`),
    ...searchesArr.map(s => `SEARCH:${String(s).trim()}`)
  ].filter(Boolean);

  concepts = conceptsArr;
  concept = query;
  search_terms = searchesArr;
}


const difficulties = pickDiffsOrAll();
    let question_count = +el.n.value || 10;
    const max = +el.n.max || 50;
    if (question_count > max) question_count = max;

    return {
      course_id,
      pack_name: (el.packName.value || '').trim(),
      question_count,
      topics,
      difficulties,
      concept,
      concepts,
      search_terms,
      watermark: watermarkSnapshot(),
      status: 'active'
    };
  }

async function createDownloadPack() {
  const name = (el.packName.value || '').trim();
  if (!name) { modalErr('Please enter a pack name.'); return; }
  
  const course_id = el.course.value || 'RN_MED';
  const token = getToken();
  if (!token) { modalErr('Session missing.'); return; }

  el.dlCreateBtn.disabled = true;
  showPageLoader('Creating your pack...', 'Generating your offline pack.');

  try {
    const res = await fetch(`${WEB_APP_URL}?action=downloads.create`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ token, payload: JSON.stringify(buildDownloadPayload()) })
    });

const out = await res.json();

if (!out || out.ok !== true) {
  hidePageLoader(); // ✅ hide only on failure

  // Backend uses blocked_reason for most “expected” failures
  const reason = (out && (out.blocked_reason || out.reason)) ? (out.blocked_reason || out.reason) : (out && out.error) ? out.error : 'unknown';

  // If we already fetched allowance, reuse it for better messaging
  const msg = allowanceMessageForReason(reason, ALLOWANCE);
  modalErr(msg);

  // If it’s a “hard block”, keep Create disabled (prevents spam clicks)
  const hardBlocks = ['trial_not_allowed','renew_required','not_subscribed','limit_reached'];
  if (hardBlocks.includes(String(reason||'').toLowerCase())) {
    el.dlCreateBtn.disabled = true;
  } else {
    el.dlCreateBtn.disabled = false;
  }

  return;
}

// ✅ success: keep overlay up and switch message
showPageLoader('Opening your pack...', 'Almost done - loading the renderer page.');



    closeModal();
// Refresh allowance in background (not blocking redirect)
try{ fetchAllowance(course_id).then(a => { ALLOWANCE = a; }); }catch(_){}

    const packId = out.pack_id;
    const dlUrl = `${WEB_APP_URL}?action=downloads.get&pack_id=${encodeURIComponent(packId)}&token=${encodeURIComponent(token)}`;

// ✅ Redirect to renderer page (token stays in localStorage)
setStatus('Pack created! Redirecting to the renderer...');

const url = `${OFFLINE_RENDERER_URL}?pack_id=${encodeURIComponent(packId)}`;
window.location.href = url;

  } catch (err) {
    hidePageLoader();
    el.dlCreateBtn.disabled = false;
    modalErr('Network error: ' + err.message);
  }
}

  async function startDownloadFlow(){
    validateAll();
    if (el.downloadBtn.disabled) return;

    const course_id = el.course.value || 'RN_MED';

    // fetch allowance fresh whenever opening modal
    showPageLoader('Checking allowance...', 'Confirming your download allowance for this course.');
    ALLOWANCE = await fetchAllowance(course_id);
    hidePageLoader();

    updateModalPills();

    if (ALLOWANCE && ALLOWANCE.can_create === false){
      openModal();
      updateModalPills();

      // Use backend reason mapping
      const msg = allowanceMessageForReason(ALLOWANCE.reason, ALLOWANCE);
      modalErr(msg);

      // Prevent create while blocked
      el.dlCreateBtn.disabled = true;

      // Optional: focus Close so user isn't stuck
      try{ el.dlCloseBtn.focus(); }catch(_){}
      return;
    }


    el.dlCreateBtn.disabled = false;
    openModal();
  }

  // ===== Events =====
  el.course.addEventListener('change', ()=>{
    el.courseBadge.textContent = courseLabel(el.course.value) || '-';
    el.sumCourse.textContent = `Course: ${courseLabel(el.course.value) || '-'}`;
    savePrefs();
    updateRestoreStripVisibility();

    loadMeta().then(()=>{
      restorePrefsAfterMeta();
      renderTopics();
      reflectDiffUI();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      setStatus('Course loaded. Adjust your filters, then download your offline pack.');
    });
  });

  el.topicFilter.addEventListener('input', ()=>{ renderTopics(); savePrefs(); });

  el.selectAll.addEventListener('click', ()=>{
    if (selectionMode()!=='topics') return;
    el.useAll.checked = false;
    saveUseAll(el.course.value || 'RN_MED', false);
    setTopicsBoxInteractivity();

    const boxes = el.topicsBox.querySelectorAll('input.tchk');
    boxes.forEach(chk=>{ chk.checked = true; SELECTED.add(chk.value); });

    renderTopics();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    reflectDiffUI();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.clearAll.addEventListener('click', ()=>{
    if (selectionMode()!=='topics') return;
    el.useAll.checked = false;
    saveUseAll(el.course.value || 'RN_MED', false);
    setTopicsBoxInteractivity();

    const boxes = el.topicsBox.querySelectorAll('input.tchk');
    boxes.forEach(chk=>{ chk.checked = false; SELECTED.delete(chk.value); });

    renderTopics();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    reflectDiffUI();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.sortToggle.addEventListener('click', ()=>{
    sortMode = (sortMode==='name') ? 'count' : 'name';
    el.sortToggle.textContent = `Sort: ${sortMode==='name' ? 'Name' : 'Count'}`;
    renderTopics();
  });

  [el.easy, el.moderate, el.hard].forEach(cb=>{
    cb.addEventListener('change', ()=>{
      reflectDiffUI();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  });

  ['change','input'].forEach(ev=>{
    el.n.addEventListener(ev, ()=>{
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  });

  el.useAll.addEventListener('change', ()=>{
    saveUseAll(el.course.value || 'RN_MED', el.useAll.checked);
    if (el.useAll.checked) SELECTED.clear();
    setTopicsBoxInteractivity();
    renderTopics();
    updateAvailEstimate();
    reflectSummary();
    reflectDiffUI();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.conceptInput.addEventListener('input', ()=>{
    conceptValue = el.conceptInput.value || '';
    renderConceptSuggestions();
    updateConceptBucketLine();
    savePrefs();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    validateAll();
    updateStepperUI();
  });

  if (el.conceptSelectShown){
    el.conceptSelectShown.addEventListener('click', ()=>{
      if (selectionMode()!=='concept') return;
      const boxes = el.conceptSuggestBox.querySelectorAll('input.concept-choice');
      if (!boxes.length) return;
      boxes.forEach(input=>{ input.checked = true; toggleConceptSelection(input.value, true); });
      addSearchTermFromCurrentInput();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
      renderConceptSuggestions();
    });
  }

  if (el.conceptClearShown){
    el.conceptClearShown.addEventListener('click', ()=>{
      if (selectionMode()!=='concept') return;
      const boxes = el.conceptSuggestBox.querySelectorAll('input.concept-choice');
      if (!boxes.length) return;
      boxes.forEach(input=>{ input.checked = false; toggleConceptSelection(input.value, false); });
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
      renderConceptSuggestions();
    });
  }

  if (el.resetConceptSearch){
    el.resetConceptSearch.addEventListener('click', ()=>{
      conceptValue = '';
      el.conceptInput.value = '';
      renderConceptSuggestions();
      updateConceptBucketLine();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  }

  if (el.clearAllConcepts){
    el.clearAllConcepts.addEventListener('click', ()=>{
      setSelectedConcepts([]);
      SEARCH_TERMS = [];
      conceptValue = '';
      el.conceptInput.value = '';
      renderConceptSuggestions();
      updateConceptBucketLine();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      savePrefs();
    });
  }

  el.modeByTopics.addEventListener('change', ()=>{
    if (!el.modeByTopics.checked) return;
    SELECT_MODE = 'topics';
    updateModeSections();
    reflectSummary();
    validateAll();
    updateStepperUI();
    savePrefs();
  });

  el.modeByConcept.addEventListener('change', ()=>{
    if (!el.modeByConcept.checked) return;
    SELECT_MODE = 'concept';
    updateModeSections();
    reflectSummary();
    validateAll();
    updateStepperUI();
    savePrefs();
  });



  el.btnNext.addEventListener('click', goNext);
  el.btnBack.addEventListener('click', goBack);
  el.downloadBtn.addEventListener('click', startDownloadFlow);

  document.querySelectorAll('.review-edit').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const stepId = btn.getAttribute('data-edit-step');
      const idx = STEPS.indexOf(stepId);
      if (idx >= 0){
        currentStepIndex = idx;
        updateStepperUI();
      }
    });
  });

  if (el.btnRestorePrefs){
    el.btnRestorePrefs.addEventListener('click', ()=>{
      const cid = el.course.value || 'RN_MED';
      const prefs = loadPrefs(cid);
      if (!prefs){ updateRestoreStripVisibility(); return; }
      restorePrefsAfterMeta();
      renderTopics();
      reflectDiffUI();
      updateSelectedBadge();
      updateAvailEstimate();
      reflectSummary();
      validateAll();
      updateStepperUI();
      setStatus('Previous setup applied for this course.');
    });
  }

  if (el.btnResetPrefs){
    el.btnResetPrefs.addEventListener('click', hardResetCurrentCourse);
  }

  // Modal events
  el.dlCloseBtn.addEventListener('click', closeModal);
  el.dlCancelBtn.addEventListener('click', closeModal);
  el.dlCreateBtn.addEventListener('click', createDownloadPack);

  // Click outside closes
  el.dlModal.addEventListener('click', (e)=>{
    if (e.target === el.dlModal) closeModal();
  });

  // Enter to create
  el.packName.addEventListener('keydown', (e)=>{
    if (e.key === 'Enter'){
      e.preventDefault();
      createDownloadPack();
    }
  });

  // ===== Init =====
  (async function init(){
    try{
      const guardResult = await window.qaGuardReady;
      if (!guardResult || guardResult.blocked){
        setStatus('Access blocked. Please return to your dashboard.');
        return;
      }
    }catch(e){
      setStatus('Could not verify your access. Please reload this page.');
      return;
    }

    const access = window.QA_ACCESS || {};
    ALLOWED_COURSE_IDS = Array.isArray(access.courseIds) ? access.courseIds.slice() : [];

    const ctxRaw = getQueryParam("course_id") || getQueryParam("cid");
    if (ctxRaw && ALLOWED_COURSE_IDS.length){
      const ctxNorm = ctxRaw.trim().toUpperCase();
      const matchId = ALLOWED_COURSE_IDS.find(id => String(id).trim().toUpperCase() === ctxNorm);
      if (matchId){
        CONTEXT_COURSE_ID = matchId;
        COURSE_LOCKED = true;
      } else {
        setStatus('Note: you do not have access to that course. Showing your available courses instead.');
      }
    }

    await loadCourses();
    if (!ALLOWED_COURSE_IDS || !ALLOWED_COURSE_IDS.length) return;

    await loadMeta();
    restorePrefsAfterMeta();
    renderTopics();
    reflectDiffUI();
    updateSelectedBadge();
    updateAvailEstimate();
    reflectSummary();
    validateAll();
    updateStepperUI();

    setStatus('Ready. Set up your pack using the steps above.');
  })();

})();
</script>
