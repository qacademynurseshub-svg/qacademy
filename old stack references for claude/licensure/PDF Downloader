  <div class="err" id="numErr" style="display:none;"></div>
</div> <!-- ✅ CLOSE step-body -->

    </div>

    <!-- STEP 5: Review -->
    <div class="step" id="stepReview" data-step="review">
      <div class="step-header">
        <h2 class="step-title">Step 5 - Review &amp; Download</h2>
        <p class="step-sub">Check your setup, then generate your offline revision pack.</p>
