  function setTopicsBoxInteractivity(){
    const topicsMode = selectionMode()==='topics';
    const on = topicsMode && !el.useAll.checked;
    el.topicSection.classList.toggle('disabled', !topicsMode);
    el.topicsBox.style.opacity = on ? 1 : 0.5;
    el.topicsBox.querySelectorAll('input.tchk').forEach(chk=>{ chk.disabled = !on; });
    el.useAll.disabled = !topicsMode;
  }

  // ---- concept count helper ----
  function conceptCountFor(value){
    if (!META || !META.concept_counts) return 0;
    const map = META.concept_counts;
    if (!value) return 0;
    const direct = map[value];
    if (typeof direct === 'number') return direct;
    const lower = String(value).toLowerCase();
    for (const key in map){
      if (Object.prototype.hasOwnProperty.call(map, key)){
        if (String(key).toLowerCase() === lower){
          return map[key] || 0;
        }
      }
    }
    return 0;
  }

  function toggleConceptSelection(concept, shouldBeSelected){
    concept = (concept || '').trim();
    if (!concept) return;

    const arr = selectedConcepts();
    const idx = arr.findIndex(c => c.toLowerCase() === concept.toLowerCase());

    if (shouldBeSelected === true){
      if (idx === -1) arr.push(concept);
    } else if (shouldBeSelected === false){
      if (idx !== -1) arr.splice(idx, 1);
    } else {
      if (idx === -1) arr.push(concept);
      else arr.splice(idx, 1);
    }
    setSelectedConcepts(arr);
  }

  function addSearchTermFromCurrentInput(){
    const q = (conceptValue || '').trim();
    if (!q) return;
    const lowerList = SEARCH_TERMS.map(s => s.toLowerCase());
    if (!lowerList.includes(q.toLowerCase())){
      SEARCH_TERMS.push(q);
    }
  }

  function updateConceptBucketLine(){
    if (!el.conceptBucketLine) return;
    const concepts = selectedConcepts();
    const searches = Array.isArray(SEARCH_TERMS) ? SEARCH_TERMS : [];
    const q = (conceptValue || '').trim();

    if (!concepts.length && !searches.length && !q){
      el.conceptBucketLine.textContent = 'No concepts selected yet. Type a keyword or pick from suggestions.';
      return;
    }

    const nConcepts = concepts.length;
    const nSearches = searches.length;

    if (nConcepts && nSearches){
      el.conceptBucketLine.textContent = `Concept bucket: ${nConcepts} concept(s) from ${nSearches} search(es).`;
    } else if (nConcepts){
      el.conceptBucketLine.textContent = `Concept bucket: ${nConcepts} concept(s).`;
    } else if (q){
      el.conceptBucketLine.textContent = `Current search: "${q}".`;
    } else if (nSearches){
      const quoted = searches.map(s => `"${s}"`);
      const summary = summariseItems(quoted, 3);
      el.conceptBucketLine.textContent = `Searches so far: ${summary}.`;
    } else {
      el.conceptBucketLine.textContent = 'Concept bucket: -';
    }
  }

  function buildConceptSuggestionsList(query){
    if (!META || !Array.isArray(META.concept_suggestions)) return [];
    const q = (query || '').toLowerCase().trim();
    let list = META.concept_suggestions.slice();
    if (q) list = list.filter(c => c.toLowerCase().includes(q));
    return list.slice(0, 20);
  }

  function renderConceptSuggestions(){
    const modeSel = selectionMode();
    const box = el.conceptSuggestBox;
    if (!box) return;

    if (modeSel !== 'concept'){
      box.style.display = 'none';
      return;
    }
    if (!META || !Array.isArray(META.concept_suggestions)){
      box.style.display = 'none';
      return;
    }

    const q = el.conceptInput.value || '';
    const list = buildConceptSuggestionsList(q);

    box.innerHTML = '';
    if (!list.length){
      box.style.display = 'block';
      box.innerHTML = '<div class="concept-empty">No suggestions. You can still use this keyword as free text.</div>';
      return;
    }

    const selectedLower = selectedConcepts().map(c => c.toLowerCase());

    list.forEach(con => {
      const row = document.createElement('label');
      row.className = 'concept-item';

      const cCount = conceptCountFor(con);
      const labelText = cCount ? `${con} (${cCount})` : con;
      row.title = cCount ? `${con}: ${cCount} question(s) available` : con;

      const isChecked = selectedLower.includes(con.toLowerCase());
      row.innerHTML = `<input type="checkbox" class="concept-choice" value="${con}"> <span>${labelText}</span>`;
      const input = row.querySelector('input');
      input.checked = isChecked;

      input.addEventListener('change', () => {
        toggleConceptSelection(con, input.checked);
        if (input.checked) addSearchTermFromCurrentInput();
        updateSelectedBadge();
        updateAvailEstimate();
        reflectSummary();
        validateAll();
        updateStepperUI();
        savePrefs();
      });

      box.appendChild(row);
    });

    box.style.display = 'block';
  }

  function updateModeSections(){
    const isTopics = (selectionMode() === 'topics');

    if (isTopics){
      el.topicSection.classList.remove('disabled', 'collapsed');
      el.conceptSection.classList.add('disabled', 'collapsed');
      setTopicsBoxInteractivity();
      el.conceptSuggestBox.style.display = 'none';
    } else {
      el.topicSection.classList.add('disabled', 'collapsed');
      el.conceptSection.classList.remove('disabled', 'collapsed');
      el.topicsBox.querySelectorAll('input.tchk').forEach(chk => chk.disabled = true);
      el.useAll.disabled = true;
      renderConceptSuggestions();
    }

    updateSelectedBadge();
    updateAvailEstimate();
    updateConceptBucketLine();
  }

  function updateSelectedBadge(){
    const totalTopics = (META && META.topics_main ? META.topics_main.length : 0);

    if (selectionMode() === 'concept'){
      const concepts = selectedConcepts();
      const searches = Array.isArray(SEARCH_TERMS) ? SEARCH_TERMS : [];
      const q = (conceptValue || '').trim();

      if (concepts.length){
        const searchCount = searches.length || (q ? 1 : 0);
        el.topicsBadge.textContent = 'Concept mode';
        el.sumTopics.textContent = searchCount
          ? `Selection: ${concepts.length} concepts • ${searchCount} searches`
          : `Selection: ${concepts.length} concepts`;
      } else if (q){
        el.topicsBadge.textContent = 'Concept search';
        el.sumTopics.textContent = `Selection: Search "${q}"`;
      } else {
        el.topicsBadge.textContent = 'Concept mode';
        el.sumTopics.textContent = 'Selection: Concept (none)';
      }

      if (el.selectedPill) el.selectedPill.textContent = 'Concept mode (topics not used)';
      updateConceptBucketLine();
      return;
    }

    const sel   = SELECTED.size;
    const isAll = el.useAll.checked;

    if (isAll){
      el.topicsBadge.textContent = 'All topics';
      el.sumTopics.textContent   = 'Selection: All topics';
      if (el.selectedPill){
        el.selectedPill.textContent = `Selected: ${totalTopics} / ${totalTopics} topics (all)`;
      }
    } else {
      el.topicsBadge.textContent = sel ? `${sel} selected` : '-';
      el.sumTopics.textContent   = `Selection: ${sel} topics`;
      if (el.selectedPill){
        el.selectedPill.textContent = `Selected: ${sel} / ${totalTopics} topics`;
      }
    }
