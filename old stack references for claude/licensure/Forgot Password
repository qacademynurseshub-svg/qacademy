<!-- =================== QAcademy — Forgot Password (Reset Request) =================== -->
<meta name="viewport" content="width=device-width, initial-scale=1" />

<style>
  :root{
    --brand:#0b7a75;
    --brand-soft:#e0f2f1;
    --muted:#6b7b7a;
    --paper:#ffffff;
    --bg:#f5f7fa;
    --danger:#b42318;
    --danger-soft:#fef2f2;
    --ok:#166534;
    --ok-soft:#ecfdf3;
  }

  body{
    margin:0;
    padding:0;
    background:var(--bg);
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  }

  .qa-fp-shell{
    min-height:70vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px 12px;
  }

  .qa-fp-card{
    width:100%;
    max-width:420px;
    background:var(--paper);
    border-radius:16px;
    box-shadow:0 16px 40px rgba(15,23,42,0.08);
    padding:20px 20px 18px;
    box-sizing:border-box;
  }

  .qa-fp-header{
    margin-bottom:12px;
  }

  .qa-fp-tag{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:4px 10px;
    border-radius:999px;
    background:var(--brand-soft);
    color:var(--brand);
    font-size:11px;
    font-weight:600;
    letter-spacing:.03em;
    text-transform:uppercase;
  }

  .qa-fp-title{
    margin:10px 0 4px;
    font-size:22px;
    font-weight:700;
    color:#0f172a;
  }

  .qa-fp-sub{
    margin:0;
    font-size:13px;
    color:var(--muted);
    line-height:1.5;
  }

  .qa-fp-hint-box{
    margin:14px 0 16px;
    padding:10px 10px 10px;
    border-radius:10px;
    background:#f9fafb;
    border:1px solid #e5e7eb;
    font-size:12px;
    color:#4b5563;
  }

  .qa-fp-hint-box b{
    display:block;
    margin-bottom:4px;
    font-size:12px;
    color:#111827;
  }

  .qa-fp-hint-list{
    padding-left:18px;
    margin:4px 0 0;
  }

  .qa-fp-hint-list li{
    margin-bottom:2px;
  }

  .qa-fp-form-group{
    margin-bottom:12px;
  }

  .qa-fp-label{
    display:block;
    font-size:12px;
    font-weight:600;
    color:#111827;
    margin-bottom:4px;
  }

  .qa-fp-input{
    width:100%;
    box-sizing:border-box;
    padding:8px 10px;
    border-radius:10px;
    border:1px solid #d1d5db;
    font-size:13px;
    outline:none;
    transition:border-color .15s, box-shadow .15s;
  }
  .qa-fp-input:focus{
    border-color:var(--brand);
    box-shadow:0 0 0 1px rgba(11,122,117,0.2);
  }

  .qa-fp-help{
    font-size:11px;
    color:#6b7280;
    margin-top:4px;
  }

  .qa-fp-actions{
    margin-top:10px;
    display:flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }

  .qa-fp-btn-main{
    border:none;
    outline:none;
    padding:9px 16px;
    border-radius:999px;
    background:var(--brand);
    color:#ffffff;
    font-size:13px;
    font-weight:600;
    cursor:pointer;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }
  .qa-fp-btn-main[disabled]{
    opacity:.7;
    cursor:default;
  }

  .qa-fp-btn-link{
    border:none;
    background:none;
    padding:0;
    font-size:12px;
    color:var(--muted);
    text-decoration:underline;
    cursor:pointer;
  }

  .qa-fp-status{
    margin-top:12px;
    font-size:12px;
    border-radius:10px;
    padding:8px 10px;
    display:none;
  }

  .qa-fp-status.ok{
    display:block;
    background:var(--ok-soft);
    color:var(--ok);
    border:1px solid #86efac;
  }

  .qa-fp-status.error{
    display:block;
    background:var(--danger-soft);
    color:var(--danger);
    border:1px solid #fecaca;
  }

  .qa-fp-footer-note{
    margin-top:14px;
    font-size:11px;
    color:#9ca3af;
    text-align:center;
  }
</style>

<div class="qa-fp-shell">
  <div class="qa-fp-card" id="qa-fp-root">
    <!-- Header -->
    <div class="qa-fp-header">
      <div class="qa-fp-tag">
        <!-- Tiny “Amanda dot” style -->
        <span style="width:7px;height:7px;border-radius:999px;background:var(--brand);display:inline-block;"></span>
        QAcademy · Account help
      </div>
      <h2 class="qa-fp-title">Forgot your password?</h2>
      <p class="qa-fp-sub">
        Don’t worry. We’ll send a reset link to the email linked to your QAcademy account.
      </p>
    </div>

    <!-- MAIN BLOCK: hint + form + actions + status -->
    <div id="qa-fp-main-block">
      <!-- Helper box: try this first -->
      <div class="qa-fp-hint-box">
        <b>Before requesting a reset, please try this:</b>
        <ul class="qa-fp-hint-list">
          <li>If you remember the <b>Google account</b> you used for QAcademy, try using <b>“Sign in with Google”</b> on the login page.</li>
          <li>Make sure you are using the <b>same email</b> you used when you created your account or joined Premium.</li>
          <li>If you already tried these and still can’t log in, request a password reset below.</li>
        </ul>
      </div>

      <!-- Reset request form -->
      <div class="qa-fp-form-group">
        <label class="qa-fp-label" for="qa-fp-ident">Email or username</label>
        <input
          id="qa-fp-ident"
          class="qa-fp-input"
          type="text"
          autocomplete="email"
          placeholder="e.g. akosua@gmail.com or akosua01"
        />
        <div class="qa-fp-help">
          Enter the email or username you use on QAcademy. We’ll email the reset link if an account exists.
        </div>
      </div>

      <!-- Actions -->
      <div class="qa-fp-actions">
        <button id="qa-fp-submit" class="qa-fp-btn-main">
          <span id="qa-fp-btn-text">Send reset link</span>
          <span id="qa-fp-btn-spinner" style="display:none;">· Working…</span>
        </button>
        <button type="button" class="qa-fp-btn-link" id="qa-fp-back-login">
          Back to login
        </button>
      </div>

      <!-- Status message (for errors) -->
      <div id="qa-fp-status" class="qa-fp-status"></div>
    </div>

    <!-- SUCCESS BLOCK: shown after successful request -->
    <div id="qa-fp-success-block" style="display:none;">
      <div class="qa-fp-status ok" style="display:block;margin-top:4px;">
        If this account exists, we’ve sent you an email with a reset link.
      </div>
      <div style="margin-top:10px;font-size:12px;color:#4b5563;">
        Please check your inbox and spam folder for an email from QAcademy. Follow the link in that email to choose a new password.
      </div>
      <div style="margin-top:16px;text-align:center;">
        <button type="button" class="qa-fp-btn-main" id="qa-fp-success-back">
          Back to login
        </button>
      </div>
    </div>

    <div class="qa-fp-footer-note">
      For your security, we’ll never tell you if an email or username is not registered.
    </div>
  </div>
</div>

<script>
  // ================== CONFIG ==================
  // TODO: Replace with your real Auth v3 WebApp URL (the same one used in login/guard).
  const AUTH_URL = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec"; // e.g. https://script.google.com/macros/s/AKfycb.../exec

  // If you ever change your login slug, update this:
  const LOGIN_SLUG = "login_23"; // current login page slug
  const LOGIN_URL  = "/p/" + LOGIN_SLUG + ".html";

  // ================== HELPERS ==================
  function qaFpShowStatus(kind, msg){
    const box = document.getElementById("qa-fp-status");
    if(!box) return;
    box.classList.remove("ok","error");
    if(!msg){
      box.style.display = "none";
      return;
    }
    box.textContent = msg;
    box.classList.add(kind === "error" ? "error" : "ok");
  }

  function qaFpSetLoading(isLoading){
    const btn      = document.getElementById("qa-fp-submit");
    const textSpan = document.getElementById("qa-fp-btn-text");
    const spinSpan = document.getElementById("qa-fp-btn-spinner");
    if(!btn || !textSpan || !spinSpan) return;

    if(isLoading){
      btn.setAttribute("disabled","disabled");
      textSpan.style.opacity = ".6";
      spinSpan.style.display = "inline";
    } else {
      btn.removeAttribute("disabled");
      textSpan.style.opacity = "1";
      spinSpan.style.display = "none";
    }
  }

  function qaFpShowSuccessState(){
    const main = document.getElementById("qa-fp-main-block");
    const success = document.getElementById("qa-fp-success-block");
    if(main) main.style.display = "none";
    if(success) success.style.display = "block";
  }

  async function qaFpHandleSubmit(){
    const input = document.getElementById("qa-fp-ident");
    if(!input) return;

    const identRaw = (input.value || "").trim();
    if(!identRaw){
      qaFpShowStatus("error","Please enter your email or username.");
      return;
    }

    qaFpShowStatus("", "");
    qaFpSetLoading(true);

    const ident = identRaw; // backend handles email vs username
    const body = new URLSearchParams();
    body.append("action","reset_request");
    body.append("email", ident);
    body.append("username", ident);
    body.append("ua", navigator.userAgent || "");
    body.append("ip", "browser"); // optional label

    // Generic message text aligned with success block
    const genericMsg = "If this account exists, we’ve sent you an email with a reset link.";

    try{
      const resp = await fetch(AUTH_URL, {
        method: "POST",
        headers: { "Content-Type":"application/x-www-form-urlencoded" },
        body
      });

      const text = await resp.text();
      let json = null;
      try{
        json = JSON.parse(text);
      } catch(e){
        console.warn("Non-JSON reset_request response:", text);
      }

      if(json && json.ok){
        console.log("reset_request response:", json);
        input.value = "";
        qaFpShowSuccessState();
      } else if(json && !json.ok){
        console.warn("reset_request error:", json);
        // Still switch to success UI to avoid leaking account existence
        qaFpShowSuccessState();
      } else {
        // Non-JSON or unexpected, still show success UI (backend likely handled it)
        qaFpShowSuccessState();
      }
    } catch(err){
      console.error("reset_request fetch error:", err);
      qaFpShowStatus("error","We could not contact the server. Please try again in a few minutes.");
    } finally {
      qaFpSetLoading(false);
    }
  }

  // ================== INIT ==================
  (function(){
    const btn = document.getElementById("qa-fp-submit");
    const backBtn = document.getElementById("qa-fp-back-login");
    const input = document.getElementById("qa-fp-ident");
    const successBackBtn = document.getElementById("qa-fp-success-back");

    if(btn){
      btn.addEventListener("click", function(ev){
        ev.preventDefault();
        qaFpHandleSubmit();
      });
    }

    if(backBtn){
      backBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        window.location.href = LOGIN_URL;
      });
    }

    if(successBackBtn){
      successBackBtn.addEventListener("click", function(ev){
        ev.preventDefault();
        window.location.href = LOGIN_URL;
      });
    }

    if(input){
      input.addEventListener("keyup", function(ev){
        if(ev.key === "Enter"){
          qaFpHandleSubmit();
        }
      });
    }
  })();
</script>
