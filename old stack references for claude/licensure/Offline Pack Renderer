        }catch(e){
          try{ doc.addImage(assets.logoDataUrl, 'JPEG', 14, 9, 26, 26); }catch(_e2){}
        }
      }

      // Brand text
      doc.setFont('helvetica','bold');
      doc.setFontSize(22);
      doc.setTextColor(255,255,255);
doc.text('QAcademy Nurses Hub', 46, 22);

      doc.setFont('helvetica','normal');
      doc.setFontSize(11);
      doc.text('Offline Revision Pack', 46, 36);

      // Main title
      doc.setTextColor(S.ink);
      doc.setFont('helvetica','bold');
      doc.setFontSize(18);

      const titleLines = pdfWrap(doc, meta.pack_name || 'Offline Pack', W - 28);
      doc.text(titleLines, 14, 74);

      let y = 74 + (titleLines.length * 7) + 6;

 // ===== Compact full Overview box (ALL fields, no truncation) =====
const boxX = 14;
const boxW = W - 28;

let oy = y; // start right where your old meta box started

// Box title
