const leftColX = innerX;
const rightColX = innerX + colW + colGap;

doc.setFont('helvetica','normal');
doc.setFontSize(10);

// Key/value renderer (wraps values)
function drawKV(x, y0, key, val){
  const keyTxt = String(key || '').trim();
  const valTxt = String(val ?? '—').trim() || '—';

  doc.setFont('helvetica','bold');
  doc.setTextColor(S.muted);
  doc.text(keyTxt.toUpperCase(), x, y0);

  doc.setFont('helvetica','normal');
  doc.setTextColor(S.ink);

  const lines = doc.splitTextToSize(valTxt, colW);
  let yy = y0 + 5.2;
  for (const ln of lines){
    doc.text(ln, x, yy);
    yy += 4.8;
  }
  return yy; // returns next y after block
}

// Items (ALL fields)
const leftItems = [
  ['Prepared for', meta.owner_label],
  ['Course', meta.course],
  ['Questions', String(meta.question_count ?? '—')]
];

const rightItems = [
  ['Pack ID', meta.pack_id],
  ['Generated', meta.created_at_human || '—'],
  ['Difficulty', meta.diffs_text || 'All']
];

// Draw left + right columns, track height
let yL = oy + padY + 2;
let yR = oy + padY + 2;

for (const [k,v] of leftItems)  yL = drawKV(leftColX,  yL, k, v) + 3;
for (const [k,v] of rightItems) yR = drawKV(rightColX, yR, k, v) + 3;

// Topics row spanning full width (wraps across whole box)
