doc.setFont('helvetica','bold');
doc.setTextColor(S.muted);
doc.text('TOPICS SELECTED', innerX, topicsY);

doc.setFont('helvetica','normal');
doc.setTextColor(S.ink);
const topicsVal = meta.topics_text || 'All topics';
const topicLines = doc.splitTextToSize(String(topicsVal), innerW);
let ty = topicsY + 5.2;
for (const ln of topicLines){
  doc.text(ln, innerX, ty);
  ty += 4.8;
}

// Footer hint in box
ty += 2;
doc.setFont('helvetica','normal');
doc.setFontSize(9);
doc.setTextColor(S.muted);
doc.text('Attempt the questions first. Use the Answer Key at the end to check your work.', innerX, ty);

// Compute box height dynamically (so it fits whatever topics length)
const boxH = (ty - oy) + 8;

// Draw the box border behind content (draw now is fine; if you want behind, move before text)
doc.setDrawColor(210);
doc.setLineWidth(0.3);
doc.roundedRect(boxX, oy, boxW, boxH, 3, 3, 'S');

// Update y to continue after the box
y = oy + boxH + 8;


      // Small disclaimer
      doc.setFontSize(9);
      doc.setTextColor(S.muted);
      doc.text('For personal study use only. Do not share.', 14, H - 18);

      // Next page for content
      doc.addPage();
    }

    function pdfAddOverview(doc, meta, L){
      const S = pdfStyles();
      const W = L.pageW;

      doc.setFont('helvetica','bold');
      doc.setFontSize(14);
      doc.setTextColor(S.ink);
      doc.text('Pack Overview', L.left, L.topY);

      let y = L.topY + 10;

      doc.setFont('helvetica','normal');
      doc.setFontSize(10);
      doc.setTextColor(S.ink);

      const maxW = L.maxW;

      const blocks = [
        ['Course', meta.course || '—'],
        ['Questions', String(meta.question_count ?? '—')],
        ['Pack ID', meta.pack_id || '—'],
        ['Generated', meta.created_at_human || '—'],
        ['Topics selected', meta.topics_text || 'All topics'],
        ['Difficulty', meta.diffs_text || 'All']
      ];

      blocks.forEach(([k,v])=>{
        doc.setFont('helvetica','bold');
        doc.text(k + ':', L.left, y);
        y += 6;

        doc.setFont('helvetica','normal');
        const lines = pdfWrap(doc, v, maxW);
        for (const ln of lines){
          y = pdfEnsureSpace(doc, y, 6, L);
          doc.text(ln, L.left, y);
          y += 5.2;
        }
        y += 3;
      });

      doc.setFont('helvetica','normal');
      doc.setFontSize(10);
      doc.setTextColor(S.muted);
      y = pdfEnsureSpace(doc, y, 14, L);
      doc.text('Attempt the questions first. Use the Answer Key at the end to check your work.', L.left, y);

      doc.addPage();
    }

    async function downloadPackPdf(pack){
      if (!window.jspdf || !window.jspdf.jsPDF) throw new Error('PDF library not loaded');
      const { jsPDF } = window.jspdf;

      const items = Array.isArray(pack.items) ? pack.items : [];

      // Meta (PDF-only)
      const created = pack.created_at ? new Date(pack.created_at) : null;

      const ownerLabel = String(pack.watermark?.owner_label || '').trim()
        || String(pack.watermark?.owner_name || '').trim()
        || 'QAcademy Student';

      const topicsArr = Array.isArray(pack.topics) ? pack.topics : [];
      const diffsArr  = Array.isArray(pack.difficulties) ? pack.difficulties : [];

      const meta = {
        pack_name: String(pack.pack_name || 'Offline Pack'),
        course: String(pack.course_id || '—'),
        pack_id: String(pack.pack_id || '—'),
        owner_label: ownerLabel,
        question_count: items.length || (pack.question_count ?? null),
        created_at_human: created ? created.toLocaleString() : '',
        topics_text: topicsArr.length ? topicsArr.map(x=>String(x)).join(', ') : 'All topics',
        diffs_text: diffsArr.length ? diffsArr.map(x=>String(x)).join(', ') : 'All'
      };

      const doc = new jsPDF({ unit:'mm', format:'a4' });
      const L = pdfLayout(doc);
      const S = pdfStyles();

      // Try embed logo on cover (PDF only). If it fails, cover still renders cleanly.
const logoDataUrl =
  (typeof QA_LOGO_DATA_URL === 'string' && QA_LOGO_DATA_URL.startsWith('data:image/'))
    ? QA_LOGO_DATA_URL
    : await pdfLoadImageAsDataUrl(QA.LOGO_URL);

      // 1) Cover page
      pdfAddCover(doc, meta, { logoDataUrl });

      // 2) Overview page (optional; set false to disable)
      const INCLUDE_OVERVIEW = false;
      if (INCLUDE_OVERVIEW) pdfAddOverview(doc, meta, L);

      // 3) Questions (print-first)
      let y = L.topY;

      doc.setFont('helvetica','bold');
      doc.setFontSize(14);
      doc.setTextColor(S.ink);
      doc.text('Questions', L.left, y);
      y += 10;

      doc.setFont('helvetica','normal');
      doc.setFontSize(11);
      doc.setTextColor(S.ink);

      const lh = 5.2;
      const smallLh = 4.6;
      const qIndent = 10;         // after Q#
      const optLabelW = 6;        // "A."
      const optIndent = 8;        // option text indent after label
      const blockGap = 3.2;

      const stemW = L.maxW - qIndent;
      const optX = L.left + qIndent;
      const optW = L.maxW - qIndent;

      for (let i=0;i<items.length;i++){
        const it = items[i];
        const qn = i + 1;

        const stem = pdfSafeText(it.stem || '');
        const opts = (it.options && typeof it.options === 'object') ? it.options : {};
        const A = pdfSafeText(opts.A || it.option_a || '');
        const B = pdfSafeText(opts.B || it.option_b || '');
        const C = pdfSafeText(opts.C || it.option_c || '');
        const D = pdfSafeText(opts.D || it.option_d || '');
        const topic = pdfSafeText(String(it.topic || '').trim());

        // Estimate height to reduce ugly splits (still not perfect, but much better)
        const stemLines = pdfWrap(doc, stem, stemW).length || 1;

        const optLines = (txt)=>{
          if (!txt) return 0;
          return pdfWrap(doc, txt, optW - optIndent).length || 1;
        };

        const nOptLines = optLines(A) + optLines(B) + optLines(C) + optLines(D);
        const topicLines = topic ? pdfWrap(doc, `Topic: ${topic}`, stemW).length : 0;

        const approx = pdfEstimateBlockHeight(
          (1 + stemLines + nOptLines + topicLines),
          lh,
          10
        );

        y = pdfEnsureSpace(doc, y, Math.min(approx, (L.bottomY - L.topY) - 10), L);

        // Q label
        doc.setFont('helvetica','bold');
        doc.setFontSize(11);
        doc.setTextColor(S.brand);
        doc.text(`Q${qn}.`, L.left, y);

        // Stem
        doc.setFont('helvetica','normal');
        doc.setFontSize(11);
        doc.setTextColor(S.ink);
        const stemLinesArr = pdfWrap(doc, stem, stemW);
        for (const ln of stemLinesArr){
          y = pdfEnsureSpace(doc, y, lh, L);
          doc.text(ln, L.left + qIndent, y);
          y += lh;
        }
        y += 1;

        // Options renderer
        const renderOpt = (label, text) => {
          if (!text) return;
          y = pdfEnsureSpace(doc, y, lh, L);

          doc.setFont('helvetica','bold');
          doc.setFontSize(10.5);
          doc.setTextColor(S.ink);
          doc.text(`${label}.`, optX, y);

          doc.setFont('helvetica','normal');
          doc.setFontSize(10.5);
          const lines = pdfWrap(doc, text, optW - optIndent);
          for (const ln of lines){
            y = pdfEnsureSpace(doc, y, lh, L);
            doc.text(ln, optX + optIndent, y);
            y += lh;
          }
          y += 0.6;
        };

        renderOpt('A', A);
        renderOpt('B', B);
        renderOpt('C', C);
        renderOpt('D', D);

        // Topic line
        if (topic){
          y = pdfEnsureSpace(doc, y, smallLh + 2, L);
          doc.setFont('helvetica','normal');
          doc.setFontSize(9.2);
          doc.setTextColor(S.muted);
          const tLines = pdfWrap(doc, `Topic: ${topic}`, L.maxW - qIndent);
          for (const ln of tLines){
            y = pdfEnsureSpace(doc, y, smallLh, L);
            doc.text(ln, L.left + qIndent, y);
            y += smallLh;
          }
          doc.setTextColor(S.ink);
          doc.setFontSize(11);
          y += 1.2;
        }

        // Divider (light)
        y = pdfEnsureSpace(doc, y, 4, L);
        doc.setDrawColor(S.line);
        doc.setLineWidth(0.3);
        doc.line(L.left, y, L.left + L.maxW, y);
        y += blockGap;
      }

      // 4) Answer Key page(s)
      doc.addPage();
      y = L.topY;

      doc.setFont('helvetica','bold');
      doc.setFontSize(14);
      doc.setTextColor(S.ink);
      doc.text('Answer Key', L.left, y);
      y += 10;

      const cols = 4;
      const colW = L.maxW / cols;
      const rowH = 7;

      doc.setFont('helvetica','normal');
      doc.setFontSize(11);
      doc.setTextColor(S.ink);

      for (let i=0;i<items.length;i++){
        const qn = i + 1;
        const letter = normalizeCorrectLetter(items[i].correct) || '—';

        const col = i % cols;
        const row = Math.floor(i / cols);

        const x = L.left + col * colW;
        const yy = y + row * rowH;

        // New page if overflowing
        if (yy > L.bottomY){
          doc.addPage();
          y = L.topY;
        }

        const yy2 = y + (Math.floor(i / cols) % 24) * rowH; // safe-ish chunking
        const x2 = L.left + col * colW;

        doc.setFont('helvetica','bold');
        doc.text(`Q${qn}`, x2, yy2);
        doc.setFont('helvetica','normal');
        doc.text(`${letter}`, x2 + 14, yy2);

        // crude reset when we wrapped page
        if (yy2 + rowH > L.bottomY){
          doc.addPage();
          y = L.topY;
        }
      }

      // 5) Header/footer pass (every page; cover excluded)
      const total = doc.internal.getNumberOfPages();
      for (let p=1; p<=total; p++){
        doc.setPage(p);
        const isCover = (p === 1);
        pdfDrawHeaderFooter(doc, meta, L, {
          skipHeader: isCover,
          skipFooter: isCover
        });
      }

      // Save
      const safeCourse = String(pack.course_id || 'COURSE').replace(/[^\w\-]+/g,'_');
      const safeName = String(pack.pack_name || 'Offline_Pack').replace(/[^\w\-]+/g,'_').slice(0,40);
      const fileName = `QAcademy_${safeCourse}_${safeName}_${pack.pack_id || ''}.pdf`.replace(/_+$/,'');
      doc.save(fileName);
    }

    /**********************
     * Boot
     **********************/
    (function init(){
      $('btnBack').addEventListener('click', ()=> history.length > 1 ? history.back() : go(QA.DASHBOARD_URL));
      $('btnPrint').addEventListener('click', ()=> window.print());
      $('btnRefresh').addEventListener('click', ()=> location.reload());

      let __lastPack = null;
      $('btnPdf').addEventListener('click', async ()=>{
        try{
          if (!__lastPack) throw new Error('Pack not loaded yet');
          showOverlay(true);
          await downloadPackPdf(__lastPack);
        }catch(err){
          showError(err.message || String(err));
        }finally{
          showOverlay(false);
        }
      });

      const packId = getParam('pack_id');
      if (!packId) { showError('Missing pack_id'); return; }

      const token = (localStorage.getItem(QA.TOKEN_KEY) || '').trim();
      if (!token) { go(QA.LOGIN_URL); return; }

      showOverlay(true);

      apiGetPack(packId, token)
        .then(data => {
          const pack = data.pack ? data.pack : data;
          if (!pack.items && Array.isArray(data.items)) pack.items = data.items;
          __lastPack = pack;
          renderBlocks(pack);
        })
        .catch(err => showError(err.message || String(err)))
        .finally(()=> showOverlay(false));
    })();
  </script>
