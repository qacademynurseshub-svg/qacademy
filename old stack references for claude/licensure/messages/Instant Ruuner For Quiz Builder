      // Deterministic shuffle (same as Timed)
      function seedFrom(str) {
        let s = 0;
        for (let i = 0; i < str.length; i++) s = (s * 31 + str.charCodeAt(i)) >>> 0;
        return s >>> 0;
      }

      function rand(so) {
        so.seed ^= so.seed << 13;
        so.seed >>>= 0;
        so.seed ^= so.seed >> 17;
        so.seed >>>= 0;
        so.seed ^= so.seed << 5;
        so.seed >>>= 0;
        return (so.seed >>> 0) / 0xFFFFFFFF;
      }

      function shuffleDet(arr, key) {
        const a = arr.slice();
        const so = {
          seed: seedFrom(key)
        };
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(rand(so) * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
      }

