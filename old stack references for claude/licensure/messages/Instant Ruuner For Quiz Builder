      // === LOAD ATTEMPT (BUILDER API) ===
      async function loadAttempt() {
        const quiz_id = qs('quiz_id') || '';
        const attempt_id = qs('attempt_id') || quiz_id;

        if (!attempt_id) {
          log("Missing attempt_id (or quiz_id) in URL.");
          return;
        }

        // include token + mode so backend can enforce ownership + mode match
        const token = (function () {
          try {
            return localStorage.getItem(TOKEN_KEY) || "";
          } catch (_) {
            return "";
          }
        })();

        const params = new URLSearchParams();
        params.set("action", "attempt");
        params.set("attempt_id", attempt_id);
        if (token) {
          params.set("token", token);
        }
        // Instant Runner always expects instant attempts
        params.set("mode", "instant");

        const url = `${BUILDER_WEB_APP_URL}?${params.toString()}`;

        try {
          const res = await fetch(url);
          let data;
          try {
            data = await res.json();
          } catch (err) {
            log("Server returned invalid response.");
            return;
          }

          // explicit backend error
          if (data && data.ok === false) {
            const msg = data.error || "Backend rejected this attempt.";
            log(msg);
            return;
          }

          if (!data || !Array.isArray(data.items)) {
            const msg = data && data.error ? data.error : "Attempt could not be loaded.";
            log(msg);
            return;
          }

          if (!data.items.length) {
            const msg = data && data.error ? data.error : "No items returned for this attempt.";
            log(msg);
            return;
          }

          ATT = data.meta || {};
          ITEMS = data.items;
          ANSW = {};
          FLAGS = {};
          FINISH_SENT = false;

          // Compute dynamic autosave interval (based on total quiz time)
          recomputeAutosaveInterval();

          // fill course pill
          const cid = String(ATT.course_id || "").toUpperCase();
          const courseLabel = COURSE_LABELS[cid] || ATT.course_id || '—';
          if (el.coursePill) {
            el.coursePill.textContent = `Course: ${courseLabel}`;
          }

          // Course-level access check using Guard v3 courses
          if (cid) {
            let allowedSet = null;
            if (ALLOWED_COURSE_IDS && ALLOWED_COURSE_IDS.length) {
              allowedSet = new Set(ALLOWED_COURSE_IDS.map(id => String(id).toUpperCase()));
            } else if (AUTH && Array.isArray(AUTH.course_ids)) {
              allowedSet = new Set(AUTH.course_ids.map(id => String(id).toUpperCase()));
            }
            if (allowedSet && !allowedSet.has(cid)) {
              log("You are not enrolled for this course. Redirecting to dashboard…");
              setTimeout(() => {
                go("/p/" + DASHBOARD_SLUG + ".html");
              }, 1200);
              return;
            }
          }

          // Attempt-level security (user_id match)
          const attUserIdRaw = (ATT.user_id || "").toString().trim();
          const localUidRaw = getLocalUserId().trim();
          const authUidRaw = AUTH ? extractUserId(AUTH).trim() : "";
          const currentUid = localUidRaw || authUidRaw || "";

          if (attUserIdRaw && currentUid && attUserIdRaw !== currentUid) {
            log("This quiz attempt is not linked to your account. Please start a new quiz from the course page.");
            setTimeout(() => {
              go("/p/" + DASHBOARD_SLUG + ".html");
            }, 1800);
            return;
          }

          // Mode must be 'instant' for this runner
          const attMode = String(ATT.mode || "").toLowerCase();
          if (attMode && attMode !== "instant") {
            log("This attempt was created for a different mode (timed). Please open it with the Timed Runner.");
            return;
          }

          const metaStatus = String(ATT.status || "").toLowerCase();
          const savedAnswers = Array.isArray(ATT.answers) ? ATT.answers : [];
          const isResume = !REVIEW_MODE && (metaStatus === "in_progress" && savedAnswers.length > 0);
          const isCompletedWithAnswers = (metaStatus === "completed" && savedAnswers.length > 0);

          TOTAL_PAGES = Math.max(1, Math.ceil(ITEMS.length / QUESTIONS_PER_PAGE));
          PAGE = 0;
          viewMode = 'ALL';

          const total = ITEMS.length;
          el.metaPill.textContent = `Attempt: ${ATT.attempt_id || attempt_id} | ${total} item${total===1?'':'s'}`;

          // REVIEW MODE FLOW
          if (REVIEW_MODE) {
            const subEl = document.querySelector('#infoCard .sub');
            if (subEl) subEl.textContent = "Reviewing a completed instant quiz • Answers are read-only";
            if (el.submitBtn) el.submitBtn.style.display = "none";

            if (!isCompletedWithAnswers) {
              log("This attempt is not available for review yet. It may still be in progress.");
            }

            hydrateFromMetaAnswers(savedAnswers);

            LOCKED = true;
            QUIZ_STARTED_AT = null;

            if (el.preCard) el.preCard.style.display = 'none';
            el.qCard.style.display = 'block';
            if (el.fabGrid) el.fabGrid.style.display = 'inline-flex';

            renderPage();
            renderProgress();

            let scrText = "Score: —";
            const rawMeta = ATT.score_raw;
            const totMeta = ATT.score_total;
            if (rawMeta != null && totMeta != null && totMeta !== "") {
              const raw = Number(rawMeta);
              const tot = Number(totMeta) || ITEMS.length;
              const perc = tot ? pct(raw, tot) : null;
              scrText = `Score: ${raw} / ${tot}` + (perc !== null ? ` (${perc}%)` : "");
            } else {
              const s = computeScore();
              const perc = pct(s.ok, s.total);
              scrText = `Score: ${s.ok} / ${s.total} (${perc}%)`;
            }
            el.scoreText.textContent = scrText;
            openReviewGrid();
            log("Reviewing your completed attempt. Answers and feedback are read-only.");
            return;
          }

          // Normal INSTANT/RESUME FLOW
          if (isResume) {
            hydrateFromMetaAnswers(savedAnswers);
            if (el.preCard) el.preCard.style.display = 'none';
            startQuiz();
          } else {
            if (shouldSkipPreflight()) {
              startQuiz();
            } else {
              preparePreflight();
            }
          }
        } catch (err) {
          log("Failed to load attempt: " + (err.message || String(err)));
        }
      }

      // === RENDER PAGE ===
      function renderPage() {
        if (!ITEMS || !ITEMS.length) {
          el.qList.innerHTML = '';
          return;
        }
        const src = getCurrentSource();
        const totalVisible = src.length;
        TOTAL_PAGES = Math.max(1, Math.ceil(totalVisible / QUESTIONS_PER_PAGE));
        PAGE = clamp(PAGE, 0, TOTAL_PAGES - 1);

        const start = PAGE * QUESTIONS_PER_PAGE;
        const end = Math.min(start + QUESTIONS_PER_PAGE, totalVisible);

        const pageText = `Page ${PAGE+1} / ${TOTAL_PAGES}`;
        el.pagePill.textContent = pageText;
        el.pagePillBottom.textContent = pageText;

        const prevDisabled = (PAGE === 0);
        const nextDisabled = (PAGE >= TOTAL_PAGES - 1);
        document.querySelectorAll('.prevPage').forEach(b => b.disabled = prevDisabled);
        document.querySelectorAll('.nextPage').forEach(b => b.disabled = nextDisabled);

        el.qList.innerHTML = '';
        for (let k = start; k < end; k++) {
          const {
            it: r,
            idx: globalIdx
          } = src[k];

          const qWrap = document.createElement('div');
          qWrap.className = 'q-block';
          qWrap.id = `q_${globalIdx}`;

          const qHead = document.createElement('div');
          qHead.className = 'q-head';

          const idxPill = document.createElement('div');
          idxPill.className = 'pill q-index';
          idxPill.textContent = `Q${globalIdx+1} / ${ITEMS.length}`;

          const stem = document.createElement('div');
          stem.className = 'qstem';
          stem.textContent = r.stem || '(no stem)';

          qHead.appendChild(idxPill);

          const topicText = (r.topic || '').trim();
          if (topicText) {
            const topicEl = document.createElement('div');
            topicEl.className = 'q-topic';
            topicEl.textContent = topicText;
            qHead.appendChild(topicEl);
          }

          qHead.appendChild(stem);
          qWrap.appendChild(qHead);

          const optsWrap = document.createElement('div');
          optsWrap.className = 'opts';

          const opts = getShuffledOptionsFor(r);
          const chosen = ANSW[r.item_id];

          opts.forEach((o, j) => {
            const label = displayLabel(j);

            const row = document.createElement('label');
            row.className = 'opt';

            const input = document.createElement('input');
            input.type = 'radio';
            input.name = `opt_${r.item_id}`;
            input.value = label;
            input.disabled = LOCKED || REVIEW_MODE;
            input.checked = (chosen === label);

            const body = document.createElement('div');
            const head = document.createElement('div');
            head.className = 'opt-title';

            const title = document.createElement('div');
            title.innerHTML = `<strong>${label}.</strong> ${o.text || ''}`;
            head.appendChild(title);

            const fb = document.createElement('div');
            fb.className = 'opt-fb';
            fb.dataset.label = label;

            input.addEventListener('change', () => {
              if (LOCKED || REVIEW_MODE) return;
              ANSW[r.item_id] = label;
              updateQuestionFeedback(r.item_id);
              renderProgress();
              // No immediate save here: page change + autosave handle persistence
            });

            body.appendChild(head);
            body.appendChild(fb);
            row.appendChild(input);
            row.appendChild(body);
            optsWrap.appendChild(row);
          });

          const ratEl = document.createElement('div');
          ratEl.className = 'rationale';
          ratEl.id = `rat_${r.item_id}`;
          ratEl.style.display = 'none';

          qWrap.appendChild(optsWrap);
          qWrap.appendChild(ratEl);

          const footer = document.createElement('div');
          footer.className = 'q-footer';

          const flagBtn = document.createElement('button');
          flagBtn.type = 'button';
          flagBtn.className = 'btn ghost small flag-btn';
          flagBtn.textContent = FLAGS[r.item_id] ? 'Unflag' : 'Flag';
          flagBtn.disabled = REVIEW_MODE;
          flagBtn.addEventListener('click', () => {
            if (REVIEW_MODE) return;
            FLAGS[r.item_id] = !FLAGS[r.item_id];
            flagBtn.textContent = FLAGS[r.item_id] ? 'Unflag' : 'Flag';
            updateFlagNavVisibility();
            saveInProgress(false);
          });

          // NEW: message about this question (opens Messages in new tab)
          const reportBtn = document.createElement('button');
          reportBtn.type = 'button';
          reportBtn.className = 'btn softer small';
          reportBtn.textContent = 'Send feedback';
          reportBtn.disabled = false;
          reportBtn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();

            // If quiz is completed/review, just open directly
            if (LOCKED || REVIEW_MODE) {
              openReportQuestion(r, globalIdx);
              return;
            }

            // Otherwise show modal, with the exact URL we’ll open
            try {
              const url = buildMessagesUrlForQuestion(r, globalIdx);
              openMsgOverlay(url);
            } catch (err) {
              alert("Could not prepare Messages link.");
            }
          });


          const wm = document.createElement('div');
          wm.className = 'watermark';
          wm.textContent = 'QAcademy';

          footer.appendChild(flagBtn);
          footer.appendChild(reportBtn);
          footer.appendChild(wm);
          qWrap.appendChild(footer);

          el.qList.appendChild(qWrap);

          // Show feedback for answered questions while in-progress,
          // and for ALL questions once the quiz is locked/submitted or in review.
          if (ANSW.hasOwnProperty(r.item_id) || LOCKED || REVIEW_MODE || FINISH_SENT) {
            updateQuestionFeedback(r.item_id);
          }
        }

        const header = document.getElementById('headerCard');
        const headerH = header ? (header.offsetHeight || 0) : 0;
        const top = el.qCard.getBoundingClientRect().top + window.scrollY - headerH - 8;
        window.scrollTo({
          top,
          behavior: 'smooth'
        });

        updateFlagNavVisibility();
      }

      // === INLINE/STANDALONE/HIDE FEEDBACK FOR ONE QUESTION ===
      function updateQuestionFeedback(itemId) {
        const r = ITEMS.find(x => String(x.item_id) === String(itemId));
        if (!r) return;

        const chosenLabel = ANSW[itemId] || '';
        const opts = getShuffledOptionsFor(r);
        const qSelIndex = ITEMS.indexOf(r);
        const qBlock = document.querySelector(`#qList #q_${qSelIndex}`);
        if (!qBlock) return;

        const rows = qBlock.querySelectorAll('.opt');
        const ratEl = document.getElementById(`rat_${r.item_id}`);

        const rat = String(r.rationale || '').trim();
        const imgUrl = String(r.rationale_img || '').trim();

        // After submission/review we want feedback even if unanswered
        const showAfterSubmit = !!(LOCKED || REVIEW_MODE || FINISH_SENT);

        /* ---------- RATIONALE BLOCK (per mode) ---------- */
        if (ratEl) {
          ratEl.innerHTML = '';

          // Before submit + no choice → no rationale
          if ((!chosenLabel && !showAfterSubmit) || feedbackMode === 'hide') {
            ratEl.style.display = 'none';
          } else if (feedbackMode === 'inline') {
            // Inline: rationale + optional image
            let hasContent = false;

            if (rat) {
              const t = document.createElement('div');
              t.className = 'rationale-text';
              t.textContent = `Rationale: ${rat}`;
              ratEl.appendChild(t);
              hasContent = true;
            }

            if (imgUrl) {
              const wrap = document.createElement('div');
              wrap.className = 'rationale-img-wrap';

              const img = document.createElement('img');
              img.className = 'rationale-img-thumb';
              img.src = imgUrl;
              img.alt = 'Rationale illustration';
              img.loading = 'lazy';
              img.decoding = 'async';

              img.addEventListener('click', function () {
                openImgOverlay(imgUrl);
              });

              const cap = document.createElement('div');
              cap.className = 'rationale-img-caption';
              cap.textContent = "Tap to enlarge";

              wrap.appendChild(img);
              wrap.appendChild(cap);
              ratEl.appendChild(wrap);
              hasContent = true;
            }

            ratEl.style.display = hasContent ? 'block' : 'none';
          } else if (feedbackMode === 'standalone') {
            // Standalone: rationale + "Why the options" + optional image
            let hasAny = false;
            const frag = document.createDocumentFragment();

            if (rat) {
              const t = document.createElement('div');
              t.className = 'rationale-text';
              t.textContent = `Rationale: ${rat}`;
              frag.appendChild(t);
              hasAny = true;
            }

            // Option explanations aggregated
            const letters = ['A', 'B', 'C', 'D'];
            let anyOptFb = false;
            const optWrap = document.createElement('div');
            let headerAdded = false;

            letters.forEach(function (letter, idx) {
              const o = opts[idx];
              if (!o || !o.text) return;
              const fbText = String(o.fb || '').trim();
              if (!fbText) return;

              if (!headerAdded) {
                const h = document.createElement('div');
                h.style.marginTop = '6px';
                h.innerHTML = "<strong>Why the options:</strong>";
                optWrap.appendChild(h);
                headerAdded = true;
              }

              const line = document.createElement('div');
              line.innerHTML = "<strong>" + letter + ".</strong> " + (o.text || '') + " — " + fbText;
              optWrap.appendChild(line);
              anyOptFb = true;
            });

            if (anyOptFb) {
              frag.appendChild(optWrap);
              hasAny = true;
            }

            if (imgUrl) {
              const wrap = document.createElement('div');
              wrap.className = 'rationale-img-wrap';

              const img = document.createElement('img');
              img.className = 'rationale-img-thumb';
              img.src = imgUrl;
              img.alt = 'Rationale illustration';
              img.loading = 'lazy';
              img.decoding = 'async';

              img.addEventListener('click', function () {
                openImgOverlay(imgUrl);
              });

              const cap = document.createElement('div');
              cap.className = 'rationale-img-caption';
              cap.textContent = "Tap to enlarge";

              wrap.appendChild(img);
              wrap.appendChild(cap);
              frag.appendChild(wrap);
              hasAny = true;
            }

            if (hasAny) {
              ratEl.appendChild(frag);
              ratEl.style.display = 'block';
            } else {
              ratEl.style.display = 'none';
            }
          }
        }

        /* ---------- OPTION-LEVEL CHIPS + INLINE FEEDBACK ---------- */
        rows.forEach((row, j) => {
          const label = ['A', 'B', 'C', 'D'][j];
          const o = opts[j];
          if (!o) return;

          const head = row.querySelector('.opt-title');
          const fb = row.querySelector('.opt-fb');
          if (!head || !fb) return;

          // Clear any existing chips
          head.querySelectorAll('.chip').forEach(ch => ch.remove());

          // Before submit + no answer → hide everything for this option
          const hasChoice = !!chosenLabel;
          const shouldShow = hasChoice || showAfterSubmit;
          if (!shouldShow) {
            fb.style.display = 'none';
            fb.textContent = '';
            return;
          }

          // Chips: always show "Correct answer" after submit/review,
          // and "Your choice" only if the learner picked it.
          if (o.isCorrect) {
            const chipC = document.createElement('span');
            chipC.className = 'chip correct';
            chipC.textContent = 'Correct answer';
            head.appendChild(chipC);
          }
          if (label === chosenLabel) {
            const chipY = document.createElement('span');
            chipY.className = 'chip your';
            chipY.textContent = 'Your choice';
            head.appendChild(chipY);
          }

          // Option feedback text only in INLINE mode
          if (feedbackMode === 'inline') {
            const fbText = String(o.fb || '').trim() || '(No feedback provided)';
            fb.textContent = fbText;
            fb.style.display = 'block';
          } else {
            fb.textContent = '';
            fb.style.display = 'none';
          }
        });
      }

      // === PROGRESS ===
      function renderProgress() {
        const total = ITEMS.length;
        const answered = Object.keys(ANSW).length;
        el.countPill.textContent = `${answered} / ${total} answered`;
        const p = pct(answered, total);
        el.progFill.style.width = p + '%';
        if (el.progLabel) el.progLabel.textContent = p + '%';

        if (!REVIEW_MODE && !LOCKED && total > 0 && answered === total) {
          submitQuiz();
        }
      }

      // === REVIEW GRID ===
      function buildGrid() {
        if (!ITEMS.length) return;
        el.grid.innerHTML = '';

        ITEMS.forEach((r, i) => {
          const answered = !!ANSW[r.item_id];
          const cell = document.createElement('div');
          cell.className = 'cell';
          if (answered) cell.classList.add('done');
          cell.textContent = (i + 1);

          if (!LOCKED && !REVIEW_MODE) {
            cell.style.borderColor = answered ? '#0b7a75' : '#d8dfdd';
            cell.title = answered ? `Question ${i+1} • answered` : `Question ${i+1} • not answered`;
          } else {
            const opts = getShuffledOptionsFor(r);
            const chosenLabel = ANSW[r.item_id] || '—';
            let good = false;
            if (chosenLabel !== '—') {
              const idx = ['A', 'B', 'C', 'D'].indexOf(chosenLabel);
              const chosenObj = opts[idx];
              good = !!(chosenObj && chosenObj.isCorrect);
            }
            cell.title = `Your: ${chosenLabel}`;
            cell.style.borderColor = answered ? (good ? '#bfe7dd' : '#f1c4c4') : '#d8dfdd';
          }

          cell.addEventListener('click', () => {
            viewMode = 'ALL';
            PAGE = Math.floor(i / QUESTIONS_PER_PAGE);
            renderPage();
            if (ANSW[r.item_id]) updateQuestionFeedback(r.item_id);
            const target = document.getElementById(`q_${i}`);
            if (target) target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
            el.reviewCard.style.display = 'none';
          });

          el.grid.appendChild(cell);
        });
      }

      function openReviewGrid() {
        buildGrid();
        el.reviewCard.style.display = 'block';
      }

      // === FLOATING GRID OVERLAY ===
      function openOverlay() {
        if (!el.gridOverlay) return;
        buildOverlayGrid();
        prevBodyOverflow = document.body.style.overflow || '';
        document.body.style.overflow = 'hidden';
        el.gridOverlay.style.display = 'flex';
      }

      function closeOverlay() {
        if (!el.gridOverlay) return;
        el.gridOverlay.style.display = 'none';
        document.body.style.overflow = prevBodyOverflow;
      }

      function buildOverlayGrid() {
        if (!ITEMS.length || !el.gridOverlayBody) return;
        el.gridOverlayBody.innerHTML = '';

        ITEMS.forEach((r, idx) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'grid-btn';
          btn.textContent = String(idx + 1);

          const answered = !!ANSW[r.item_id];
          const flagged = !!FLAGS[r.item_id];
          if (answered) btn.classList.add('answered');
          if (flagged) btn.classList.add('flagged');

          btn.addEventListener('click', () => {
            viewMode = 'ALL';
            PAGE = Math.floor(idx / QUESTIONS_PER_PAGE);
            renderPage();
            if (ANSW[r.item_id]) updateQuestionFeedback(r.item_id);
            const target = document.getElementById(`q_${idx}`);
            if (target) target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
            closeOverlay();
          });

          el.gridOverlayBody.appendChild(btn);
        });
      }

      // === IMAGE OVERLAY HELPERS ===
      function openImgOverlay(url) {
        if (!el.imgOverlay || !el.imgOverlayImg) return;
        prevBodyOverflowImg = document.body.style.overflow || '';
        el.imgOverlayImg.src = url;
        el.imgOverlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }

      function closeImgOverlay() {
        if (!el.imgOverlay || !el.imgOverlayImg) return;
        el.imgOverlay.style.display = 'none';
        el.imgOverlayImg.src = '';
        document.body.style.overflow = prevBodyOverflowImg;
      }

      // === ANSWER PAYLOAD BUILDER ===
      function buildAnswersPayload() {
        const out = [];
        ITEMS.forEach((r) => {
          const opts = getShuffledOptionsFor(r);
          const chosenLabel = ANSW[r.item_id] || '';
          const idx = ['A', 'B', 'C', 'D'].indexOf(chosenLabel);
          const chosenObj = idx >= 0 ? opts[idx] : null;

          const correctIdx = opts.findIndex(o => o.isCorrect);
          const correctLabel = correctIdx >= 0 ? ['A', 'B', 'C', 'D'][correctIdx] : '';

          out.push({
            item_id: r.item_id,
            chosen: chosenLabel,
            correct: correctLabel,
            is_correct: !!(chosenObj && chosenObj.isCorrect),
            flagged: !!FLAGS[r.item_id],
            time_spent_s: null
          });
        });
        return out;
      }

      // === RESUME HYDRATOR ===
      function hydrateFromMetaAnswers(metaAnswers) {
        if (!Array.isArray(metaAnswers) || !metaAnswers.length) return;

        ANSW = {};
        FLAGS = {};

        metaAnswers.forEach(function (entry) {
          const itemId = String(entry.item_id || "").trim();
          if (!itemId) return;

          const chosen = String(entry.chosen || "").trim().toUpperCase();
          if (['A', 'B', 'C', 'D'].indexOf(chosen) >= 0) {
            ANSW[itemId] = chosen;
          }

          if (entry.flagged) {
            FLAGS[itemId] = true;
          }
        });

        if (!REVIEW_MODE && ATT && ATT.time_taken_s != null && ATT.time_taken_s !== "") {
          const used = parseInt(ATT.time_taken_s, 10);
          if (!isNaN(used) && used > 0) {
            QUIZ_STARTED_AT = Date.now() - (used * 1000);
          }
        }
      }

      // === attempt.update (in-progress save) ===
      async function saveInProgress(force) {
        if (REVIEW_MODE) return;
        if (!ATT || !ATT.attempt_id) return;
        if (LOCKED) return;

        const now = Date.now();
        if (!force && (now - LAST_SAVE_AT < MIN_SAVE_INTERVAL_MS)) return;
        LAST_SAVE_AT = now;

        const attemptId = ATT.attempt_id;
        const answersArray = buildAnswersPayload();
        const usedSec = QUIZ_STARTED_AT ? Math.max(0, Math.round((now - QUIZ_STARTED_AT) / 1000)) : 0;

        const payload = {
          attempt_id: attemptId,
          status: "in_progress",
          time_taken_s: usedSec,
          answers: answersArray
        };

        try {
          const body = new URLSearchParams();
          body.append("action", "attempt.update");
          body.append("payload", JSON.stringify(payload));

          const res = await fetch(BUILDER_WEB_APP_URL, {
            method: "POST",
            headers: {
              "Content-Type": "application/x-www-form-urlencoded"
            },
            body
          });

          let data = null;
          try {
            data = await res.json();
          } catch (_) {}
          if (!data || data.ok === false) {
            console.warn("attempt.update (instant) error:", data);
          } else {
            console.log("attempt.update (instant) ok");
          }
        } catch (err) {
          console.error("attempt.update (instant) failed:", err);
        }
      }

      // === attempt.finish ===
      async function sendAttemptFinish(attemptId, scoreRaw, scoreTotal, timeTakenSec, answersArray) {
        if (REVIEW_MODE) return;
        if (!attemptId) return;
        if (FINISH_SENT) return;
        FINISH_SENT = true;

        const payload = {
          attempt_id: attemptId,
          status: "completed",
          completion_reason: "user",
          score_raw: scoreRaw,
          score_total: scoreTotal,
          time_taken_s: timeTakenSec,
          answers: answersArray || []
        };

        try {
          const body = new URLSearchParams();
          body.append("action", "attempt.finish");
          body.append("payload", JSON.stringify(payload));

          const res = await fetch(BUILDER_WEB_APP_URL, {
            method: "POST",
            headers: {
              "Content-Type": "application/x-www-form-urlencoded"
            },
            body
          });

          let data = null;
          try {
            data = await res.json();
          } catch (_) {}

          if (!data || data.ok === false) {
            console.warn("attempt.finish (instant) error:", data);
          } else {
            console.log("attempt.finish (instant) ok");
          }
        } catch (err) {
          console.error("attempt.finish (instant) failed:", err);
        }
      }

      // === SUBMIT ===
      async function submitQuiz() {
        if (REVIEW_MODE) return;
        if (LOCKED) return;

        const total = ITEMS.length;
        const answered = Object.keys(ANSW).length;
        if (answered < total) {
          const okConfirm = confirm(`You have ${total-answered} unanswered question(s). Submit now?`);
          if (!okConfirm) return;
        }

        LOCKED = true;

        document.querySelectorAll('input[type="radio"]').forEach(x => x.disabled = true);

        const s = computeScore();
        SCORE = s.ok;

        const attemptId = ATT && ATT.attempt_id ? ATT.attempt_id : (qs('attempt_id') || qs('quiz_id') || '');
        const nowMs = Date.now();
        const timeTakenSec = QUIZ_STARTED_AT ? Math.max(0, Math.round((nowMs - QUIZ_STARTED_AT) / 1000)) : null;
        const answersArray = buildAnswersPayload();

        qaShowLoader("Submitting your results...");
        await sendAttemptFinish(attemptId, s.ok, s.total, timeTakenSec, answersArray);
        qaHideLoader();

        viewMode = 'ALL';
        PAGE = 0;
        renderPage();

        el.scoreText.textContent = `Score: ${s.ok} / ${s.total} (${pct(s.ok,s.total)}%)`;
        openReviewGrid();
        el.restartBtn.style.display = 'inline-block';
      }

      // === RESTART ===
      function restart() {
        const ref = document.referrer || '';
        if (ref) {
          location.href = ref;
        } else {
          location.href = location.pathname;
        }
      }

      // === EXIT OVERLAY HELPERS ===
      function openExitOverlay() {
        if (!el.exitOverlay) return;
        prevBodyOverflowExit = document.body.style.overflow || '';
        document.body.style.overflow = 'hidden';
        el.exitOverlay.style.display = 'flex';
      }

      function closeExitOverlay() {
        if (!el.exitOverlay) return;
        el.exitOverlay.style.display = 'none';
        document.body.style.overflow = prevBodyOverflowExit;
        PENDING_NAV_HREF = null;
      }

      function openMsgOverlay(url) {
        if (!el.msgOverlay) return;
        PENDING_MSG_URL = url || null;

        // lock scroll like your other overlays
        prevBodyOverflowExit = document.body.style.overflow || '';
        document.body.style.overflow = 'hidden';
        el.msgOverlay.style.display = 'flex';
      }

      function closeMsgOverlay() {
        if (!el.msgOverlay) return;
        el.msgOverlay.style.display = 'none';
        document.body.style.overflow = prevBodyOverflowExit;
        PENDING_MSG_URL = null;
      }


      // === NAV (both pagers) ===
      document.querySelectorAll('.prevPage').forEach(b => b.addEventListener('click', () => {
        saveInProgress(false);
        PAGE--;
        renderPage();
      }));
      document.querySelectorAll('.nextPage').forEach(b => b.addEventListener('click', () => {
        saveInProgress(false);
        PAGE++;
        renderPage();
      }));

      el.reviewBtn.addEventListener('click', openReviewGrid);
      el.backToQuizBtn.addEventListener('click', () => {
        el.reviewCard.style.display = 'none';
      });
      el.submitBtn.addEventListener('click', submitQuiz);
      el.restartBtn.addEventListener('click', restart);

      if (el.fabGrid) {
        el.fabGrid.addEventListener('click', openOverlay);
      }
      if (el.gridOverlayClose) {
        el.gridOverlayClose.addEventListener('click', closeOverlay);
      }

      if (el.viewAllBtn) {
        el.viewAllBtn.addEventListener('click', () => {
          viewMode = 'ALL';
          PAGE = 0;
          renderPage();
          updateFlagNavVisibility();
        });
      }
      if (el.viewFlaggedBtn) {
        el.viewFlaggedBtn.addEventListener('click', () => {
          viewMode = 'FLAGGED';
          PAGE = 0;
          renderPage();
          updateFlagNavVisibility();
        });
      }
      if (el.prevFlagBtn) {
        el.prevFlagBtn.addEventListener('click', jumpToPrevFlagged);
      }
      if (el.nextFlagBtn) {
        el.nextFlagBtn.addEventListener('click', jumpToNextFlagged);
      }

      // NEW: feedback mode button handlers
      if (el.fbInlineBtn) {
        el.fbInlineBtn.addEventListener('click', () => {
          feedbackMode = "inline";
          saveFeedbackMode(feedbackMode);
          updateFeedbackUI();
          if (ITEMS && ITEMS.length) renderPage();
        });
      }
      if (el.fbStandaloneBtn) {
        el.fbStandaloneBtn.addEventListener('click', () => {
          feedbackMode = "standalone";
          saveFeedbackMode(feedbackMode);
          updateFeedbackUI();
          if (ITEMS && ITEMS.length) renderPage();
        });
      }
      if (el.fbHideBtn) {
        el.fbHideBtn.addEventListener('click', () => {
          feedbackMode = "hide";
          saveFeedbackMode(feedbackMode);
          updateFeedbackUI();
          if (ITEMS && ITEMS.length) renderPage();
        });
      }

      // Exit button + overlay
      if (el.exitBtn) {
        el.exitBtn.addEventListener('click', () => {
          if (LOCKED || REVIEW_MODE) {
            const ref = document.referrer || '';
            if (ref) location.href = ref;
            else go("/p/" + DASHBOARD_SLUG + ".html");
            return;
          }
          PENDING_NAV_HREF = null;
          openExitOverlay();
        });
      }

      if (el.exitCancelBtn) {
        el.exitCancelBtn.addEventListener('click', () => {
          closeExitOverlay();
        });
      }

      // === Message overlay events ===
      if (el.msgOverlayClose) el.msgOverlayClose.addEventListener('click', closeMsgOverlay);
      if (el.msgCancelBtn) el.msgCancelBtn.addEventListener('click', closeMsgOverlay);

      if (el.msgSaveOpenBtn) {
        el.msgSaveOpenBtn.addEventListener('click', async function () {
          const url = PENDING_MSG_URL;
          qaShowLoader("Saving your progress...");
          await saveInProgress(true);
          qaHideLoader();
          closeMsgOverlay();
          if (url) window.open(url, "_blank", "noopener,noreferrer");
        });
      }

      if (el.exitSaveBtn) {
        el.exitSaveBtn.addEventListener('click', async () => {
          qaShowLoader("Saving your progress...");
          await saveInProgress(true);
          const target = PENDING_NAV_HREF;
          closeExitOverlay();
          qaHideLoader();
          log("Progress saved as in-progress. You can resume this attempt from your history when available.");
          if (target) {
            location.href = target;
          } else {
            const ref = document.referrer || '';
            if (ref) location.href = ref;
            else go("/p/" + DASHBOARD_SLUG + ".html");
          }
        });
      }

      if (el.exitSubmitBtn) {
        el.exitSubmitBtn.addEventListener('click', () => {
          const target = PENDING_NAV_HREF;
          closeExitOverlay();
          submitQuiz().then(() => {
            if (target) {
              setTimeout(() => {
                location.href = target;
              }, 400);
            }
          });
        });
      }

      // Image overlay events
      if (el.imgOverlayClose) {
        el.imgOverlayClose.addEventListener('click', closeImgOverlay);
      }
      if (el.imgOverlay) {
        el.imgOverlay.addEventListener('click', function (e) {
          if (e.target === el.imgOverlay) closeImgOverlay();
        });
      }

      // Preflight buttons
      el.preStartBtn.addEventListener('click', () => {
        if (el.preSkip && el.preSkip.checked) setSkipPreflight(true);
        startQuiz();
      });
      el.preCancelBtn.addEventListener('click', () => {
        const ref = document.referrer || '';
        if (ref) {
          location.href = ref;
        } else {
          location.href = location.pathname;
        }
      });

      // === LINK-GUARD: intercept navigation while quiz is active ===
      document.addEventListener('click', function (e) {
        if (REVIEW_MODE) return;
        if (!ATT || !ITEMS.length || LOCKED) return;
        if (!el.qCard || el.qCard.style.display === 'none') return;

        const target = e.target;
        if (!target || typeof target.closest !== 'function') return;

        if (el.exitOverlay && el.exitOverlay.contains(target)) return;
        if (el.gridOverlay && el.gridOverlay.contains(target)) return;
        if (el.reviewCard && el.reviewCard.contains(target)) return;
        if (el.imgOverlay && el.imgOverlay.contains(target)) return;
        if (el.msgOverlay && el.msgOverlay.contains(target)) return;


        const link = target.closest('a');
        if (!link) return;

        const href = link.getAttribute('href') || '';
        if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;

        if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;

        e.preventDefault();
        PENDING_NAV_HREF = link.href;
        openExitOverlay();
      });

      // === beforeunload ===
      window.addEventListener('beforeunload', function (e) {
        if (REVIEW_MODE) return;
        if (!ATT || !ITEMS.length || LOCKED) return;
        if (!el.qCard || el.qCard.style.display === 'none') return;
        e.preventDefault();
        e.returnValue = '';
      });

      // Initial review-mode header tweak (only sub text, pill handled by updateFeedbackUI)
      if (REVIEW_MODE) {
        const subEl = document.querySelector('#infoCard .sub');
        if (subEl) subEl.textContent = "Reviewing a completed instant quiz • Answers are read-only";
      }

      // Init feedbackMode from storage / URL and update UI
      feedbackMode = loadFeedbackMode();
      updateFeedbackUI();

      // === BACKGROUND AUTOSAVE (dynamic interval) ===
      let AUTOSAVE_TIMER_ID = null;

      function startAutosaveLoop() {
        // Clear any previous loop (safety)
        if (AUTOSAVE_TIMER_ID !== null) {
          clearTimeout(AUTOSAVE_TIMER_ID);
          AUTOSAVE_TIMER_ID = null;
        }

        function tick() {
          // Only autosave when:
          // - Not in review mode
          // - We have an active attempt
          // - Quiz not locked/submitted
          // - Items loaded
          // - Quiz card is visible (user actually in the quiz)
          if (!REVIEW_MODE &&
            ATT && ATT.attempt_id &&
            !LOCKED &&
            ITEMS && ITEMS.length &&
            el.qCard && el.qCard.style.display !== 'none') {
            // Throttling still enforced inside saveInProgress
            saveInProgress(false);
          }

          // Schedule next tick using the CURRENT interval
          AUTOSAVE_TIMER_ID = setTimeout(tick, AUTOSAVE_INTERVAL_MS);
        }

        // Kick off the first tick
        AUTOSAVE_TIMER_ID = setTimeout(tick, AUTOSAVE_INTERVAL_MS);
      }

      // === INIT: verify auth first, then load attempt ===
      (async function initGuarded() {
        log("Checking access...");
        qaShowLoader("Checking your access...");
        AUTH = await verifyToken();
        if (!AUTH) {
          qaHideLoader();
          return;
        }
        log("Access OK. Loading attempt...");
        qaShowLoader("Loading your quiz...");
        await loadAttempt();
        qaHideLoader();

        // Start dynamic autosave loop after attempt metadata/items are loaded
        startAutosaveLoop();
      })();
    })();
  </script>
</body>

