<html lang="en">

<head>
  <meta charset="utf-8"></meta>
  <meta content="width=device-width,initial-scale=1" name="viewport"></meta>
  <title>QAcademy — Instant Runner</title>
  <style>
    :root {
      --brand: #0b7a75;
      --muted: #859998;
      --ink: #1f2a28;
      --bg: #f6f8f7;
      --card: #ffffff;
      --soft: rgba(0, 0, 0, .06);
    }

    * {
      box-sizing: border-box
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: system-ui, Segoe UI, Roboto, sans-serif
    }

    .wrap {
      max-width: 920px;
      margin: 24px auto;
      padding: 0 14px
    }

    .card {
      background: var(--card);
      border: 1px solid var(--soft);
      border-radius: 16px;
      box-shadow: 0 10px 24px rgba(0, 0, 0, .06);
      padding: 16px;
      margin-bottom: 14px
    }

    h1 {
      margin: 0 0 6px;
      font-size: 22px;
      color: #0b7a75;
      font-weight: 800;
      letter-spacing: .2px
    }

    .sub {
      color: #576663;
      font-size: 13px;
      margin-bottom: 10px
    }

    .bar {
      display: flex;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
      margin: 6px 0 8px;
      flex-wrap: wrap
    }

    .pill {
      padding: 6px 10px;
      border-radius: 999px;
      background: #eef3f2;
      color: #25413d;
      border: 1px solid #dbe4e2;
      font-size: 12px
    }

    /* Slim sticky header bar (progress + view + flag nav) */
    #headerCard {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(255, 255, 255, .97);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #dbe4e2;
      border-radius: 0 0 16px 16px;
      box-shadow: 0 6px 18px rgba(0, 0, 0, .08);
      padding: 8px 12px;
      margin-bottom: 10px;
    }

    .headerBar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .progress {
      position: relative;
      height: 10px;
      background: #e6eceb;
      border-radius: 999px;
      overflow: hidden;
      border: 1px solid #cfe0dd;
      margin-top: 4px;
    }

    .progress>div {
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      width: 0%;
      background: repeating-linear-gradient(45deg, #0b7a75, #0b7a75 10px, #0a6a66 10px, #0a6a66 20px);
      box-shadow: inset 0 0 6px rgba(0, 0, 0, .15);
      background-size: 40px 40px;
      animation: qaStripes 1.2s linear infinite;
    }

    .progLabel {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      color: #0b7a75;
      mix-blend-mode: multiply;
      pointer-events: none;
    }

    @keyframes qaStripes {
      from {
        background-position: 0 0;
      }

      to {
        background-position: 40px 0;
      }
    }

    .flag-controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: 6px;
      flex-wrap: wrap;
    }

    .view-toggle {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center
    }

    .flag-nav {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center
    }

    /* NEW: feedback-mode buttons */
    .feedback-toggle {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }

    .btn {
      background: #0b7a75;
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 10px 14px;
      font-weight: 700;
      cursor: pointer
    }

    .btn.ghost {
      background: #e6f2f0;
      color: #0a6c67
    }

    .btn.softer {
      background: #eef3f2;
      color: #25413d
    }

    .btn.small {
      padding: 6px 10px;
      font-size: 12px;
      border-radius: 10px
    }

    .btn:disabled {
      opacity: .6;
      cursor: not-allowed
    }

    /* highlight active feedback mode button */
    .btn.softer.small.activeFeedback {
      background: #0b7a75;
      color: #ffffff;
      border-color: #0b7a75;
    }

    .qstem {
      font-weight: 700;
      margin: 4px 0 0
    }

    .q-topic {
      font-size: 11px;
      color: #6b7b78;
      margin-top: 2px;
    }

    .opts {
      display: grid;
      gap: 10px;
      margin-top: 8px
    }

    .opt {
      border: 1px solid #d8dfdd;
      border-radius: 12px;
      background: #fff;
      padding: 10px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 10px;
      align-items: flex-start;
      cursor: pointer
    }

    .opt input {
      margin-top: 3px
    }

    .opt-title {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap
    }

    .chip {
      display: inline-block;
      border-radius: 999px;
      padding: 4px 8px;
      font-size: 12px;
      border: 1px solid #dbe4e2;
      background: #eef3f2;
      color: #25413d
    }

    .chip.correct {
      background: #e6f7f3;
      color: #0a6c67;
      border-color: #bfe7dd
    }

    .chip.your {
      background: #fff8e6;
      color: #6a4a0a;
      border-color: #f3d9a5
    }

    .opt-fb {
      grid-column: 1 / -1;
      margin: 4px 0 0 26px;
      padding: 8px 10px;
      border-left: 3px solid #e6efed;
      background: #f8fbfa;
      border-radius: 8px;
      color: #3b4a47;
      font-size: 13px;
      white-space: pre-wrap;
      display: none
    }

    .rationale {
      margin-top: 12px;
      padding: 10px;
      border: 1px dashed #d8dfdd;
      border-radius: 10px;
      background: #fcfefd;
      color: #31403d;
      font-size: 13px;
      white-space: pre-wrap;
      display: none;
    }

    /* Rationale image block */
    .rationale-text {
      margin-bottom: 6px;
    }

    .rationale-img-wrap {
      margin-top: 4px;
      text-align: left;
    }

    .rationale-img-thumb {
      max-width: 100%;
      max-height: 180px;
      border-radius: 10px;
      border: 1px solid #d8dfdd;
      display: block;
      cursor: pointer;
    }

    .rationale-img-caption {
      font-size: 11px;
      color: #4b5a58;
      margin-top: 4px;
    }

    .nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 12px
    }

    .status {
      font-family: ui-monospace, Consolas, monospace;
      background: #0a302e;
      color: #dbfff8;
      border-radius: 12px;
      padding: 12px;
      white-space: pre-wrap
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(44px, 1fr));
      gap: 8px
    }

    .cell {
      border: 1px solid #d8dfdd;
      border-radius: 10px;
      background: #fff;
      text-align: center;
      padding: 8px 0;
      font-weight: 700;
      cursor: pointer
    }

    .cell.active {
      border-color: #0b7a75;
      box-shadow: 0 0 0 2px rgba(11, 122, 117, .15) inset
    }

    .cell.done {
      background: #f0f9f8
    }

    .score {
      font-size: 18px;
      font-weight: 900;
      color: #0b7a75
    }

    /* Multi-question paging + question card layout */
    .q-block {
      padding: 6px 0 30px 0;
      border-bottom: 1px dashed #e0e6e5;
      margin-bottom: 8px;
      position: relative;
    }

    .q-head {
      margin-bottom: 4px;
    }

    .q-index {
      display: inline-block;
      margin-bottom: 4px;
    }

    .q-footer {
      margin-top: 6px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .flag-btn {
      padding: 6px 10px;
      font-size: 12px;
      border-radius: 10px
    }

    .watermark {
      font-size: 11px;
      font-weight: 700;
      color: #0b7a75;
      opacity: .75;
      border-radius: 999px;
      border: 1px solid #e6eceb;
      padding: 4px 8px;
      background: rgba(255, 255, 255, .9);
    }


    .pagebar {
      display: flex;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
      margin-top: 8px;
      flex-wrap: wrap
    }

    .pagebar.sticky {
      position: sticky;
      top: 0;
      z-index: 10;
      background: #ffffffcc;
      backdrop-filter: blur(6px);
      border-bottom: 1px solid #e6eeec;
      padding: 8px 12px;
      margin: -16px -16px 12px;
      border-radius: 16px 16px 0 0;
    }

    /* Floating grid button */
    .fab-grid {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 40;
      box-shadow: 0 10px 24px rgba(0, 0, 0, .18);
      border-radius: 999px;
    }

    /* Generic overlay container (reused) */
    .grid-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .35);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 60;
    }

    .grid-panel {
      width: 100%;
      max-width: 360px;
      max-height: 70vh;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 12px 28px rgba(0, 0, 0, .28);
      padding: 10px 12px;
      overflow-y: auto;
    }

    .grid-header {
      position: sticky;
      top: 0;
      background: #fff;
      padding-bottom: 6px;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      font-size: 14px;
      font-weight: 700;
      color: #1f2a28;
      border-bottom: 1px solid #e2e8f0;
    }

    .grid-body {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(36px, 1fr));
      gap: 6px;
    }

    .grid-btn {
      min-width: 36px;
      height: 36px;
      border-radius: 8px;
      border: 1px solid #e2e8f0;
      background: #fff;
      cursor: pointer;
      font-weight: 700;
      font-size: 13px;
    }

    .grid-btn.answered {
      background: #eef2ff;
      border-color: #c7d2fe;
    }

    .grid-btn.flagged {
      background: #fff7ed;
      border-color: #fdba74;
    }

    /* Image rationale overlay */
    .img-panel {
      width: 100%;
      max-width: 520px;
      max-height: 80vh;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 12px 28px rgba(0, 0, 0, .28);
      padding: 10px 12px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    #imgOverlayImg {
      max-width: 100%;
      max-height: 70vh;
      border-radius: 10px;
      object-fit: contain;
    }

    /* GLOBAL LOADER OVERLAY (same style as Timed Runner) */
    .qa-loader-overlay {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(15, 23, 42, .55);
      z-index: 999;
    }

    .qa-loader-card {
      background: #ffffff;
      border-radius: 18px;
      padding: 14px 18px;
      box-shadow: 0 16px 40px rgba(15, 23, 42, .35);
      display: flex;
      gap: 12px;
      align-items: center;
      max-width: 320px;
      width: 90%;
    }

    .qa-loader-spinner {
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 3px solid #e2ecea;
      border-top-color: #0b7a75;
      animation: qaSpin 0.8s linear infinite;
    }

    .qa-loader-text {
      font-size: 13px;
      color: #1f2a28;
    }

    .qa-loader-title {
      font-weight: 700;
      margin-bottom: 2px;
    }

    .qa-loader-sub {
      font-size: 12px;
      color: #4b5a58;
    }

    @keyframes qaSpin {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }

    @media (max-width:720px) {
      .bar {
        flex-direction: column;
        align-items: flex-start
      }

      .flag-controls {
        flex-direction: column;
        align-items: flex-start
      }

      .headerBar {
        align-items: flex-start
      }
    }

    @media (max-width:480px) {
      #headerCard {
        padding: 6px 10px;
        border-radius: 0 0 12px 12px;
      }

      .headerBar {
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
      }

      .view-toggle span {
        display: none;
      }

      /* hide "View:" label on very small screens */
      .feedback-toggle span {
        display: none;
      }

      /* hide "Feedback:" label on very small screens */

      .btn.small {
        padding: 4px 8px;
        font-size: 11px;
        border-radius: 9px;
      }

      .flag-controls {
        margin-top: 4px;
        gap: 6px;
      }
    }
  </style>
</head>

<body>
  <div class="wrap">

    <div class="card" id="infoCard">
      <h1>Instant Quiz</h1>
      <div class="sub">Practice mode • Feedback behaves according to the selected feedback mode</div>
      <div class="bar">
        <div class="pill" id="userPill">User: —</div>
        <div class="pill" id="coursePill">Course: —</div>
        <div class="pill" id="metaPill">Attempt: —</div>
        <div class="pill" id="countPill">0 / 0 answered</div>
      </div>
    </div>

    <div class="card" id="headerCard">
      <div class="headerBar">
        <div class="pill" id="modePill">Instant:Inline feedback</div>
        <div style="flex: 1; min-width: 140px;">
          <div class="progress">
            <div id="progFill"></div>
            <div class="progLabel" id="progLabel">0%</div>
          </div>
        </div>
        <div class="view-toggle">
          <span style="color: #4b5a58; font-size: 11px; margin-right: 4px;">View:</span>
          <button class="btn softer small" id="viewAllBtn" type="button">All</button>
          <button class="btn softer small" id="viewFlaggedBtn" type="button">Flagged</button>
        </div>
        <div class="feedback-toggle">
          <span style="color:#4b5a58;font-size:11px;margin-right:4px;">Feedback:</span>
          <button class="btn softer small" id="fbInlineBtn" type="button">Inline</button>
          <button class="btn softer small" id="fbStandaloneBtn" type="button">Standalone</button>
          <button class="btn softer small" id="fbHideBtn" type="button">Hide</button>
        </div>
      </div>

      <div class="flag-controls">
        <div style="color: #4b5a58; font-size: 11px;">Flag navigation:</div>
        <div class="flag-nav">
          <button class="btn softer small" id="prevFlagBtn" style="display: none;" type="button">Prev flagged</button>
          <button class="btn softer small" id="nextFlagBtn" style="display: none;" type="button">Next flagged</button>
        </div>
      </div>
    </div>

    <div class="card" id="preCard" style="display: none;">
      <h2 style="font-size: 18px; margin: 0 0 4px;">Ready to start your practice quiz?</h2>
      <p class="sub" id="preSummary">Loading quiz details...</p>
      <div class="pill" id="preMetaPill">Mode: Instant • Questions: —</div>

      <div style="color: #3b4a47; font-size: 13px; margin-top: 10px;">
        <p style="margin: 0 0 4px;">How this quiz works:</p>
        <ul style="margin: 4px 0 0 18px; padding: 0;">
          <li>Questions are shown in pages. Use <strong>Prev</strong> and <strong>Next</strong> to move.</li>
          <li>Your choice is recorded immediately and feedback follows the selected feedback mode.</li>
          <li>You can change your answers before you submit the quiz.</li>
          <li>At the end you’ll see your score and a question grid so you can jump around.</li>
        </ul>
      </div>

      <label style="align-items: center; color: #3b4a47; display: flex; font-size: 12px; gap: 6px; margin-top: 10px;">
        <input id="preSkip" type="checkbox" />
        <span>Don’t show this again on this device</span>
      </label>

      <div class="nav" style="margin-top: 10px;">
        <button class="btn ghost" id="preCancelBtn" type="button">Cancel</button>
        <button class="btn" id="preStartBtn" type="button">Start quiz</button>
      </div>
    </div>

    <div class="card" id="qCard" style="display: none;">

      <div class="pagebar sticky" id="pagebarTop">
        <div class="pill" id="pagePill">Page 1 / 1</div>
        <div style="display: flex; gap: 8px;">
          <button class="btn softer prevPage" type="button">◀ Prev Page</button>
          <button class="btn softer nextPage" type="button">Next Page ▶</button>
        </div>
      </div>

      <div id="qList"></div>

      <div class="pagebar" id="pagebarBottom">
        <div class="pill" id="pagePillBottom">Page 1 / 1</div>
        <div style="display: flex; gap: 8px;">
          <button class="btn softer prevPage" type="button">◀ Prev Page</button>
          <button class="btn softer nextPage" type="button">Next Page ▶</button>
        </div>
      </div>

      <div class="nav">
        <button class="btn ghost" id="reviewBtn" type="button">Review</button>
        <button class="btn" id="submitBtn" type="button">Submit</button>
        <button class="btn ghost" id="exitBtn" type="button">Exit</button>
        <button class="btn ghost" id="restartBtn" style="display: none;" type="button">Restart</button>
      </div>
    </div>

    <div class="card" id="reviewCard" style="display: none;">
      <div style="align-items: center; display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between;">
        <div class="score" id="scoreText">Score: —</div>
        <button class="btn softer" id="backToQuizBtn" type="button">Back to quiz</button>
      </div>
      <div class="grid" id="grid"></div>
    </div>

    <div class="card" id="logCard">
      <div class="status" id="log">Loading attempt…</div>
    </div>
  </div>

  <button class="btn softer fab-grid" id="fabGrid" style="display: none;" type="button">Questions ▢</button>

  <div class="grid-overlay" id="gridOverlay">
    <div class="grid-panel">
      <div class="grid-header">
        <span>Question grid</span>
        <button class="btn softer small" id="gridOverlayClose" type="button">Close</button>
      </div>
      <div class="grid-body" id="gridOverlayBody"></div>
    </div>
  </div>

  <div class="grid-overlay" id="exitOverlay">
    <div class="grid-panel">
      <div class="grid-header">
        <span>Leave this quiz?</span>
      </div>
      <div style="color: #3b4a47; font-size: 13px; margin-bottom: 10px;">
        <p style="margin: 0 0 6px;">
          If you leave now:
        </p>
        <ul style="margin: 0 0 8px 18px; padding: 0;">
          <li><strong>Save &amp; resume later</strong> will store your current answers as an in-progress attempt.</li>
          <li><strong>Submit &amp; exit</strong> will mark this attempt as completed and show your results.</li>
          <li><strong>Cancel</strong> will return you to the quiz.</li>
        </ul>
      </div>
      <div class="nav" style="margin-top: 4px;">
        <button class="btn ghost" id="exitCancelBtn" type="button">Cancel</button>
        <button class="btn softer" id="exitSaveBtn" type="button">Save &amp; resume later</button>
        <button class="btn" id="exitSubmitBtn" type="button">Submit &amp; exit</button>
      </div>
    </div>
  </div>

  <div class="grid-overlay" id="msgOverlay">
    <div class="grid-panel">
      <div class="grid-header">
        <span>Send Feedback On This Question?</span>
        <button class="btn softer small" id="msgOverlayClose" type="button">Close</button>
      </div>

      <div style="color:#3b4a47;font-size:13px;margin-bottom:10px;">
        <p style="margin:0 0 8px;">
          You’re about to open the Messages page for this question in a new tab.
        </p>
        <ul style="margin:0 0 8px 18px;padding:0;">
          <li>Your current quiz stays open.</li>
          <li>We’ll save your progress, then open Messages in a new tab.</li>
        </ul>
      </div>

      <div class="nav" style="margin-top:4px;">
        <button class="btn ghost" id="msgCancelBtn" type="button">Cancel</button>
        <button class="btn" id="msgSaveOpenBtn" type="button">Save &amp; open messages</button>
      </div>
    </div>
  </div>


  <div class="grid-overlay" id="imgOverlay">
    <div class="img-panel">
      <div class="grid-header" style="margin-bottom:4px;">
        <span>Rationale image</span>
        <button class="btn softer small" id="imgOverlayClose" type="button">Close</button>
      </div>
      <img id="imgOverlayImg" alt="Rationale illustration" />
    </div>
  </div>

  <div class="qa-loader-overlay" id="qaLoader">
    <div class="qa-loader-card">
      <div class="qa-loader-spinner"></div>
      <div class="qa-loader-text">
        <div class="qa-loader-title">Working on it...</div>
        <div class="qa-loader-sub" id="qaLoaderMsg">Preparing your quiz</div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      // === CONFIG (AUTH + BUILDER + GUARD V3 STYLE) ===
      const DEFAULT_AUTH_URL = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec"; // auth/verify
      const DEFAULT_BUILDER_URL = "https://script.google.com/macros/s/AKfycbx_CDJU5juEDxybplqBlYjJP0tAS52-HIOWE6is19Ub7NqhaV_16MnFmstJpWcdorHT/exec"; // builder/attempt
      const DEFAULT_LOGIN_SLUG = "login_23";
      const DEFAULT_DASHBOARD_SLUG = "dashboard_23";
      const DEFAULT_MESSAGES_SLUG = "messages"; // <-- set to your real messages page slug if different
      const DEFAULT_TOKEN_KEY = "qa_token";
      const DEFAULT_USER_ID_KEY = "qa_user_id";

      var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === "object") ? window.QA_CONFIG : {};

      const AUTH_WEB_APP_URL = cfg.AUTH_URL || cfg.authUrl || DEFAULT_AUTH_URL;
      const BUILDER_WEB_APP_URL = cfg.BUILDER_API_URL || cfg.builderApiUrl || DEFAULT_BUILDER_URL;

