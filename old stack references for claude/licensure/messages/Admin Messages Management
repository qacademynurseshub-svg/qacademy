function getFilteredScopeSuggestions(audience, typedToken){
  const all = getScopeValuesForAudience(audience) || [];
  const q = String(typedToken || "").trim().toLowerCase();
  if(!q) return all.slice(0, 20);

  const starts = [];
  const contains = [];
  for(const v of all){
    const vv = String(v||"");
    const l = vv.toLowerCase();
    if(l.startsWith(q)) starts.push(vv);
    else if(l.includes(q)) contains.push(vv);
  }
  return starts.concat(contains).slice(0, 20);
}

