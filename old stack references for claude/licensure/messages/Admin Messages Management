$("cAudience").onchange = syncComposeVisibility;
$("cContext").onchange = syncComposeVisibility;

// Fix C: live suggestions for comma-separated scope values
$("cScopeValues").addEventListener("input", () => {
  const audience = $("cAudience").value;
  const inp = $("cScopeValues");
  if(!inp) return;

  if(audience === "single" || audience === "all_active"){
    hideScopeSug();
    setNativeDatalistEnabled(true);
    return;
  }

  const raw = inp.value || "";
  const multi = hasComma(raw);

  if(!multi){
    hideScopeSug();
    setNativeDatalistEnabled(true);
    return;
  }

  setNativeDatalistEnabled(false);

  if(!STATE.scopeMeta || !STATE.scopeMeta.ok){
    hideScopeSug();
    return;
  }

  const tokenText = getLastTokenFromCSVInput(raw);
  const sug = getFilteredScopeSuggestions(audience, tokenText);

  showScopeSug(sug, (picked) => {
    const nowRaw = inp.value || "";
    inp.value = replaceLastTokenInCSVInput(nowRaw, picked);

    if(!inp.value.trim().endsWith(",")){
      inp.value = inp.value.replace(/\s+$/,"") + ", ";
    }

    hideScopeSug();
    inp.focus();
  });
});

$("btnUserSearch").onclick = () => searchUsers($("cUserSearch").value);
$("cUserSearch").addEventListener("keydown", (e)=>{ if(e.key==="Enter") searchUsers($("cUserSearch").value); });

$("composeMask").addEventListener("click", (e)=>{
  if(e.target && e.target.id === "composeMask") showComposeDesktop(false);
});

(async function init(){
  setGlobalLoader(true, "Checking session...");
  setStatus("Checking session…", true);

  if(!token()){
    setStatus("Not logged in", false);
    location.href = QA.LOGIN_URL;
    return;
  }

  await loadScopeMeta(false);
  syncComposeVisibility();

  await loadThreads();
  setGlobalLoader(false);
  setStatus("Ready", true);
})();
</script>
