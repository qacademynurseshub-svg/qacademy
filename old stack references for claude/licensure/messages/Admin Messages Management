/* ===========================
   Scope meta (suggestions)
=========================== */
async function loadScopeMeta(force=false){
  const t = token();
  if(!t) return;

  const now = Date.now();
  const hasGoodCache = STATE.scopeMeta && STATE.scopeMeta.ok;
  const isFresh = hasGoodCache && (now - (STATE.scopeMetaLoadedAt||0) < 10*60*1000);
  if(isFresh && !force) return;

  try{
    const res = await postForm({ action:"admin.scope.meta", token:t });

    if(res && res.ok){
      STATE.scopeMeta = res;
      STATE.scopeMetaLoadedAt = now;

      const courseIds = (res.courses && Array.isArray(res.courses.course_ids)) ? res.courses.course_ids : [];
      fillDatalist("dlCCourseIds", courseIds);
      fillDatalist("dlMCourseIds", courseIds);

      refreshScopeSuggestions();
      return;
    }

    STATE.scopeMeta = null;
    STATE.scopeMetaLoadedAt = 0;

  }catch(_){
    STATE.scopeMeta = null;
    STATE.scopeMetaLoadedAt = 0;
  }
}

function getScopeValuesForAudience(audience){
  const m = STATE.scopeMeta;
  if(!m || !m.ok) return [];

  if(audience === "program") return (m.programs && m.programs.program_ids) ? m.programs.program_ids : [];
  if(audience === "course")  return (m.courses  && m.courses.course_ids)   ? m.courses.course_ids   : [];
  if(audience === "product") return (m.products && m.products.product_ids) ? m.products.product_ids : [];
  if(audience === "kind")    return (m.products && m.products.subscription_kinds) ? m.products.subscription_kinds : [];
  if(audience === "cohort")  return (m.users    && m.users.cohort_ids) ? m.users.cohort_ids : [];
  if(audience === "level")   return (m.users    && m.users.level_ids)  ? m.users.level_ids  : [];

  return [];
}

function refreshScopeSuggestions(){
  const audience = $("cAudience") ? $("cAudience").value : "single";

  const vals = getScopeValuesForAudience(audience);
  fillDatalist("dlCScopeValues", vals);

  function hintFor(aud){
    if(aud === "single") return "";
    if(aud === "all_active") return "No scope needed. This targets all active users.";
    const values = getScopeValuesForAudience(aud);
    const n = values.length;
    if(!STATE.scopeMeta) return "Suggestions not loaded yet. You can still paste comma-separated IDs.";
    if(n === 0) return "No values found in Sheets for this scope. Check sheet headers/data.";
    const sample = values.slice(0, 6).join(", ");
    return `Available: ${n}. Examples: ${sample}`;
  }
  setScopeHelp("cScopeHelp", hintFor(audience));
}

