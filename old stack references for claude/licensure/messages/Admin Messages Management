function currentFilters(){
  return {
    status: ($("fStatus").value || "").trim(),
    unread_only: ($("fUnread").value || "").trim(),
    context_type: ($("fContext").value || "").trim(),
    query: ($("fQuery").value || "").trim(),
    limit: ($("fLimit").value || "80").trim()
  };
}

async function loadThreads(){
  showErr("threadsErr", "");
  showErr("chatErr", "");
  setStatus("Loading threads…", true);

  const t = token();
  if(!t){ location.href = QA.LOGIN_URL; return; }

  const btn = $("btnRefresh");
  const old = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = `<span class="spin"></span>`;

  try{
    const f = currentFilters();
    const res = await postForm({
      action: "admin.thread.list",
      token: t,
      status: f.status,
      unread_only: f.unread_only,
      context_type: f.context_type,
      query: f.query,
      limit: f.limit
    });

    if(!res.ok){
      setStatus("Error", false);
      showErr("threadsErr", "List failed: " + (res.error || "unknown"));
      if(String(res.error||"").toLowerCase().includes("forbidden")){
        $("threads").innerHTML = '<div class="hint"><b>Admin only.</b> Your account is not allowed to view this page.</div>';
      }
      return;
    }

    STATE.threads = res.threads || [];
    renderThreads();
    setStatus("Ready", true);
  }catch(e){
    setStatus("Error", false);
    showErr("threadsErr", "List failed: network error");
  } finally {
    btn.disabled = false;
    btn.innerHTML = old;
  }
}

async function openThread(threadId){
  showErr("chatErr", "");
  const t = token();
  if(!t){ location.href = QA.LOGIN_URL; return; }

  if(STATE.busyOpen) return;
  STATE.busyOpen = true;

  STATE.activeThreadId = threadId;
  renderThreads();
  setStatus("Opening…", true);
  setGlobalLoader(true, "Opening conversation...");

  try{
    const res = await postForm({
      action:"admin.thread.open",
      token:t,
      thread_id: threadId,
      open_limit:"600"
    });

    if(!res.ok){
      setStatus("Error", false);
      showErr("chatErr", "Open failed: " + (res.error || "unknown"));
      return;
    }

    STATE.activeThread = res.thread || null;
    STATE.activeMessages = res.messages || [];
    renderChat();
    setStatus("Ready", true);

    markThreadReadLocally(threadId);
    updateThreadLastSeenLocally(res.thread);
    renderThreads();

  } finally {
    STATE.busyOpen = false;
    setGlobalLoader(false);
  }
}

async function adminReply(){
  showErr("chatErr", "");
  const t = token();
  if(!t){ location.href = QA.LOGIN_URL; return; }
  if(!STATE.activeThreadId){
    showErr("chatErr", "Select a thread first.");
    return;
  }
  if(STATE.activeThread && isThreadClosed(STATE.activeThread)){
    showErr("chatErr", "Thread is CLOSED. Reopen to reply.");
    return;
  }
  if(STATE.busySend) return;

  const box = $("msgBox");
  const text = (box.value || "").trim();
  if(!text) return;

  STATE.busySend = true;
  $("btnSend").disabled = true;
  $("msgBox").disabled = true;
  $("btnSend").innerHTML = `<span class="spin"></span> Sending…`;
  setStatus("Sending…", true);

  try{
    const res = await postForm({
      action:"admin.thread.reply",
      token:t,
      thread_id: STATE.activeThreadId,
      body_text: text
    });

    $("btnSend").innerHTML = `Send`;
    STATE.busySend = false;

    if(!res.ok){
      setStatus("Error", false);
      $("msgBox").disabled = false;
      showErr("chatErr", "Reply failed: " + (res.error || "unknown"));
      renderChat();
      return;
    }

    box.value = "";
    await openThread(STATE.activeThreadId);
  } catch(e){
    $("btnSend").innerHTML = `Send`;
    STATE.busySend = false;
    $("msgBox").disabled = false;
    setStatus("Error", false);
    showErr("chatErr", "Reply failed: network error");
    renderChat();
  } finally {
    recomputeSendEnabled();
  }
}

