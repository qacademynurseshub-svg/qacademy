      const row = document.createElement("div");
      row.className = "rrow";
      const headline = (u.name ? u.name : (u.email ? u.email : u.user_id));
      row.innerHTML = `
        <div class="rtitle">${esc(headline || "User")}</div>
        <div class="rsub">${esc(u.user_id || "")}${u.email ? " • " + esc(u.email) : ""}${u.program_id ? " • " + esc(u.program_id) : ""}</div>
      `;
      row.onclick = () => {
        setPickedUser({ user_id: u.user_id, email: u.email || "", name: u.name || "" });
        if($("cUserIdManual")) $("cUserIdManual").value = u.user_id || "";
      };
      resultsEl.appendChild(row);
    });

  } finally {
    setGlobalLoader(false);
  }
}

function buildBulkPayload(){
  const audience = $("cAudience").value;
  const ctxType = $("cContext").value;

  const subject  = ($("cSubject").value || "");
  const ref_text = ($("cRefText").value || "");
  const body_text = ($("cBody").value || "");

  const course_id = (ctxType === "course")
    ? (($("cCourseId").value || "").trim())
    : "";

  const scopeValues = ($("cScopeValues").value || "");
  const list = splitCSV(scopeValues);

  const scope = {
    program_ids: [],
    course_ids: [],
    product_ids: [],
    subscription_kinds: [],
    cohort_ids: [],
    level_ids: [],
    user_ids: []
  };

  if(audience === "single"){
    const picked = STATE.pickedUser && STATE.pickedUser.user_id ? STATE.pickedUser.user_id : "";
    const manual = ($("cUserIdManual").value || "");
    const uid = (picked || manual).trim();
    if(uid) scope.user_ids = [uid];
  } else if(audience === "all_active"){
    // flag only
  } else if(audience === "program"){
    scope.program_ids = list;
  } else if(audience === "course"){
    scope.course_ids = list;
  } else if(audience === "product"){
    scope.product_ids = list;
  } else if(audience === "kind"){
    scope.subscription_kinds = list;
  } else if(audience === "cohort"){
    scope.cohort_ids = list;
  } else if(audience === "level"){
    scope.level_ids = list;
  }

  return {
    audience: String(audience||"").trim(),
    subject: String(subject||"").trim(),
    ref_text: String(ref_text||"").trim(),
    body_text: String(body_text||"").trim(),
    context_type: String(ctxType||"general").trim(),
    course_id: course_id,
    scope
  };
}

function validateBulkPayload(p){
  if(!p.body_text) return "Message is required.";
  if(p.context_type === "course" && !p.course_id) return "course_id is required for course context.";

  if(p.audience === "single"){
    const n = (p.scope.user_ids || []).length;
    if(n !== 1) return "Pick exactly one user (search or manual user_id).";
    return "";
  }

  const hasAnyScope =
    (p.scope.program_ids.length || p.scope.course_ids.length || p.scope.product_ids.length ||
     p.scope.subscription_kinds.length || p.scope.cohort_ids.length || p.scope.level_ids.length || p.scope.user_ids.length);

  if(!hasAnyScope && p.audience !== "all_active"){
    return "Select an audience scope (or choose All active users).";
  }

  return "";
}

async function sendBulk(){
  clearComposeErrors();

  const t = token();
  if(!t){ location.href = QA.LOGIN_URL; return; }

  const p = buildBulkPayload();
  const err = validateBulkPayload(p);
  if(err){
    showErr("composeErr", err);
    return;
  }

  const include_inactive = !!$("cIncludeInactive")?.checked;

  const payload = {
    action: "admin.bulk.send",
    token: t,

    subject: p.subject,
    body_text: p.body_text,

    bulk_ref_text: p.ref_text,
    bulk_context_type: p.context_type,
    bulk_course_id: p.course_id,

    all_active: (p.audience === "all_active") ? "true" : "false",
    include_inactive: include_inactive ? "true" : "false",

    force_single: (p.audience === "single") ? "true" : "false",

    program_ids: (p.scope.program_ids || []).join(","),
    course_ids: (p.scope.course_ids || []).join(","),
    product_ids: (p.scope.product_ids || []).join(","),
    subscription_kinds: (p.scope.subscription_kinds || []).join(","),
    cohort_ids: (p.scope.cohort_ids || []).join(","),
    level_ids: (p.scope.level_ids || []).join(","),
    user_ids: (p.scope.user_ids || []).join(",")
  };

  setGlobalLoader(true, "Sending...");
  try{
    const res = await postForm(payload);

    if(!res.ok){
      showErr("composeErr", "Send failed: " + (res.error || "unknown"));
      return;
    }

    setStatus("Sent", true);
    showComposeDesktop(false);

    await loadThreads();

    const targetUid = (p.scope.user_ids && p.scope.user_ids[0]) ? p.scope.user_ids[0] : "";
    if(targetUid && (res.resolved_count === 1 || String(res.resolved_count||"") === "1")){
      const ctx = String(p.context_type||"general").toLowerCase();
      const cid = String(p.course_id||"");

      const candidates = (STATE.threads||[])
        .filter(x => String(x.user_id||"") === targetUid)
        .filter(x => String(x.context_type||"").toLowerCase() === ctx)
        .filter(x => (ctx !== "course" ? true : String(x.course_id||"") === cid))
        .sort((a,b)=>String(b.last_message_at||"").localeCompare(String(a.last_message_at||"")));

      if(candidates.length){
        await openThread(candidates[0].thread_id);
      }
    }

  } finally {
    setGlobalLoader(false);
  }
}

