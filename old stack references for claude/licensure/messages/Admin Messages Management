<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Admin Inbox</title>
<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#0f172a;
    --bg:#f6f8f7;
    --card:#ffffff;
    --line:#e5e7eb;
    --soft:rgba(0,0,0,.06);
    --danger:#b91c1c;
    --warn:#8f2727;
    --ok:#0a6c67;
  }
  *{box-sizing:border-box}
  body{
    margin:0;
    font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
    background:var(--bg);
    color:var(--ink);
  }
  .wrap{
    max-width:1200px;
    margin:18px auto;
    padding:0 12px 22px;
  }

  /* Full Screen Loader Overlay */
  #globalLoader {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(2px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    flex-direction: column;
    gap: 12px;
  }

  /* ===== Topbar ===== */
  .topbar{
    display:flex;
    gap:10px;
    align-items:center;
    justify-content:space-between;
    margin-bottom:10px;
    flex-wrap:wrap;
  }
  .title{
    font-weight:900;
    letter-spacing:-.02em;
    font-size:18px;
  }
  .top-actions{
    display:flex;
    gap:10px;
    align-items:center;
    flex-wrap:wrap;
    justify-content:flex-end;
  }
  .pill{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:8px 10px;
    border-radius:999px;
    background:var(--card);
    border:1px solid var(--line);
    box-shadow:0 6px 20px var(--soft);
    color:#334155;
    font-size:12px;
    white-space:nowrap;
  }
  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    padding:10px 12px;
    border-radius:12px;
    border:1px solid var(--line);
    background:var(--card);
    box-shadow:0 6px 20px var(--soft);
    font-weight:800;
    cursor:pointer;
    color:var(--ink);
    text-decoration:none;
    user-select:none;
  }
  .btn:active{transform:translateY(1px)}
  .btn.primary{
    background:var(--brand);
    border-color:var(--brand);
    color:#fff;
  }
  .btn.primary[disabled],
  .btn[disabled]{
    opacity:.65;
    cursor:not-allowed;
  }
  .btn.danger{
    background:#fff;
    border-color:#fecaca;
    color:var(--danger);
  }
  .btn.ghost{
    background:transparent;
    box-shadow:none;
  }

  /* ===== Filters Toolbar (TOP) ===== */
  .filtersBar{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:16px;
    box-shadow:0 10px 30px var(--soft);
    padding:10px;
    margin-bottom:12px;
  }
  .filtersRow{
    display:flex;
    gap:10px;
    align-items:flex-end;
    flex-wrap:wrap;
  }
  .filtersRow + .filtersRow{ margin-top:10px; }

  .f{
    min-width:170px;
    flex:0 0 auto;
  }
  .f.grow{
    flex:1 1 380px;
    min-width:240px;
  }
  label{
    font-size:12px;
    color:#64748b;
    font-weight:900;
    display:block;
    margin-bottom:6px;
  }
  select, input{
    width:100%;
    padding:10px 10px;
    border-radius:12px;
    border:1px solid var(--line);
    outline:none;
    font-size:14px;
    background:#fff;
  }
  select:focus, input:focus{
    border-color: rgba(11,122,117,.55);
    box-shadow:0 0 0 4px rgba(11,122,117,.12);
  }
  .filtersActions{
    display:flex;
    gap:10px;
    align-items:center;
    justify-content:flex-end;
    flex-wrap:wrap;
    margin-left:auto;
  }
  .tinyhint{
    font-size:12px;
    color:#64748b;
    margin-top:8px;
  }

  /* ===== Main Grid ===== */
  .grid{
    display:grid;
    grid-template-columns: 420px 1fr;
    gap:12px;
  }
  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
  }
  .card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:16px;
    box-shadow:0 10px 30px var(--soft);
    overflow:hidden;
  }

  /* ===== Threads List (LEFT) ===== */
  .listHead{
    padding:12px;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
  }
  .listHead .sub{ font-size:12px; color:#475569; }

  .threads{
    max-height:72vh;
    overflow:auto;
  }
  @media (max-width: 980px){
    .threads{ max-height:44vh; }
  }

  .trow{
    padding:12px;
    border-bottom:1px solid var(--line);
    cursor:pointer;
    display:flex;
    gap:10px;
    align-items:flex-start;
  }
  .trow:hover{ background:#f8fafc; }
  .trow.active{ background:#ecfeff; }

  .dot{
    width:10px;height:10px;border-radius:999px;
    margin-top:4px;
    background:transparent;
    border:1px solid var(--line);
    flex:0 0 auto;
  }
  .dot.unread{ background:var(--brand); border-color:var(--brand); }

  .tmeta{ flex:1; min-width:0; }
  .tline1{
    display:flex;
    gap:8px;
    align-items:center;
    justify-content:space-between;
  }
  .tctx{
    font-weight:900;
    font-size:13px;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
  }
  .twhen{
    font-size:11px;
    color:#64748b;
    white-space:nowrap;
    margin-left:10px;
  }
  .chips{
    display:flex;
    gap:6px;
    flex-wrap:wrap;
    margin-top:6px;
  }
  .chip{
    font-size:11px;
    padding:4px 8px;
    border-radius:999px;
    border:1px solid var(--line);
    background:#f8fafc;
    color:#334155;
    max-width:100%;
  }
  .chip.brand{
    border-color: rgba(11,122,117,.25);
    background: rgba(11,122,117,.10);
    color: var(--brand);
    font-weight:900;
  }
  .chip.warn{
    border-color:#fecaca;
    background:#fef2f2;
    color:#b91c1c;
    font-weight:900;
  }
  .chip.status-open{
    border-color: rgba(10,108,103,.25);
    background: rgba(10,108,103,.10);
    color: var(--ok);
    font-weight:900;
  }
  .chip.status-closed{
    border-color: rgba(143,39,39,.25);
    background: rgba(143,39,39,.10);
    color: var(--warn);
    font-weight:900;
  }

  /* ===== Chat (RIGHT) ===== */
  .chatHead{
    padding:12px;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:10px;
  }
  .chatTitle{
    font-weight:900;
    font-size:13px;
    min-width:0;
    flex:1;
  }
  .chatTitle .dim{
    display:block;
    font-weight:800;
    font-size:12px;
    color:#64748b;
    white-space:pre-wrap;
    overflow:visible;
    text-overflow:clip;
    word-break:break-word;
    margin-top:4px;
  }

  .chat{
    height:62vh;
    overflow:auto;
    padding:12px;
    background:linear-gradient(180deg,#ffffff,#fbfffe);
  }
  @media (max-width: 980px){
    .chat{ height:52vh; }
  }
  .chat .banner{ margin:0 0 10px 0; }

  .msg{
    display:flex;
    margin:10px 0;
  }
  .bubble{
    max-width: 85%;
    padding:10px 12px;
    border-radius:14px;
    border:1px solid var(--line);
    box-shadow:0 8px 18px var(--soft);
    background:#fff;
    line-height:1.45;
    white-space:pre-wrap;
    word-wrap:break-word;
  }
  .msg.admin{ justify-content:flex-end; }
  .msg.admin .bubble{
    background:rgba(11,122,117,.10);
    border-color: rgba(11,122,117,.25);
  }
  .meta{
    font-size:11px;
    color:#64748b;
    margin-top:6px;
  }

  .composer{
    border-top:1px solid var(--line);
    padding:10px;
    display:flex;
    gap:10px;
    align-items:flex-end;
    background:#fff;
  }
  textarea{
    width:100%;
    min-height:42px;
    max-height:160px;
    resize:vertical;
    border-radius:12px;
    border:1px solid var(--line);
    padding:10px 10px;
    font-family:inherit;
    font-size:14px;
    outline:none;
  }
  textarea:focus{
    border-color: rgba(11,122,117,.55);
    box-shadow:0 0 0 4px rgba(11,122,117,.12);
  }
  textarea[disabled]{
    opacity:.75;
    background:#f8fafc;
    cursor:not-allowed;
  }

  .err{
    background:#fef2f2;
    border:1px solid #fecaca;
    color:var(--danger);
    padding:10px 12px;
    border-radius:12px;
    margin:12px;
    font-weight:900;
    font-size:13px;
  }

  .spin{
    display:inline-block;
    width:14px;height:14px;border-radius:50%;
    border:2px solid rgba(15,23,42,.15);
    border-top-color: rgba(15,23,42,.6);
    animation:spin 1s linear infinite;
  }
  .spin-large{
    width:40px;height:40px;
    border-width:4px;
    border-top-color: var(--brand);
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  .hint{
    font-size:12px;
    color:#64748b;
    padding:10px 12px;
  }

  .banner{
    margin:12px;
    border-radius:12px;
    padding:10px 12px;
    border:1px solid var(--line);
    background:#f8fafc;
    color:#334155;
    font-size:13px;
    font-weight:900;
    display:none;
    white-space:pre-wrap;
    word-wrap:break-word;
  }
  .banner.closed{
    border-color: rgba(143,39,39,.25);
    background: rgba(143,39,39,.08);
    color: var(--warn);
  }
  .banner.info{
    border-color: rgba(11,122,117,.25);
    background: rgba(11,122,117,.08);
    color: var(--brand);
  }

  /* ===== Compose (modal) ===== */
  .composeBody{
    padding:12px;
    display:grid;
    gap:10px;
  }
  .row2{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:10px;
  }
  @media (max-width: 980px){
    .row2{ grid-template-columns: 1fr; }
  }
  .help{
    font-size:12px;
    color:#64748b;
    line-height:1.45;
  }
  .results{
    border:1px solid var(--line);
    border-radius:12px;
    overflow:hidden;
    background:#fff;
  }
  .rrow{
    padding:10px 10px;
    border-bottom:1px solid var(--line);
    cursor:pointer;
  }
  .rrow:hover{ background:#f8fafc; }
  .rrow:last-child{ border-bottom:none; }
  .rtitle{ font-weight:900; font-size:13px; }
  .rsub{ font-size:12px; color:#64748b; margin-top:2px; }

  .modalMask{
    position:fixed;
    inset:0;
    background:rgba(15,23,42,.45);
    display:none;
    align-items:flex-start;
    justify-content:center;
    padding:22px 12px;
    z-index: 9000;
  }
  .modal{
    width:min(900px, 100%);
    background:var(--card);
    border:1px solid var(--line);
    border-radius:16px;
    box-shadow:0 25px 80px rgba(0,0,0,.25);
    overflow:hidden;
  }
  .modalHead{
    padding:12px;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
  }
  .modalHead .h{
    font-weight:900;
  }
  .modalFoot{
    padding:12px;
    border-top:1px solid var(--line);
    display:flex;
    gap:10px;
    align-items:center;
    justify-content:flex-end;
    flex-wrap:wrap;
    background:#fff;
  }
/* === PATCH: make the compose modal scroll properly === */
.modalMask{
  overflow:auto;
  -webkit-overflow-scrolling: touch;
}

.modal{
  max-height: calc(100vh - 44px);
  display:flex;
  flex-direction:column;
}

.composeBody{
  overflow:auto;
  -webkit-overflow-scrolling: touch;
  flex: 1 1 auto;
  min-height: 0;
}

.modalHead,
.modalFoot{
  flex: 0 0 auto;
}
body.modal-open{ overflow:hidden; }

  /* ===== Fix C: token-aware suggestions for comma-separated scope ===== */
  .sugBox{
    margin-top:8px;
    border:1px solid var(--line);
    border-radius:12px;
    background:#fff;
    overflow:hidden;
    max-height:220px;
    overflow:auto;
  }
  .sugItem{
    padding:10px 10px;
    border-bottom:1px solid var(--line);
    cursor:pointer;
    font-weight:800;
    font-size:13px;
    color:#334155;
  }
  .sugItem:hover{ background:#f8fafc; }
  .sugItem:last-child{ border-bottom:none; }
  .sugMuted{
    font-weight:700;
    color:#64748b;
    font-size:12px;
  }

  .toggleRow{
    display:flex;
    gap:10px;
    align-items:center;
    padding:8px 10px;
    border:1px solid var(--line);
    border-radius:12px;
    background:#fff;
  }
  .toggleRow input[type="checkbox"]{
    width:auto;
    padding:0;
    margin:0;
  }
  .toggleRow .tlabel{
    font-size:13px;
    font-weight:900;
    color:#334155;
    margin:0;
  }
  .toggleRow .tsub{
    font-size:12px;
    color:#64748b;
    font-weight:700;
    margin-left:auto;
    white-space:nowrap;
  }
</style>
</head>
<body>

<div id="globalLoader">
  <div class="spin spin-large"></div>
  <div id="loaderText" style="font-weight: 800; color: var(--ink);">Please wait...</div>
</div>

<!-- Desktop compose modal -->
<div id="composeMask" class="modalMask" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="modal">
    <div class="modalHead">
      <div class="h">New message</div>
      <div style="display:flex;gap:10px;align-items:center;">
        <button class="btn" id="btnComposeCloseDesk" type="button">Close</button>
      </div>
    </div>

    <div class="composeBody" id="composeBodyDesk">
      <div class="help">
        Target users using scopes (like announcements). For a single user, search by name/email.
        Manual user_id also works.
      </div>

      <div class="row2">
        <div>
          <label>Audience</label>
          <select id="cAudience">
            <option value="single" selected>Single user</option>
            <option value="all_active">All active users</option>
            <option value="program">Program</option>
            <option value="course">Course (entitlement)</option>
            <option value="product">Product</option>
            <option value="kind">Subscription kind</option>
            <option value="cohort">Cohort</option>
            <option value="level">Level</option>
          </select>
        </div>
        <div>
          <label>Thread context</label>
          <select id="cContext">
            <option value="general" selected>general</option>
            <option value="course">course</option>
          </select>
        </div>
      </div>

      <div class="toggleRow">
        <input type="checkbox" id="cIncludeInactive" />
        <label class="tlabel" for="cIncludeInactive">Include inactive users</label>
        <span class="tsub">Admin only</span>
      </div>

      <div id="cCourseWrap" style="display:none;">
        <label>course_id (required for course context)</label>
        <input id="cCourseId" list="dlCCourseIds" placeholder="e.g., RN_MED" />
        <datalist id="dlCCourseIds"></datalist>
        <div class="help">This sets which thread it lands in (course thread). Not the scope filter.</div>
      </div>

      <div id="cSingleWrap">
        <label>Search user (name/email/user_id)</label>
        <input id="cUserSearch" placeholder="Type then Search…" />
        <div style="display:flex;gap:10px;margin-top:8px;flex-wrap:wrap;">
          <button class="btn" id="btnUserSearch" type="button">Search</button>
          <span class="pill" id="pickedUserPill" style="display:none;"></span>
        </div>
        <div id="userResults" class="results" style="display:none;margin-top:10px;"></div>
        <div class="help" style="margin-top:8px;">
          If search fails, paste user_id below.
        </div>
        <label style="margin-top:8px;">user_id (manual fallback)</label>
        <input id="cUserIdManual" placeholder="USR_..." />
      </div>

      <div id="cScopeWrap" style="display:none;">
        <label>Scope values (comma-separated)</label>
        <input id="cScopeValues" list="dlCScopeValues" placeholder="Start typing… (comma-separated)" />
        <datalist id="dlCScopeValues"></datalist>
        <div id="cScopeSug" class="sugBox" style="display:none;"></div>
        <div class="help" id="cScopeHelp" style="margin-top:6px;"></div>
      </div>

      <div class="row2">
        <div>
          <label>Subject (optional)</label>
          <input id="cSubject" placeholder="Short title (optional)" />
        </div>
        <div>
          <label>Ref text (optional)</label>
          <input id="cRefText" placeholder="Optional reference" />
        </div>
      </div>

      <div>
        <label>Message</label>
        <textarea id="cBody" placeholder="Type your message…"></textarea>
      </div>

      <div id="composeErr" class="err" style="display:none;"></div>
      <div class="help" id="composeHint">
        Tip: If sending to multiple courses, do one course batch at a time (course context), or use general context.
      </div>
    </div>

    <div class="modalFoot">
      <button class="btn" id="btnComposeCancelDesk" type="button">Cancel</button>
      <button class="btn primary" id="btnComposeSendDesk" type="button">Send</button>
    </div>
  </div>
</div>

<div class="wrap">

  <!-- Topbar -->
  <div class="topbar">
    <div class="title">Admin Inbox</div>
    <div class="top-actions">
      <span class="pill" id="qaStatus"><span class="spin"></span> Loading…</span>
      <a class="btn" id="btnBack" href="/p/dashboard_23.html">← Dashboard</a>
      <button class="btn" id="btnNew" type="button">New message</button>
      <button class="btn primary" id="btnRefresh" type="button">Refresh</button>
    </div>
  </div>

  <!-- TOP Filters -->
  <div class="filtersBar">
    <div class="filtersRow">
      <div class="f">
        <label>Status</label>
        <select id="fStatus">
          <option value="">All</option>
          <option value="OPEN" selected>OPEN</option>
          <option value="CLOSED">CLOSED</option>
        </select>
      </div>

      <div class="f">
        <label>Unread only</label>
        <select id="fUnread">
          <option value="">No</option>
          <option value="true">Yes</option>
        </select>
      </div>

      <div class="f">
        <label>Context</label>
        <select id="fContext">
          <option value="">All</option>
          <option value="general">general</option>
          <option value="course">course</option>
          <option value="question">question</option>
        </select>
      </div>

      <div class="f">
        <label>Limit</label>
        <select id="fLimit">
          <option value="40">40</option>
          <option value="80" selected>80</option>
          <option value="150">150</option>
        </select>
      </div>

      <div class="filtersActions">
        <button class="btn" id="btnClearFilters" type="button">Clear</button>
        <button class="btn primary" id="btnApplyFilters" type="button">Apply</button>
      </div>
    </div>

    <div class="filtersRow">
      <div class="f grow">
        <label>Search (owner, user_id, course, question_id, thread_id, ref_text)</label>
        <input id="fQuery" placeholder="Type and press Enter…" />
      </div>
    </div>

    <div class="tinyhint">Tip: keep replies short, clear, and action-based.</div>
  </div>

  <!-- Main Grid -->
  <div class="grid">

    <!-- Left: Threads -->
    <div class="card threads-card">
      <div class="listHead">
        <div>
          <div style="font-weight:900;">Threads</div>
          <div class="sub" id="threadsSub">—</div>
        </div>
      </div>

      <div id="threadsErr" style="display:none;" class="err"></div>
      <div class="threads" id="threads"></div>
    </div>

    <!-- Right: Chat -->
    <div class="card chat-card">
      <div class="chatHead">
        <div class="chatTitle">
          <span id="chatLabel">Select a thread</span>
          <span class="dim" id="chatSub"></span>
        </div>

        <div style="display:flex;gap:10px;align-items:center;">
          <button class="btn danger" id="btnClose" type="button" style="display:none;">Close</button>
          <button class="btn" id="btnReopen" type="button" style="display:none;">Reopen</button>
        </div>
      </div>

      <div id="chatErr" style="display:none;" class="err"></div>
      <div id="threadBanner" class="banner"></div>

      <div class="chat" id="chat">
        <div id="refBox" class="banner info" style="display:none;"></div>
        <div id="refHelp" class="banner" style="display:none;"></div>

        <div id="chatList">
          <div class="hint">Pick a thread to view messages.</div>
        </div>
      </div>

      <div class="composer">
        <textarea id="msgBox" placeholder="Reply as admin… (Ctrl+Enter to send)"></textarea>
        <button class="btn primary" id="btnSend" type="button" disabled>Send</button>
      </div>
    </div>

  </div>
</div>

<script>
/* ===========================
   CONFIG
=========================== */
const QA = {
  MSG_URL: "https://script.google.com/macros/s/AKfycbyyPv8GxEZ4trRpHFVG1IzctDn_1utELw62WBqbJVGmHdRH0PLI5h1jsROsRnA0VGt4/exec",
  TOKEN_KEY: "qa_token",
  LOGIN_URL: "/p/login_23.html"
};

/* ===========================
   Helpers
=========================== */
function $(id){ return document.getElementById(id); }
function token(){ return localStorage.getItem(QA.TOKEN_KEY) || ""; }

function setGlobalLoader(show, text = "Loading...") {
  const loader = $("globalLoader");
  const txt = $("loaderText");
  if(txt) txt.textContent = text;
