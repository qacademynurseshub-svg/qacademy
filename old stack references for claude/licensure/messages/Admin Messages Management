/* ===== Fix C helpers: comma-token aware suggestions ===== */
function getLastTokenFromCSVInput(raw){
  const s = String(raw || "");
  const parts = s.split(",");
  const last = parts.length ? parts[parts.length - 1] : "";
  return last.trim();
}

function replaceLastTokenInCSVInput(raw, newToken){
  const s = String(raw || "");
  const parts = s.split(",");
  if(!parts.length) return newToken;

  parts[parts.length - 1] = " " + String(newToken || "").trim();
  const joined = parts.map((p,i)=> (i===0 ? p.trim() : p.trim())).join(", ");
  return joined.replace(/\s+,/g, ",");
}

