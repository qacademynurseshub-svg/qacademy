function renderThreads(){
  const box = $("threads");
  box.innerHTML = "";

  const list = STATE.threads || [];
  $("threadsSub").textContent = list.length ? (list.length + " loaded") : "No threads";

  if(!list.length){
    box.innerHTML = '<div class="hint">No threads match your filters.</div>';
    return;
  }

  list.forEach(t => {
    const tid = t.thread_id;
    const isActive = tid === STATE.activeThreadId;

    const ctx = (t.context_type || "general").toUpperCase();
    const chips = [];

    // HUMAN: Owner label (fallback to user_id)
    const oLabel = ownerLabel(t);
    if(oLabel) chips.push(`<span class="chip warn">${esc(oLabel)}</span>`);

    // HUMAN: Course title (course_id) if present
    const cLabel = courseLabel(t);
    if(cLabel) chips.push(`<span class="chip brand">${esc(cLabel)}</span>`);

    // Keep technical breadcrumbs as small chips (optional)
    if(t.question_id) chips.push(`<span class="chip">Q: ${esc(t.question_id)}</span>`);
    if(t.quiz_id) chips.push(`<span class="chip">quiz</span>`);
    if(t.attempt_id) chips.push(`<span class="chip">attempt</span>`);

    const st = (t.status ? String(t.status) : "").toUpperCase();
    if(st){
      chips.push(`<span class="chip ${st==="CLOSED" ? "status-closed":"status-open"}">${esc(st)}</span>`);
    }

    const row = document.createElement("div");
    row.className = "trow" + (isActive ? " active" : "");
    row.innerHTML = `
      <span class="dot ${t.unread ? "unread":""}"></span>
      <div class="tmeta">
        <div class="tline1">
          <div class="tctx">${esc(ctx)} • ${esc(t.thread_id)}</div>
          <div class="twhen">${esc(fmtWhen(t.last_message_at))}</div>
        </div>
        <div class="chips">${chips.join("")}</div>
      </div>
    `;
    row.onclick = () => openThread(tid);
    box.appendChild(row);
  });
}

function renderChat(){
  const thread = STATE.activeThread;
  const messages = STATE.activeMessages || [];
  const chat = $("chat");
  const list = $("chatList");

  setBanner("", "");
  setRefBox("");
  setRefHelp("");
  if(list) list.innerHTML = "";

  if(!thread){
    $("chatLabel").textContent = "Select a thread";
    $("chatSub").textContent = "";
    if(list) list.innerHTML = '<div class="hint">Pick a thread to view messages.</div>';

    setComposerEnabled(false);
    $("btnClose").style.display = "none";
    $("btnReopen").style.display = "none";
    return;
  }

  const ctx = String(thread.context_type || "general").toLowerCase();
  $("chatLabel").textContent = String((thread.context_type || "general")).toUpperCase();

  const sub = [];
  const oLabel = ownerLabel(thread);
  if(oLabel) sub.push("Owner: " + oLabel);

  const cLabel = courseLabel(thread);
  if(cLabel) sub.push("Course: " + cLabel);

  if(thread.question_id) sub.push("Question: " + String(thread.question_id));
  $("chatSub").textContent = sub.join("\n");

  if(ctx === "question"){
    const rt = thread.ref_text ? String(thread.ref_text) : "";
    if(rt){
      setRefBox("Reference:\n" + rt);
      setRefHelp(
        "Reply with a fix or explanation.\n" +
        "Mention what part is wrong (stem or option) and what should change."
      );
    }
  }

  const status = String(thread.status || "OPEN").toUpperCase();
  $("btnClose").style.display  = (status === "OPEN") ? "inline-flex" : "none";
  $("btnReopen").style.display = (status !== "OPEN") ? "inline-flex" : "none";

  $("btnClose").disabled = STATE.busyLifecycle;
  $("btnReopen").disabled = STATE.busyLifecycle;

  if(isThreadClosed(thread)){
    setBanner("closed", "🔒 This thread is CLOSED. Reopen to reply.");
    setComposerEnabled(false);
  }else{
    setBanner("", "");
    setComposerEnabled(!STATE.busySend);
  }

  if(!messages.length){
    if(list) list.innerHTML = '<div class="hint">No messages yet.</div>';
    return;
  }

  messages.forEach(m => {
    const who = (m.sender_type || "").toLowerCase();
    const row = document.createElement("div");
    row.className = "msg " + (who === "admin" ? "admin" : "user");
    row.innerHTML = `
      <div class="bubble">
        ${esc(m.body_text)}
        <div class="meta">${esc((who||"").toUpperCase())} • ${esc(fmtWhen(m.created_at))}</div>
      </div>
    `;
    if(list) list.appendChild(row);
  });

  chat.scrollTop = chat.scrollHeight;
  recomputeSendEnabled();
}

/* ===========================
   Local thread patching
=========================== */
function patchThreadLocally(threadId, patch){
  const list = STATE.threads || [];
  for(let i=0;i<list.length;i++){
    if(list[i].thread_id === threadId){
      list[i] = Object.assign({}, list[i], patch);
      break;
    }
  }
}
function markThreadReadLocally(threadId){ patchThreadLocally(threadId, { unread:false }); }
function updateThreadLastSeenLocally(thread){
  if(!thread || !thread.thread_id) return;
  const lm = thread.last_message_at || thread.updated_at || "";
  const patch = { unread:false };
  if(lm) patch.last_message_at = lm;
  if(thread.status) patch.status = thread.status;
  patchThreadLocally(thread.thread_id, patch);
}

