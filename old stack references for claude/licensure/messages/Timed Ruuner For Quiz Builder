  function jumpToNextFlagged(){
    const pages = flaggedPageIndexes();
    if (!pages.length){ alert('No flagged questions.'); return; }
    const cur = PAGE;
    const next = pages.find(p => p > cur);
    PAGE = (next !== undefined) ? next : pages[0];
    viewMode = 'ALL';
    renderPage();
  }

  function jumpToPrevFlagged(){
    const pages = flaggedPageIndexes();
    if (!pages.length){ alert('No flagged questions.'); return; }
    const cur = PAGE;
    let target = null;
    for (let i=pages.length-1;i>=0;i--){
      if (pages[i] < cur){ target = pages[i]; break; }
    }
    PAGE = (target !== null && target !== undefined) ? target : pages[pages.length-1];
    viewMode = 'ALL';
    renderPage();
