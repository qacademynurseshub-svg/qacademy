function safeTrim(s, max){
  const t = String(s || "").replace(/\s+/g,' ').trim();
  if(!max) return t;
  return t.length > max ? (t.slice(0, max-1) + "…") : t;
}

function buildFriendlyRefText(r, globalIdx){
  const courseId = String((ATT && ATT.course_id) || "").trim();
  const courseLabel = COURSE_LABELS[courseId] || courseId || "Your course";
  const topic = safeTrim(r && r.topic, 240);
  const stem  = safeTrim(r && r.stem, 900);

  const opts = getShuffledOptionsFor(r);
  const lines = [];
  for (let j = 0; j < Math.min(4, opts.length); j++){
    const label = ['A','B','C','D'][j] || '?';
    const txt = safeTrim(opts[j] && opts[j].text, 360);
    lines.push(`${label}. ${txt || '(blank)'}`);
  }

  const chosenLabel = String(ANSW && ANSW[r.item_id] ? ANSW[r.item_id] : "").trim().toUpperCase();
  let chosenText = "";
  if (chosenLabel){
    const idx = ['A','B','C','D'].indexOf(chosenLabel);
    if (idx >= 0 && opts[idx]) chosenText = safeTrim(opts[idx].text, 360);
  }

  const ref = [];
  ref.push(`QAcademy - Question feedback (Timed quiz)`);
  ref.push(`Course: ${courseLabel}`);
  ref.push(`Question: ${globalIdx + 1} of ${ITEMS.length || "?"}`);
  if (topic) ref.push(`Topic: ${topic}`);
  ref.push("");
  ref.push("Question:");
  ref.push(stem || "(no question text)");
  ref.push("");
  ref.push("Options (as shown):");
  ref.push(...lines);
  ref.push("");
  if (chosenLabel){
    ref.push(`My answer: ${chosenLabel}${chosenText ? " - " + chosenText : ""}`);
  } else {
    ref.push(`My answer: (not answered yet)`);
  }
  return ref.join("\n");
}

function buildMessagesUrlForQuestion(r, globalIdx){
  const courseId  = String((ATT && ATT.course_id) || "").trim();
  const attemptId = String((ATT && ATT.attempt_id) || "").trim();
  const quizId    = String((ATT && (ATT.quiz_id || ATT.base_quiz_id || ATT.fixed_quiz_id)) || "").trim();
  const qid       = String((r && r.item_id) || "").trim();

  // Friendly ref_text (no technical IDs inside)
  const refText = buildFriendlyRefText(r, globalIdx);

  const p = new URLSearchParams();
  p.set("context_type", "question");
  if (courseId)  p.set("course_id", courseId);
  if (attemptId) p.set("attempt_id", attemptId); // kept for backend linkage (not shown in ref_text)
  if (quizId)    p.set("quiz_id", quizId);       // kept for backend linkage (not shown in ref_text)
  if (qid)       p.set("question_id", qid);      // kept for backend linkage (not shown in ref_text)
  p.set("ref_text", refText);

  return MESSAGES_PAGE_URL + "?" + p.toString();
}

function openReportQuestion(r, globalIdx){
