  function seedFrom(str){ let s=0; for(let i=0;i<str.length;i++) s = (s*31 + str.charCodeAt(i)) >>> 0; return s>>>0; }
  function rand(so){ so.seed ^= so.seed << 13; so.seed >>>= 0; so.seed ^= so.seed >> 17; so.seed >>>= 0; so.seed ^= so.seed << 5; so.seed >>>= 0; return (so.seed>>>0)/0xFFFFFFFF; }
  function shuffleDet(arr, key){
    const a = arr.slice(); const so = { seed: seedFrom(key) };
    for (let i=a.length-1;i>0;i--){ const j = Math.floor(rand(so)*(i+1)); [a[i],a[j]] = [a[j],a[i]]; }
    return a;
  }
  function displayLabel(i){ return ['A','B','C','D'][i] || '?'; }

  function getShuffledOptionsFor(r){
    const cached = SHUF.get(r.item_id);
    if (cached) return cached;

    const raw = [
      { id:'A', text:r.option_a, fb:r.fb_a, isCorrect: (String(r.correct||'').trim().toUpperCase()==='A') },
      { id:'B', text:r.option_b, fb:r.fb_b, isCorrect: (String(r.correct||'').trim().toUpperCase()==='B') },
      { id:'C', text:r.option_c, fb:r.fb_c, isCorrect: (String(r.correct||'').trim().toUpperCase()==='C') },
      { id:'D', text:r.option_d, fb:r.fb_d, isCorrect: (String(r.correct||'').trim().toUpperCase()==='D') }
    ].filter(o => (String(o.text||'').trim().length>0));

    const correctCount = raw.reduce((acc,o)=> acc + (o.isCorrect?1:0), 0);
    let arr = raw;
    if (SHUFFLE_OPTIONS && correctCount===1 && raw.length>1){
      arr = shuffleDet(raw, String(ATT.attempt_id||'') + '|' + String(r.item_id||''));
    }

    SHUF.set(r.item_id, arr);
    return arr;
  }

