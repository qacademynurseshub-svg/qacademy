      }
    }
    return "";
  }

  async function verifyToken(){
    const token = localStorage.getItem(TOKEN_KEY);
    if(!token){
      go("/p/" + LOGIN_SLUG + ".html");
      return null;
    }
    try{
      const body = new URLSearchParams({ action:"verify", token });
      const res  = await fetch(AUTH_WEB_APP_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body
      });
      if(!res.ok) throw new Error("Verify HTTP " + res.status);
      const payload = await res.json();
      if(!payload || !payload.ok){
        localStorage.removeItem(TOKEN_KEY);
        AUTH = null;
        ALLOWED_COURSE_IDS = [];
        go("/p/" + LOGIN_SLUG + ".html");
        return null;
      }

      // Save auth payload
      AUTH = payload;

      // Guard v3-style: derive active course_ids
      const courses = Array.isArray(payload.courses) ? payload.courses : [];
      const active  = courses.filter(c => String(c.status || '').toLowerCase() === 'active');
      ALLOWED_COURSE_IDS = active
        .map(c => (c.course_id || '').trim())
        .filter(Boolean);

      // Store user_id locally for later cross-checks
      const uid = extractUserId(payload);
      if (uid){
        try{ localStorage.setItem(USER_ID_KEY, uid); }catch(_){}
      }

      // Show "Signed in as" on top card
      if (el.userLine){
        const niceName = extractUserName(payload);
        if (niceName){
          el.userLine.textContent = "Signed in as: " + niceName;
        } else if (uid){
          el.userLine.textContent = "Signed in as: " + uid;
        }
      }

      return payload;
    }catch(err){
      console.error("Timed runner guard verify failed:", err);
      localStorage.removeItem(TOKEN_KEY);
      AUTH = null;
      ALLOWED_COURSE_IDS = [];
      go("/p/" + LOGIN_SLUG + ".html");
      return null;
    }
  }


