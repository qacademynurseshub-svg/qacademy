<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Timed Runner</title>
<style>
  :root{
    --brand:#0b7a75; --muted:#859998; --ink:#1f2a28; --bg:#f6f8f7; --card:#ffffff; --soft:rgba(0,0,0,.06);
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:system-ui,Segoe UI,Roboto,sans-serif}
  .wrap{max-width:920px;margin:24px auto;padding:0 14px}
  .card{background:var(--card);border:1px solid var(--soft);border-radius:16px;box-shadow:0 10px 24px rgba(0,0,0,.06);padding:16px;margin-bottom:14px}
  h1{margin:0 0 6px;font-size:22px;color:#0b7a75;font-weight:800;letter-spacing:.2px}
  .sub{color:#576663;font-size:13px;margin-bottom:10px}
  .bar{display:flex;gap:10px;align-items:center;justify-content:space-between;margin:6px 0 8px;flex-wrap:wrap}
  .pill{padding:6px 10px;border-radius:999px;background:#eef3f2;color:#25413d;border:1px solid #dbe4e2;font-size:12px}
  .pill.timer{background:#fff7e6;border-color:#f3d9a5;color:#6a4a0a}

  /* Slim sticky header bar (timer + progress + view/flag controls) */
  #headerCard{
    position:sticky;
    top:0;
    z-index:30;
    background:rgba(255,255,255,.97);
    backdrop-filter:blur(8px);
    border-bottom:1px solid #dbe4e2;
    border-radius:0 0 16px 16px;
    box-shadow:0 6px 18px rgba(0,0,0,.08);
    padding:8px 12px;
    margin-bottom:10px;
  }

  .headerRow{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    flex-wrap:wrap;
  }
  .headerRow-top{
    margin-bottom:4px;
  }
  .headerRow-bottom{
    margin-top:2px;
  }
  .header-progress{
    flex:1;
    min-width:140px;
  }

  .progress{
    position:relative;
    height:10px;
    background:#e6eceb;
    border-radius:999px;
    overflow:hidden;
    border:1px solid #cfe0dd;
    margin-top:4px;
  }
  .progress > div{
    position:absolute;
    left:0;top:0;height:100%;width:0%;
    background:repeating-linear-gradient(45deg, #0b7a75, #0b7a75 10px, #0a6a66 10px, #0a6a66 20px);
    box-shadow:inset 0 0 6px rgba(0,0,0,.15);
    background-size:40px 40px;
    animation:qaStripes 1.2s linear infinite;
  }
  .progLabel{
    position:absolute;
    inset:0;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:10px;
    font-weight:700;
    color:#0b7a75;
    mix-blend-mode:multiply;
    pointer-events:none;
  }
  @keyframes qaStripes{from{background-position:0 0;}to{background-position:40px 0;}}

  .view-toggle{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    align-items:center;
  }
  .flag-nav{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    align-items:center;
    justify-content:flex-end;
  }
  .view-label,
  .flag-label{
    font-size:11px;
    color:#4b5a58;
  }

  /* NEW: feedback toggle group */
  .feedback-toggle{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    align-items:center;
  }
  .fb-btn.active{
    background:#0b7a75;
    color:#ffffff;
  }

  .btn{background:#0b7a75;color:#fff;border:none;border-radius:12px;padding:10px 14px;font-weight:700;cursor:pointer}
  .btn.ghost{background:#e6f2f0;color:#0a6c67}
  .btn.softer{background:#eef3f2;color:#25413d}
  .btn.small{padding:6px 10px;font-size:12px;border-radius:10px}
  .btn:disabled{opacity:.6;cursor:not-allowed}

  .qstem{font-weight:700;margin:4px 0 0}
  .q-topic{
    font-size:11px;
    color:#6b7b78;
    margin-top:2px;
  }
  .opts{display:grid;gap:10px;margin-top:8px}
  .opt{border:1px solid #d8dfdd;border-radius:12px;background:#fff;padding:10px;display:grid;grid-template-columns:auto 1fr;gap:10px;align-items:flex-start;cursor:pointer}
  .opt input{margin-top:3px}
  .opt-title{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
  .chip{display:inline-block;border-radius:999px;padding:4px 8px;font-size:12px;border:1px solid #dbe4e2;background:#eef3f2;color:#25413d}
  .chip.correct{background:#e6f7f3;color:#0a6c67;border-color:#bfe7dd}
  .chip.your{background:#fff8e6;color:#6a4a0a;border-color:#f3d9a5}
  .opt-fb{grid-column:1 / -1;margin:4px 0 0 26px;padding:8px 10px;border-left:3px solid #e6efed;background:#f8fbfa;border-radius:8px;color:#3b4a47;font-size:13px;white-space:pre-wrap;display:none}

  /* Rationale box + image thumbnail */
  .rationale{
    margin-top:12px;
    padding:10px;
    border:1px dashed #d8dfdd;
    border-radius:10px;
    background:#fcfefd;
    color:#31403d;
    font-size:13px;
    white-space:pre-wrap;
    display:none;
  }
  .rationale-text{
    margin-bottom:6px;
  }
  .rationale-img-wrap{
    margin-top:4px;
    text-align:left;
  }
  .rationale-img-thumb{
    max-width:100%;
    max-height:180px;
    border-radius:10px;
    border:1px solid #d8dfdd;
    display:block;
    cursor:pointer;
  }
  .rationale-img-caption{
    font-size:11px;
    color:#4b5a58;
    margin-top:4px;
  }

  .nav{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}

  .status{font-family:ui-monospace,Consolas,monospace;background:#0a302e;color:#dbfff8;border-radius:12px;padding:12px;white-space:pre-wrap}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(44px,1fr));gap:8px}
  .cell{border:1px solid #d8dfdd;border-radius:10px;background:#fff;text-align:center;padding:8px 0;font-weight:700;cursor:pointer}
  .cell.active{border-color:#0b7a75;box-shadow:0 0 0 2px rgba(11,122,117,.15) inset}
  .cell.done{background:#f0f9f8}
  .score{font-size:18px;font-weight:900;color:#0b7a75}

  .q-block{
    padding:6px 0 30px 0;
    border-bottom:1px dashed #e0e6e5;
    margin-bottom:8px;
    position:relative;
  }
  .q-head{
    margin-bottom:4px;
  }
  .q-index{
    display:inline-block;
    margin-bottom:4px;
  }

  .q-footer{
    margin-top:6px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
  }
  .flag-btn{padding:6px 10px;font-size:12px;border-radius:10px}
  /* Report button (safe add-on) */
.report-btn{padding:6px 10px;font-size:12px;border-radius:10px}
.report-btn::after{content:"";} /* keeps layout stable */


  .watermark{
    font-size:11px;
    font-weight:700;
    color:#0b7a75;
    opacity:.75;
    border-radius:999px;
    border:1px solid #e6eceb;
    padding:4px 8px;
    background:rgba(255,255,255,.9);
  }

  .pagebar{display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:8px;flex-wrap:wrap}

  .fab-grid{
    position:fixed;
    right:16px;
    bottom:16px;
    z-index:40;
    box-shadow:0 10px 24px rgba(0,0,0,.18);
    border-radius:999px;
  }

  /* Floating overlays (grid, exit, summary, image) */
  .grid-overlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.35);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:60;
  }
  .grid-panel{
    width:100%;
    max-width:360px;
    max-height:70vh;
    background:#fff;
    border-radius:14px;
    box-shadow:0 12px 28px rgba(0,0,0,.28);
    padding:10px 12px;
    overflow-y:auto;
  }
  .grid-header{
    position:sticky;
    top:0;
    background:#fff;
    padding-bottom:6px;
    margin-bottom:6px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    font-size:14px;
    font-weight:700;
    color:#1f2a28;
    border-bottom:1px solid #e2e8f0;
  }
  .grid-body{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(36px,1fr));
    gap:6px;
  }
  .grid-btn{
    min-width:36px;
    height:36px;
    border-radius:8px;
    border:1px solid #e2e8f0;
    background:#fff;
    cursor:pointer;
    font-weight:700;
    font-size:13px;
  }
  .grid-btn.answered{background:#eef2ff;border-color:#c7d2fe;}
  .grid-btn.flagged{background:#fff7ed;border-color:#fdba74;}

  /* Image rationale overlay panel */
  .img-panel{
    width:100%;
    max-width:520px;
    max-height:80vh;
    background:#fff;
    border-radius:14px;
    box-shadow:0 12px 28px rgba(0,0,0,.28);
    padding:10px 12px;
    display:flex;
    flex-direction:column;
    gap:8px;
  }
  #imgOverlayImg{
    max-width:100%;
    max-height:70vh;
    border-radius:10px;
    object-fit:contain;
  }
/* Report overlay tweaks (uses existing overlay + panel styles) */
#reportOverlay .grid-panel{ max-width:420px; }

  /* === Loader overlay (Timed Runner) === */
  .qa-loader{
    position:fixed;
    inset:0;
    z-index:80;
    display:none;
    align-items:center;
    justify-content:center;
    pointer-events:auto;
  }
.qa-loader-backdrop{
  position:absolute;
  inset:0;
  background:rgba(15,23,42,0.35); /* matches Instant loader feel */
  backdrop-filter:blur(1px);
}

  .qa-loader-card{
    position:relative;
    z-index:1;
    min-width:220px;
    max-width:280px;
    padding:14px 16px;
    border-radius:14px;
    background:#ffffff;
    box-shadow:0 16px 40px rgba(0,0,0,0.28);
    display:flex;
    align-items:center;
    gap:12px;
  }
  .qa-loader-spinner{
    width:26px;
    height:26px;
    border-radius:999px;
    border:3px solid #e5f3f1;
    border-top-color:#0b7a75;
    animation:qa-spin 0.7s linear infinite;
  }
  .qa-loader-text{
    font-size:13px;
    color:#1f2a28;
  }
  @keyframes qa-spin{
    from{transform:rotate(0deg);}
    to{transform:rotate(360deg);}
  }

  @media (max-width:720px){
    .bar{flex-direction:column;align-items:flex-start}
    .headerRow{
      flex-direction:column;
      align-items:flex-start;
    }
  }

  @media (max-width:480px){
    #headerCard{
      padding:6px 10px;
      border-radius:0 0 12px 12px;
    }
    .headerRow{
      gap:6px;
    }
    .view-label,
    .flag-label{
      display:none;
    }
    .btn.small{
      padding:4px 8px;
      font-size:11px;
      border-radius:9px;
    }
    .view-toggle,
    .flag-nav,
    .feedback-toggle{
      gap:6px;
    }
  }
</style>
</head>
<body>
<div class="wrap">

  <!-- NON-STICKY INFO CARD (heading + meta) -->
  <div class="card" id="infoCard">
    <h1>Timed Quiz</h1>
    <div class="sub" id="userLine">Signed in as: —</div>
    <div class="sub">No feedback until submit • Auto-submit at 0</div>
    <div class="bar">
      <div class="pill" id="metaPill">Attempt: —</div>
      <div class="pill" id="countPill">0 / 0 answered</div>
    </div>
  </div>

  <!-- SLIM STICKY HEADER BAR (timer + progress + view/flag toggles) -->
  <div class="card" id="headerCard">
    <!-- Row 1: Timer + Progress -->
    <div class="headerRow headerRow-top">
      <div class="pill timer" id="timerPill">⏳ —:—</div>
      <div class="header-progress">
        <div class="progress">
          <div id="progFill"></div>
          <div id="progLabel" class="progLabel">0%</div>
        </div>
      </div>
    </div>

    <!-- Row 2: View + Feedback mode + Flag navigation -->
    <div class="headerRow headerRow-bottom">
      <div class="view-toggle">
        <span class="view-label">View:</span>
        <button class="btn softer small" id="viewAllBtn">All</button>
        <button class="btn softer small" id="viewFlaggedBtn">Flagged</button>
      </div>

      <!-- NEW: Feedback mode buttons (Inline / Standalone / Hide) -->
      <div class="feedback-toggle">
        <span class="view-label">Feedback:</span>
        <button class="btn softer small fb-btn" data-mode="inline">Inline</button>
        <button class="btn softer small fb-btn" data-mode="standalone">Standalone</button>
        <button class="btn softer small fb-btn" data-mode="hide">Hide</button>
      </div>

      <div class="flag-nav">
        <span class="flag-label">Flags:</span>
        <button class="btn softer small" id="prevFlagBtn" style="display:none;">Prev</button>
        <button class="btn softer small" id="nextFlagBtn" style="display:none;">Next</button>
      </div>
    </div>
  </div>

  <!-- PREFLIGHT CARD -->
  <div id="preCard" class="card" style="display:none;">
    <h2 style="margin:0 0 4px;font-size:18px;">Ready to start your timed quiz?</h2>
    <p class="sub" id="preSummary">Loading quiz details…</p>
    <div class="pill" id="preMetaPill">Mode: Timed • Questions: — • Time: —</div>

    <div style="margin-top:10px;font-size:13px;color:#3b4a47;">
      <p style="margin:0 0 4px;">How this quiz works:</p>
      <ul style="margin:4px 0 0 18px;padding:0;">
        <li>The timer starts when you click <strong>Start quiz</strong>.</li>
        <li>Questions are shown in pages. Use <strong>Prev</strong> and <strong>Next</strong> to move.</li>
        <li>You can change your answers any time before you submit or time runs out.</li>
        <li>When time reaches 0, the quiz is <strong>auto-submitted</strong>.</li>
        <li>Feedback and explanations appear only after submission, with a question grid for review.</li>
      </ul>
    </div>

    <p style="margin:8px 0 0;font-size:12px;color:#8f2727;">
      ⚠️ Closing or refreshing this page during the quiz may cause you to lose your answers.
    </p>

    <label style="display:flex;align-items:center;gap:6px;margin-top:10px;font-size:12px;color:#3b4a47;">
      <input type="checkbox" id="preSkip" />
      <span>Don’t show this again on this device</span>
    </label>

    <div class="nav" style="margin-top:10px;">
      <button class="btn ghost" id="preCancelBtn">Cancel</button>
      <button class="btn" id="preStartBtn">Start quiz</button>
    </div>
  </div>

  <!-- QUIZ CARD -->
  <div id="qCard" class="card" style="display:none;">
    <!-- Top pager -->
    <div class="pagebar" id="pagebarTop">
      <div class="pill" id="pagePill">Page 1 / 1</div>
      <div style="display:flex;gap:8px;">
        <button class="btn softer prevPage" id="prevPageBtn">◀ Prev Page</button>
        <button class="btn softer nextPage" id="nextPageBtn">Next Page ▶</button>
      </div>
    </div>

    <div id="qList"></div>

    <!-- Bottom pager -->
    <div class="pagebar" id="pagebarBottom">
      <div class="pill" id="pagePillBottom">Page 1 / 1</div>
      <div style="display:flex;gap:8px;">
        <button class="btn softer prevPage">◀ Prev Page</button>
        <button class="btn softer nextPage">Next Page ▶</button>
      </div>
    </div>

    <div class="nav">
      <button class="btn ghost" id="reviewBtn">Review</button>
      <button class="btn" id="submitBtn">Submit</button>
      <button class="btn ghost" id="exitBtn">Exit</button>
      <button class="btn ghost" id="restartBtn" style="display:none;">Restart</button>
    </div>
  </div>

  <!-- REVIEW CARD (stays at bottom as secondary access) -->
  <div id="reviewCard" class="card" style="display:none;">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
      <div class="score" id="scoreText">Score: —</div>
      <button class="btn softer" id="backToQuizBtn">Back to quiz</button>
    </div>

    <!-- Summary block -->
    <div id="summaryMeta" style="margin-top:8px;font-size:13px;color:#3b4a47;">
      <div id="summaryLine1">Course — • Timed exam mode</div>
      <div id="summaryLine2">Questions: — • Time allowed: — • Time used: —</div>
      <div id="summaryLine3" style="margin-top:4px;font-size:12px;opacity:.85;">Status: —</div>
    </div>

    <!-- Grading block -->
    <div id="gradeBlock" style="margin-top:10px;font-size:13px;color:#1f2a28;">
      <div id="gradeHeading" style="font-weight:700;"></div>
      <div id="gradeMessage" style="margin-top:2px;font-size:12px;color:#4b5a58;"></div>
    </div>

    <div class="grid" id="grid" style="margin-top:10px;"></div>
  </div>

  <!-- LOG CARD -->
  <div id="logCard" class="card">
    <div class="status" id="log">Loading attempt…</div>
  </div>
</div>

<!-- Floating grid button -->
<button id="fabGrid" class="btn softer fab-grid" style="display:none;">Questions ▢</button>

<!-- Floating grid overlay -->
<div id="gridOverlay" class="grid-overlay">
  <div class="grid-panel">
    <div class="grid-header">
      <span>Question grid</span>
      <button id="gridOverlayClose" class="btn softer small" type="button">Close</button>
    </div>
    <div id="gridOverlayBody" class="grid-body"></div>
  </div>
</div>

<!-- Exit confirmation overlay -->
<div id="exitOverlay" class="grid-overlay">
  <div class="grid-panel">
    <div class="grid-header">
      <span>Leave this quiz?</span>
    </div>
    <div style="font-size:13px;color:#3b4a47;margin-bottom:10px;">
      <p style="margin:0 0 6px;">
        If you leave now:
      </p>
      <ul style="margin:0 0 8px 18px;padding:0;">
        <li><strong>Save &amp; resume later</strong> will store your current answers as an in-progress attempt.</li>
        <li><strong>Submit &amp; exit</strong> will mark this attempt as completed and show your results.</li>
        <li><strong>Cancel</strong> will return you to the quiz and keep the timer running.</li>
      </ul>
    </div>
    <div class="nav" style="margin-top:4px;">
      <button class="btn ghost" id="exitCancelBtn" type="button">Cancel</button>
      <button class="btn softer" id="exitSaveBtn" type="button">Save &amp; resume later</button>
      <button class="btn" id="exitSubmitBtn" type="button">Submit &amp; exit</button>
    </div>
  </div>
</div>
<!-- Report confirmation overlay (opens Messages in a new tab) -->
<div id="reportOverlay" class="grid-overlay">
  <div class="grid-panel">
    <div class="grid-header">
      <span>Send Feedback On This Question?</span>
    </div>

    <div style="font-size:13px;color:#3b4a47;margin-bottom:10px;">
      <p style="margin:0 0 6px;">
        This will open Messages in a new tab. <strong>Your quiz stays open here and the timer continues.</strong>
      </p>
      <p style="margin:0;font-size:12px;opacity:.9;">
        Tip: After sending your message, switch back to this tab to continue.
      </p>
    </div>

    <label style="display:flex;align-items:center;gap:6px;margin-top:8px;font-size:12px;color:#3b4a47;">
      <input type="checkbox" id="reportSkip" />
      <span>Don’t show this again on this device</span>
    </label>

    <div class="nav" style="margin-top:10px;">
      <button class="btn ghost" id="reportCancelBtn" type="button">Cancel</button>
      <button class="btn" id="reportOpenBtn" type="button">Open Messages</button>
    </div>
  </div>
</div>

  
<!-- Summary overlay shown immediately after submit/auto-submit -->
<div id="summaryOverlay" class="grid-overlay">
  <div class="grid-panel">
    <div class="grid-header">
      <span>Quiz result</span>
    </div>
    <div style="font-size:13px;color:#3b4a47;margin-bottom:10px;">
      <div id="summaryOverlayScore" style="font-size:18px;font-weight:900;color:#0b7a75;margin-bottom:4px;">
        Score: —
      </div>
      <div id="summaryOverlayLine1">Course — • Timed exam mode</div>
      <div id="summaryOverlayLine2">Questions: — • Time allowed: — • Time used: —</div>
      <div id="summaryOverlayLine3" style="margin-top:4px;font-size:12px;opacity:.85;">Status: —</div>
      <div id="summaryOverlayGradeHeading" style="margin-top:6px;font-weight:700;"></div>
      <div id="summaryOverlayGradeMessage" style="margin-top:2px;font-size:12px;color:#4b5a58;"></div>
    </div>
    <div class="nav" style="margin-top:4px;">
      <button class="btn" id="summaryReviewBtn" type="button">Review questions</button>
    </div>
  </div>
</div>

<!-- Image rationale overlay -->
<div id="imgOverlay" class="grid-overlay">
  <div class="img-panel">
    <div class="grid-header" style="margin-bottom:4px;">
      <span>Rationale image</span>
      <button class="btn softer small" id="imgOverlayClose" type="button">Close</button>
    </div>
    <img id="imgOverlayImg" alt="Rationale illustration" />
  </div>
</div>

<!-- Loader overlay -->
<div id="qaLoader" class="qa-loader">
  <div class="qa-loader-backdrop"></div>
  <div class="qa-loader-card">
    <div class="qa-loader-spinner"></div>
    <div class="qa-loader-text" id="qaLoaderText">Loading…</div>
  </div>
</div>

<script>
(function(){
  // === CONFIG (AUTH + BUILDER) ===
  const AUTH_WEB_APP_URL       = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec"; // verify
  const BUILDER_WEB_APP_URL    = "https://script.google.com/macros/s/AKfycbx_CDJU5juEDxybplqBlYjJP0tAS52-HIOWE6is19Ub7NqhaV_16MnFmstJpWcdorHT/exec";  // attempt / attempts APIs

  const TOKEN_KEY              = "qa_token";
  const USER_ID_KEY            = "qa_user_id";   // must match guard
  const LOGIN_SLUG             = "login_23";
