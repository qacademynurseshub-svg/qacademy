  function recomputeAutosaveInterval(){
    if (!ITEMS || !ITEMS.length) return;
    // System is 1 min per question ⇒ totalMs = n * 60,000
    const totalMs = ITEMS.length * 60000;
    const raw = Math.floor(totalMs * 0.10);     // 10% of total quiz time
    AUTOSAVE_INTERVAL_MS = clamp(raw, 60000, 600000); // clamp between 1 and 10 minutes
