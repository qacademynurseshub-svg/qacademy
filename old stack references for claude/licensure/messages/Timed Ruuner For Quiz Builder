      out.push({
        item_id: r.item_id,
        chosen: chosenLabel,
        correct: correctLabel,
        is_correct: !!(chosenObj && chosenObj.isCorrect),
        flagged: !!FLAGS[r.item_id],
        time_spent_s: null
      });
    });
    return out;
  }

  // === NEW: HYDRATE FROM META ANSWERS (for Resume + Review) ===
  function hydrateFromMetaAnswers(metaAnswers){
    if (!Array.isArray(metaAnswers) || !metaAnswers.length) return;

    ANSW = {};
    FLAGS = {};

    metaAnswers.forEach(function(entry){
      const itemId = String(entry.item_id || "").trim();
      if (!itemId) return;

      const chosen = String(entry.chosen || "").trim().toUpperCase();
      if (['A','B','C','D'].indexOf(chosen) >= 0){
        ANSW[itemId] = chosen;
      }

      if (entry.flagged){
        FLAGS[itemId] = true;
      }
    });

    // Timer restore for timed attempts
    if (ATT && ATT.time_taken_s != null && ATT.time_taken_s !== ""){
      const used = parseInt(ATT.time_taken_s, 10);
      if (!isNaN(used) && used >= 0 && totalSec > 0){
        const remaining = totalSec - used;
        leftSec = remaining > 0 ? remaining : 1; // never less than 1s
      }
    }
  }

  // === attempt.update — partial save while in_progress ===
  async function saveInProgress(force){
    if (!ATT || !ATT.attempt_id) return;
    if (LOCKED) return; // don't update once completed

    const now = Date.now();
    if (!force && (now - LAST_SAVE_AT < MIN_SAVE_INTERVAL_MS)) return;
    LAST_SAVE_AT = now;

    const attemptId = ATT.attempt_id;
    const answersArray = buildAnswersPayload();
    const usedSec = totalSec > 0 ? Math.max(0, totalSec - leftSec) : 0;

    const payload = {
      attempt_id: attemptId,
      status: "in_progress",
      time_taken_s: usedSec,
      answers: answersArray
    };

    try{
      const body = new URLSearchParams();
      body.append("action", "attempt.update");
      body.append("payload", JSON.stringify(payload));

      const res = await fetch(BUILDER_WEB_APP_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body
      });

      let data = null;
      try{ data = await res.json(); }catch(_){}
      if (!data || data.ok === false){
        console.warn("attempt.update error:", data);
      } else {
        console.log("attempt.update ok");
      }
    }catch(err){
      console.error("attempt.update failed:", err);
    }
  }

  // === SEND attempt.finish TO BACKEND ===
  async function sendAttemptFinish(attemptId, scoreRaw, scoreTotal, timeTakenSec, answersArray, auto){
    if (!attemptId) return;
    if (FINISH_SENT) return;
    FINISH_SENT = true;

    const payload = {
      attempt_id: attemptId,
      status: "completed",
      completion_reason: auto ? "timeout" : "user",
      score_raw: scoreRaw,
      score_total: scoreTotal,
      time_taken_s: timeTakenSec,
      answers: answersArray || []
    };

    try{
      const body = new URLSearchParams();
      body.append("action", "attempt.finish");
      body.append("payload", JSON.stringify(payload));

      const res = await fetch(BUILDER_WEB_APP_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body
      });

      let data = null;
      try{ data = await res.json(); }catch(_){}

      if (!data || data.ok === false){
        console.warn("attempt.finish error:", data);
      } else {
        console.log("attempt.finish ok");
      }
    }catch(err){
      console.error("attempt.finish failed:", err);
    }
  }

  // === SUBMIT ===
  function submitQuiz(auto=false){
    if(LOCKED) return;

    if (!auto){
      const total = ITEMS.length;
      const answered = Object.keys(ANSW).length;
      if (answered < total){
        const okConfirm = confirm(`You have ${total-answered} unanswered question(s). Submit now?`);
        if (!okConfirm) return;
      }
    }

    qaShowLoader(auto ? "Time is up — submitting your answers..." : "Submitting your answers...");

    try{
      LOCKED = true;
      stopTimer();

      document.querySelectorAll('input[type="radio"]').forEach(x => x.disabled = true);

      let ok = 0;
      ITEMS.forEach(r=>{
        const opts = getShuffledOptionsFor(r);
        const chosenLabel = ANSW[r.item_id];
        if (!chosenLabel) return;
        const idx = ['A','B','C','D'].indexOf(chosenLabel);
        const chosenObj = opts[idx];
        if (chosenObj && chosenObj.isCorrect) ok++;
      });
      SCORE = ok;
      const total = ITEMS.length;

      // Timing: total allowed vs time actually used
      const allowedMin = totalSec > 0 ? Math.round(totalSec / 60) : (ATT && ATT.duration_min ? ATT.duration_min : '');
      const usedSec   = totalSec > 0 ? Math.max(0, totalSec - leftSec) : 0;
      const usedStr   = totalSec > 0 ? mmss(usedSec) : '—:—';
      const courseLabel = COURSE_LABELS[ATT && ATT.course_id] || (ATT && ATT.course_id) || '—';
      const statusText  = auto
        ? 'Completed : Auto-submitted when time reached 0'
        : 'Completed : Submitted before time expired';

      if (el.summaryLine1){
        el.summaryLine1.textContent = `${courseLabel} | Timed exam mode`;
      }
      if (el.summaryLine2){
        const allowedPart = allowedMin ? `Time allowed: ${allowedMin} min` : 'Time allowed: —';
        el.summaryLine2.textContent = `Questions: ${total} | ${allowedPart} | Time used: ${usedStr}`;
      }
      if (el.summaryLine3){
        el.summaryLine3.textContent = `Status: ${statusText}`;
      }

      // Build analytics payload and send attempt.finish in the background
      const attemptId = ATT && ATT.attempt_id ? ATT.attempt_id : (qs('attempt_id') || qs('quiz_id') || '');
      const answersArray = buildAnswersPayload();
      sendAttemptFinish(attemptId, ok, total, usedSec, answersArray, auto);

      // Lock to first page for review
      viewMode = 'ALL';
      PAGE = 0;
      renderPage();
      revealPageFeedback();

      el.scoreText.textContent = `Score: ${ok} / ${total} (${pct(ok,total)}%)`;
      updateGradeText(ok, total);
      openReviewGrid();
      el.restartBtn.style.display = 'inline-block';

      // Finally: show summary overlay so result is seen first
      openSummaryOverlay();
    } finally {
      qaHideLoader();
    }
  }

  // === RESTART ===
  function restart(){
    const ref = document.referrer || '';
    if (ref) { location.href = ref; }
    else { location.href = location.pathname; }
  }

  // === NAV + BUTTONS ===
  document.querySelectorAll('.prevPage').forEach(b=> b.addEventListener('click', ()=>{
    saveInProgress(false);
    PAGE--;
    renderPage();
  }));
  document.querySelectorAll('.nextPage').forEach(b=> b.addEventListener('click', ()=>{
    saveInProgress(false);
    PAGE++;
    renderPage();
  }));

  el.reviewBtn.addEventListener('click', openReviewGrid);
  el.backToQuizBtn.addEventListener('click', ()=>{ el.reviewCard.style.display='none'; });
  el.submitBtn.addEventListener('click', ()=> submitQuiz(false));
  el.restartBtn.addEventListener('click', restart);

  if (el.fabGrid){
    el.fabGrid.addEventListener('click', openOverlay);
  }
  if (el.gridOverlayClose){
    el.gridOverlayClose.addEventListener('click', closeOverlay);
  }

  if (el.viewAllBtn){
    el.viewAllBtn.addEventListener('click', ()=>{
      viewMode = 'ALL';
      PAGE = 0;
      renderPage();
      updateFlagNavVisibility();
    });
  }
  if (el.viewFlaggedBtn){
    el.viewFlaggedBtn.addEventListener('click', ()=>{
      viewMode = 'FLAGGED';
      PAGE = 0;
      renderPage();
      updateFlagNavVisibility();
    });
  }
  if (el.prevFlagBtn){
    el.prevFlagBtn.addEventListener('click', jumpToPrevFlagged);
  }
  if (el.nextFlagBtn){
    el.nextFlagBtn.addEventListener('click', jumpToNextFlagged);
  }

  // NEW: feedback buttons click = set specific mode
  if (el.fbButtons && el.fbButtons.length){
    el.fbButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = (btn.dataset.mode || 'inline').toLowerCase();
        saveFeedbackMode(mode);
      });
    });
  }

  // Exit button + overlay
  if (el.exitBtn){
    el.exitBtn.addEventListener('click', ()=>{
      // If already completed, just return to previous page / dashboard
      if (LOCKED){
        const ref = document.referrer || '';
        if (ref) location.href = ref;
        else go("/p/" + DASHBOARD_SLUG + ".html");
        return;
      }
      PENDING_NAV_HREF = null; // deliberate exit, not link navigation
      openExitOverlay();
    });
  }
  if (el.exitCancelBtn){
    el.exitCancelBtn.addEventListener('click', ()=>{
      closeExitOverlay();
    });
  }
  if (el.exitSaveBtn){
    el.exitSaveBtn.addEventListener('click', async ()=>{
      qaShowLoader("Saving your progress...");
      try{
        await saveInProgress(true);
      } finally {
        qaHideLoader();
      }
      const target = PENDING_NAV_HREF;
      closeExitOverlay();
      stopTimer();
      log("Progress saved as in-progress. You can resume this attempt from your history when available.");
      if (target){
        location.href = target;
      } else {
        const ref = document.referrer || '';
        if (ref) location.href = ref;
        else go("/p/" + DASHBOARD_SLUG + ".html");
      }
    });
  }
  if (el.exitSubmitBtn){
    el.exitSubmitBtn.addEventListener('click', ()=>{
      const target = PENDING_NAV_HREF;
      closeExitOverlay();
      submitQuiz(false);
      if (target){
        setTimeout(()=>{ location.href = target; }, 400);
      }
    });
  }

    // Report overlay events
  if (el.reportCancelBtn){
    el.reportCancelBtn.addEventListener('click', closeReportOverlay);
  }
  if (el.reportOpenBtn){
    el.reportOpenBtn.addEventListener('click', ()=>{
      const url = PENDING_REPORT_URL;
      const skip = !!(el.reportSkip && el.reportSkip.checked);

      if (skip) setSkipReportConfirm(true);

      closeReportOverlay();

      if (url){
        window.open(url, "_blank", "noopener,noreferrer");
      } else {
        alert("Could not open Messages.");
      }
    });
  }
  if (el.reportOverlay){
    el.reportOverlay.addEventListener('click', function(e){
      if (e.target === el.reportOverlay) closeReportOverlay();
    });
  }

  // Summary overlay events
  if (el.summaryReviewBtn){
    el.summaryReviewBtn.addEventListener('click', ()=>{
      closeSummaryOverlay();
    });
  }
  if (el.summaryOverlay){
    el.summaryOverlay.addEventListener('click', function(e){
      if (e.target === el.summaryOverlay) closeSummaryOverlay();
    });
  }

  // Image overlay events
  if (el.imgOverlayClose){
    el.imgOverlayClose.addEventListener('click', closeImgOverlay);
  }
  if (el.imgOverlay){
    el.imgOverlay.addEventListener('click', function(e){
      if (e.target === el.imgOverlay) closeImgOverlay();
    });
  }

  el.preStartBtn.addEventListener('click', ()=>{
    if (el.preSkip && el.preSkip.checked) setSkipPreflight(true);
    startQuiz();
  });
  el.preCancelBtn.addEventListener('click', ()=>{
    const ref = document.referrer || '';
    if (ref) { location.href = ref; }
    else { location.href = location.pathname; }
  });

  // === LINK-GUARD: intercept in-site navigation while quiz is active ===
  document.addEventListener('click', function(e){
    if (!ATT || !ITEMS.length || LOCKED) return;
    if (!el.qCard || el.qCard.style.display === 'none') return; // quiz not started yet

    const target = e.target;
    if (!target || typeof target.closest !== 'function') return;

    // Ignore clicks inside overlays (they have their own handlers)
    if (el.exitOverlay && el.exitOverlay.contains(target)) return;
    if (el.gridOverlay && el.gridOverlay.contains(target)) return;
    if (el.reviewCard && el.reviewCard.contains(target)) return;
    if (el.imgOverlay && el.imgOverlay.contains(target)) return;
    if (el.summaryOverlay && el.summaryOverlay.contains(target)) return;
    if (el.reportOverlay && el.reportOverlay.contains(target)) return;


    const link = target.closest('a');
    if (!link) return;

    const href = link.getAttribute('href') || '';
    if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;

    // Allow new-tab / background-tab behaviour
    if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;

    e.preventDefault();
    PENDING_NAV_HREF = link.href;
    openExitOverlay();
  });

  // === beforeunload: browser back / close / full reload ===
  window.addEventListener('beforeunload', function(e){
    if (!ATT || !ITEMS.length || LOCKED) return;
    if (leftSec <= 0) return;
    e.preventDefault();
    e.returnValue = '';
  });

  // === INIT: Guard first, then attempt ===
  (async function initGuarded(){
    // Load feedback mode (URL param > localStorage) and update UI
    feedbackMode = loadFeedbackMode();
    updateFeedbackUI();

    qaShowLoader("Checking access...");
    log("Checking access...");
    AUTH = await verifyToken();
    if (!AUTH){
      qaHideLoader();
      return;
    }
    qaShowLoader("Loading quiz...");
    log("Access OK. Loading attempt...");
    await loadAttempt();
    qaHideLoader();
  })();

})();
</script>

