  // Mirror of the guard's extractUserId (fallback if needed)
  function extractUserId(payload){
    if (!payload || typeof payload !== "object") return "";

    var rawUser = payload.user || payload.account || payload.profile || null;

    var candidates = [
      payload.user_id,
      payload.username,
      payload.email,
      payload.id,
      rawUser && rawUser.user_id,
      rawUser && rawUser.id,
      rawUser && rawUser.username,
      rawUser && rawUser.email
    ];

    for (var i = 0; i < candidates.length; i++){
      var v = candidates[i];
      if (v !== undefined && v !== null){
        var s = String(v).trim();
        if (s) return s;
      }
    }
    return "";
  }

  // NEW: extract a friendly display name
  function extractUserName(payload){
    if (!payload || typeof payload !== "object") return "";

    var rawUser = payload.user || payload.account || payload.profile || null;

    var candidates = [
      payload.name,
      payload.full_name,
      payload.display_name,
      rawUser && (rawUser.name || rawUser.full_name || rawUser.display_name),
      payload.email,
      rawUser && rawUser.email
    ];

