  // === LOAD ATTEMPT (GUARDED) ===
  async function loadAttempt(){
    const quiz_id    = qs('quiz_id') || '';
    const attempt_id = qs('attempt_id') || quiz_id;

    if (!attempt_id){
      log("Missing attempt_id (or quiz_id) in URL.");
      return;
    }

    // Include token + mode so backend can enforce ownership + mode
    const token = (function(){
      try {
        return localStorage.getItem(TOKEN_KEY) || "";
      } catch(_){
        return "";
      }
    })();

    const params = new URLSearchParams();
    params.set("action", "attempt");
    params.set("attempt_id", attempt_id);
    if (token){
      params.set("token", token);
    }
    // Timed Runner always expects timed attempts
    params.set("mode", "timed");

    const url = `${BUILDER_WEB_APP_URL}?${params.toString()}`;

    try{
      const res = await fetch(url);
      let data;
      try {
        data = await res.json();
      } catch(err) {
        log("Server returned invalid response.");
        return;
      }

      // Backend explicit error (e.g. wrong user, wrong mode, not found)
      if (data && data.ok === false){
        const msg = data.error || "Backend rejected this attempt.";
        log(msg);
        return;
      }

      // Missing or malformed items array
      if (!data || !Array.isArray(data.items)){
        const msg = data && data.error ? data.error : "Attempt could not be loaded.";
        log(msg);
        return;
      }

      // Empty after hydration / security block
      if (!data.items.length){
        const msg = data && data.error ? data.error : "No items returned for this attempt.";
        log(msg);
        return;
      }

      ATT   = data.meta || {};
      ITEMS = data.items;
      ANSW  = {};
      FLAGS = {};
      FINISH_SENT = false;

      // Compute autosave interval now that ITEMS are known
      recomputeAutosaveInterval();

      // Course-level access check (Guard v3 style)
      const cid = String(ATT.course_id || "").toUpperCase();
      if (cid){
        let allowedSet = null;

        if (ALLOWED_COURSE_IDS && ALLOWED_COURSE_IDS.length){
          allowedSet = new Set(ALLOWED_COURSE_IDS.map(id => String(id).toUpperCase()));
        } else if (AUTH && Array.isArray(AUTH.course_ids)){
          // Fallback for older payloads that return course_ids only
          allowedSet = new Set(AUTH.course_ids.map(id => String(id).toUpperCase()));
        }

        if (allowedSet && !allowedSet.has(cid)){
          log("You are not enrolled for this course. Redirecting to dashboard…");
          setTimeout(()=>{ go("/p/" + DASHBOARD_SLUG + ".html"); }, 1200);
          return;
        }
      }

      // Attempt-level security (user_id match)
      const attUserIdRaw = (ATT.user_id || "").toString().trim();
      const localUidRaw  = getLocalUserId().trim();
      const authUidRaw   = AUTH ? extractUserId(AUTH).trim() : "";
      const currentUid   = localUidRaw || authUidRaw || "";

      if (attUserIdRaw && currentUid && attUserIdRaw !== currentUid){
        log("This quiz attempt is not linked to your account. Please start a new quiz from the course page.");
        setTimeout(()=>{ go("/p/" + DASHBOARD_SLUG + ".html"); }, 1800);
        return;
      }

      // Mode must be 'timed' for the timed runner
      const attMode = String(ATT.mode || "").toLowerCase();
      if (attMode && attMode !== "timed"){
        log("This attempt was created for a different mode (instant). Please open it with the Instant Runner.");
        return;
      }

      // ---- Timer + meta setup ----
      const urlMins   = parseInt(qs('mins') || '', 10);
      const metaMins  = parseInt(ATT.duration_min || ATT.duration || '', 10);
      const nFallback = parseInt(ATT.n || ITEMS.length || 0, 10);
      const mins = (Number.isFinite(urlMins) && urlMins>0) ? urlMins
                 : (Number.isFinite(metaMins) && metaMins>0) ? metaMins
                 : (Number.isFinite(nFallback) && nFallback>0) ? nFallback
                 : 30;

      totalSec   = mins * 60;
      PAGE       = 0;
      viewMode   = 'ALL';

      const total = ITEMS.length;
      const courseLabel = COURSE_LABELS[ATT.course_id] || ATT.course_id || '—';
      el.metaPill.textContent = `${courseLabel} | Attempt: ${ATT.attempt_id || attempt_id} | ${total} item${total===1?'':''} | ${mins} min`;

      const metaStatus   = String(ATT.status || "").toLowerCase();
      const savedAnswers = Array.isArray(ATT.answers) ? ATT.answers : [];
      const isCompleted  = (metaStatus === "completed");
      const isResume     = (metaStatus === "in_progress" && savedAnswers.length > 0);

      // --- REVIEW MODE (completed attempt, read-only, full feedback) ---
      if (isCompleted){
        hydrateFromMetaAnswers(savedAnswers);

        LOCKED = true;
        stopTimer();

        // Timer pill as review indicator
        el.timerPill.textContent = "Review mode (completed)";
        el.timerPill.style.background = "#eef3f2";
        el.timerPill.style.borderColor = "#dbe4e2";
        el.timerPill.style.color = "#25413d";

        // Summary lines based on meta
        const usedSecMeta = (ATT.time_taken_s != null && ATT.time_taken_s !== "")
          ? Math.max(0, parseInt(ATT.time_taken_s, 10) || 0)
          : 0;
        const usedStr = usedSecMeta ? mmss(usedSecMeta) : "—:—";
        const compReason = String(ATT.completion_reason || "").toLowerCase();
        const statusText = (compReason === "timeout")
          ? "Completed : Auto-submitted when time reached 0"
          : "Completed : Submitted before time expired";

        if (el.summaryLine1){
          el.summaryLine1.textContent = `${courseLabel} | Timed exam mode`;
        }
        if (el.summaryLine2){
          const allowedPart = mins ? `Time allowed: ${mins} min` : "Time allowed: —";
          el.summaryLine2.textContent = `Questions: ${total} | ${allowedPart} | Time used: ${usedStr}`;
        }
        if (el.summaryLine3){
          el.summaryLine3.textContent = `Status: ${statusText}`;
        }

        // Compute score from saved answers
        let okScore = 0;
        ITEMS.forEach(r => {
          const opts = getShuffledOptionsFor(r);
          const chosen = ANSW[r.item_id] || "";
          if (!chosen) return;
          const idx = ['A','B','C','D'].indexOf(chosen);
          const chosenObj = idx >= 0 ? opts[idx] : null;
          if (chosenObj && chosenObj.isCorrect) okScore++;
        });
        SCORE = okScore;
        if (el.scoreText){
          el.scoreText.textContent = `Score: ${okScore} / ${total} (${pct(okScore,total)}%)`;
        }
        updateGradeText(okScore, total);

        // Show quiz and feedback in locked mode
        el.qCard.style.display = 'block';
        if (el.fabGrid) el.fabGrid.style.display = 'inline-flex';
        renderPage();
        revealPageFeedback();
        openReviewGrid();
        log("Review mode: completed timed attempt. Timer is off; answers and feedback are visible.");
        return;
      }

      // --- RESUME MODE (in_progress with saved answers) ---
      if (isResume){
        hydrateFromMetaAnswers(savedAnswers);

        el.preCard.style.display = 'none';
        el.qCard.style.display = 'block';
        if (el.fabGrid) el.fabGrid.style.display = 'inline-flex';

        PAGE = 0;
        viewMode = 'ALL';
        renderPage();
        renderProgress();

        const initialLeft = (leftSec && leftSec > 0) ? leftSec : totalSec;
        startTimer(initialLeft);
        startAutosaveLoop();
        log("Resuming your in-progress timed attempt. Timer continues from where you left off.");
        return;
      }

      // --- FRESH ATTEMPT ---
      if (shouldSkipPreflight()){
        el.qCard.style.display = 'block';
        if (el.fabGrid) el.fabGrid.style.display = 'inline-flex';
        renderPage();
        renderProgress();
        startTimer(totalSec);
        startAutosaveLoop();
        log("Timer started. Work through the questions and submit before time runs out.");
      } else {
        preparePreflight(mins);
      }
    }catch(err){
      log("Failed to load attempt: " + (err.message||String(err)));
    }
  }


