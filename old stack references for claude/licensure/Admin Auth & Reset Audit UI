<script>
(function(){
  'use strict';

  var DEFAULT_AUTH_URL = 'https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec';

  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};
  var AUTH_URL = cfg.AUTH_URL || DEFAULT_AUTH_URL;

  function setLoader(on){
    var el = document.getElementById('qaLoader');
    if(!el) return;
    el.style.display = on ? 'flex' : 'none';
  }

  function setGlobalError(msg){
    var box = document.getElementById('qaGlobalError');
    if(!box) return;
    if(msg){
      box.style.display = 'block';
      box.textContent = msg;
    } else {
      box.style.display = 'none';
      box.textContent = '';
    }
  }

  function setStatus(id, msg, bad){
    var el = document.getElementById(id);
    if(!el) return;
    if(!msg){
      el.innerHTML = '';
      return;
    }
    el.innerHTML = bad ? '<span class="qa-status-bad">' + msg + '</span>' : msg;
  }

  function getToken(){
    try{
      return localStorage.getItem('qa_token') || '';
    }catch(e){
      return '';
    }
  }

  function fmtLocal(ts){
    if(!ts) return '';
    var d = new Date(ts);
    if(isNaN(d.getTime())) return ts;
    return d.toLocaleString();
  }

  function truncateHash(h){
    if(!h) return '';
    h = String(h);
    if(h.length <= 10) return h;
    return h.slice(0,10) + '…';
  }

  function boolBadge(ok){
    if(ok){
      return '<span class="qa-badge qa-badge-ok">OK</span>';
    }
    return '<span class="qa-badge qa-badge-fail">Failed</span>';
  }

  function statusBadge(st){
    if(!st) return '';
    var up = String(st).toUpperCase();
    var cls = 'qa-badge qa-badge-pill';
    var txt = up;
    if(up === 'USED'){
      cls = 'qa-badge qa-badge-ok';
    } else if(up === 'EXPIRED' || up === 'FAILED'){
      cls = 'qa-badge qa-badge-fail';
    }
    return '<span class="' + cls + '">' + txt + '</span>';
  }

  function parseRangePreset(kind, val){
    var now = new Date();
    var since = new Date(now.getTime());
    if(val === '24h'){
      since = new Date(now.getTime() - 24*60*60*1000);
    } else if(val === '7d'){
      since = new Date(now.getTime() - 7*24*60*60*1000);
    } else if(val === '30d'){
      since = new Date(now.getTime() - 30*24*60*60*1000);
    } else {
      return null;
    }
    return { since: since, until: now };
  }

  function setDateTimeInput(el, date){
    if(!el) return;
    if(!date){
      el.value = '';
      return;
    }
    var pad = function(n){ return (n<10?'0':'') + n; };
    var y = date.getFullYear();
    var m = pad(date.getMonth()+1);
    var d = pad(date.getDate());
    var h = pad(date.getHours());
    var mi = pad(date.getMinutes());
    el.value = y + '-' + m + '-' + d + 'T' + h + ':' + mi;
  }

  function setDefaultAuthRange(){
    var range = parseRangePreset('auth', '24h');
    if(range){
      setDateTimeInput(document.getElementById('authSince'), range.since);
      setDateTimeInput(document.getElementById('authUntil'), range.until);
      var pills = document.querySelectorAll('[data-range-auth]');
      pills.forEach(function(p){
        p.classList.toggle('qa-pill-active', p.getAttribute('data-range-auth') === '24h');
      });
    }
  }

  function setDefaultResetRange(){
    var range = parseRangePreset('reset', '7d');
    if(range){
      setDateTimeInput(document.getElementById('resetSince'), range.since);
      setDateTimeInput(document.getElementById('resetUntil'), range.until);
      var pills = document.querySelectorAll('[data-range-reset]');
      pills.forEach(function(p){
        p.classList.toggle('qa-pill-active', p.getAttribute('data-range-reset') === '7d');
      });
    }
  }

  async function fetchAuthEvents(){
    setStatus('authStatus','');
    setGlobalError('');

    var token  = getToken();
    if(!token){
      setStatus('authStatus','No admin token found. Please sign in again.', true);
      return;
    }

    var email  = document.getElementById('authEmail').value.trim();
    var userId = document.getElementById('authUserId').value.trim();
    var kind   = document.getElementById('authKind').value.trim();
    var limit  = document.getElementById('authLimit').value.trim();
    var since  = document.getElementById('authSince').value;
    var until  = document.getElementById('authUntil').value;
    var onlyFailed = document.getElementById('authOnlyFailed').checked ? 'true' : '';

    if(!limit){ limit = '200'; }

    setLoader(true);
    try{
      var body = {
        action: 'admin_list_auth_events',
        token: token,
        filter_email: email,
        filter_user_id: userId,
        kind: kind,
        only_failed: onlyFailed,
        since_utc: since,
        until_utc: until,
        limit: limit
      };

      var res = await fetch(AUTH_URL, {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body: new URLSearchParams(body)
      });

      if(!res.ok){
        throw new Error('HTTP ' + res.status);
      }
      var data = await res.json();
      if(!data.ok){
        var msg = 'Error: ' + (data.error || 'unknown_error');
        setStatus('authStatus', msg, true);
        setLoader(false);
        return;
      }

      var events = data.events || [];
      renderAuthTable(events);
    }catch(err){
      console.error(err);
      setStatus('authStatus', 'Request failed — check console / network.', true);
    }finally{
      setLoader(false);
    }
  }

  function renderAuthTable(events){
    var tbody = document.getElementById('authTableBody');
    if(!tbody) return;
    tbody.innerHTML = '';

    if(!events.length){
      var tr = document.createElement('tr');
      var td = document.createElement('td');
      td.colSpan = 10;
      td.textContent = 'No events found for this filter.';
      tr.appendChild(td);
      tbody.appendChild(tr);
      document.getElementById('authMetaCounts').textContent = '0 events.';
      document.getElementById('authMetaHint').textContent = '';
      return;
    }

    var okCount = 0, failCount = 0;
    events.forEach(function(ev){
      if(ev.ok){ okCount++; } else { failCount++; }
      var tr = document.createElement('tr');

      var cTime = document.createElement('td');
      cTime.textContent = fmtLocal(ev.ts_utc);

      var cEmail = document.createElement('td');
      cEmail.className = 'qa-ellipsis';
      cEmail.title = ev.email || '';
      cEmail.textContent = ev.email || '';

      var cIdent = document.createElement('td');
      cIdent.className = 'qa-ellipsis qa-text-mono';
      cIdent.title = ev.identifier || '';
      cIdent.textContent = ev.identifier || '';

      var cUser = document.createElement('td');
      cUser.className = 'qa-ellipsis';
      cUser.title = ev.name || '';
      cUser.textContent = ev.name || '';

      var cProg = document.createElement('td');
      cProg.textContent = ev.program_id || '';

      var cRole = document.createElement('td');
      cRole.textContent = ev.role || '';

      var cKind = document.createElement('td');
      cKind.textContent = ev.kind || '';

      var cOk = document.createElement('td');
      cOk.innerHTML = boolBadge(!!ev.ok);

      var cErr = document.createElement('td');
      cErr.className = 'qa-text-mono qa-ellipsis';
      cErr.title = ev.error_code || '';
      cErr.textContent = ev.error_code || '';

      var cNote = document.createElement('td');
      cNote.className = 'qa-ellipsis';
      cNote.title = ev.note || '';
      cNote.textContent = ev.note || '';

      tr.appendChild(cTime);
      tr.appendChild(cEmail);
      tr.appendChild(cIdent);
      tr.appendChild(cUser);
      tr.appendChild(cProg);
      tr.appendChild(cRole);
      tr.appendChild(cKind);
      tr.appendChild(cOk);
      tr.appendChild(cErr);
      tr.appendChild(cNote);

      tbody.appendChild(tr);
    });

    document.getElementById('authMetaCounts').innerHTML =
      '<strong>' + events.length + '</strong> events &middot; ' +
      '<strong>' + okCount + '</strong> OK, ' +
      '<strong>' + failCount + '</strong> failed.';

    document.getElementById('authMetaHint').textContent =
      'Scroll to explore. Use filters above to narrow down users, kinds or time windows.';
  }

  async function fetchResetRequests(){
    setStatus('resetStatusBar','');
    setGlobalError('');

    var token = getToken();
    if(!token){
      setStatus('resetStatusBar','No admin token found. Please sign in again.', true);
      return;
    }

    var ident = document.getElementById('resetIdentifier').value.trim();
    var email = document.getElementById('resetEmail').value.trim();
    var status = document.getElementById('resetStatus').value.trim();
    var limit = document.getElementById('resetLimit').value.trim();
    var since = document.getElementById('resetSince').value;
    var until = document.getElementById('resetUntil').value;

    if(!limit){ limit = '200'; }

    setLoader(true);
    try{
      var body = {
        action: 'admin_list_reset_requests',
        token: token,
        filter_identifier: ident,
        filter_email: email,
        status: status,
        since_utc: since,
        until_utc: until,
        limit: limit
      };

      var res = await fetch(AUTH_URL, {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body: new URLSearchParams(body)
      });

      if(!res.ok){
        throw new Error('HTTP ' + res.status);
      }
      var data = await res.json();
      if(!data.ok){
        var msg = 'Error: ' + (data.error || 'unknown_error');
        setStatus('resetStatusBar', msg, true);
        setLoader(false);
        return;
      }

      var rows = data.requests || [];
      renderResetTable(rows);
    }catch(err){
      console.error(err);
      setStatus('resetStatusBar', 'Request failed — check console / network.', true);
    }finally{
      setLoader(false);
    }
  }

  function renderResetTable(rows){
    var tbody = document.getElementById('resetTableBody');
    if(!tbody) return;
    tbody.innerHTML = '';

    if(!rows.length){
      var tr = document.createElement('tr');
      var td = document.createElement('td');
      td.colSpan = 10;
      td.textContent = 'No reset requests found for this filter.';
      tr.appendChild(td);
      tbody.appendChild(tr);
      document.getElementById('resetMetaCounts').textContent = '0 requests.';
      document.getElementById('resetMetaHint').textContent = '';
      return;
    }

    var withToken = 0, usedCount = 0;
    rows.forEach(function(r){
      if(r.has_token){ withToken++; }
      if(r.used_utc){ usedCount++; }

      var tr = document.createElement('tr');

      var cReq = document.createElement('td');
      cReq.textContent = fmtLocal(r.requested_utc);

      var cEmail = document.createElement('td');
      cEmail.className = 'qa-ellipsis';
      cEmail.title = r.email || '';
      cEmail.textContent = r.email || '';

      var cId = document.createElement('td');
      cId.className = 'qa-ellipsis qa-text-mono';
      cId.title = r.identifier_raw || '';
      cId.textContent = r.identifier_raw || '';

      var cStatus = document.createElement('td');
      cStatus.innerHTML = statusBadge(r.status || '');

      var cHas = document.createElement('td');
      cHas.innerHTML = r.has_token ? '<span class="qa-badge qa-badge-pill">Yes</span>' : '<span class="qa-badge qa-badge-pill">No</span>';

      var cUsed = document.createElement('td');
      cUsed.textContent = fmtLocal(r.used_utc);

      var cLast = document.createElement('td');
      cLast.textContent = fmtLocal(r.last_check_utc);

      var cIp = document.createElement('td');
      cIp.className = 'qa-text-mono';
      cIp.title = r.ip_hash || '';
      cIp.textContent = truncateHash(r.ip_hash || '');

      var cUa = document.createElement('td');
      cUa.className = 'qa-text-mono';
      cUa.title = r.ua_hash || '';
      cUa.textContent = truncateHash(r.ua_hash || '');

      var cNote = document.createElement('td');
      cNote.className = 'qa-ellipsis';
      cNote.title = r.action_note || '';
      cNote.textContent = r.action_note || '';

      tr.appendChild(cReq);
      tr.appendChild(cEmail);
      tr.appendChild(cId);
      tr.appendChild(cStatus);
      tr.appendChild(cHas);
      tr.appendChild(cUsed);
      tr.appendChild(cLast);
      tr.appendChild(cIp);
      tr.appendChild(cUa);
      tr.appendChild(cNote);

      tbody.appendChild(tr);
    });

    document.getElementById('resetMetaCounts').innerHTML =
      '<strong>' + rows.length + '</strong> requests &middot; ' +
      '<strong>' + withToken + '</strong> with tokens &middot; ' +
      '<strong>' + usedCount + '</strong> marked as USED.';

    document.getElementById('resetMetaHint').textContent =
      'Look for clusters with same IP/UA hash, repeated identifiers or repeated failures.';
  }

  function clearAuthFilters(){
    document.getElementById('authEmail').value = '';
    document.getElementById('authUserId').value = '';
    document.getElementById('authKind').value = '';
    document.getElementById('authLimit').value = '200';
    document.getElementById('authSince').value = '';
    document.getElementById('authUntil').value = '';
    document.getElementById('authOnlyFailed').checked = false;
    setStatus('authStatus','');
  }

  function clearResetFilters(){
    document.getElementById('resetIdentifier').value = '';
    document.getElementById('resetEmail').value = '';
    document.getElementById('resetStatus').value = '';
    document.getElementById('resetLimit').value = '200';
    document.getElementById('resetSince').value = '';
    document.getElementById('resetUntil').value = '';
    setStatus('resetStatusBar','');
  }

  function setupTabs(){
    var tabAuth  = document.getElementById('tabAuth');
    var tabReset = document.getElementById('tabReset');
    var secAuth  = document.getElementById('sectionAuth');
    var secReset = document.getElementById('sectionReset');

    function activate(which){
      if(which === 'auth'){
        tabAuth.classList.add('qa-tab-active');
        tabReset.classList.remove('qa-tab-active');
        secAuth.style.display = '';
        secReset.style.display = 'none';
      }else{
        tabReset.classList.add('qa-tab-active');
        tabAuth.classList.remove('qa-tab-active');
        secReset.style.display = '';
        secAuth.style.display = 'none';
      }
    }

    tabAuth.addEventListener('click', function(){ activate('auth'); });
    tabReset.addEventListener('click', function(){ activate('reset'); });
  }

  function setupRangePills(){
    var pillsAuth = document.querySelectorAll('[data-range-auth]');
    pillsAuth.forEach(function(el){
      el.addEventListener('click', function(){
        pillsAuth.forEach(function(p){ p.classList.remove('qa-pill-active'); });
        el.classList.add('qa-pill-active');
        var val = el.getAttribute('data-range-auth');
        var range = parseRangePreset('auth', val);
        if(range){
          setDateTimeInput(document.getElementById('authSince'), range.since);
          setDateTimeInput(document.getElementById('authUntil'), range.until);
        }
      });
    });

    var pillsReset = document.querySelectorAll('[data-range-reset]');
    pillsReset.forEach(function(el){
      el.addEventListener('click', function(){
        pillsReset.forEach(function(p){ p.classList.remove('qa-pill-active'); });
        el.classList.add('qa-pill-active');
        var val = el.getAttribute('data-range-reset');
        var range = parseRangePreset('reset', val);
        if(range){
          setDateTimeInput(document.getElementById('resetSince'), range.since);
          setDateTimeInput(document.getElementById('resetUntil'), range.until);
        }
      });
    });
  }

  function setupNav(){
    var btnDash   = document.getElementById('qaBtnDashboard');
    var btnLogout = document.getElementById('qaBtnLogout');

    if(btnDash){
      btnDash.addEventListener('click', function(){
        if(typeof window.qaGoToDashboard === 'function'){
          window.qaGoToDashboard();
        }
      });
    }
    if(btnLogout){
      btnLogout.addEventListener('click', function(){
        if(typeof window.qaLogout === 'function'){
          window.qaLogout();
        } else {
          try{
            localStorage.removeItem('qa_token');
            localStorage.removeItem('qa_user_id');
          }catch(e){}
          window.location.reload();
        }
      });
    }
  }

  function setupActions(){
    var btnFetchAuth   = document.getElementById('btnFetchAuth');
    var btnClearAuth   = document.getElementById('btnClearAuth');
    var btnFetchReset  = document.getElementById('btnFetchReset');
    var btnClearReset  = document.getElementById('btnClearReset');

    if(btnFetchAuth){
      btnFetchAuth.addEventListener('click', fetchAuthEvents);
    }
    if(btnClearAuth){
      btnClearAuth.addEventListener('click', function(){
        clearAuthFilters();
        document.getElementById('authTableBody').innerHTML = '';
        document.getElementById('authMetaCounts').textContent = 'Filters cleared.';
        document.getElementById('authMetaHint').textContent = '';
      });
    }

    if(btnFetchReset){
      btnFetchReset.addEventListener('click', fetchResetRequests);
    }
    if(btnClearReset){
      btnClearReset.addEventListener('click', function(){
        clearResetFilters();
        document.getElementById('resetTableBody').innerHTML = '';
        document.getElementById('resetMetaCounts').textContent = 'Filters cleared.';
        document.getElementById('resetMetaHint').textContent = '';
      });
    }
  }

  function hydrateAdminPillFromGuard(){
    var user = (window.QA_USER || {});
    var name = user.name || [user.forename, user.surname].filter(Boolean).join(' ') || user.email || 'Admin';
    var role = (user.role || '').toString().toUpperCase();

    var elName = document.getElementById('qaAdminName');
    if(elName){
      elName.textContent = name + (role ? ' (' + role + ')' : '');
    }
    var pill = document.getElementById('qaAdminInfo');
    if(pill && user.email){
      pill.title = user.email;
    }
  }

  document.addEventListener('DOMContentLoaded', function(){
    setupTabs();
    setupRangePills();
    setupNav();
    setupActions();

    if(window.qaGuardReady && typeof window.qaGuardReady.then === 'function'){
      window.qaGuardReady
        .then(function(info){
          if(!info || info.blocked || window.QA_GUARD_STATE === 'blocked'){
            return;
          }
          hydrateAdminPillFromGuard();
          setDefaultAuthRange();
          setDefaultResetRange();
          fetchAuthEvents();
          fetchResetRequests();
        })
        .catch(function(err){
          console.error(err);
          setGlobalError('Unable to verify admin access. Please reload or sign in again.');
        });
    } else {
      setGlobalError('Guard not initialised — please check Auth v3 Guard snippet.');
    }
  });

})();
</script>

</body>
</html>
