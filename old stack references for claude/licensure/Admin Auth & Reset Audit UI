<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Admin Auth & Reset Audit</title>

<style>
  :root{
    --brand:#0b7a75;
    --brand-soft:#e0f2f1;
    --muted:#859998;
    --ink:#0f172a;
    --bg:#f6f8f7;
    --card:#ffffff;
    --soft:rgba(0,0,0,.06);
    --danger:#b42318;
    --danger-soft:#fff5f5;
    --ok:#166534;
    --ok-soft:#ecfdf3;
  }

  *{box-sizing:border-box}

  body{
    margin:0;
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg);
    color:var(--ink);
  }

  .qa-shell{
    max-width:1120px;
    margin:24px auto 40px;
    padding:0 14px;
  }

  .qa-header{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    justify-content:space-between;
    gap:8px 12px;
    margin-bottom:16px;
  }

  .qa-title-wrap{
    display:flex;
    flex-direction:column;
    gap:4px;
  }

  .qa-title{
    font-size:1.2rem;
    font-weight:650;
    letter-spacing:.01em;
  }

  .qa-subtitle{
    font-size:.85rem;
    color:var(--muted);
  }

  .qa-admin-pill{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:6px 10px;
    border-radius:999px;
    background:var(--brand-soft);
    color:var(--brand);
    font-size:.8rem;
    font-weight:500;
  }

  .qa-admin-pill span{
    max-width:240px;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }

  .qa-nav{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
  }

  .qa-btn{
    border:1px solid var(--soft);
    background:var(--card);
    color:var(--ink);
    border-radius:999px;
    padding:6px 12px;
    font-size:.8rem;
    display:inline-flex;
    align-items:center;
    gap:6px;
    cursor:pointer;
  }

  .qa-btn:hover{
    box-shadow:0 1px 4px rgba(0,0,0,.08);
  }

  .qa-btn-primary{
    border-color:var(--brand);
    background:var(--brand);
    color:#fff;
  }

  .qa-btn-danger{
    border-color:var(--danger);
    color:var(--danger);
  }

  .qa-tabs{
    display:flex;
    gap:6px;
    margin:8px 0 12px;
    border-bottom:1px solid var(--soft);
  }

  .qa-tab{
    border:none;
    background:transparent;
    padding:8px 14px;
    font-size:.85rem;
    cursor:pointer;
    border-radius:999px 999px 0 0;
    color:var(--muted);
  }

  .qa-tab.qa-tab-active{
    background:var(--card);
    color:var(--brand);
    border:1px solid var(--soft);
    border-bottom-color:var(--card);
  }

  .qa-section{
    margin-top:10px;
  }

  .qa-card{
    background:var(--card);
    border-radius:16px;
    border:1px solid var(--soft);
    box-shadow:0 10px 24px rgba(15,23,42,.04);
    padding:12px 14px 14px;
    margin-bottom:14px;
  }

  .qa-card-header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:6px;
    margin-bottom:10px;
  }

  .qa-card-title{
    font-size:.9rem;
    font-weight:600;
  }

  .qa-card-sub{
    font-size:.78rem;
    color:var(--muted);
  }

  .qa-filter-grid{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:8px;
    margin-bottom:8px;
  }

  @media(max-width:900px){
    .qa-filter-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
  }
  @media(max-width:600px){
    .qa-filter-grid{grid-template-columns:repeat(1,minmax(0,1fr));}
  }

  .qa-field{
    display:flex;
    flex-direction:column;
    gap:2px;
  }

  .qa-label{
    font-size:.75rem;
    font-weight:500;
    color:var(--muted);
  }

  .qa-input,
  .qa-select{
    border-radius:999px;
    border:1px solid var(--soft);
    padding:6px 10px;
    font-size:.8rem;
    background:var(--bg);
  }

  .qa-input:focus,
  .qa-select:focus{
    outline:1px solid var(--brand-soft);
    border-color:var(--brand);
    background:#fff;
  }

  .qa-field-inline{
    display:flex;
    align-items:center;
    gap:6px;
    font-size:.78rem;
    color:var(--muted);
  }

  .qa-checkbox{
    width:14px;
    height:14px;
    accent-color:var(--brand);
  }

  .qa-filter-actions{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    justify-content:space-between;
    gap:6px;
    margin-top:4px;
  }

  .qa-filter-left,
  .qa-filter-right{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    align-items:center;
  }

  .qa-pill{
    font-size:.7rem;
    padding:3px 8px;
    border-radius:999px;
    border:1px solid var(--soft);
    background:#f9fafb;
    cursor:pointer;
  }

  .qa-pill-active{
    border-color:var(--brand);
    color:var(--brand);
    background:var(--brand-soft);
  }

  .qa-meta-row{
    display:flex;
    flex-wrap:wrap;
    justify-content:space-between;
    gap:6px;
    margin-top:6px;
    font-size:.75rem;
    color:var(--muted);
  }

  .qa-meta-row span strong{
    color:var(--ink);
  }

  .qa-table-wrap{
    border-radius:12px;
    border:1px solid var(--soft);
    overflow:auto;
    max-height:430px;
  }

  table{
    width:100%;
    border-collapse:collapse;
    font-size:.78rem;
  }

  thead{
    background:#f9fafb;
    position:sticky;
    top:0;
    z-index:1;
  }

  th,td{
    padding:6px 8px;
    border-bottom:1px solid #eef1f4;
    text-align:left;
    vertical-align:top;
  }

  th{
    font-size:.7rem;
    text-transform:uppercase;
    letter-spacing:.04em;
    color:var(--muted);
    white-space:nowrap;
  }

  tr:nth-child(even) td{
    background:#fafbfb;
  }

  .qa-badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:2px 8px;
    border-radius:999px;
    font-size:.7rem;
    font-weight:500;
    white-space:nowrap;
  }

  .qa-badge-ok{
    background:var(--ok-soft);
    color:var(--ok);
  }

  .qa-badge-fail{
    background:var(--danger-soft);
    color:var(--danger);
  }

  .qa-badge-pill{
    background:#e5e7eb;
    color:#111827;
  }

  .qa-text-mono{
    font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
    font-size:.74rem;
  }

  .qa-ellipsis{
    max-width:180px;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }

  .qa-status-bar{
    font-size:.75rem;
    color:var(--muted);
    margin-bottom:8px;
    min-height:18px;
  }

  .qa-status-bar span.qa-status-bad{
    color:var(--danger);
  }

  /* Loader overlay (local to this page) */
  .qa-loader-overlay{
    position:fixed;
    inset:0;
    background:rgba(15,23,42,.16);
    backdrop-filter:blur(2px);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:9999;
  }

  .qa-loader-box{
    background:#ffffff;
    border-radius:16px;
    padding:12px 16px;
    box-shadow:0 18px 45px rgba(15,23,42,.18);
    display:flex;
    align-items:center;
    gap:10px;
    font-size:.86rem;
  }

  .qa-spinner{
    width:16px;
    height:16px;
    border-radius:999px;
    border:2px solid #e2e8f0;
    border-top-color:var(--brand);
    animation:qa-spin 0.7s linear infinite;
  }

  @keyframes qa-spin{
    to{transform:rotate(360deg);}
  }

  .qa-alert{
    padding:6px 10px;
    border-radius:10px;
    font-size:.75rem;
    margin-top:4px;
  }

  .qa-alert-danger{
    background:var(--danger-soft);
    color:var(--danger);
  }
</style>

<!-- ====== PAGE CONFIG FOR GUARD v3 (set BEFORE guard snippet) ====== -->
<script>
  window.QA_CONFIG = window.QA_CONFIG || {};
  window.QA_CONFIG.AUTH_URL = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";

  // Mark this as an admin-only tool page
  window.QA_PAGE_KIND = 'admin';
  window.QA_REQUIRE_ADMIN = true;
</script>

<!-- =================== QAcademy — Guard v3 (Auth v3 + Products + Subscriptions) =================== -->
<script>
(function(){
  'use strict';

  /* ============== CONFIG (PER SITE + PER PAGE) ============== */

  var DEFAULT_AUTH_URL       = 'https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec';
  var DEFAULT_LOGIN_SLUG     = 'login_23';
  var DEFAULT_DASHBOARD_SLUG = 'dashboard_23';

  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};

  var AUTH_URL       = cfg.AUTH_URL       || DEFAULT_AUTH_URL;
  var LOGIN_SLUG     = cfg.LOGIN_SLUG     || DEFAULT_LOGIN_SLUG;
  var DASHBOARD_SLUG = cfg.DASHBOARD_SLUG || DEFAULT_DASHBOARD_SLUG;

  var PAGE_KIND     = window.QA_PAGE_KIND || 'course';
  var COURSE_ID     = window.QA_COURSE_ID || null;
  var REQUIRE_ADMIN = (typeof window.QA_REQUIRE_ADMIN === 'boolean')
    ? window.QA_REQUIRE_ADMIN
    : (String(PAGE_KIND).toLowerCase() === 'admin');

  window.QA_GUARD_STATE      = 'pending';
  window.QA_GUARD_BLOCK_TYPE = null;

  var guardResolve, guardReject;
  window.qaGuardReady = new Promise(function(resolve, reject){
    guardResolve = resolve;
    guardReject  = reject;
  });

  function persistGuardState(state, blockType){
    window.QA_GUARD_STATE      = state;
    window.QA_GUARD_BLOCK_TYPE = blockType || null;
  }

  function buildPageUrl(slug){
    slug = String(slug || '').replace(/^\s+|\s+$/g, '');
    if(!slug) return '/';
    return '/p/' + slug + '.html';
  }

  function go(url){
    window.location.replace(url);
  }

  function qaGoToLogin(reason){
    var url = buildPageUrl(LOGIN_SLUG);
    if(reason){
      var sep = url.indexOf('?') === -1 ? '?' : '&';
      url += sep + 'reason=' + encodeURIComponent(reason);
    }
    go(url);
  }

  function qaGoToDashboard(){
    go(buildPageUrl(DASHBOARD_SLUG));
  }

  function qaLogout(){
    try{
      localStorage.removeItem('qa_token');
      localStorage.removeItem('qa_user_id');
    }catch(e){}
    qaGoToLogin('logout');
  }

  window.qaGoToLogin     = qaGoToLogin;
  window.qaGoToDashboard = qaGoToDashboard;
  window.qaLogout        = qaLogout;

  var overlayId = 'qa-guard-overlay';

  function ensureOverlay(){
    var el = document.getElementById(overlayId);
    if(el) return el;

    el = document.createElement('div');
    el.id = overlayId;
    el.style.position = 'fixed';
    el.style.inset = '0';
    el.style.zIndex = '99999';
    el.style.background = 'rgba(15,23,42,0.86)';
    el.style.display = 'flex';
    el.style.alignItems = 'center';
    el.style.justifyContent = 'center';
    el.style.fontFamily = 'system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
    el.style.padding = '16px';
    el.style.boxSizing = 'border-box';

    el.innerHTML =
      '<div id="qa-guard-overlay-inner" style="max-width:420px;width:100%;background:#ffffff;border-radius:16px;padding:18px 20px;box-shadow:0 18px 45px rgba(15,23,42,0.45);text-align:center;">' +
        '<div id="qa-guard-overlay-title" style="font-size:18px;font-weight:600;margin-bottom:6px;color:#0b7a75;">Checking your access…</div>' +
        '<div id="qa-guard-overlay-body" style="font-size:14px;color:#475569;margin-bottom:14px;">Please wait a moment.</div>' +
        '<div id="qa-guard-overlay-actions" style="font-size:13px;color:#94a3b8;"></div>' +
      '</div>';

    document.body.appendChild(el);
    return el;
  }

  function showOverlay(title, body, actionsHtml){
    var el = ensureOverlay();
    var t = el.querySelector('#qa-guard-overlay-title');
    var b = el.querySelector('#qa-guard-overlay-body');
    var a = el.querySelector('#qa-guard-overlay-actions');

    if(t && typeof title === 'string') t.textContent = title;
    if(b && typeof body === 'string')  b.textContent = body;
    if(a) a.innerHTML = actionsHtml || '';

    el.style.display = 'flex';
  }

  function hideOverlay(){
    var el = document.getElementById(overlayId);
    if(el) el.style.display = 'none';
  }

  function buildBlockedActions(type){
    var btnStyle = 'display:inline-flex;align-items:center;justify-content:center;padding:8px 14px;border-radius:999px;border:none;background:#0b7a75;color:#ffffff;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;';
    if(type === 'no_course_access' || type === 'admin_required' || type === 'account_issue'){
      return '<button type="button" onclick="qaGoToDashboard()" style="' + btnStyle + '">Go to Dashboard</button>';
    }
    if(type === 'session_expired'){
      return '<button type="button" onclick="qaGoToLogin(\'session_expired\')" style="' + btnStyle + '">Go to Login</button>';
    }
    return '';
  }

  function handleBlocked(type, title, body){
    persistGuardState('blocked', type);
    var actionsHtml = buildBlockedActions(type);
    showOverlay(title, body, actionsHtml);
    guardResolve({ ok:false, blocked:true, type:type });
  }

  function runGuard(){
    showOverlay('Checking your access…', 'Please wait while we verify your session.', '');

    var token = null;
    try{
      token = localStorage.getItem('qa_token');
    }catch(e){
      token = null;
    }

    if(!token){
      handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
      qaGoToLogin('no_token');
      return;
    }

    if(!AUTH_URL){
      hideOverlay();
      persistGuardState('error', 'missing_auth_url');
      var err = new Error('Guard misconfigured: AUTH_URL is missing.');
      guardReject(err);
      console.error(err);
      return;
    }

    fetch(AUTH_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: 'verify', token: token })
    })
    .then(function(res){ return res.json(); })
    .then(function(data){
      if(!data || data.ok !== true){
        var errCode = (data && data.error) || 'unknown_error';

        if(errCode === 'missing_token' || errCode === 'not_found' || errCode === 'expired'){
          try{
            localStorage.removeItem('qa_token');
            localStorage.removeItem('qa_user_id');
          }catch(e){}
          handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
          qaGoToLogin('session_expired');
          return;
        }

        if(errCode === 'user_missing' || errCode === 'user_inactive' || errCode === 'user_expired'){
          handleBlocked('account_issue', 'Account issue', 'There is a problem with your account. Please contact QAcademy support.');
          return;
        }

        persistGuardState('error', errCode);
        hideOverlay();
        var err = new Error('Guard verify failed: ' + errCode);
        guardReject(err);
        console.error(err);
        return;
      }

      var u      = data.user   || {};
      var flags  = data.flags  || {};
      var access = (data.access && typeof data.access === 'object') ? data.access : {};
      var courseIds = Array.isArray(access.courses) ? access.courses.slice() : [];
      var upperIds  = courseIds.map(function(c){
        return String(c || '').trim().toUpperCase();
      }).filter(Boolean);
      var coursesMeta = Array.isArray(data.courses) ? data.courses : [];

      var QA_USER = {
        id:        u.user_id || '',
        user_id:   u.user_id || '',
        username:  u.username || '',
        email:     u.email || '',
        name:      u.name || '',
        forename:  u.forename || '',
        surname:   u.surname || '',
        phone_number: u.phone_number || '',
        program_id:   u.program_id || '',
        cohort:       u.cohort || '',
        avatar_url:   u.avatar_url || '',
        role:         u.role || '',
        is_admin:     !!(flags && flags.is_admin),
        must_change_password: !!u.must_change_password,
        user_expires_utc: u.expires_utc || ''
      };

      var QA_ACCESS = {
        courseIds: upperIds,
        access_expires_utc: access.expires_utc || '',
        coursesMeta: coursesMeta,
        hasCourse: function(courseId){
          var cid = String(courseId || '').trim().toUpperCase();
          if(!cid) return false;
          return this.courseIds.indexOf(cid) !== -1;
        }
      };

      window.QA_USER   = QA_USER;
      window.QA_ACCESS = QA_ACCESS;

      try{
        if(QA_USER.user_id){
          localStorage.setItem('qa_user_id', QA_USER.user_id);
        }
      }catch(e){}

      var kind = String(PAGE_KIND || '').toLowerCase();
      var cid  = COURSE_ID ? String(COURSE_ID).trim().toUpperCase() : '';

      if(kind === 'dashboard'){
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      if(kind === 'admin' || REQUIRE_ADMIN){
        if(!QA_USER.is_admin){
          handleBlocked('admin_required', 'Admin access required', 'This page is only available to QAcademy admins.');
          return;
        }
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      if(
        kind === 'course' ||
        kind === 'runner_instant' ||
        kind === 'runner_timed' ||
        kind === 'history_course'
      ){
        if(!cid){
          persistGuardState('error', 'missing_course_id');
          hideOverlay();
          var err2 = new Error('Guard misconfigured: QA_COURSE_ID is missing for course-tied page.');
          guardReject(err2);
          console.error(err2);
          return;
        }

        if(!QA_ACCESS.hasCourse(cid)){
          handleBlocked(
            'no_course_access',
            'No access to this course',
            'Your current subscription does not include this course. Please go back to your dashboard to see the courses you have access to.'
          );
          return;
        }

        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind, course_id:cid });
        return;
      }

      if(kind === 'history'){
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      persistGuardState('ready', null);
      hideOverlay();
      guardResolve({ ok:true, blocked:false, kind:kind });
    })
    .catch(function(err){
      persistGuardState('error', 'network');
      console.error('Guard network/error', err);
      showOverlay(
        'Network problem',
        'We could not verify your access due to a network error. Please check your connection and reload this page.',
        ''
      );
      guardReject(err);
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', runGuard);
  } else {
    runGuard();
  }

})();
</script>
</head>
<body>

<div class="qa-loader-overlay" id="qaLoader">
  <div class="qa-loader-box">
    <div class="qa-spinner"></div>
    <div>Loading audit data&hellip;</div>
  </div>
</div>

<div class="qa-shell">
  <header class="qa-header">
    <div class="qa-title-wrap">
      <div class="qa-title">Security &amp; Auth Audit</div>
      <div class="qa-subtitle">Review login activity and password reset flows in one place.</div>
    </div>
    <div class="qa-nav">
      <div class="qa-admin-pill" id="qaAdminInfo" title="">
        <strong>Admin</strong>
        <span id="qaAdminName">Loading&hellip;</span>
      </div>
      <button type="button" class="qa-btn" id="qaBtnDashboard">
        ⬅ Dashboard
      </button>
      <button type="button" class="qa-btn" id="qaBtnLogout">
        ⏏ Sign out
      </button>
    </div>
  </header>

  <div class="qa-tabs">
    <button type="button" class="qa-tab qa-tab-active" data-tab="auth" id="tabAuth">Login &amp; Auth Events</button>
    <button type="button" class="qa-tab" data-tab="reset" id="tabReset">Password Reset Requests</button>
  </div>

  <!-- AUTH EVENTS SECTION -->
  <section class="qa-section" id="sectionAuth">
    <div class="qa-card">
      <div class="qa-card-header">
        <div>
          <div class="qa-card-title">Filter login / auth events</div>
          <div class="qa-card-sub">Search by email, user ID, kind and time window. Backend enforces admin rights.</div>
        </div>
      </div>

      <div class="qa-filter-grid">
        <div class="qa-field">
          <label class="qa-label" for="authEmail">Email (exact)</label>
          <input id="authEmail" class="qa-input" type="email" placeholder="e.g. mybackpacc@gmail.com" />
        </div>
        <div class="qa-field">
          <label class="qa-label" for="authUserId">User ID (exact)</label>
          <input id="authUserId" class="qa-input" type="text" placeholder="e.g. U1234" />
        </div>
        <div class="qa-field">
          <label class="qa-label" for="authKind">Kind</label>
          <select id="authKind" class="qa-select">
            <option value="">Any kind</option>
            <option value="LOGIN_EMAIL">LOGIN_EMAIL</option>
            <option value="LOGIN_USERNAME">LOGIN_USERNAME</option>
            <option value="LOGIN_GOOGLE">LOGIN_GOOGLE</option>
            <option value="VERIFY_TOKEN">VERIFY_TOKEN</option>
            <option value="RESET_FLOW">RESET_FLOW</option>
          </select>
        </div>
        <div class="qa-field">
          <label class="qa-label" for="authLimit">Limit (max 500)</label>
          <input id="authLimit" class="qa-input" type="number" min="1" max="500" value="200" />
