<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Practical Skills (Procedures)</title>

<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#1f2a28;
    --bg:#f6f8f7;
    --card:#ffffff;
    --soft:rgba(0,0,0,.07);
  }
  body{
    margin:0;
    background:var(--bg);
    font-family:system-ui,Segoe UI,Roboto,sans-serif;
    color:var(--ink);
  }
  .wrap{
    max-width:900px;
    margin:30px auto;
    padding:0 16px;
  }
  .card{
    background:var(--card);
    border-radius:14px;
    padding:18px 20px;
    margin-bottom:26px;
    box-shadow:0 2px 6px rgba(0,0,0,.08);
  }
  h2{
    margin:0 0 14px;
    color:var(--brand);
    font-size:24px;
  }
  h3{
    margin:0;
    color:var(--brand);
    font-size:20px;
  }
  p{line-height:1.6; margin:0 0 10px;}
  button, .btn{
    padding:10px 16px;
    background:var(--brand);
    color:#fff;
    border:none;
    border-radius:8px;
    cursor:pointer;
    font-size:15px;
  }
  .btn-secondary{
    background:var(--muted);
  }
  .btn-small{
    padding:6px 10px;
    font-size:12px;
    border-radius:999px;
  }
  .card-header-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:8px;
    gap:8px;
    flex-wrap:wrap;
  }
  .manual-link{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:8px;
    padding:12px 14px;
    background:var(--soft);
    border-radius:10px;
    margin-bottom:10px;
    font-size:14px;
    flex-wrap:wrap;
  }
  .manual-link span:first-child{
    font-weight:500;
  }
  iframe{
    width:100%;
    height:80vh;
    border:1px solid #ccc;
    border-radius:10px;
    background:#fff;
  }
</style>
</head>
<body>

<!-- Wrap hidden until auth passes -->
<div id="qa-proc" style="display:none;">
  <div class="wrap">

    <!-- Title -->
    <div class="card">
      <h2>Practical Skills — Procedures</h2>
      <p>
        Official NMC Ghana procedure manuals to support your practical and OSCE preparation. 
        This page adapts to your programme and also gives you access to procedures from other programmes.
      </p>
      <p><strong>Your programme:</strong> <span id="progLabel">Loading…</span></p>
    </div>

    <!-- Your Programme block -->
    <div class="card" id="progBlock">
      <h3 style="margin-bottom:8px;">Your Programme Procedures</h3>
      <p id="progText"></p>

      <button id="viewMyBtn" onclick="viewMyProgramInside()">View Inside QAcademy</button>
      <a id="openExternal" href="#" target="_blank" rel="noopener noreferrer">
        <button class="btn-secondary" style="margin-left:6px;">Open on NMC Website</button>
      </a>
    </div>

    <!-- NAC/NAP explanation -->
    <div class="card" id="nonManualBlock" style="display:none;">
      <h3 style="margin-bottom:8px;">NAC/NAP Procedures</h3>
      <p>
        The NAC/NAP programme does <strong>not</strong> include an NMC Practical/OSCE examination,
        and no official procedure manual is provided for NAC/NAP candidates.
      </p>
      <p>
        You can still explore procedures from other programmes below, especially if you are planning to upgrade in the future.
      </p>
    </div>

    <!-- Viewer (collapsed by default) -->
    <div class="card" id="viewerBlock" style="display:none;">
      <div class="card-header-row">
        <h3>Procedure Viewer</h3>
        <button type="button" class="btn-secondary btn-small" onclick="hideViewer()">Hide viewer</button>
      </div>
      <p id="viewerLabel"></p>
      <iframe id="manualFrame" src=""></iframe>
      <p style="margin-top:10px;">
        If the viewer does not load,
        <a id="fallbackLink" href="#" target="_blank" rel="noopener noreferrer" style="color:var(--brand);text-decoration:underline;">
          open the procedures on the NMC website
        </a>.
      </p>
    </div>

    <!-- Other manuals (collapsible body) -->
    <div class="card">
      <div class="card-header-row">
        <h3>Other Programme Procedures</h3>
        <button type="button" id="manualListToggleBtn"
                class="btn-secondary btn-small"
                onclick="toggleManualList()">
          Hide list
        </button>
      </div>
      <p id="manualListDesc">
        Explore procedure manuals from other NMC programmes. These are public and useful for reference, comparison, or upgrading.
      </p>
      <div id="manualList"></div>
    </div>

  </div>
</div>

<script>
// ===================== Manual mapping =====================
const manuals = {
  "RN":   { name:"Registered General Nursing (RGN)", url:"https://nmc.gov.gh/procedures/view/RGN" },
  "RM":   { name:"Registered Midwifery (RM)",        url:"https://nmc.gov.gh/procedures/view/RM" },
  "RPHN": { name:"Public Health Nursing (RPHN)",     url:"https://nmc.gov.gh/procedures/view/PHN" },
  "RMHN": { name:"Mental Health Nursing (RMHN)",     url:"https://nmc.gov.gh/procedures/view/RMN" },
  "RCMN": { name:"Community/CHN/CMCN (RCMN)",        url:"https://nmc.gov.gh/procedures/view/RCMN" },
  "PAED": { name:"Paediatrics (PAED)",               url:"https://nmc.gov.gh/procedures/view/PAED" },
  "PM":   { name:"Perioperative / PM",               url:"https://nmc.gov.gh/procedures/view/PM" },

  // Post-basic
  "CCN":  { name:"Critical Care Nursing (Post-Basic)",    url:"https://nmc.gov.gh/pb-procedures/view/CCN" },
  "ENT":  { name:"ENT Nursing (Post-Basic)",              url:"https://nmc.gov.gh/pb-procedures/view/ENT" },
  "ENUR": { name:"Emergency Nursing (Post-Basic)",        url:"https://nmc.gov.gh/pb-procedures/view/ENUR" },
  "NP":   { name:"Nurse Practitioner (Post-Basic)",       url:"https://nmc.gov.gh/pb-procedures/view/NP" },
  "OPN":  { name:"Ophthalmic Nursing (Post-Basic)",       url:"https://nmc.gov.gh/pb-procedures/view/OPN" },
  "PON":  { name:"Peri-Operative Nursing (Post-Basic)",   url:"https://nmc.gov.gh/pb-procedures/view/PON" },
};

let qaMyProgramCode = ""; // normalized programme code used for "View X Inside QAcademy"

// helper: normalise program code
function normalizeProgramCode(raw){
  if(!raw) return "";
  const t = raw.toUpperCase().replace(/\s+/g,"");
  if(t.startsWith("RN")) return "RN";
  if(t.startsWith("RMHN") || t==="RMHN" || t==="RMN" || t==="MHN") return "RMHN";
  if(t.startsWith("RM")) return "RM";
  if(t.includes("RPHN") || t==="PHN") return "RPHN";
  if(t.includes("RCMN")) return "RCMN";
  if(t.includes("PAED")) return "PAED";
  if(t==="PM") return "PM";
  if(t.includes("NAC") || t.includes("NAP")) return "NACNAP";
  return t; // fallback
}

// build the "other manuals" list once
function buildManualList(){
  const list = document.getElementById("manualList");
  list.innerHTML = "";
  for(const code in manuals){
    const m = manuals[code];
    const div = document.createElement("div");
    div.className = "manual-link";
    div.innerHTML = `
      <span>${m.name}</span>
      <span>
        <button onclick="switchManual('${code}')" class="btn">View</button>
        <a href="${m.url}" target="_blank" rel="noopener noreferrer">
          <button class="btn-secondary">Open</button>
        </a>
      </span>`;
    list.appendChild(div);
  }
}

function initProcedures(programRaw){
  const progLabel      = document.getElementById("progLabel");
  const progBlock      = document.getElementById("progBlock");
  const nonManualBlock = document.getElementById("nonManualBlock");
  const viewerLabel    = document.getElementById("viewerLabel");
  const iframe         = document.getElementById("manualFrame");
  const fallbackLink   = document.getElementById("fallbackLink");
  const openExternal   = document.getElementById("openExternal");
  const viewerBlock    = document.getElementById("viewerBlock");
  const viewMyBtn      = document.getElementById("viewMyBtn");

  const code = normalizeProgramCode(programRaw);
  qaMyProgramCode = code; // store globally for "View X Inside QAcademy"
  progLabel.textContent = programRaw || code || "—";

  if(code === "NACNAP"){
    // NAC/NAP: no direct manual, hide programme block
    progBlock.style.display      = "none";
    nonManualBlock.style.display = "block";

    viewerLabel.textContent = "Select a programme below to view its procedures.";
    iframe.src              = "";
    fallbackLink.href       = "#";
    viewerBlock.style.display = "none"; // stays collapsed until user chooses
  } else {
    nonManualBlock.style.display = "none";
    const data = manuals[code];

    // Dynamic button label: "View RN Inside QAcademy" etc.
    if(code && viewMyBtn){
      viewMyBtn.textContent = "View " + code + " Inside QAcademy";
    }

    if(data){
      document.getElementById("progText").innerHTML =
        `Below is the official NMC Procedure Manual mapped for <strong>${data.name}</strong>.`;

      // Prepare viewer content, but keep card collapsed until user clicks
      iframe.src             = data.url;
      viewerLabel.textContent= data.name;
      fallbackLink.href      = data.url;
      openExternal.href      = data.url;
    } else {
      document.getElementById("progText").innerHTML =
        "No direct procedure manual is mapped for your programme. Please choose one from the list below.";
      viewerLabel.textContent = "Select a programme below to view its procedures.";
      iframe.src              = "";
      fallbackLink.href       = "#";
      openExternal.href       = "#";
      viewerBlock.style.display = "none";
    }
  }

  buildManualList();
}

// Always reset viewer to *my programme* when clicking "View X Inside QAcademy"
function viewMyProgramInside(){
  const block        = document.getElementById("viewerBlock");
  const iframe       = document.getElementById("manualFrame");
  const viewerLabel  = document.getElementById("viewerLabel");
  const fallbackLink = document.getElementById("fallbackLink");

  if(!qaMyProgramCode){
    // No mapped programme: just open viewer and prompt selection
    block.style.display = "block";
    viewerLabel.textContent = "Select a programme below to view its procedures.";
    iframe.src = "";
    fallbackLink.href = "#";
  } else {
    const m = manuals[qaMyProgramCode];
    block.style.display = "block";

    if(m){
      iframe.src            = m.url;
      viewerLabel.textContent = m.name;
      fallbackLink.href     = m.url;
    } else {
      viewerLabel.textContent = "Select a programme below to view its procedures.";
      iframe.src = "";
      fallbackLink.href = "#";
    }
  }

  window.scrollTo({
    top: block.offsetTop - 20,
    behavior: "smooth"
  });
}

function switchManual(code){
  const m = manuals[code];
  if(!m) return;

  const block        = document.getElementById("viewerBlock");
  const iframe       = document.getElementById("manualFrame");
  const viewerLabel  = document.getElementById("viewerLabel");
  const fallbackLink = document.getElementById("fallbackLink");

  // Show viewer when user chooses a manual
  block.style.display = "block";

  iframe.src             = m.url;
  viewerLabel.textContent= m.name;
  fallbackLink.href      = m.url;

  window.scrollTo({
    top: block.offsetTop - 20,
    behavior: "smooth"
  });
}

function hideViewer(){
  const block = document.getElementById("viewerBlock");
  block.style.display = "none";
}

// Toggle collapse for "Other Programme Procedures"
function toggleManualList(){
  const list   = document.getElementById("manualList");
  const desc   = document.getElementById("manualListDesc");
  const btn    = document.getElementById("manualListToggleBtn");
  const isHidden = list.style.display === "none";

  if(isHidden){
    list.style.display = "block";
    desc.style.display = "block";
    btn.textContent    = "Hide list";
  } else {
    list.style.display = "none";
    desc.style.display = "none";
    btn.textContent    = "Show list";
  }
}

// ===================== Auth + verify (same pattern as dashboard) =====================
(async function(){
  const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";
  const TOKEN_KEY   = "qa_token";
  const LOGIN_PAGE  = "/p/login_23.html";

  const token = localStorage.getItem(TOKEN_KEY);
  if(!token){ location.replace(LOGIN_PAGE); return; }

  async function verify(token){
    const body = new URLSearchParams({ action:"verify", token });
    const res  = await fetch(WEB_APP_URL, {
      method:"POST",
      headers:{ "Content-Type":"application/x-www-form-urlencoded" },
      body
    });
    if(!res.ok) throw new Error("Verify HTTP " + res.status);
    return res.json();
  }

  let payload;
  try{
    payload = await verify(token);
    if(!payload || !payload.ok){
      localStorage.removeItem(TOKEN_KEY);
      location.replace(LOGIN_PAGE);
      return;
    }
  } catch(err){
    console.error("Practical Skills verify failed:", err);
    localStorage.removeItem(TOKEN_KEY);
    location.replace(LOGIN_PAGE);
    return;
  }

  // Helpers copied from dashboard style
  function getField(p, key){
    if(p && p[key]) return p[key];
    if(p.user && p.user[key]) return p.user[key];
    if(p.profile && p.profile[key]) return p.profile[key];
    return "";
  }
  function normalize(id){ return (id || "").toUpperCase().replace(/\s+/g,""); }
  function inferProgramFromCourses(cs){
    const ids = (cs||[]).map(c=>normalize(c.course_id));
    if(ids.some(id=>/^RN_/.test(id))) return "RN";
    if(ids.some(id=>/^RM_/.test(id))) return "RM";
    if(ids.some(id=>/^RMHN_/.test(id)||/^MHN_/.test(id))) return "RMHN";
    if(ids.some(id=>/^RPHN_/.test(id))) return "RPHN";
    if(ids.some(id=>/^NAC_/.test(id)||/^NAP_/.test(id))) return "NAC/NAP";
    return "";
  }
  function deriveProgram(p,courses){
    const direct = getField(p,"program_id");
    if(direct) return direct;
    if(Array.isArray(p.programs) && p.programs.length) return p.programs[0];
    if(Array.isArray(p.enrollments) && p.enrollments.length){
      const e = p.enrollments[0];
      if(e && (e.program || e.program_id)) return e.program || e.program_id;
    }
    return inferProgramFromCourses(courses);
  }

  const courses    = Array.isArray(payload.courses)?payload.courses:[];
  const programRaw = deriveProgram(payload, courses) || localStorage.getItem("qa_program") || "";

  // Show page and init UI
  document.getElementById("qa-proc").style.display = "block";
  initProcedures(programRaw);
})();
</script>

</body>
</html>
