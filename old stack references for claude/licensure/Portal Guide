<script>
/* ===================
  QA_CONFIG (clone-safe)
  - Update these paths after cloning
=================== */
const QA_CONFIG = {
  PAGES: {
    dashboard: "/p/dashboard.html",
    fixed_quizzes: "/p/fixed-quizzes.html",
    quiz_builder: "/p/quiz-builder.html",
    learning_history: "/p/learning-history.html",
    downloads: "/p/downloads.html",
    messages: "/p/messages.html",
    join_premium: "/p/join-premium.html"
  }
};

// Smooth scroll helper
function qaScrollTo(id){
  const el = document.getElementById(id);
  if(!el) return;
  el.scrollIntoView({ behavior:"smooth", block:"start" });
}

// Wire clone-safe page links (buttons)
(function wirePageLinks(){
  document.querySelectorAll("[data-qa-link]").forEach(a=>{
    const key = a.getAttribute("data-qa-link");
    const href = (QA_CONFIG.PAGES && QA_CONFIG.PAGES[key]) ? QA_CONFIG.PAGES[key] : "#";
    a.setAttribute("href", href);
  });
})();

// Build nav links (desktop + mobile) from sections
const QA_SECTIONS = [
  { id:"quick-start", label:"Quick Start" },
  { id:"dashboard", label:"Dashboard" },
  { id:"fixed-quizzes", label:"Fixed Quizzes" },
  { id:"quiz-builder", label:"Quiz Builder" },
  { id:"modes", label:"Instant vs Timed" },
  { id:"after-quiz", label:"After Your Quiz" },
  { id:"learning-history", label:"Learning History" },
  { id:"downloads", label:"My Downloads" },
  { id:"messages", label:"Messages" },
  { id:"telegram", label:"Telegram" },
  { id:"payments", label:"Payments" },
  { id:"faqs", label:"FAQs" }
];

function buildNav(targetEl){
  if(!targetEl) return;
  targetEl.innerHTML = QA_SECTIONS.map(s => `
    <a href="#${s.id}" data-qa-anchor="${s.id}">
      <span class="qa-dot"></span>
      <span>${s.label}</span>
    </a>
  `).join("");
}

buildNav(document.getElementById("qaNavList"));
buildNav(document.getElementById("qaNavMobileList"));

// Smooth scrolling for anchor links (and auto-close mobile drawer)
function bindNavClicks(scope){
  if(!scope) return;
  scope.querySelectorAll('a[data-qa-anchor]').forEach(a=>{
    a.addEventListener("click", (e)=>{
      e.preventDefault();
      const id = a.getAttribute("data-qa-anchor");
      qaScrollTo(id);

      // close mobile drawer if open
      const mob = document.getElementById("qaNavMobile");
      const btn = document.getElementById("qaNavMobileBtn");
      if(mob && mob.getAttribute("data-open")==="true"){
        mob.setAttribute("data-open","false");
        btn && btn.setAttribute("aria-expanded","false");
      }
    });
  });
}

bindNavClicks(document.getElementById("qaNavList"));
bindNavClicks(document.getElementById("qaNavMobileList"));

// Mobile nav drawer toggle
(function mobileNav(){
  const wrap = document.getElementById("qaNavMobile");
  const btn = document.getElementById("qaNavMobileBtn");
  if(!wrap || !btn) return;
  btn.addEventListener("click", ()=>{
    const isOpen = wrap.getAttribute("data-open")==="true";
    wrap.setAttribute("data-open", String(!isOpen));
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
})();

// Active section highlight (IntersectionObserver)
(function activeSectionHighlight(){
  const links = Array.from(document.querySelectorAll('a[data-qa-anchor]'));
  const map = new Map();
  links.forEach(a => map.set(a.getAttribute("data-qa-anchor"), a));

  function setActive(id){
    links.forEach(a => a.setAttribute("aria-current","false"));
    const active = map.get(id);
    if(active) active.setAttribute("aria-current","true");

    // Mirror to other nav (desktop/mobile)
    document.querySelectorAll(`a[data-qa-anchor="${id}"]`).forEach(a=>{
      a.setAttribute("aria-current","true");
    });
  }

  const sections = QA_SECTIONS
    .map(s => document.getElementById(s.id))
    .filter(Boolean);

  if(!("IntersectionObserver" in window) || sections.length===0){
    setActive("quick-start");
    return;
  }

  const obs = new IntersectionObserver((entries)=>{
    // choose the most visible intersecting section
    const visible = entries
      .filter(e => e.isIntersecting)
      .sort((a,b)=> (b.intersectionRatio - a.intersectionRatio))[0];
    if(visible && visible.target && visible.target.id){
      setActive(visible.target.id);
    }
  }, { root:null, threshold:[0.2, 0.35, 0.5, 0.65] });

  sections.forEach(s => obs.observe(s));
  setActive("quick-start");
})();

// FAQ accordion behavior (accessible)
(function faqAccordion(){
  const root = document.getElementById("qaFaq");
  if(!root) return;

  root.querySelectorAll(".qa-acc-item").forEach(item=>{
    const btn = item.querySelector(".qa-acc-btn");
    const panel = item.querySelector(".qa-acc-panel");
    if(!btn || !panel) return;

    btn.addEventListener("click", ()=>{
      const isOpen = item.getAttribute("data-open")==="true";

      // close others (single-open behavior)
      root.querySelectorAll(".qa-acc-item").forEach(i=>{
        i.setAttribute("data-open","false");
        const b = i.querySelector(".qa-acc-btn");
        const ic = i.querySelector(".qa-acc-icon");
        if(b) b.setAttribute("aria-expanded","false");
        if(ic) ic.textContent = "+";
      });

      // open current if it was closed
      if(!isOpen){
        item.setAttribute("data-open","true");
        btn.setAttribute("aria-expanded","true");
        const icon = item.querySelector(".qa-acc-icon");
        if(icon) icon.textContent = "–";
      }
    });
  });
})();
</script>
