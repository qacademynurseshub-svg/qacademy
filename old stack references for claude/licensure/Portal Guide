<!-- =================== QAcademy — Help Page: Portal Guide (Modular v1) ===================
  DESIGN GOALS
  - Student-professional tone
  - Clone-safe (links controlled by QA_CONFIG)
  - Edit-friendly blocks (BLOCK START/END markers)
  - Sticky "On this page" mini-nav (desktop) + collapsible drawer (mobile)
  - FAQ accordion (accessible, no libraries)

  NOTE
  - Keep secrets/user data out of this page.
======================================================================================== -->

<style>
  :root{
    --qa-brand:#0b7a75;
    --qa-brand-2:#859998;
    --qa-ink:#0f172a;
    --qa-muted:#475569;
    --qa-bg:#f7faf9;
    --qa-card:#ffffff;
    --qa-line:rgba(15,23,42,.12);
    --qa-shadow:0 12px 30px rgba(2,6,23,.08);
    --qa-radius:18px;
    --qa-radius-sm:14px;
    --qa-max:1100px;
  }

  .qa-page{
    background:linear-gradient(180deg, rgba(11,122,117,.08), rgba(133,153,152,.06) 55%, rgba(247,250,249,1) 100%);
    padding:20px 0 60px;
    color:var(--qa-ink);
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  }

  .qa-shell{
    width:min(var(--qa-max), calc(100% - 28px));
    margin:0 auto;
    display:grid;
    grid-template-columns: 280px 1fr;
    gap:16px;
    align-items:start;
  }

  /* Sticky mini-nav */
  .qa-nav{
    position:sticky;
    top:14px;
    background:rgba(255,255,255,.9);
    backdrop-filter:saturate(1.2) blur(10px);
    border:1px solid var(--qa-line);
    border-radius:var(--qa-radius);
    box-shadow:var(--qa-shadow);
    overflow:hidden;
  }
  .qa-nav-head{
    padding:14px 14px 10px;
    border-bottom:1px solid var(--qa-line);
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:10px;
  }
  .qa-nav-title{
    font-weight:800;
    font-size:14px;
    letter-spacing:.2px;
  }
  .qa-nav-badge{
    font-size:12px;
    padding:4px 10px;
    border-radius:999px;
    border:1px solid rgba(11,122,117,.25);
    color:var(--qa-brand);
    background:rgba(11,122,117,.08);
    white-space:nowrap;
  }
  .qa-nav-list{
    padding:10px;
    display:flex;
    flex-direction:column;
    gap:6px;
  }
  .qa-nav a{
    display:flex;
    align-items:center;
    gap:10px;
    text-decoration:none;
    color:var(--qa-ink);
    padding:10px 10px;
    border-radius:12px;
    border:1px solid transparent;
    font-size:13px;
    line-height:1.2;
  }
  .qa-nav a:hover{
    background:rgba(11,122,117,.07);
    border-color:rgba(11,122,117,.18);
  }
  .qa-nav a[aria-current="true"]{
    background:rgba(11,122,117,.12);
    border-color:rgba(11,122,117,.30);
    color:var(--qa-brand);
    font-weight:750;
  }
  .qa-dot{
    width:8px;height:8px;border-radius:999px;
    background:rgba(71,85,105,.45);
    flex:0 0 auto;
  }
  .qa-nav a[aria-current="true"] .qa-dot{ background:var(--qa-brand); }

  /* Content */
  .qa-main{
    background:rgba(255,255,255,.75);
    backdrop-filter:saturate(1.1) blur(8px);
    border:1px solid var(--qa-line);
    border-radius:var(--qa-radius);
    box-shadow:var(--qa-shadow);
    overflow:hidden;
  }

  .qa-hero{
    padding:22px 18px 18px;
    border-bottom:1px solid var(--qa-line);
    background:linear-gradient(135deg, rgba(11,122,117,.10), rgba(133,153,152,.12));
  }
  .qa-title{
    font-size:28px;
    font-weight:900;
    margin:0 0 6px;
    letter-spacing:-.4px;
  }
  .qa-sub{
    margin:0;
    color:rgba(15,23,42,.72);
    line-height:1.55;
    max-width:70ch;
    font-size:14.5px;
  }
  .qa-hero-actions{
    margin-top:14px;
    display:flex;
    flex-wrap:wrap;
    gap:10px;
  }

  .qa-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    padding:10px 12px;
    border-radius:14px;
    border:1px solid rgba(15,23,42,.14);
    background:#fff;
    color:var(--qa-ink);
    text-decoration:none;
    font-weight:750;
    font-size:13px;
    box-shadow:0 10px 18px rgba(2,6,23,.05);
  }
  .qa-btn:hover{ transform:translateY(-1px); }
  .qa-btn:active{ transform:translateY(0px); }

  .qa-btn-primary{
    border-color:rgba(11,122,117,.35);
    background:linear-gradient(135deg, rgba(11,122,117,.95), rgba(11,122,117,.78));
    color:#fff;
  }

  .qa-section{
    padding:18px;
    border-top:1px solid var(--qa-line);
  }
  .qa-section:first-of-type{ border-top:none; }

  .qa-h2{
    margin:0 0 6px;
    font-size:18px;
    font-weight:900;
    letter-spacing:-.2px;
  }
  .qa-lead{
    margin:0 0 12px;
    color:rgba(15,23,42,.70);
    line-height:1.6;
    font-size:14px;
  }

  .qa-grid{
    display:grid;
    grid-template-columns:repeat(12, 1fr);
    gap:12px;
  }

  .qa-card{
    grid-column:span 12;
    background:var(--qa-card);
    border:1px solid var(--qa-line);
    border-radius:var(--qa-radius-sm);
    padding:14px;
    box-shadow:0 10px 22px rgba(2,6,23,.05);
  }

  .qa-card h3{
    margin:0 0 8px;
    font-size:14.5px;
    font-weight:900;
  }
  .qa-card p{
    margin:0;
    color:rgba(15,23,42,.70);
    line-height:1.6;
    font-size:13.5px;
  }
  .qa-ul{
    margin:10px 0 0;
    padding-left:18px;
    color:rgba(15,23,42,.72);
    line-height:1.6;
    font-size:13.5px;
  }

  .qa-tip{
    margin-top:10px;
    padding:10px 12px;
    border-radius:14px;
    border:1px solid rgba(11,122,117,.22);
    background:rgba(11,122,117,.07);
    color:rgba(15,23,42,.82);
    font-size:13.5px;
    line-height:1.55;
  }

  /* FAQ accordion */
  .qa-acc{
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .qa-acc-item{
    border:1px solid var(--qa-line);
    background:#fff;
    border-radius:var(--qa-radius-sm);
    overflow:hidden;
    box-shadow:0 10px 18px rgba(2,6,23,.04);
  }
  .qa-acc-btn{
    width:100%;
    text-align:left;
    padding:12px 14px;
    background:transparent;
    border:0;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    cursor:pointer;
    font-weight:850;
    color:var(--qa-ink);
    font-size:14px;
  }
  .qa-acc-btn:hover{ background:rgba(11,122,117,.06); }
  .qa-acc-icon{
    width:28px;height:28px;border-radius:10px;
    border:1px solid rgba(15,23,42,.12);
    display:grid;place-items:center;
    flex:0 0 auto;
    color:rgba(15,23,42,.75);
    background:rgba(255,255,255,.8);
  }
  .qa-acc-panel{
    display:none;
    padding:0 14px 14px;
    color:rgba(15,23,42,.72);
    line-height:1.65;
    font-size:13.5px;
  }
  .qa-acc-item[data-open="true"] .qa-acc-panel{ display:block; }
  .qa-acc-item[data-open="true"] .qa-acc-icon{ color:var(--qa-brand); border-color:rgba(11,122,117,.26); background:rgba(11,122,117,.07); }

  /* CTA Footer */
  .qa-cta{
    padding:18px;
    border-top:1px solid var(--qa-line);
    background:linear-gradient(135deg, rgba(11,122,117,.10), rgba(133,153,152,.10));
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    align-items:center;
    justify-content:space-between;
  }
  .qa-cta h3{
    margin:0;
    font-size:16px;
    font-weight:900;
    letter-spacing:-.2px;
  }
  .qa-cta p{
    margin:4px 0 0;
    color:rgba(15,23,42,.72);
    font-size:13.5px;
    line-height:1.5;
  }
  .qa-cta-left{ min-width:240px; }
  .qa-cta-actions{ display:flex; flex-wrap:wrap; gap:10px; }

  /* Mobile: collapsible nav drawer */
  .qa-nav-mobile{
    display:none;
    margin:0 auto 12px;
    width:min(var(--qa-max), calc(100% - 28px));
    border:1px solid var(--qa-line);
    border-radius:var(--qa-radius);
    background:rgba(255,255,255,.9);
    box-shadow:var(--qa-shadow);
    overflow:hidden;
  }
  .qa-nav-mobile-btn{
    width:100%;
    border:0;
    background:transparent;
    padding:14px;
    font-weight:900;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    cursor:pointer;
  }
  .qa-nav-mobile-panel{
    display:none;
    padding:10px;
    border-top:1px solid var(--qa-line);
  }
  .qa-nav-mobile[data-open="true"] .qa-nav-mobile-panel{ display:block; }

  /* Responsive */
  @media (max-width: 900px){
    .qa-shell{ grid-template-columns: 1fr; }
    .qa-nav{ display:none; }
    .qa-nav-mobile{ display:block; }
  }
  @media (min-width: 740px){
    .qa-card.span6{ grid-column:span 6; }
  }
</style>

<div class="qa-page">
  <!-- Optional: paste your global header snippet here -->
  <!-- QA_GLOBAL_HEADER -->

  <!-- Mobile mini-nav -->
  <div class="qa-nav-mobile" id="qaNavMobile">
    <button class="qa-nav-mobile-btn" type="button" id="qaNavMobileBtn" aria-expanded="false" aria-controls="qaNavMobilePanel">
      <span>On this page</span>
      <span style="color:rgba(15,23,42,.65);font-weight:800;font-size:13px;">Tap to open</span>
    </button>
    <div class="qa-nav-mobile-panel" id="qaNavMobilePanel">
      <div class="qa-nav-list" id="qaNavMobileList"></div>
    </div>
  </div>

  <div class="qa-shell">
    <!-- Desktop sticky nav -->
    <aside class="qa-nav" aria-label="On this page">
      <div class="qa-nav-head">
        <div class="qa-nav-title">On this page</div>
        <div class="qa-nav-badge">Portal Guide</div>
      </div>
      <nav class="qa-nav-list" id="qaNavList"></nav>
    </aside>

    <main class="qa-main" id="qaMain">
      <!-- =========================
        BLOCK START: HERO
      ========================== -->
      <section class="qa-hero" id="top">
        <h1 class="qa-title">Portal Guide</h1>
        <p class="qa-sub">
          Use this guide to navigate QAcademy confidently—practice, review, track progress, and improve consistently.
        </p>
        <div class="qa-hero-actions">
          <a class="qa-btn qa-btn-primary" href="#" data-qa-link="dashboard">Go to Dashboard</a>
          <a class="qa-btn" href="#" data-qa-link="fixed_quizzes">Fixed Quizzes</a>
          <a class="qa-btn" href="#" data-qa-link="quiz_builder">Quiz Builder</a>
          <a class="qa-btn" href="#" data-qa-link="learning_history">Learning History</a>
          <a class="qa-btn" href="#" data-qa-link="downloads">My Downloads</a>
        </div>
      </section>
      <!-- =========================
        BLOCK END: HERO
      ========================== -->

      <!-- =========================
        BLOCK START: QUICK START
      ========================== -->
      <section class="qa-section" id="quick-start" data-qa-section>
        <h2 class="qa-h2">Quick Start (2 minutes)</h2>
        <p class="qa-lead">Follow this simple flow to start practicing immediately and study with a clear plan.</p>

        <div class="qa-grid">
          <div class="qa-card span6">
            <h3>Step 1 — Sign in</h3>
            <p>Log in to your QAcademy account and open your Dashboard.</p>
          </div>
          <div class="qa-card span6">
            <h3>Step 2 — Start practicing</h3>
            <p>Use Fixed Quizzes (fast) or Quiz Builder (target weak areas) to begin your session.</p>
          </div>
          <div class="qa-card">
            <h3>Step 3 — Review and plan</h3>
            <p>After your quiz, review explanations and check Learning History to decide what to practice next.</p>
          </div>
        </div>
      </section>
      <!-- =========================
        BLOCK END: QUICK START
      ========================== -->

      <!-- =========================
        BLOCK START: DASHBOARD
      ========================== -->
      <section class="qa-section" id="dashboard" data-qa-section>
        <h2 class="qa-h2">Dashboard (Your home page)</h2>
        <p class="qa-lead">
          Your Dashboard helps you find everything quickly—active courses, practice tools, and your account status.
        </p>
        <div class="qa-card">
          <h3>Use the Dashboard to:</h3>
          <ul class="qa-ul">
            <li>See your active courses and access status</li>
            <li>Jump into Fixed Quizzes, Quiz Builder, Learning History, Downloads, and Messages</li>
            <li>Continue your study routine without searching for links</li>
          </ul>
        </div>
      </section>
      <!-- =========================
        BLOCK END: DASHBOARD
      ========================== -->

      <!-- =========================
        BLOCK START: FIXED QUIZZES
      ========================== -->
      <section class="qa-section" id="fixed-quizzes" data-qa-section>
        <h2 class="qa-h2">Fixed Quizzes (Ready-made practice)</h2>
        <p class="qa-lead">
          Fixed Quizzes are prepared sets you can start immediately—no topic selection required.
        </p>

        <div class="qa-grid">
          <div class="qa-card span6">
            <h3>Recommended for</h3>
            <ul class="qa-ul">
              <li>Daily practice</li>
              <li>Fast revision before exams</li>
              <li>Quick mock sessions</li>
            </ul>
          </div>
          <div class="qa-card span6">
            <h3>How to use it well</h3>
            <p>Start a set, finish it, then review your explanations carefully. Use Learning History to identify repeated weak areas.</p>
            <div class="qa-tip"><strong>Tip:</strong> If you keep missing the same topic, switch to Quiz Builder and focus on that area.</div>
          </div>
        </div>
      </section>
      <!-- =========================
        BLOCK END: FIXED QUIZZES
      ========================== -->

      <!-- =========================
        BLOCK START: QUIZ BUILDER
      ========================== -->
      <section class="qa-section" id="quiz-builder" data-qa-section>
        <h2 class="qa-h2">Quiz Builder (Custom practice)</h2>
        <p class="qa-lead">
          Quiz Builder lets you create targeted practice by choosing course, topics, difficulty, number of questions, and mode.
        </p>

        <div class="qa-grid">
          <div class="qa-card span6">
            <h3>What you choose</h3>
            <ul class="qa-ul">
              <li>Course</li>
              <li>Topics</li>
              <li>Difficulty</li>
              <li>Number of questions</li>
              <li>Mode (Instant or Timed)</li>
            </ul>
          </div>
          <div class="qa-card span6">
            <h3>Recommended settings</h3>
            <ul class="qa-ul">
              <li><strong>New topic:</strong> 10–20 questions, Instant</li>
              <li><strong>Revision:</strong> 25–50 questions, mixed difficulty</li>
              <li><strong>Mock exam:</strong> 50–100 questions, Timed</li>
            </ul>
          </div>
        </div>
      </section>
      <!-- =========================
        BLOCK END: QUIZ BUILDER
      ========================== -->

      <!-- =========================
        BLOCK START: MODES
      ========================== -->
      <section class="qa-section" id="modes" data-qa-section>
        <h2 class="qa-h2">Instant vs Timed (Choose the right mode)</h2>
        <p class="qa-lead">Both modes are valuable. Use Instant for learning and Timed for exam readiness.</p>

        <div class="qa-grid">
          <div class="qa-card span6">
            <h3>Instant Mode</h3>
            <p>Feedback shows as you answer. Best for learning, understanding concepts, and improving quickly.</p>
          </div>
          <div class="qa-card span6">
            <h3>Timed Mode</h3>
            <p>Exam-style practice. Best for speed, accuracy, and confidence under pressure.</p>
          </div>
        </div>
      </section>
      <!-- =========================
        BLOCK END: MODES
      ========================== -->

      <!-- =========================
        BLOCK START: AFTER QUIZ
      ========================== -->
      <section class="qa-section" id="after-quiz" data-qa-section>
        <h2 class="qa-h2">After your quiz (Improve faster)</h2>
        <p class="qa-lead">Your improvement comes from the review process, not only from answering questions.</p>

        <div class="qa-card">
          <ul class="qa-ul">
            <li>Review explanations carefully—focus on <em>why</em> an option is correct</li>
            <li>Identify repeated weak areas</li>
            <li>Build your next session around weak topics (Quiz Builder) or repeat a similar Fixed Quiz</li>
          </ul>
        </div>
      </section>
      <!-- =========================
        BLOCK END: AFTER QUIZ
      ========================== -->

      <!-- =========================
        BLOCK START: LEARNING HISTORY
      ========================== -->
      <section class="qa-section" id="learning-history" data-qa-section>
        <h2 class="qa-h2">Learning History (Track your progress)</h2>
        <p class="qa-lead">
          Learning History helps you review past attempts, identify weak topics, and monitor improvement over time.
        </p>

        <div class="qa-grid">
          <div class="qa-card span6">
            <h3>What it helps you do</h3>
            <ul class="qa-ul">
              <li>Review your past attempts and scores</li>
              <li>Identify topics you repeatedly miss</li>
              <li>Monitor improvement over time</li>
            </ul>
          </div>
          <div class="qa-card span6">
            <h3>Best practice</h3>
            <p>After each session, select 1–2 weak topics from Learning History and practice them in Quiz Builder.</p>
          </div>
        </div>
      </section>
      <!-- =========================
        BLOCK END: LEARNING HISTORY
      ========================== -->

      <!-- =========================
        BLOCK START: DOWNLOADS
      ========================== -->
      <section class="qa-section" id="downloads" data-qa-section>
        <h2 class="qa-h2">My Downloads (Offline Packs)</h2>
        <p class="qa-lead">Offline packs help you study without internet and re-open your materials anytime.</p>

        <div class="qa-card">
          <ul class="qa-ul">
            <li>Generate a pack from your course/topics</li>
            <li>Find it later inside <strong>My Downloads</strong></li>
            <li>Re-open packs without needing to regenerate</li>
          </ul>
          <div class="qa-tip"><strong>Note:</strong> Download limits may apply depending on your subscription.</div>
        </div>
      </section>
      <!-- =========================
        BLOCK END: DOWNLOADS
      ========================== -->

      <!-- =========================
        BLOCK START: MESSAGES
      ========================== -->
      <section class="qa-section" id="messages" data-qa-section>
        <h2 class="qa-h2">Messages (Support and tutors)</h2>
        <p class="qa-lead">Use Messages to get help quickly—general support, course support, or question-specific support.</p>

        <div class="qa-grid">
          <div class="qa-card span6">
            <h3>When to message</h3>
            <ul class="qa-ul">
              <li><strong>General support:</strong> account or access questions</li>
              <li><strong>Course support:</strong> help with a course topic</li>
              <li><strong>Question support:</strong> “Message about this question” inside a quiz</li>
            </ul>
          </div>
          <div class="qa-card span6">
            <h3>To get faster help</h3>
            <p>Include the topic, what confused you, and a short screenshot if needed. Avoid sharing personal details.</p>
          </div>
