<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Router</title>
<style>
  :root{
    --brand:#0b7a75;
    --ink:#1f2a28;
    --muted:#5b6a68;
    --bg:#f6f8f7;
    --card:#ffffff;
    --line:rgba(0,0,0,.10);
    --danger:#b42318;
    --warn:#b54708;
    --radius:16px;
    --shadow:0 10px 28px rgba(0,0,0,.08);
    --max:1100px;
    --pad:16px;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:var(--max);margin:0 auto;padding:22px var(--pad) 30px}
  .top{
    position:sticky;top:0;z-index:10;
    background:rgba(246,248,247,.88);
    backdrop-filter:saturate(1.2) blur(10px);
    border-bottom:1px solid var(--line);
  }
  .top .bar{max-width:var(--max);margin:0 auto;padding:12px var(--pad);display:flex;gap:12px;align-items:center;justify-content:space-between}
  .brand{display:flex;gap:10px;align-items:center;min-width:0}
  .logo{
    width:38px;height:38px;border-radius:12px;
    background:linear-gradient(135deg, rgba(11,122,117,.16), rgba(133,153,152,.10));
    border:1px solid rgba(11,122,117,.24);
    display:grid;place-items:center;font-weight:950;color:var(--brand);
    box-shadow:0 10px 20px rgba(11,122,117,.10);
  }
  .brand h1{margin:0;font-size:14px;line-height:1.1}
  .brand .sub{margin-top:2px;font-size:12px;color:rgba(31,42,40,.68);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;justify-content:flex-end}
  .chip{
    display:inline-flex;gap:8px;align-items:center;
    padding:6px 10px;border-radius:999px;border:1px solid var(--line);
    background:#fff;font-size:12px;color:rgba(31,42,40,.78);
    max-width:52vw;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  }
  .dot{width:8px;height:8px;border-radius:99px;background:var(--brand)}
  .btn{
    appearance:none;border:1px solid var(--line);background:#fff;color:var(--ink);
    padding:9px 12px;border-radius:12px;cursor:pointer;
    font-weight:750;font-size:13px;box-shadow:0 8px 18px rgba(0,0,0,.05);
  }
  .btn.primary{background:var(--brand);border-color:rgba(11,122,117,.28);color:#fff}
  .btn.danger{border-color:rgba(180,35,24,.25);color:var(--danger);background:rgba(180,35,24,.04)}
  .btn:disabled{opacity:.55;cursor:not-allowed}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:16px}
  @media (max-width:980px){ .grid{grid-template-columns:1fr} }

  .card{
    background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
    box-shadow:var(--shadow);overflow:hidden;
  }
  .card .hd{padding:14px 14px 10px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
  .card .hd h2{margin:0;font-size:14px;letter-spacing:.2px}
  .card .hd p{margin:4px 0 0;font-size:12px;color:rgba(31,42,40,.68);line-height:1.35}
  .card .bd{padding:14px}
  .bigTitle{font-size:18px;font-weight:950;margin:0 0 6px}
  .muted{color:rgba(31,42,40,.68);font-size:13px;line-height:1.45}
  .pill{
    display:inline-flex;gap:6px;align-items:center;
    padding:5px 9px;border-radius:999px;border:1px solid var(--line);
    background:rgba(0,0,0,.02);font-size:12px;color:rgba(31,42,40,.76);font-weight:750;
  }
  .pill.ok{border-color:rgba(2,122,72,.22);background:rgba(2,122,72,.06);color:rgba(2,122,72,.92)}
  .pill.warn{border-color:rgba(181,71,8,.22);background:rgba(181,71,8,.06);color:rgba(181,71,8,.95)}
  .pill.bad{border-color:rgba(180,35,24,.22);background:rgba(180,35,24,.06);color:rgba(180,35,24,.95)}
  .hr{height:1px;background:var(--line);margin:12px 0}
  .status{
    margin-top:14px;
    background:#fff;border:1px solid var(--line);border-radius:14px;
    padding:12px;box-shadow:0 8px 18px rgba(0,0,0,.05);
    display:flex;gap:10px;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;
  }
  .status .t{font-weight:900}
  .status .m{font-size:12px;color:rgba(31,42,40,.70);margin-top:2px;line-height:1.35;max-width:720px}
  .spin{
    width:18px;height:18px;border-radius:50%;
    border:2px solid rgba(0,0,0,.14);
    border-top-color: rgba(11,122,117,.85);
    animation:spin .8s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>

<body>
  <div class="top">
    <div class="bar">
      <div class="brand">
        <div class="logo">QA</div>
        <div style="min-width:0">
          <h1>QAcademy</h1>
          <div class="sub" id="subline">Checking your session…</div>
        </div>
      </div>
      <div class="actions">
        <span class="chip" id="userChip" style="display:none"><span class="dot"></span><span id="userChipText">Signed in</span></span>
        <button class="btn" id="btnRetry" type="button" style="display:none">Retry</button>
        <button class="btn danger" id="btnSignOut" type="button">Sign out</button>
      </div>
    </div>
  </div>

  <div class="wrap">
    <div class="status" id="statusBox">
      <div style="display:flex;gap:10px;align-items:flex-start">
        <div class="spin" id="spin"></div>
        <div>
          <div class="t" id="statusTitle">Checking access…</div>
          <div class="m" id="statusMsg">Please wait a moment.</div>
        </div>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
        <span class="pill" id="pillAuth">Auth: —</span>
        <span class="pill" id="pillTA">Teacher Assess: —</span>
      </div>
    </div>

    <div class="grid" style="margin-top:14px">
      <!-- Licensure Portal -->
      <div class="card">
        <div class="hd">
          <div>
            <h2>Licensure Portal</h2>
            <p>Your NMC licensure prep area (courses, quiz builder, history, announcements).</p>
          </div>
          <span class="pill ok" id="pillLic">Ready</span>
        </div>
        <div class="bd">
          <div class="bigTitle">My NMC Licensure</div>
          <div class="muted">
            Go to your licensure dashboard and learning tools.
          </div>
          <div class="hr"></div>
          <button class="btn primary" id="btnGoLic" type="button" disabled>Open Licensure Dashboard</button>
        </div>
      </div>

      <!-- Teacher Assess -->
      <div class="card">
        <div class="hd">
          <div>
            <h2>Teacher Assess</h2>
            <p>Classes, quizzes, bank, library picker, results — built on Alpha auth.</p>
          </div>
          <span class="pill" id="pillTAState">Checking…</span>
        </div>
        <div class="bd">
          <div class="bigTitle">My Teacher Assess</div>
          <div class="muted" id="taDesc">
            If you’re a teacher, you’ll be taken to the teacher dashboard. Otherwise you’ll be taken to My Classes.
          </div>
          <div class="hr"></div>
          <button class="btn primary" id="btnGoTA" type="button" disabled>Open Teacher Assess</button>
          <div class="muted" style="margin-top:10px" id="taNote"></div>
        </div>
      </div>
    </div>

    <div class="muted" style="margin-top:14px;text-align:center">
      QAcademy • Router
    </div>
  </div>

<script>
/** ==========================================================
 * CONFIG — REPLACE THESE
 * ========================================================== */
const AUTH_URL = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec"; // <-- replace with your Portal Auth WebApp URL
const TA_URL   = "https://script.google.com/macros/s/AKfycbz54M_jWoRq4cOC2gUQeRhd55AeEJ5vnELJ0gkBSodO58fr7WGa9jwk6JNwPptf8p8X/exec"; // <-- replace with your Teacher Assess WebApp URL

// Slugs (no domains)
const SLUG_LIC_DASH     = "dashboard_23";       // <-- your current licensure dashboard slug
const SLUG_TEACHER_DASH = "teacher-dashboard";  // <-- set to your new teacher dashboard slug
const SLUG_MY_CLASSES   = "my-classes";         // <-- set to your student TA dashboard slug

// Router slug (optional; used only for fallbacks)
const SLUG_ROUTER       = "router";

/** ==========================================================
 * Helpers
 * ========================================================== */
const $ = (id)=>document.getElementById(id);

function pageUrl(slug){
  slug = String(slug||"").trim();
  return slug ? ("/p/" + slug + ".html") : "/";
}

function safeReturnTo(raw){
  raw = String(raw||"").trim();
  if(!raw) return "";
  if(raw[0] !== "/") return "";
  if(raw.startsWith("//")) return "";
  if(raw.toLowerCase().includes("javascript:")) return "";
  return raw;
}

function getQS(name){
  try{ return new URLSearchParams(location.search||"").get(name) || ""; }
  catch(_){ return ""; }
}

function getToken(){
  try{ return (localStorage.getItem("qa_token")||"").trim(); }catch(_){ return ""; }
}
function clearToken(){
  try{ localStorage.removeItem("qa_token"); localStorage.removeItem("qa_user_id"); }catch(_){}
}

async function postForm(url, data){
  const body = new URLSearchParams();
  Object.entries(data||{}).forEach(([k,v])=>{ if(v!=null) body.set(k, String(v)); });

  let res, txt;
  try{
    res = await fetch(url, {
      method:"POST",
      mode:"cors",
      credentials:"omit",
      headers:{ "Content-Type":"application/x-www-form-urlencoded;charset=UTF-8" },
      body
    });
    txt = await res.text();
  }catch(e){
    return { ok:false, error:"network_error", detail:String(e && (e.message||e) || e) };
  }

  try{ return JSON.parse(txt); }
  catch(_){ return { ok:false, error:"bad_json", raw:txt }; }
}

function setStatus(title, msg){
  $("statusTitle").textContent = title || "";
  $("statusMsg").textContent = msg || "";
}
function setPill(id, text, cls){
  const el = $(id);
  el.textContent = text;
  el.classList.remove("ok","warn","bad");
  if(cls) el.classList.add(cls);
}

function enableBtn(btnId, on){
  const b = $(btnId);
  b.disabled = !on;
}

function showRetry(on){
  $("btnRetry").style.display = on ? "" : "none";
}

/** ==========================================================
 * Router logic
 * ========================================================== */
async function runRouter(){
  $("spin").style.display = "";
  showRetry(false);

  setPill("pillAuth","Auth: checking…","warn");
  setPill("pillTA","Teacher Assess: checking…","warn");
  $("pillTAState").textContent = "Checking…";
  $("pillTAState").className = "pill warn";

  enableBtn("btnGoLic", false);
  enableBtn("btnGoTA", false);

  const token = getToken();
  if(!token){
    $("subline").textContent = "Signed out";
    setStatus("Sign in required", "Your session is missing in this browser. Please sign in again.");
    setPill("pillAuth","Auth: missing token","bad");
    setPill("pillTA","Teacher Assess: —","");

    $("spin").style.display = "none";
    showRetry(true);
    return;
  }

  // support return_to
  const rt = safeReturnTo(getQS("return_to"));
  if(rt){
    try{ sessionStorage.setItem("qa_return_to_router", rt); }catch(_){}
  }

  // 1) Auth verify (Portal)
  const v = await postForm(AUTH_URL, { action:"verify", token });
  if(!v || v.ok !== true){
    const code = (v && v.error) ? String(v.error) : "verify_failed";
    $("subline").textContent = "Access denied";
    setStatus("Session problem", "Please sign in again.");
    setPill("pillAuth", "Auth: " + code, "bad");

    // clear token on common invalids
    if(code === "missing_token" || code === "expired" || code === "not_found"){
      clearToken();
    }

    $("spin").style.display = "none";
    showRetry(true);
    return;
  }

  // Auth ok
  const u = v.user || {};
  const name = String(u.name || "").trim() || String(u.username || "").trim() || "Signed in";
  const email = String(u.email || "").trim();
  $("userChipText").textContent = email ? (name + " • " + email) : name;
  $("userChip").style.display = "inline-flex";
  $("subline").textContent = "Choose where to go";

  setPill("pillAuth","Auth: OK","ok");
  enableBtn("btnGoLic", true);

  // If return_to exists, and it’s not this router page, we can just continue there
  // (works for deep links; target page guard will still enforce access)
  let rt2 = "";
  try{ rt2 = safeReturnTo(sessionStorage.getItem("qa_return_to_router") || ""); }catch(_){}
  if(rt2){
    // avoid looping back to router
    const loop = rt2.includes("/p/" + SLUG_ROUTER + ".html");
    if(!loop){
      setStatus("Continuing…", "Taking you to your requested page.");
      $("spin").style.display = "";
      window.location.href = rt2;
      return;
    }
  }

  // 2) Teacher Assess role check (TA WebApp)
  // If TA_URL not configured, still allow going to My Classes as default.
  let taIsTeacher = false;
  let taPendingNote = "";
  let taOk = false;

  if(!TA_URL || String(TA_URL).includes("REPLACE_WITH")){
    setPill("pillTA","Teacher Assess: URL not set","warn");
    $("pillTAState").textContent = "Needs setup";
    $("pillTAState").className = "pill warn";
    $("taNote").textContent = "Router TA_URL is not set yet. Once you replace it, teacher detection will work.";
    enableBtn("btnGoTA", true); // still allow
    $("btnGoTA").onclick = ()=> window.location.href = pageUrl(SLUG_MY_CLASSES);
    setStatus("Ready", "Pick Licensure Portal or Teacher Assess.");
    $("spin").style.display = "none";
    return;
  }

  const tv = await postForm(TA_URL, { action:"teacher.verify", token });

  // teacher.verify ok => teacher
  if(tv && tv.ok === true){
    taIsTeacher = true;
    taOk = true;
  } else {
    // not a teacher OR not approved OR role mismatch — we treat as student for TA entry
    taIsTeacher = false;
    taOk = false;

    const err = (tv && tv.error) ? String(tv.error) : "";
    // “pending” behavior A: still open My Classes, show note
    if(err && (err.includes("not_approved") || err.includes("pending") || err.includes("teacher_inactive"))){
      taPendingNote = "Teacher access is pending/disabled. You can still use My Classes.";
    }
  }

  if(taIsTeacher){
    setPill("pillTA","Teacher Assess: Teacher","ok");
    $("pillTAState").textContent = "Teacher";
    $("pillTAState").className = "pill ok";
    $("taDesc").textContent = "You’re verified as a teacher. This will open your Teacher Dashboard.";
    $("taNote").textContent = "";
    enableBtn("btnGoTA", true);
    $("btnGoTA").onclick = ()=> window.location.href = pageUrl(SLUG_TEACHER_DASH);
  } else {
    setPill("pillTA","Teacher Assess: Student","ok");
    $("pillTAState").textContent = "Student";
    $("pillTAState").className = "pill ok";
    $("taDesc").textContent = "You’ll be taken to My Classes (student access for Teacher Assess).";
    $("taNote").textContent = taPendingNote || "";
    enableBtn("btnGoTA", true);
    $("btnGoTA").onclick = ()=> window.location.href = pageUrl(SLUG_MY_CLASSES);
  }

  setStatus("Ready", "Pick Licensure Portal or Teacher Assess.");
  $("spin").style.display = "none";
}

$("btnRetry").addEventListener("click", runRouter);
$("btnSignOut").addEventListener("click", ()=>{
  clearToken();
  // send to login (slug only; adjust if your login slug differs)
  window.location.href = "/p/login_23.html";
});

$("btnGoLic").addEventListener("click", ()=> window.location.href = pageUrl(SLUG_LIC_DASH));

runRouter();
</script>
</body>
</html>
